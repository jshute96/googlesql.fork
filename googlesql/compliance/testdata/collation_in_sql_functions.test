==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,TABLE_VALUED_FUNCTIONS]
[name=collation_in_tvf_with_any_string_applies_correct_defaults]
SELECT
  col, x, y, COUNT(*) AS count
FROM tvf_with_any_string((SELECT col_ci AS col FROM StringTable))
GROUP BY col, x, y
ORDER BY col
--
ARRAY<STRUCT<col STRING, x STRING, y STRING, count INT64>>[{"A", "A", "B", 2}]
--
AggregateFunctionSignature::COUNT(*):FN_COUNT_STAR
FunctionErrorMode::COUNT(*):FN_COUNT_STAR:DEFAULT_ERROR_MODE
FunctionName::COUNT(*)
FunctionSignature::COUNT(*):FN_COUNT_STAR
LanguageFeature::FEATURE_TABLE_VALUED_FUNCTIONS
LanguageFeature:VERSION_1_4:FEATURE_TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS
ProductMode:InternalAndExternal
ResolvedNodeKind:Expression:RESOLVED_AGGREGATE_FUNCTION_CALL
ResolvedNodeKind:Expression:RESOLVED_COLUMN_REF
ResolvedNodeKind:Expression:RESOLVED_LITERAL
ResolvedNodeKind:Scan:RESOLVED_AGGREGATE_SCAN
ResolvedNodeKind:Scan:RESOLVED_ORDER_BY_SCAN
ResolvedNodeKind:Scan:RESOLVED_PROJECT_SCAN
ResolvedNodeKind:Scan:RESOLVED_TABLE_SCAN
ResolvedNodeKind:Scan:RESOLVED_TVFSCAN
ResolvedNodeKind:Statement:RESOLVED_QUERY_STMT
TimeResolution:Any
