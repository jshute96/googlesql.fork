[name=collation_in_templated_tvf_explicit_return]
SELECT
  col_ci,
  (col_ci = 'A' AND col_ci = 'a') OR (col_ci = 'B' AND col_ci = 'b') AS is_collated
FROM tvf_templated_explicit_return(TABLE StringTable, ['a', 'b'])
ORDER BY col_ci
