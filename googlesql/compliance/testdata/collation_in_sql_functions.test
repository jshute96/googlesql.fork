[required_features=TABLE_VALUED_FUNCTIONS,TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS]
[name=collation_in_tvf_fixed_table_passthrough_implicit_return]
SELECT
  col_ci,
  cnt
FROM tvf_fixed_table_passthrough_implicit_return(TABLE StringTable)
WHERE col_ci = 'a' AND col_ci != 'A'
ORDER BY col_ci
--
ARRAY<STRUCT<col_ci STRING, cnt INT64>>[{"a", 2}]
