# Ensure that collation gets dropped on concrete (STRING) args, and propagate
# for ANY STRING args.
[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS]
[name=collation_in_any_string_udfs]
SELECT
  udf_with_any_string(col_ci) udf_with_defaults,
  udf_with_any_string(col_ci, "X", COLLATE("x", "binary")) udf_explicit_args,
  COUNT(*) AS count
FROM StringTable
GROUP BY udf_with_defaults, udf_explicit_args
--
ARRAY<STRUCT<
        udf_with_defaults STRING,
        udf_explicit_args STRING,
        count INT64
      >>
[unknown order:
  {"A_and_ne_AB", "A_and_ne_Xx", 4},
  {"B_and_ne_AB", "B_and_ne_Xx", 2}
]
--
