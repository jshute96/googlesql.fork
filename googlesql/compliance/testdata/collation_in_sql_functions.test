TypeKind:TYPE_STRING
collation_propagated_to_sql_function
==

# Like the above, but also uses the output columns in contexts, e.g. GROUP BY
# Ensure that collation gets dropped on concrete (STRING) args, and propagate
# for ANY STRING args.
[name=collation_in_tvf_with_any_string_explicit_args]
SELECT
  col, x, y, COUNT(*) AS count
FROM tvf_with_any_string((SELECT col_ci AS col FROM StringTable), "A", COLLATE("a", "binary"))
GROUP BY col, x, y
ORDER BY col
--
ARRAY<STRUCT<col STRING, x STRING, y STRING, count INT64>>[{"A", "A", "a", 2}]
--
AggregateFunctionSignature::COUNT(*):FN_COUNT_STAR
FunctionErrorMode::COLLATE:FN_COLLATE:DEFAULT_ERROR_MODE
FunctionErrorMode::COUNT(*):FN_COUNT_STAR:DEFAULT_ERROR_MODE
FunctionName::COLLATE
FunctionName::COUNT(*)
FunctionSignature::COLLATE:FN_COLLATE
FunctionSignature::COUNT(*):FN_COUNT_STAR
LanguageFeature::FEATURE_TABLE_VALUED_FUNCTIONS
