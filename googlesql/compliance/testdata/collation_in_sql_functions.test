[default extract_labels]
[prepare_database]
CREATE TABLE StringTable(
  primary_Key INT64,
  col_ci STRING COLLATE 'und:ci',
  col_binary STRING COLLATE 'binary',
  col_no_collation STRING) AS
SELECT 1 AS primary_Key, "a" AS col_ci, "a" col_binary, "a" UNION ALL
SELECT 2, "A", "A", "A" UNION ALL
SELECT 3, "a", "A", "a" UNION ALL
SELECT 4, "A", "a", "A" UNION ALL
SELECT 5, "b", "b", "b" UNION ALL
SELECT 6, "B", "B", "B"
--
ARRAY<STRUCT<
        primary_Key INT64,
        col_ci STRING,
        col_binary STRING,
        col_no_collation STRING
      >>
[{1, "a", "a", "a"},
 {2, "A", "A", "A"},
 {3, "a", "A", "a"},
 {4, "A", "a", "A"},
 {5, "b", "b", "b"},
 {6, "B", "B", "B"}]
==

[required_features=ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS]
[prepare_database]
CREATE TEMP FUNCTION udf_with_collated_return(s1 STRING) AS (
  COLLATE(s1, 'und:ci')
);

==

[required_features=TEMPLATE_FUNCTIONS]
[prepare_database]
CREATE TEMP FUNCTION templated_udf_with_collated_return(x ANY TYPE) AS (
  COLLATE(CAST(x AS STRING), 'und:ci')
);

==

[prepare_database]
CREATE TEMP FUNCTION udf_with_fixed_args(s1 STRING, s2 STRING)
AS (
  s1 = s2
);
==

[required_features=]
[prepare_database]
CREATE TEMP FUNCTION udf_fixed_calls_another_udf(a STRUCT<x STRING, y ARRAY<STRING>>)
AS (
  udf_with_fixed_args(a.x || 'suffix', ARRAY_FIRST(a.y) || 'suffix')
);
==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION]
[prepare_database]
CREATE TEMP AGGREGATE FUNCTION uda_with_fixed_args(s1 STRING) AS (
 (COUNT(distinct s1))
);

==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION]
[prepare_database]
CREATE TEMP AGGREGATE FUNCTION uda_fixed_calls_another_uda(s1 STRING) AS (
  uda_with_fixed_args(s1 || 'suffix')
);
==


[required_features=ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION,TEMPLATE_FUNCTIONS]
[prepare_database]
CREATE TEMP FUNCTION udf_templated(s1 ANY TYPE, s2 ANY TYPE)
AS (
  s1 = s2
);

==

[required_features=ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION,TEMPLATE_FUNCTIONS]
[prepare_database]
CREATE TEMP AGGREGATE FUNCTION uda_templated(s1 ANY TYPE)
AS (
  (COUNT(DISTINCT s1))
);
==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION]
[prepare_database]
CREATE TABLE FUNCTION tvf_fixed_table_passthrough_implicit_return(t TABLE<primary_key INT64, col_ci STRING>)
AS (
  SELECT col_ci, count(*) AS cnt FROM t GROUP BY col_ci
);

==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION]
[prepare_database]
CREATE TABLE FUNCTION tvf_fixed_table_passthrough_explicit_return(t TABLE<primary_key INT64, col_ci STRING>)
RETURNS TABLE<col_ci STRING, cnt INT64>
AS (
  SELECT col_ci, count(*) AS cnt FROM t GROUP BY col_ci
);

==

[required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,CREATE_TABLE_FUNCTION]
[prepare_database]
CREATE TABLE FUNCTION tvf_fixed_args(t TABLE<primary_key INT64, col_ci STRING>, a ARRAY<STRING>)
AS (
  SELECT * FROM t WHERE t.col_ci IN (SELECT * FROM UNNEST(a))
);

==

[required_features=CREATE_TABLE_FUNCTION,TEMPLATE_FUNCTIONS]
[prepare_database]
CREATE TABLE FUNCTION tvf_templated_implicit_return(t ANY TABLE, a ANY TYPE)
AS (
  SELECT * FROM t WHERE t.col_ci IN (SELECT * FROM UNNEST(a))
);
==

[required_features=CREATE_TABLE_FUNCTION,TEMPLATE_FUNCTIONS]
[prepare_database]
CREATE TABLE FUNCTION tvf_templated_explicit_return(t ANY TABLE, a ANY TYPE)
RETURNS TABLE<col_ci STRING, cnt INT64>
AS (
  SELECT col_ci, 1 AS cnt
  FROM t
  WHERE t.col_ci IN (SELECT * FROM UNNEST(a))
);
==

[required_features=TEMPLATE_FUNCTIONS,ANY_STRING_TEMPLATED_ARGUMENT]
[prepare_database]
# For all function kinds, we also ensure that concrete arguments do not leak
# collation from their inputs.
CREATE TEMP FUNCTION udf_with_any_string(s1 ANY STRING, s2 ANY STRING DEFAULT "A", s3 STRING DEFAULT "B") AS (
  s1
  || IF(s2 = s3, '_and_eq_', '_and_ne_')
  || s2
  || s3
);
==

[required_features=TEMPLATE_FUNCTIONS,ANY_STRING_TEMPLATED_ARGUMENT,FUNCTION_ARGUMENTS_WITH_DEFAULTS]
[prepare_database]
CREATE TEMP AGGREGATE FUNCTION uda_with_any_string(s1 ANY STRING DEFAULT "default_val", s2 ANY STRING DEFAULT "A" NOT AGGREGATE, s3 STRING DEFAULT "B" NOT AGGREGATE) AS (
  CAST(IF (s2 = s3, COUNT(DISTINCT s1), COUNT(DISTINCT s1) - 100) AS STRING)
    || s2 || s3
);
==

[required_features=CREATE_TABLE_FUNCTION,TEMPLATE_FUNCTIONS,ANY_STRING_TEMPLATED_ARGUMENT,FUNCTION_ARGUMENTS_WITH_DEFAULTS]
[prepare_database]
CREATE TABLE FUNCTION tvf_with_any_string(t TABLE<col STRING>, x ANY STRING DEFAULT "A", y STRING DEFAULT "B") AS (
  SELECT *, x, y FROM t WHERE col = x
)
==

[default required_features=TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
[name=collation_in_fixed_udfs]
SELECT
  primary_key,
  col_ci,
  col_binary,
  udf_with_fixed_args(col_ci, COLLATE(col_binary, 'und:ci')),
  udf_fixed_calls_another_udf((COLLATE(col_ci, 'binary'), [col_binary, 'arg']))
FROM StringTable
ORDER BY primary_key
--
ARRAY<STRUCT<primary_key INT64, col_ci STRING, col_binary STRING, BOOL, BOOL>>[known order:
  {1, "a", "a", true, true},
  {2, "A", "A", true, true},
  {3, "a", "A", false, false},
  {4, "A", "a", false, false},
  {5, "b", "b", true, true},
  {6, "B", "B", true, true}
]
--
