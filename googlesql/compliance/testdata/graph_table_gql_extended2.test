  let k = 1
  match (n)
  OPTIONAL CALL (k, n) {
    MATCH (n) -[e IS transfer]->{1,2} (x) WHERE LENGTH(n.account_kind) > k
    let hops = count(element_id(e))
    RETURN hops, x, n AS n2
  }
  return n.name AS name, n.account_id AS n, hops, x.account_id AS x, n2.account_id AS m2
) gt
order by 1,2,3,4,5
