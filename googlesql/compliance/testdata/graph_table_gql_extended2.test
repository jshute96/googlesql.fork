[required_features=SQL_GRAPH,SQL_GRAPH_ADVANCED_QUERY,SQL_GRAPH_SET_OPERATION_PROPAGATION_MODE]
[name=composite_query_in_block_1_left_except_all]
[exclude_in_sql_builder_pipe_sql_equivalence_tests]
select *, COUNT(*) AS count
from graph_table(aml
  MATCH (a:Account)-[e:Transfer]->(b:Account)
  return a.account_id AS source_account_id, b.account_id AS target_account_id
  LEFT EXCEPT ALL
  MATCH (a:Account)-[e:Transfer]->(b:Account)
