  {1010, 1010, 1010, 1020, 1020, 1030},
  {1010, 1010, 1010, 1020, 1020, 1030},
  {1010, 1010, 1010, 1020, 1020, 1030},
  {1020, 1020, 1020, 1030, 1030, 1010},
  {1020, 1020, 1020, 1030, 1030, 1010},
  {1020, 1020, 1020, 1030, 1030, 1020},
  {1020, 1020, 1020, 1030, 1030, 1020},
  {1020, 1020, 1020, 1030, 1030, 1040},
  {1020, 1020, 1020, 1030, 1030, 1040},
  {1030, 1030, NULL, 1040, NULL, NULL},
