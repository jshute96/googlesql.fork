[required_features=RANGE_TYPE,CIVIL_TIME]
SELECT [RANGE<DATETIME> "[2014-01-01, 2015-01-01)", RANGE<DATETIME> "[2014-01-01, UNBOUNDED)", RANGE<DATETIME> "[UNBOUNDED, 2015-01-01)", RANGE<DATETIME> "[UNBOUNDED, UNBOUNDED)"][ORDINAL(1)]
