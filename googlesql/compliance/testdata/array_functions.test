==
## ARRAY_DISTINCT is supposed to pick the first element among the items that are
## distinct.
[name=array_distinct_string_collate_ci]
[required_features=ARRAY_DISTINCT,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
SELECT ARRAY_DISTINCT([COLLATE('a', 'und:ci'), COLLATE('B', 'und:ci'),
                       COLLATE('A', 'und:ci'), COLLATE('b', 'und:ci')])
--
ARRAY<STRUCT<ARRAY<>>>[{ARRAY<STRING>[known order:"a", "B"]}]
==
[name=array_distinct_struct_with_collated_strings]
[required_features=ARRAY_DISTINCT,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,GROUP_BY_STRUCT]
SELECT ARRAY_DISTINCT([
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('a', ''), COLLATE('x', '')),
  STRUCT(COLLATE('A', 'und:ci'), COLLATE('a', ''), COLLATE('x', '')),
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('A', ''), COLLATE('x', '')),
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('a', ''), COLLATE('X', ''))
])
--
ARRAY<STRUCT<ARRAY<>>>[
  {ARRAY<STRUCT<STRING, STRING, STRING>>[known order:
     {"a", "a", "x"},
     {"a", "A", "x"},
     {"a", "a", "X"}
   ]}
]
==
[name=array_distinct_struct_with_nested_collated_strings]
[required_features=ARRAY_DISTINCT,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT,GROUP_BY_STRUCT]
SELECT ARRAY_DISTINCT([
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('a', ''), STRUCT(COLLATE('x', ''))),
  STRUCT(COLLATE('A', 'und:ci'), COLLATE('a', ''), STRUCT(COLLATE('x', ''))),
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('A', ''), STRUCT(COLLATE('x', ''))),
  STRUCT(COLLATE('a', 'und:ci'), COLLATE('a', ''), STRUCT(COLLATE('X', '')))
])
--
ARRAY<STRUCT<ARRAY<>>>[
  {ARRAY<STRUCT<STRING, STRING, STRUCT<STRING>>>[known order:
     {"a", "a", {"x"}},
     {"a", "A", {"x"}},
     {"a", "a", {"X"}}
   ]}
]
==
[name=array_distinct_unknown_order]
[required_features=ARRAY_DISTINCT]
SELECT ARRAY_DISTINCT(ARRAY_AGG(rand_order_elem.elem))
FROM (SELECT elem FROM UNNEST([1, 2, 3, 4]) elem UNION ALL
      SELECT elem2 AS elem FROM UNNEST([2, 3, 4, 5]) elem2) rand_order_elem
--
ARRAY<STRUCT<ARRAY<>>>[{ARRAY<INT64>[unknown order:4, 3, 5, 2, 1]}]
==
