  {1010, 1020},
  {1010, 1030},
  {1010, 1030},
  {1010, 1030},
  {1010, 1030},
  {1020, 1010},
  {1020, 1010},
  {1030, 1010},
  {1030, 1020},
  {1030, 1020}
]
==

[name=concatenated_quantifiers_test]
# Test the concatenation of 2 quantified paths
