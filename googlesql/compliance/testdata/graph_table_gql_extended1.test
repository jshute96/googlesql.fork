[name=quantified_path_with_zero_lower_bound_test_7]
select * from graph_table(aml
  MATCH ANY CHEAPEST ((a:Human)-[e1:Login COST 1]->(b:Account)){0,1}-[e2:Transfer COST e2.amount]->{0, 1}(y:Account {account_id: 1030})
  return ARRAY_LENGTH(e1) AS e1_len, ARRAY_LENGTH(e2) AS e2_len, y.account_id AS y_id
)
order by e1_len, e2_len, y_id
--
ARRAY<STRUCT<e1_len INT64, e2_len INT64, y_id INT64>>[known order:
  {0, 0, 1030},
  {0, 1, 1030},
  {1, 0, 1030}
]
==
[name=fixed_quantified_test]
select * from graph_table(aml
  MATCH (x:Account)((a)-[e:Transfer]->(b)){3}(y:Account)
  return x.account_id AS x_id, y.account_id AS y_id
)
order by x_id, y_id
--
ARRAY<STRUCT<x_id INT64, y_id INT64>>[known order:
  {1010, 1010},
  {1010, 1010},
  {1010, 1010},
  {1010, 1010},
  {1010, 1010},
  {1010, 1020},
  {1010, 1020},
  {1010, 1030},
  {1010, 1030},
  {1010, 1030},
  {1010, 1030},
  {1020, 1010},
  {1020, 1010},
  {1020, 1020},
  {1020, 1020},
  {1020, 1020},
  {1020, 1020},
  {1030, 1010},
  {1030, 1020},
  {1030, 1020},
  {1030, 1030},
  {1030, 1030},
  {1030, 1030},
  {1030, 1030}
]
==

[name=lower_upper_quantified_test]
select * from graph_table(aml
  MATCH (x:Account)((a)-[e:Transfer]->(b)){1,2}(y:Account)
  return x.account_id AS x_id, y.account_id AS y_id
)
