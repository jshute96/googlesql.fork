ARRAY<STRUCT<BOOL>>[{false}]
==

[name=group_rows_within_in_subquery_lhs_null_subquery_with_null]
SELECT CAST(NULL AS INT64) IN (
  WITH group_rows() AS GROUP ROWS
  SELECT val
  FROM group_rows()
