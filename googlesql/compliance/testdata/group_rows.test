[default required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS]

[prepare_database]
CREATE TABLE TestTable AS
SELECT * FROM UNNEST([
  STRUCT(1 AS id, "A" AS team, "anya" AS name),
  STRUCT(2 AS id, "A" AS team, "boren" AS name),
  STRUCT(3 AS id, "B" AS team, "carot" AS name)
]);
--
ARRAY<STRUCT<id INT64, team STRING, name STRING>>[
  {2, "A", "boren"},
  {1, "A", "anya"},
  {3, "B", "carot"}
]
==

[prepare_database]
CREATE TABLE CollatedTable(
  string_ci STRING COLLATE 'und:ci',
  string_binary STRING COLLATE 'binary'
) AS
SELECT "a" string_ci, "a" string_binary UNION ALL
SELECT "A" string_ci, "A" string_binary UNION ALL
SELECT "b" string_ci, "b" string_binary;
--
ARRAY<STRUCT<string_ci STRING, string_binary STRING>>[
  {"a", "a"},
  {"A", "A"},
  {"b", "b"}
]
==

[prepare_database]
CREATE TABLE TimestampPrecisionTable AS
SELECT *
FROM UNNEST([
  STRUCT(
    CAST('2123-01-02 04:05:06.123456789123+00' AS TIMESTAMP(6))  AS timestamp_6,
    CAST('2123-01-02 04:05:06.123456789123+00' AS TIMESTAMP(9))  AS timestamp_9,
    CAST('2123-01-02 04:05:06.123456789123+00' AS TIMESTAMP(12))  AS timestamp_12
  )
]);
--
ARRAY<STRUCT<
        timestamp_6 TIMESTAMP,
        timestamp_9 TIMESTAMP,
        timestamp_12 TIMESTAMP
      >>
[{
   2123-01-02 04:05:06.123456+00,
   2123-01-02 04:05:06.123456789+00,
   2123-01-02 04:05:06.123456789123+00
 }]
==

[name=group_rows_not_referenced]
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT 55
)
FROM TestTable
--
ARRAY<STRUCT<INT64>>[{55}]
==

[name=group_rows_with_group_by_in_parent_query]
SELECT
  team,
  (
    WITH group_rows() AS GROUP ROWS
    SELECT MAX(name)
    FROM group_rows()
  ) AS group_rows_value
FROM TestTable
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<
        team STRING,
        group_rows_value STRING
      >>
[known order:{"A", "boren"}, {"B", "carot"}]
==

[name=group_rows_without_group_by_in_parent_query]
SELECT
  (
    WITH group_rows() AS GROUP ROWS
    SELECT MAX(name)
    FROM group_rows()
  ) AS group_rows_value
FROM TestTable
--
ARRAY<STRUCT<group_rows_value STRING>>[{"carot"}]
==

[name=group_rows_in_scalar_subquery_multiple_rows_error]
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT name
  FROM group_rows()
) AS scalar_val
FROM TestTable
--
ERROR: generic::out_of_range: Scalar subquery produced more than one element.
==

[name=group_rows_in_scalar_subquery_zero_rows_null]
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT name
  FROM group_rows()
  WHERE name = "non-existent"
) AS name
FROM TestTable
--
ARRAY<STRUCT<name STRING>>[{NULL}]
==

[name=group_rows_in_array_subquery]
SELECT
  team,
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT name
    FROM group_rows()
  ) AS group_rows_value
FROM TestTable
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<
        team STRING,
        group_rows_value ARRAY<>
      >>
[known order:{
               "A",
               ARRAY<STRING>[unknown order:"boren", "anya"]
             },
             {
               "B",
               ARRAY<STRING>["carot"]
             }]
==

[name=select_star_from_group_rows]
SELECT
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT AS STRUCT *
    FROM group_rows()
  ) AS arr
FROM TestTable
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<arr ARRAY<>>>[known order:
  {ARRAY<STRUCT<id INT64, team STRING, name STRING>>[unknown order:
     {1, "A", "anya"},
     {2, "A", "boren"}
   ]},
  {ARRAY<STRUCT<id INT64, team STRING, name STRING>>[{3, "B", "carot"}]}
]
==

[name=access_correlated_column_in_group_rows_subquery]
SELECT
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT (t.team, gr.name)
    FROM group_rows() gr
    ORDER BY t.team
  ) AS val
FROM TestTable AS t
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<val ARRAY<>>>[known order:
  {ARRAY<STRUCT<STRING, STRING>>[unknown order:{"A", "anya"}, {"A", "boren"}]},
  {ARRAY<STRUCT<STRING, STRING>>[{"B", "carot"}]}
]
==

[name=group_rows_without_group_in_parent_query]
SELECT
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT name
    FROM group_rows()
    ORDER BY name
  ) AS all_names
FROM TestTable
--
ARRAY<STRUCT<all_names ARRAY<>>>[
  {ARRAY<STRING>[unknown order:"anya", "boren", "carot"]}
]
==

[name=arithmetic_on_multiple_group_rows]
SELECT
  id,
  (
    WITH group_rows() AS GROUP ROWS
    SELECT COUNT(*) FROM group_rows()
  ) + (
    WITH group_rows() AS GROUP ROWS
    SELECT SUM(id) FROM group_rows()
  ) AS composite
FROM TestTable
GROUP BY id
ORDER BY id
--
ARRAY<STRUCT<id INT64, composite INT64>>[known order:{1, 2}, {2, 3}, {3, 4}]
==

[name=having_group_rows]
SELECT name
FROM TestTable
GROUP BY id, name
HAVING (
  WITH group_rows() AS GROUP ROWS
  SELECT COUNT(*)
  FROM group_rows()
  WHERE name LIKE "bo%"
) >= 1
ORDER BY id
--
ARRAY<STRUCT<name STRING>>[{"boren"}]
==

[name=conditional_group_rows]
SELECT
  id,
  IF(id > 1, (
    WITH group_rows() AS GROUP ROWS
    SELECT name FROM group_rows()
  ), "skipped") AS conditional_val
FROM TestTable
GROUP BY id
ORDER BY id
--
ARRAY<STRUCT<
        id INT64,
        conditional_val STRING
      >>
[known order:{1, "skipped"}, {2, "boren"}, {3, "carot"}]
==

[name=define_and_use_group_rows_within_cte]
WITH cte AS (
  SELECT ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT t.name
    FROM group_rows()
  )
  FROM TestTable t
)
SELECT *
FROM cte
--
ARRAY<STRUCT<ARRAY<>>>[
  {ARRAY<STRING>[unknown order:"boren", "anya", "carot"]}
]
==

[name=define_group_rows_and_use_it_in_a_following_cte]
SELECT ARRAY(
  WITH
    group_rows() AS GROUP ROWS,
    cte AS (
      SELECT t.id
      FROM group_rows()
    )
    SELECT *
    FROM cte
)
FROM TestTable t
--
ARRAY<STRUCT<ARRAY<>>>[{ARRAY<INT64>[unknown order:1, 2, 3]}]
==

# TODO: Ref impl hoists WITH clauses in subqueries to the top
# level, losing the local evaluation context needed by GROUP_ROWS(). The general
# solution involves supporting scoped WITH clauses that evaluate in the correct
# local context while preserving run-once semantics.
[name=group_rows_cte_referenced_twice_fails]
[labels=bug_in_reference_impl]
SELECT ARRAY(
  WITH
    group_rows() AS GROUP ROWS,
    cte AS (
      SELECT t.id
      FROM group_rows()
    )
    SELECT *
    FROM cte
    UNION ALL
    SELECT *
    FROM cte
)
FROM TestTable t
--
ARRAY<STRUCT<ARRAY<>>>[{ARRAY<INT64>[unknown order:1, 2, 3, 1, 2, 3]}]
==

[name=group_rows_with_collation]
[required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT string_ci
  FROM group_rows()
  WHERE string_ci = "a"
) AS arr
FROM CollatedTable
--
ARRAY<STRUCT<arr ARRAY<>>>[{ARRAY<STRING>[unknown order:"A", "a"]}]
==

[name=group_rows_with_timestamp_precision]
SELECT
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT AS STRUCT *
    FROM group_rows()
  ) AS arr
FROM TimestampPrecisionTable
--
ARRAY<STRUCT<arr ARRAY<>>>[
  {ARRAY<STRUCT<
           timestamp_6 TIMESTAMP,
           timestamp_9 TIMESTAMP,
           timestamp_12 TIMESTAMP
         >>
   [{
          2123-01-02 04:05:06.123456+00,
          2123-01-02 04:05:06.123456789+00,
          2123-01-02 04:05:06.123456789123+00
        }]}
]
==

[name=group_rows_on_join_clause]
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT AS STRUCT t1.*, t2.*
  FROM group_rows()
)
FROM TestTable t1, CollatedTable t2
WHERE t1.team = t2.string_binary
--
ARRAY<STRUCT<ARRAY<>>>[
  {ARRAY<STRUCT<id INT64,
                team STRING,
                name STRING,
                string_ci STRING,
                string_binary STRING>>
   [unknown order:
     {1, "A", "anya", "A", "A"},
     {2, "A", "boren", "A", "A"}
   ]}
]
==

[name=group_rows_self_join]
SELECT ARRAY(
  WITH gr() AS GROUP ROWS
  SELECT AS STRUCT gr1.name as name1, gr2.name as name2
  FROM gr() gr1
  JOIN gr() gr2 ON gr1.id < gr2.id
  ORDER BY name1, name2
) as joined_gr
FROM TestTable
--
ARRAY<STRUCT<joined_gr ARRAY<>>>[
  {ARRAY<STRUCT<name1 STRING, name2 STRING>>[unknown order:
     {"anya", "carot"},
     {"anya", "boren"},
     {"boren", "carot"}
   ]}
]
==

[name=group_rows_joined_with_table]
SELECT
  team,
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT (string_binary, name)
    FROM CollatedTable t
    JOIN group_rows() gr
    ON t.string_binary = gr.team
  )
FROM TestTable
GROUP BY team
--
ARRAY<STRUCT<team STRING, ARRAY<>>>[unknown order:
  {
    "A",
    ARRAY<STRUCT<STRING, STRING>>[unknown order:{"A", "boren"}, {"A", "anya"}]
  },
  {
    "B",
    ARRAY<STRUCT<STRING, STRING>>(NULL)
  }
]
==

[name=nested_group_rows_name_shadowing_different_tables]
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT name
    FROM group_rows()
  )
  FROM TestTable t
  JOIN group_rows() gr
  ON t.team = gr.string_binary
)
FROM CollatedTable
--
ARRAY<STRUCT<ARRAY<>>>[{ARRAY<STRING>[unknown order:"anya", "boren"]}]
==

[name=nested_group_rows_name_shadowing_same_tables]
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT (t.name, gr.name)
    FROM group_rows()
  )
  FROM TestTable t
  JOIN group_rows() gr
  ON t.team = gr.team
)
FROM TestTable
--
ARRAY<STRUCT<ARRAY<>>>[
  {ARRAY<STRUCT<STRING, STRING>>[unknown order:
     {"boren", "boren"},
     {"anya", "boren"},
     {"boren", "anya"},
     {"anya", "anya"},
     {"carot", "carot"}
   ]}
]
==

[name=multiple_group_rows_subqueries]
SELECT
  ARRAY(
    WITH group_rows1() AS GROUP ROWS
    SELECT id
    FROM group_rows1()
  ),
  (
    WITH group_rows2() AS GROUP ROWS
    SELECT SUM(id)
    FROM group_rows2()
  ),
  (
    WITH group_rows2() AS GROUP ROWS
    SELECT MAX(team)
    FROM group_rows2()
  )
FROM TestTable
--
ARRAY<STRUCT<ARRAY<>, INT64, STRING>>[
  {
    ARRAY<INT64>[unknown order:2, 1, 3],
    6,
    "B"
  }
]
==

[name=nested_group_rows]
SELECT
  string_binary,
  (
    SELECT ARRAY(
      WITH group_rows() AS GROUP ROWS
      SELECT name
      FROM group_ROWS()
      WHERE team = string_binary
  )
  FROM TestTable
)
FROM CollatedTable
--
ARRAY<STRUCT<string_binary STRING, ARRAY<>>>[unknown order:
  {
    "A",
    ARRAY<STRING>[unknown order:"anya", "boren"]
  },
  {"a", ARRAY<STRING>(NULL)},
  {"b", ARRAY<STRING>(NULL)}
]
==

[name=nested_subquery_referring_to_outer_group_rows]
SELECT
  team,
  (
    WITH group_rows() AS GROUP ROWS
    SELECT n
    FROM (
      SELECT MAX(name) AS n
      FROM group_rows()
  )
)
FROM TestTable
GROUP BY team
--
ARRAY<STRUCT<team STRING, STRING>>[unknown order:
  {"A", "boren"},
  {"B", "carot"}
]
==

[name=nested_group_rows_reference_outer_group_rows]
SELECT
  team,
  (
    WITH outer_group_rows() AS GROUP ROWS
    SELECT ARRAY(
      WITH inner_group_rows() AS GROUP ROWS
      SELECT (string_binary, name)
      FROM inner_group_rows() t1, outer_group_rows() t2
      WHERE t1.string_binary != t2.team
    )
    FROM CollatedTable
  ) as nested_val
FROM TestTable
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<team STRING, nested_val ARRAY<>>>[known order:
  {"A",
   ARRAY<STRUCT<STRING, STRING>>[unknown order:
     {"b", "boren"},
     {"a", "boren"},
     {"b", "anya"},
     {"a", "anya"}
   ]},
  {"B",
   ARRAY<STRUCT<STRING, STRING>>[unknown order:
     {"A", "carot"},
     {"a", "carot"},
     {"b", "carot"}
   ]}
]
==

[name=nested_subquery_referencing_multiple_group_rows]
SELECT
  team,
  (
    WITH outer_group_rows() AS GROUP ROWS
    SELECT ARRAY(
        WITH inner_group_rows() AS GROUP ROWS
        SELECT (string_binary, name)
        FROM (
          SELECT *
          FROM inner_group_rows() t1, outer_group_rows() t2
          WHERE t1.string_binary != t2.team
        )
      )
    FROM CollatedTable
  )
FROM TestTable
GROUP BY team
--
ARRAY<STRUCT<team STRING, ARRAY<>>>[unknown order:
  {"A",
   ARRAY<STRUCT<STRING, STRING>>[unknown order:
     {"b", "boren"},
     {"a", "boren"},
     {"b", "anya"},
     {"a", "anya"}
   ]},
  {"B",
   ARRAY<STRUCT<STRING, STRING>>[unknown order:
     {"A", "carot"},
     {"a", "carot"},
     {"b", "carot"}
   ]}
]
==

[name=group_rows_in_exists_subquery]
SELECT
  team,
  EXISTS(
    WITH group_rows() AS GROUP ROWS
    SELECT name, id
    FROM group_rows()
    WHERE name = "boren"
  ) AS has_boren
FROM TestTable
GROUP BY team
ORDER BY team
--
ARRAY<STRUCT<team STRING, has_boren BOOL>>[known order:
  {"A", true},
  {"B", false}
]
==

[name=group_rows_in_qualify_subquery]
[required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS,QUALIFY,ANALYTIC_FUNCTIONS]
SELECT
  team,
  ROW_NUMBER() OVER(ORDER BY team) as rn
FROM TestTable
GROUP BY team
QUALIFY (
  WITH group_rows() AS GROUP ROWS
  SELECT COUNT(*)
  FROM group_rows()
) = 1
ORDER BY team
--
ARRAY<STRUCT<team STRING, rn INT64>>[{"B", 2}]
==

[name=group_rows_within_in_subquery]
SELECT "A" IN (
  WITH group_rows() AS GROUP ROWS
  SELECT team
  FROM group_rows()
)
FROM TestTable
GROUP BY id
--
ARRAY<STRUCT<BOOL>>[unknown order:{true}, {true}, {false}]
==

[name=group_rows_within_in_subquery_with_collation]
[required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
SELECT "B" IN (
  WITH group_rows() AS GROUP ROWS
  SELECT string_ci
  FROM group_rows()
  WHERE string_binary = "b"
)
FROM CollatedTable
--
ARRAY<STRUCT<BOOL>>[{true}]
==

[name=group_rows_within_in_subquery_with_collation_lhs]
[required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
SELECT COLLATE('B', 'und:ci') IN (
  WITH group_rows() AS GROUP ROWS
  SELECT "b"
  FROM group_rows()
  WHERE string_binary = "b"
)
FROM CollatedTable
--
ARRAY<STRUCT<BOOL>>[{true}]
==

[name=group_rows_within_in_unnest_array_subquery_with_collation]
[required_features=WITH_ON_SUBQUERY,WITH_GROUP_ROWS,ANNOTATION_FRAMEWORK,COLLATION_SUPPORT]
SELECT "B" IN UNNEST(ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT string_ci
  FROM group_rows()
  WHERE string_binary = "b"
))
FROM CollatedTable
--
ARRAY<STRUCT<BOOL>>[{true}]
==

[name=group_rows_within_in_subquery_null_behavior]
SELECT 5 IN (
  WITH group_rows() AS GROUP ROWS
  SELECT val
  FROM group_rows()
)
FROM UNNEST([1, 2, CAST(NULL AS INT64)]) AS val
--
ARRAY<STRUCT<BOOL>>[{NULL}]
==

[name=group_rows_within_in_subquery_lhs_null]
SELECT CAST(NULL AS INT64) IN (
  WITH group_rows() AS GROUP ROWS
  SELECT val
  FROM group_rows()
)
FROM UNNEST([1, 2, 3]) AS val
--
ARRAY<STRUCT<BOOL>>[{NULL}]
==

[name=group_rows_within_in_subquery_lhs_null_empty_subquery]
SELECT CAST(NULL AS INT64) IN (
  WITH group_rows() AS GROUP ROWS
  SELECT val
  FROM group_rows()
  WHERE false
)
FROM UNNEST([1, 2, 3]) AS val
