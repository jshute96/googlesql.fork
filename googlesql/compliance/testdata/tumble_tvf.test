==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=window_start_end_boundaries]
WITH CteWithWindowStartEndAndBoundaries AS (
  SELECT TIMESTAMP '2025-01-01 00:00:00+00' AS ts_col,
         "a" AS window_START,
         "b" AS window_END,
  UNION ALL
  SELECT TIMESTAMP '2025-01-02 00:00:00+00' AS ts_col,
         "a" AS window_START,
         "b" AS window_END,
)
SELECT * FROM tumble(TABLE CteWithWindowStartEndAndBoundaries, "ts_col", INTERVAL 1 DAY);
--
ARRAY<STRUCT<
        ts_col TIMESTAMP,
        WINDOW_START TIMESTAMP,
        WINDOW_END TIMESTAMP
      >>
[unknown order:{
                 2025-01-01 00:00:00+00,
                 2025-01-01 00:00:00+00,
                 2025-01-02 00:00:00+00
               },
               {
                 2025-01-02 00:00:00+00,
                 2025-01-02 00:00:00+00,
                 2025-01-03 00:00:00+00
               }]
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=null_timestamps_results_in_null_window_start_end]
WITH CteWithNullTimestamps AS (
  SELECT 1 as id, TIMESTAMP '2025-01-01 00:00:00+00' AS ts_col
  UNION ALL
  SELECT 2 as id, CAST(NULL AS TIMESTAMP) AS ts_col
  UNION ALL
  SELECT 3 as id, CAST(NULL AS TIMESTAMP) AS ts_col
)
SELECT * FROM tumble(TABLE CteWithNullTimestamps, "ts_col", INTERVAL 1 DAY);
--
ARRAY<STRUCT<
        id INT64,
        ts_col TIMESTAMP,
        WINDOW_START TIMESTAMP,
        WINDOW_END TIMESTAMP
      >>
[unknown order:{
                 1,
                 2025-01-01 00:00:00+00,
                 2025-01-01 00:00:00+00,
                 2025-01-02 00:00:00+00
               },
               {2, NULL, NULL, NULL},
               {3, NULL, NULL, NULL}]
==
# Omitting the WINDOW_START and WINDOW_END in the select does not affect Tumble.
# Column pruning does not affect Tumble TVF reference implementation.
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS,NAMED_ARGUMENTS]
[name=only_ts_col_selected]
SELECT ts_col FROM tumble(TABLE TableWithTimestampColumn, "ts_col", INTERVAL 1 DAY, origin => TIMESTAMP("2026-01-01 02:00:00+00"));
--
ARRAY<STRUCT<ts_col TIMESTAMP>>[unknown order:
  {2025-01-02 08:00:00+00},
  {2025-01-04 08:00:00+00},
  {2025-01-01 08:00:00+00},
  {2025-01-03 08:00:00+00}
]
==
# Omitting the ts_col and WINDOW_END in the select does not affect Tumble.
# Column pruning does not affect Tumble TVF reference implementation.
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS,NAMED_ARGUMENTS]
[name=only_window_start_selected]
SELECT WINDOW_START FROM tumble(TABLE TableWithTimestampColumn, "ts_col", INTERVAL 1 DAY, origin => TIMESTAMP("2026-01-01 02:00:00+00"));
--
ARRAY<STRUCT<WINDOW_START TIMESTAMP>>[unknown order:
  {2025-01-02 02:00:00+00},
  {2025-01-04 02:00:00+00},
  {2025-01-01 02:00:00+00},
  {2025-01-03 02:00:00+00}
]
==
# Omitting the ts_col and WINDOW_START in the select does not affect Tumble.
# Column pruning does not affect Tumble TVF reference implementation.
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS,NAMED_ARGUMENTS]
[name=only_window_end_selected]
SELECT WINDOW_END FROM tumble(TABLE TableWithTimestampColumn, "ts_col", INTERVAL 1 DAY, origin => TIMESTAMP("2026-01-01 02:00:00+00"));
--
ARRAY<STRUCT<WINDOW_END TIMESTAMP>>[unknown order:
  {2025-01-03 02:00:00+00},
  {2025-01-05 02:00:00+00},
  {2025-01-02 02:00:00+00},
  {2025-01-04 02:00:00+00}
]
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=window_generation_underflow]
WITH CteWithMinTimestamp AS (
  SELECT TIMESTAMP '0001-01-01 00:00:00+00' AS ts_col
)
SELECT * FROM tumble(TABLE CteWithMinTimestamp, "ts_col", INTERVAL 3 DAY);
--
ERROR: generic::out_of_range: Bucket for 0001-01-01 00:00:00+00 is outside of timestamp range
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=window_generation_overflow]
WITH CteWithMaxTimestamp AS (
  SELECT TIMESTAMP '9999-12-31 23:59:59.999999+00' AS ts_col
)
SELECT * FROM tumble(TABLE CteWithMaxTimestamp, "ts_col", INTERVAL 1 DAY);
--
ERROR: generic::out_of_range: Bucket for 9999-12-31 23:59:59.999999+00 is outside of timestamp range
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=zero_window_size]
SELECT * FROM tumble(TABLE TableWithTimestampColumn, "ts_col", INTERVAL 0 DAY);
--
ERROR: generic::out_of_range: Window size cannot be zero.
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=negative_window_size]
SELECT * FROM tumble(TABLE TableWithTimestampColumn, "ts_col", - INTERVAL 1 DAY);
--
ERROR: generic::out_of_range: Window size cannot be negative.
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=null_window_size]
SELECT * FROM tumble(TABLE TableWithTimestampColumn, "ts_col", CAST(NULL AS INTERVAL));
--
ERROR: generic::out_of_range: Window size cannot be null.
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS,NAMED_ARGUMENTS]
[name=null_origin]
SELECT * FROM tumble(TABLE TableWithTimestampColumn, "ts_col", INTERVAL 1 DAY, origin => NULL);
--
ERROR: generic::out_of_range: Origin cannot be null.
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=tumble_duplicate_columns]
SELECT *
FROM TUMBLE(
  (SELECT 10 as val, 20 as val, TIMESTAMP '2024-01-01 00:00:00' as ts),
  'ts',
  INTERVAL 1 HOUR
)
--
ARRAY<STRUCT<
        val INT64,
        val INT64,
        ts TIMESTAMP,
        WINDOW_START TIMESTAMP,
        WINDOW_END TIMESTAMP
      >>
[{
   10,
   20,
   2024-01-01 08:00:00+00,
   2024-01-01 08:00:00+00,
   2024-01-01 09:00:00+00
 }]
==
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=tumble_pruned_columns]
SELECT WINDOW_START
FROM TUMBLE(
  (SELECT 10 as val, 20 as val, TIMESTAMP '2024-01-01 00:00:00' as ts),
  'ts',
  INTERVAL 1 HOUR
)
--
ARRAY<STRUCT<WINDOW_START TIMESTAMP>>[{2024-01-01 08:00:00+00}]

==
# Run-once semantics:
# These tests try to ensure that expressions provided as TVF arguments are
# evaluated exactly once. In particular, this is intended to check that the
# **TUMBLE function rewriter** preserves run-once semantics.
#
# The input table has 20 rows with the same timestamp, so they should all
# have the same window_start. If the expression is evaluated more than once,
# it's extremely likely that some rows will have different window_start values,
# and the test will fail.
[required_features=INTERVAL_TYPE,TABLE_VALUED_FUNCTIONS,TUMBLE_HOP_TVFS]
[name=tumble_run_once_window_size]
WITH Events AS (
  SELECT TIMESTAMP '2025-09-01 05:01:00' AS ts
  FROM UNNEST(GENERATE_ARRAY(1, 20)) AS n
)
SELECT
  IF(windows_count = 1, 'Correct', 'Incorrect!')
FROM (
  SELECT count(distinct WINDOW_START) as windows_count
  FROM TUMBLE(TABLE Events, 'ts', IF(RAND() > 0.5, INTERVAL '1' MINUTE, INTERVAL '10' MINUTE))
)
--
ARRAY<STRUCT<STRING>>[{"Correct"}]
