[default show_sqlbuilder_output]
[default no_show_resolved_ast]
[default language_features=MAXIMUM,+PIPES,+PIPE_ASSERT]
# No payload.
FROM KeyValue
|> ASSERT key = 10
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  assertscan_3.a_1 AS Key,
  assertscan_3.a_2 AS Value
FROM
  (
    SELECT
      a_1 AS a_1,
      a_2 AS a_2
    FROM
      (
        FROM
          KeyValue
        |> SELECT
             KeyValue.Key AS a_1,
             KeyValue.Value AS a_2
        |> ASSERT a_1 = 10, "key = 10"
      )
  ) AS assertscan_3;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> ASSERT(KeyValue.Key) = 10, "key = 10"
|> SELECT
     KeyValue.Key,
     KeyValue.Value;
==

# One payload.
FROM KeyValue
|> ASSERT key = 10, "payload1"
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  assertscan_3.a_1 AS Key,
  assertscan_3.a_2 AS Value
FROM
  (
    SELECT
      a_1 AS a_1,
      a_2 AS a_2
    FROM
      (
        FROM
          KeyValue
        |> SELECT
             KeyValue.Key AS a_1,
             KeyValue.Value AS a_2
        |> ASSERT a_1 = 10, "payload1"
      )
  ) AS assertscan_3;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> ASSERT(KeyValue.Key) = 10, "payload1"
|> SELECT
     KeyValue.Key,
     KeyValue.Value;
==

# Multiple payloads.
FROM KeyValue
|> ASSERT key = 10, key, "payload2"
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  assertscan_3.a_1 AS Key,
  assertscan_3.a_2 AS Value
FROM
  (
    SELECT
      a_1 AS a_1,
      a_2 AS a_2
    FROM
      (
        FROM
          KeyValue
        |> SELECT
             KeyValue.Key AS a_1,
             KeyValue.Value AS a_2
        |> ASSERT a_1 = 10, CONCAT(IFNULL(CAST(a_1 AS STRING), "NULL"), " ", "payload2")
      )
  ) AS assertscan_3;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> ASSERT(KeyValue.Key) = 10, CONCAT(IFNULL(CAST(KeyValue.Key AS STRING), "NULL"), " ", "payload2")
|> SELECT
     KeyValue.Key,
     KeyValue.Value;
==

# Multiple ASSERT operators.
FROM KeyValue
|> ASSERT key = 10, "payload1"
|> ASSERT key = 20, "payload2"
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  assertscan_4.a_1 AS Key,
  assertscan_4.a_2 AS Value
FROM
  (
    SELECT
      assertscan_3.a_1 AS a_1,
      assertscan_3.a_2 AS a_2
    FROM
      (
        (
          SELECT
            a_1 AS a_1,
            a_2 AS a_2
          FROM
            (
              FROM
                KeyValue
              |> SELECT
                   KeyValue.Key AS a_1,
                   KeyValue.Value AS a_2
              |> ASSERT a_1 = 10, "payload1"
            )
        ) AS assertscan_3
        |> ASSERT(assertscan_3.a_1) = 20, "payload2"
      )
  ) AS assertscan_4;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> ASSERT(KeyValue.Key) = 10, "payload1"
|> ASSERT(KeyValue.Key) = 20, "payload2"
|> SELECT
     KeyValue.Key,
     KeyValue.Value;
==

# Nested ASSERT operators.
SELECT * FROM (
  FROM KeyValue
  |> ASSERT key = 10, "payload1"
)
|> ASSERT key = 20, "payload2"
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  assertscan_4.a_1 AS Key,
  assertscan_4.a_2 AS Value
FROM
  (
    SELECT
      a_1 AS a_1,
      a_2 AS a_2
    FROM
      (
        (
          SELECT
            a_1 AS a_1,
            a_2 AS a_2
          FROM
            (
              FROM
                KeyValue
              |> SELECT
                   KeyValue.Key AS a_1,
                   KeyValue.Value AS a_2
              |> ASSERT a_1 = 10, "payload1"
            )
        ) AS assertscan_3
        |> SELECT
             assertscan_3.a_1,
             assertscan_3.a_2
        |> ASSERT a_1 = 20, "payload2"
      )
  ) AS assertscan_4;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> ASSERT(KeyValue.Key) = 10, "payload1"
|> SELECT
     KeyValue.Key,
     KeyValue.Value
|> ASSERT Key = 20, "payload2"
|> SELECT
     Key,
     Value;
