[language_features=NONE,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_SUBQUERY]
select *
from TestTable T
where T.KitchenSink.string_val
      {{LIKE|NOT LIKE}} {{ANY|SOME|ALL}}
      (select * from T.KitchenSink.repeated_string_val)
--
ALTERNATION GROUPS:
    LIKE,ANY
    LIKE,SOME
--
