ALTERNATION GROUP: ALL
--
ERROR: UNNEST expression used with LIKE ALL does not allow named arguments [at 2:36]
select 'a' LIKE ALL UNNEST(['a'],  mode => 'STRICT');
                                   ^
==

[language_features=NONE,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_ARRAY]
# Alias inside UNNEST is not allowed
select 'a' LIKE {{ANY|SOME|ALL}} UNNEST(['a'] as array);

--
ALTERNATION GROUP: ANY
--
ERROR: Syntax error: Unexpected keyword ARRAY [at 2:37]
select 'a' LIKE ANY UNNEST(['a'] as array);
                                    ^
--
ALTERNATION GROUP: SOME
--
ERROR: Syntax error: Unexpected keyword ARRAY [at 2:38]
select 'a' LIKE SOME UNNEST(['a'] as array);
                                     ^
--
ALTERNATION GROUP: ALL
--
ERROR: Syntax error: Unexpected keyword ARRAY [at 2:37]
select 'a' LIKE ALL UNNEST(['a'] as array);
                                    ^
==

[language_features=MAXIMUM,+LIKE_ANY_SOME_ALL]
select [struct('ab' as x)].x like all unnest([struct('a%' as y), struct('%b')].y);
--
ERROR: Cannot access field x on a value with type ARRAY<STRUCT<x STRING>>. You may need an explicit call to FLATTEN, and the flattened argument may only contain 'dot' after the first array [at 1:28]
select [struct('ab' as x)].x like all unnest([struct('a%' as y), struct('%b')...
                           ^

==

