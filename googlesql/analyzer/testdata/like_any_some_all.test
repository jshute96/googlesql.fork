[language_features=NONE,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_ARRAY]
select 'a' LIKE {{ANY|SOME|ALL}} UNNEST([1, 2, 3])
--
ALTERNATION GROUP: ANY
--
ERROR: No matching signature for operator LIKE ANY|SOME UNNEST for argument types: STRING, ARRAY<INT64> [at 1:12]
select 'a' LIKE ANY UNNEST([1, 2, 3])
           ^
--
ALTERNATION GROUP: SOME
--
ERROR: No matching signature for operator LIKE ANY|SOME UNNEST for argument types: STRING, ARRAY<INT64> [at 1:12]
select 'a' LIKE SOME UNNEST([1, 2, 3])
           ^
--
ALTERNATION GROUP: ALL
--
ERROR: No matching signature for operator LIKE ALL UNNEST for argument types: STRING, ARRAY<INT64> [at 1:12]
select 'a' LIKE ALL UNNEST([1, 2, 3])
           ^
==

select ('a', 'b') LIKE ANY ('a');
--
ERROR: No matching signature for operator LIKE ANY|SOME for argument types STRUCT<STRING, STRING> and {STRING} [at 1:19]
select ('a', 'b') LIKE ANY ('a');
                  ^
==

SELECT 'b' LIKE ANY ('a', NULL, CURRENT_TIMESTAMP());
--
ERROR: No matching signature for operator LIKE ANY|SOME for argument types literal STRING and {NULL, STRING, TIMESTAMP} [at 1:12]
SELECT 'b' LIKE ANY ('a', NULL, CURRENT_TIMESTAMP());
           ^
==

select 'a' LIKE {{ANY|SOME|ALL}} (select 'a')
--
ALTERNATION GROUP: ANY
--
ERROR: The LIKE ANY|SOME|ALL operator does not support subquery expression as patterns. Patterns must be string or bytes; did you mean LIKE ANY (pattern1, pattern2, ...)? [at 1:22]
select 'a' LIKE ANY (select 'a')
                     ^
--
ALTERNATION GROUP: SOME
--
ERROR: The LIKE ANY|SOME|ALL operator does not support subquery expression as patterns. Patterns must be string or bytes; did you mean LIKE SOME (pattern1, pattern2, ...)? [at 1:23]
select 'a' LIKE SOME (select 'a')
                      ^
--
ALTERNATION GROUP: ALL
--
ERROR: The LIKE ANY|SOME|ALL operator does not support subquery expression as patterns. Patterns must be string or bytes; did you mean LIKE ALL (pattern1, pattern2, ...)? [at 1:22]
select 'a' LIKE ALL (select 'a')
                     ^
==

[language_features=NONE,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_SUBQUERY]
select 1 {{LIKE|NOT LIKE}} {{ANY|SOME|ALL}} (select 1)
--
ALTERNATION GROUP: LIKE,ANY
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 LIKE ANY (select 1)
       ^
--
ALTERNATION GROUP: LIKE,SOME
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 LIKE SOME (select 1)
       ^
--
ALTERNATION GROUP: LIKE,ALL
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 LIKE ALL (select 1)
       ^
--
ALTERNATION GROUP: NOT LIKE,ANY
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 NOT LIKE ANY (select 1)
       ^
--
ALTERNATION GROUP: NOT LIKE,SOME
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 NOT LIKE SOME (select 1)
       ^
--
ALTERNATION GROUP: NOT LIKE,ALL
--
ERROR: Cannot execute a LIKE expression subquery with types INT64 and INT64 [at 1:8]
select 1 NOT LIKE ALL (select 1)
       ^
==

