    |           |                     +-ColumnRef(type=STRING, column=$array.pattern#4)
    |           +-input_scan=
    |             +-ProjectScan
    |               +-column_list=$subquery1.[input#2, patterns#3]
    |               +-expr_list=
    |               | +-input#2 := Literal(type=STRING, value="a")
    |               | +-patterns#3 :=
    |               |   +-FunctionCall(GoogleSQL:$make_array(repeated(1) STRING) -> ARRAY<STRING>)
    |               |     +-Literal(type=STRING, value="b")
    |               +-input_scan=
    |                 +-SingleRowScan
    +-input_scan=
      +-SingleRowScan

==

