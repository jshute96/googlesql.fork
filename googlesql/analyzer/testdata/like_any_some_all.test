SELECT COLLATE('Google', 'und:ci') LIKE ANY (SELECT 'google')
--
QueryStmt
+-output_column_list=
| +-$query.$col1#2 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#2]
    +-expr_list=
    | +-$col1#2 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=LIKE_ANY
    |     +-in_expr=
    |     | +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
    |     |   +-type_annotation_map={Collation:"und:ci"}
