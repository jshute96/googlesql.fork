# Test collation conflict error in quantified LIKE with subquery.
# TODO: Collation/Annotation specific GoogleSQL analyzer tests are not working as expected while executed in java mode.
[no_java]
[language_features=NONE,+ANNOTATION_FRAMEWORK,+COLLATION_SUPPORT,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_SUBQUERY]
SELECT COLLATE('A', 'und:ci') LIKE ANY (SELECT COLLATE('a', 'binary'))
--
ERROR: Collation conflict: "und:ci" vs. "binary". Collation for LIKE operator is different on input expr ("und:ci") and subquery column ("binary") [at 1:41]
SELECT COLLATE('A', 'und:ci') LIKE ANY (SELECT COLLATE('a', 'binary'))
                                        ^

==

# Test collation propagation with table columns in quantified LIKE subquery.
# TODO: Collation/Annotation specific GoogleSQL analyzer tests are not working as expected while executed in java mode.
[no_java]
[language_features=NONE,+ANNOTATION_FRAMEWORK,+COLLATION_SUPPORT,+LIKE_ANY_SOME_ALL,+LIKE_ANY_SOME_ALL_SUBQUERY]
# string_ci column has 'und:ci' collation.
SELECT 'google' LIKE ALL (SELECT string_ci FROM CollatedTable)
--
QueryStmt
+-output_column_list=
| +-$query.$col1#5 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#5]
    +-expr_list=
    | +-$col1#5 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=LIKE_ALL
    |     +-in_expr=
    |     | +-Literal(type=STRING, value="google")
    |     +-in_collation=und:ci
    |     +-subquery=
    |       +-ProjectScan
    |         +-column_list=[CollatedTable.string_ci#1{Collation:"und:ci"}]
    |         +-input_scan=
    |           +-TableScan(column_list=[CollatedTable.string_ci#1{Collation:"und:ci"}], table=CollatedTable, column_index_list=[0])
    +-input_scan=
      +-SingleRowScan

