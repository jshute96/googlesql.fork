# Tests for Single VECTOR_SEARCH TVF signatures.
#
# Similar to approx_distance_functions for supplied arguments, we would Nested
# serilization logic to run Java tests.
[default no_java]
[default language_features=MAXIMUM,+SINGLE_HYBRID_VECTOR_SEARCH_TVF]
[default no_enable_literal_replacement]
# Disable literal replacement for VECTOR_SEARCH TVF because argument options
# is an immutable constant.

# Basic call with ARRAY<DOUBLE> query_value
SELECT * FROM vector_search(TABLE base_table, 'embedding', query_value => ARRAY<DOUBLE>[1.0, 2.0, 3.0])
--
QueryStmt
+-output_column_list=
| +-vector_search.base#16 AS base [STRUCT<id INT64, embedding ARRAY<DOUBLE>, string_col STRING>]
| +-vector_search.distance#17 AS distance [DOUBLE]
+-query=
  +-ProjectScan
    +-column_list=vector_search.[base#16, distance#17]
    +-input_scan=
      +-TVFScan
        +-column_list=vector_search.[base#16, distance#17]
        +-tvf=GoogleSQL:vector_search((ANY TABLE, STRING {must_be_non_null: true} column_to_search, ANY TABLE, optional STRING query_column_to_search, optional PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto> {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, ANY TABLE, optional STRING query_column_to_search, optional JSON {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, ARRAY<FLOAT> {must_be_non_null: true} query_value, optional PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto> {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, ARRAY<FLOAT> {must_be_non_null: true} query_value, optional JSON {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, ARRAY<DOUBLE> {must_be_non_null: true} query_value, optional PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto> {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, ARRAY<DOUBLE> {must_be_non_null: true} query_value, optional JSON {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, STRING {must_be_non_null: true} query_value, optional PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto> {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE; (ANY TABLE, STRING {must_be_non_null: true} column_to_search, STRING {must_be_non_null: true} query_value, optional JSON {must_be_immutable_constant: true} options, optional INT64 {default_value: 10} top_k, optional STRING {default_value: "EUCLIDEAN"} distance_type, optional DOUBLE {default_value: NULL} max_distance) -> ANY TABLE)
        +-signature=(TABLE<id INT64, embedding ARRAY<DOUBLE>, string_col STRING>, literal STRING, ARRAY<DOUBLE>, null PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto>, literal INT64, literal STRING, null DOUBLE) -> TABLE<base STRUCT<id INT64, embedding ARRAY<DOUBLE>, string_col STRING>, distance DOUBLE>
        +-argument_list=
        | +-FunctionArgument
        | | +-scan=
        | | | +-TableScan(column_list=base_table.[id#13, embedding#14, string_col#15], node_source="table_clause", table=base_table, column_index_list=[0, 1, 2])
        | | +-argument_column_list=base_table.[id#13, embedding#14, string_col#15]
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=STRING, value="embedding")
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=ARRAY<DOUBLE>, value=[1, 2, 3], has_explicit_type=TRUE)
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto>, value=NULL, preserve_in_literal_remover=TRUE)
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=INT64, value=10)
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=STRING, value="EUCLIDEAN")
        | +-FunctionArgument
        |   +-expr=
        |     +-Literal(type=DOUBLE, value=NULL)
        +-column_index_list=[0, 1]
        +-function_call_signature=(ANY TABLE, STRING column_to_search, ARRAY<DOUBLE> query_value, optional(1) PROTO<googlesql_test.TestApproxDistanceFunctionOptionsProto> options, optional(1) INT64 top_k, optional(1) STRING distance_type, optional(1) DOUBLE max_distance) -> ANY TABLE
