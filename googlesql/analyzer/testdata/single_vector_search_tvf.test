# VECTOR_SEARCH TVF used in a function definition
CREATE TEMP FUNCTION OneSidedChamferDistanceSingle(
  colA STRING,
  distance_type STRING)
RETURNS DOUBLE
AS (
  (
    SELECT AVG(distance) AS distance
    FROM
      VECTOR_SEARCH(
        TABLE base_table, colA,
        query_value => ARRAY<DOUBLE>[1.0, 2.0, 3.0],
        top_k => 1,
        distance_type => distance_type)
  )
);
