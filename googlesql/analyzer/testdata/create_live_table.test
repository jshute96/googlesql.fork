[default language_features=NONE,+CREATE_LIVE_TABLE]

CREATE LIVE TABLE my_live_table AS SELECT 1 AS a;
--
CreateLiveTableStmt
+-name_path=my_live_table
+-column_definition_list=
| +-ColumnDefinition(name="a", type=INT64, column=my_live_table.a#2)
+-output_column_list=
| +-$create_as.a#1 AS a [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$create_as.a#1]
    +-expr_list=
    | +-a#1 := Literal(type=INT64, value=1)
    +-input_scan=
      +-SingleRowScan
==

CREATE LIVE TABLE IF NOT EXISTS my_project.my_live_table
OPTIONS (refresh_interval = '10m')
AS SELECT 1 AS a, 'foo' AS b;
--
CreateLiveTableStmt
+-name_path=my_project.my_live_table
+-create_mode=CREATE_IF_NOT_EXISTS
+-option_list=
| +-refresh_interval := Literal(type=STRING, value="10m")
+-column_definition_list=
| +-ColumnDefinition(name="a", type=INT64, column=my_project.my_live_table.a#3)
| +-ColumnDefinition(name="b", type=STRING, column=my_project.my_live_table.b#4)
+-output_column_list=
| +-$create_as.a#1 AS a [INT64]
| +-$create_as.b#2 AS b [STRING]
+-query=
  +-ProjectScan
    +-column_list=$create_as.[a#1, b#2]
    +-expr_list=
    | +-a#1 := Literal(type=INT64, value=1)
    | +-b#2 := Literal(type=STRING, value="foo")
    +-input_scan=
      +-SingleRowScan
==

CREATE LIVE TABLE my_live_table (x INT64, PRIMARY KEY(x)) AS SELECT 1 AS x;
--
CreateLiveTableStmt
+-name_path=my_live_table
+-column_definition_list=
| +-ColumnDefinition(name="x", type=INT64, column=my_live_table.x#1)
+-primary_key=
| +-PrimaryKey(column_offset_list=[0], column_name_list=[x])
+-output_column_list=
| +-$create_as.x#2 AS x [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$create_as.x#2]
    +-expr_list=
    | +-x#2 := Literal(type=INT64, value=1)
    +-input_scan=
      +-SingleRowScan
==

[language_features=NONE,+CREATE_LIVE_TABLE,+CREATE_TABLE_PARTITION_BY]
CREATE LIVE TABLE t PARTITION BY x AS SELECT 1 AS y, 2 AS x;
--
CreateLiveTableStmt
+-name_path=t
+-column_definition_list=
| +-ColumnDefinition(name="y", type=INT64, column=t.y#3)
| +-ColumnDefinition(name="x", type=INT64, column=t.x#4)
+-pseudo_column_list=t.[pseudo_column_int32#5, pseudo_column_kitchensink#6, pseudo_column_timestamp#7]
+-output_column_list=
| +-$create_as.y#1 AS y [INT64]
| +-$create_as.x#2 AS x [INT64]
+-query=
| +-ProjectScan
|   +-column_list=$create_as.[y#1, x#2]
|   +-expr_list=
|   | +-y#1 := Literal(type=INT64, value=1)
|   | +-x#2 := Literal(type=INT64, value=2)
|   +-input_scan=
|     +-SingleRowScan
+-partition_by_list=
  +-ColumnRef(type=INT64, column=t.x#4)
==

[language_features=NONE,+CREATE_LIVE_TABLE,+CREATE_TABLE_CLUSTER_BY]
CREATE LIVE TABLE t CLUSTER BY x AS SELECT 1 AS y, 2 AS x;
--
CreateLiveTableStmt
+-name_path=t
+-column_definition_list=
| +-ColumnDefinition(name="y", type=INT64, column=t.y#3)
| +-ColumnDefinition(name="x", type=INT64, column=t.x#4)
+-pseudo_column_list=t.[pseudo_column_int32#5, pseudo_column_kitchensink#6, pseudo_column_timestamp#7]
+-output_column_list=
| +-$create_as.y#1 AS y [INT64]
| +-$create_as.x#2 AS x [INT64]
+-query=
| +-ProjectScan
|   +-column_list=$create_as.[y#1, x#2]
|   +-expr_list=
|   | +-y#1 := Literal(type=INT64, value=1)
|   | +-x#2 := Literal(type=INT64, value=2)
|   +-input_scan=
|     +-SingleRowScan
+-cluster_by_list=
  +-ColumnRef(type=INT64, column=t.x#4)
==

CREATE OR REPLACE LIVE TABLE t AS SELECT 1 AS a;
--
CreateLiveTableStmt
+-name_path=t
+-create_mode=CREATE_OR_REPLACE
+-column_definition_list=
| +-ColumnDefinition(name="a", type=INT64, column=t.a#2)
+-output_column_list=
| +-$create_as.a#1 AS a [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$create_as.a#1]
    +-expr_list=
    | +-a#1 := Literal(type=INT64, value=1)
    +-input_scan=
      +-SingleRowScan
==

[language_features=MAXIMUM,-CREATE_LIVE_TABLE]
CREATE LIVE TABLE my_live_table AS SELECT 1 AS a;
--
ERROR: CREATE LIVE TABLE is not supported [at 1:1]
CREATE LIVE TABLE my_live_table AS SELECT 1 AS a;
^
==

DROP LIVE TABLE my_live_table;
--
DropStmt(object_type="LIVE TABLE", is_if_exists=FALSE, name_path=my_live_table)
==

DROP LIVE TABLE IF EXISTS my_live_table;
--
DropStmt(object_type="LIVE TABLE", is_if_exists=TRUE, name_path=my_live_table)
==

[language_features=NONE,+CREATE_LIVE_TABLE,+CREATE_TABLE_WITH_CONNECTION]
CREATE LIVE TABLE t WITH CONNECTION connection1 AS SELECT 1 AS a;
--
CreateLiveTableStmt
+-name_path=t
+-column_definition_list=
| +-ColumnDefinition(name="a", type=INT64, column=t.a#2)
+-connection=
| +-Connection(connection=connection1)
+-output_column_list=
| +-$create_as.a#1 AS a [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$create_as.a#1]
    +-expr_list=
    | +-a#1 := Literal(type=INT64, value=1)
    +-input_scan=
      +-SingleRowScan
==

CREATE LIVE TABLE t AS SELECT AS VALUE STRUCT(1 AS id, 'Alice' AS name) AS a;
--
CreateLiveTableStmt
+-name_path=t
+-column_definition_list=
| +-ColumnDefinition(name="$value_column", type=STRUCT<id INT64, name STRING>, column=t.$value_column#2)
+-is_value_table=TRUE
+-output_column_list=
| +-$create_as.a#1 AS `$value_column` [STRUCT<id INT64, name STRING>]
+-query=
  +-ProjectScan
    +-column_list=[$create_as.a#1]
    +-expr_list=
    | +-a#1 := Literal(type=STRUCT<id INT64, name STRING>, value={id:1, name:"Alice"})
    +-input_scan=
      +-SingleRowScan
==

CREATE LIVE TABLE dynamic_data_table
OPTIONS (refresh_interval = '10m')
AS SELECT 1 AS id, CURRENT_TIMESTAMP() AS last_refresh_time;
--
CreateLiveTableStmt
+-name_path=dynamic_data_table
+-option_list=
| +-refresh_interval := Literal(type=STRING, value="10m")
+-column_definition_list=
| +-ColumnDefinition(name="id", type=INT64, column=dynamic_data_table.id#3)
| +-ColumnDefinition(name="last_refresh_time", type=TIMESTAMP, column=dynamic_data_table.last_refresh_time#4)
+-output_column_list=
| +-$create_as.id#1 AS id [INT64]
| +-$create_as.last_refresh_time#2 AS last_refresh_time [TIMESTAMP]
+-query=
  +-ProjectScan
    +-column_list=$create_as.[id#1, last_refresh_time#2]
    +-expr_list=
    | +-id#1 := Literal(type=INT64, value=1)
    | +-last_refresh_time#2 := FunctionCall(GoogleSQL:current_timestamp() -> TIMESTAMP)
    +-input_scan=
      +-SingleRowScan
