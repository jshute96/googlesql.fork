# Test deduplication of columns in the rewrite struct for columns referenced
# multiple times.
FROM KeyValueLazy kv
|> WHERE kv.value IS NOT NULL
|> WHERE kv.key * kv.key > 100
|> SELECT kv.value, kv.key
--
QueryStmt
+-output_column_list=
| +-$pipe_select.value#2 AS value [STRING]
| +-$pipe_select.key#3 AS key [INT64]
+-query=
  +-ProjectScan
    +-column_list=$pipe_select.[value#2, key#3]
    +-expr_list=
    | +-value#2 :=
    | | +-GetRowField
    | |   +-type=STRING
    | |   +-expr=
    | |   | +-ColumnRef(type=ROW<KeyValueLazy>, column=KeyValueLazy.$row#1)
    | |   +-column=KeyValueLazy.Value
    | +-key#3 :=
    |   +-GetRowField
    |     +-type=INT64
    |     +-expr=
    |     | +-ColumnRef(type=ROW<KeyValueLazy>, column=KeyValueLazy.$row#1)
    |     +-column=KeyValueLazy.Key
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValueLazy.$row#1]
        +-input_scan=
        | +-FilterScan
        |   +-column_list=[KeyValueLazy.$row#1]
        |   +-input_scan=
        |   | +-TableScan(column_list=[KeyValueLazy.$row#1], table=KeyValueLazy, alias="kv", read_as_row_type=TRUE)
        |   +-filter_expr=
        |     +-FunctionCall(GoogleSQL:$not(BOOL) -> BOOL)
        |       +-FunctionCall(GoogleSQL:$is_null(STRING) -> BOOL)
        |         +-GetRowField
        |           +-type=STRING
        |           +-expr=
        |           | +-ColumnRef(type=ROW<KeyValueLazy>, column=KeyValueLazy.$row#1)
        |           +-column=KeyValueLazy.Value
        +-filter_expr=
          +-FunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
            +-FunctionCall(GoogleSQL:$multiply(INT64, INT64) -> INT64)
            | +-GetRowField
            | | +-type=INT64
            | | +-expr=
            | | | +-ColumnRef(type=ROW<KeyValueLazy>, column=KeyValueLazy.$row#1)
            | | +-column=KeyValueLazy.Key
            | +-GetRowField
            |   +-type=INT64
            |   +-expr=
            |   | +-ColumnRef(type=ROW<KeyValueLazy>, column=KeyValueLazy.$row#1)
            |   +-column=KeyValueLazy.Key
            +-Literal(type=INT64, value=100)


[REWRITTEN AST]
