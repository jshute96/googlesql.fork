# Alias-prefixed and un-prefixed references to ROW type fields which are found
# (value) and not found (filename).
FROM KeyValue{{Lazy|FindOnly}} kv1, EnumTable et
|> SELECT kv1.value, value, et.filename, filename
--
ALTERNATION GROUP: Lazy
--
QueryStmt
+-output_column_list=
| +-$pipe_select.value#7 AS value [STRING]
| +-$pipe_select.value#8 AS value [STRING]
| +-EnumTable.Filename#5 AS filename [STRING]
| +-EnumTable.Filename#5 AS filename [STRING]
+-query=
  +-ProjectScan
    +-column_list=[$pipe_select.value#7, $pipe_select.value#8, EnumTable.Filename#5, EnumTable.Filename#5]
