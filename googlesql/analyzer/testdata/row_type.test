+-output_column_list=
| +-$pipe_select.value#2 AS value [STRING]
| +-$pipe_select.key#3 AS key [INT64]
+-query=
  +-ProjectScan
    +-column_list=$pipe_select.[value#2, key#3]
    +-expr_list=
    | +-value#2 :=
    | | +-GetStructField
    | |   +-type=STRING
    | |   +-expr=
    | |   | +-ColumnRef(type=STRUCT<Value STRING, Key INT64>, column=KeyValueLazy.$row$scanrow#4)
    | |   +-field_idx=0
    | +-key#3 :=
    |   +-GetStructField
    |     +-type=INT64
    |     +-expr=
    |     | +-ColumnRef(type=STRUCT<Value STRING, Key INT64>, column=KeyValueLazy.$row$scanrow#4)
    |     +-field_idx=1
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValueLazy.$row$scanrow#4]
        +-input_scan=
        | +-FilterScan
        |   +-column_list=[KeyValueLazy.$row$scanrow#4]
