# Expression matching between ROW field access in SELECT list and GROUP BY, with
# a simple ResolvedGetRowField.
[enabled_ast_rewrites=NONE]
SELECT Key, T.Key, key, KEY, kEy
FROM KeyValueFindOnly AS T
GROUP BY T.Key
--
QueryStmt
+-output_column_list=
| +-$groupby.Key#2 AS Key [INT64]
| +-$groupby.Key#2 AS Key [INT64]
| +-$groupby.Key#2 AS key [INT64]
| +-$groupby.Key#2 AS KEY [INT64]
| +-$groupby.Key#2 AS kEy [INT64]
+-query=
  +-ProjectScan
    +-column_list=$groupby.[Key#2, Key#2, Key#2, Key#2, Key#2]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$groupby.Key#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValueFindOnly.$row#1], table=KeyValueFindOnly, alias="T", read_as_row_type=TRUE)
        +-group_by_list=
          +-Key#2 :=
            +-GetRowField
              +-type=INT64
              +-expr=
              | +-ColumnRef(type=ROW<KeyValueFindOnly>, column=KeyValueFindOnly.$row#1)
              +-column=KeyValueFindOnly.Key
==

# Expression matching between ROW field access in SELECT list and GROUP BY, with
# a complex expression containing multiple nested ResolvedGetRowFields.
# Literal replacement disabled because it will replace only replace some of the
# empty strings, resulting in the expressions not matching.
[enabled_ast_rewrites=NONE]
[no_enable_literal_replacement]
SELECT CONCAT("", Key, value), CONCAT("", T.Key, VaLuE)
FROM KeyValueFindOnly AS T
GROUP BY CONCAT("", T.Key, T.value)
--
QueryStmt
+-output_column_list=
| +-$groupby.$groupbycol1#2 AS `$col1` [STRING]
| +-$groupby.$groupbycol1#2 AS `$col2` [STRING]
+-query=
  +-ProjectScan
    +-column_list=$groupby.[$groupbycol1#2, $groupbycol1#2]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$groupby.$groupbycol1#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValueFindOnly.$row#1], table=KeyValueFindOnly, alias="T", read_as_row_type=TRUE)
        +-group_by_list=
          +-$groupbycol1#2 :=
            +-FunctionCall(GoogleSQL:concat(STRING, repeated(2) STRING) -> STRING)
              +-Literal(type=STRING, value="")
              +-Cast(INT64 -> STRING)
              | +-GetRowField
              |   +-type=INT64
              |   +-expr=
              |   | +-ColumnRef(type=ROW<KeyValueFindOnly>, column=KeyValueFindOnly.$row#1)
              |   +-column=KeyValueFindOnly.Key
              +-GetRowField
                +-type=STRING
                +-expr=
                | +-ColumnRef(type=ROW<KeyValueFindOnly>, column=KeyValueFindOnly.$row#1)
                +-column=KeyValueFindOnly.Value
