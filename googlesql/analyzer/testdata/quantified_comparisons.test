###---------------------------------------------------------------------
### Error cases - general: test feature not enabled.
###---------------------------------------------------------------------

# List case.
[language_features=NONE]
select 1 = any (1,2,3)
--
ERROR: Quantified comparisons (= ANY) are not supported [at 1:10]
select 1 = any (1,2,3)
         ^
==

# Array case.
[language_features=NONE]
select 1 > all unnest([4,5,6])
--
ERROR: Quantified comparisons (> ALL) are not supported [at 1:10]
select 1 > all unnest([4,5,6])
         ^
==

# Subquery case.
[language_features=NONE]
select 123 <= some (select * from unnest([1,2,3]))
--
ERROR: Quantified comparisons (<= SOME) are not supported [at 1:12]
select 123 <= some (select * from unnest([1,2,3]))
           ^
==

###---------------------------------------------------------------------
### Error cases - UNNEST
###---------------------------------------------------------------------

# UNNEST in this context does not support the full UNNEST
# functionality supported in the FROM context (multiple arrays, named
# params, aliases)
select 1 < any unnest([1,2], [3,4])
--
ERROR: UNNEST expression used with < ANY does not allow multiple arguments [at 1:30]
select 1 < any unnest([1,2], [3,4])
                             ^
==

select 2 > all unnest([3,4], mode => 'STRICT')
--
ERROR: UNNEST expression used with > ALL does not allow named arguments [at 1:30]
select 2 > all unnest([3,4], mode => 'STRICT')
                             ^
==

select 3 = some unnest([1,2] as banana)
--
ERROR: UNNEST expression used with = SOME does not allow argument aliases inside UNNEST [at 1:30]
select 3 = some unnest([1,2] as banana)
                             ^
==

# No matching signatures.
select 1 = any unnest(['a'])
--
ERROR: No matching signature for operator = ANY UNNEST for argument types: INT64, ARRAY<STRING> [at 1:10]
select 1 = any unnest(['a'])
         ^
==

# String literal compared to bytes.
[language_features=MAXIMUM,+GENERAL_QUANTIFIED_COMPARISONS,-IMPLICIT_COERCION_STRING_LITERAL_TO_BYTES]
select b'foo' = any unnest(['foo']);
--
ERROR: No matching signature for operator = ANY UNNEST for argument types: BYTES, ARRAY<STRING>. STRING and BYTES are different types that are not directly comparable. To write a BYTES literal, use a b-prefixed literal such as b'bytes value' [at 1:15]
select b'foo' = any unnest(['foo']);
              ^
==

# String literal compared to bytes.
[language_features=MAXIMUM,+GENERAL_QUANTIFIED_COMPARISONS,-IMPLICIT_COERCION_STRING_LITERAL_TO_BYTES]
select 'foo' = any unnest([b'foo']);
--
ERROR: No matching signature for operator = ANY UNNEST for argument types: STRING, ARRAY<BYTES>. STRING and BYTES are different types that are not directly comparable. To write a BYTES literal, use a b-prefixed literal such as b'bytes value' [at 1:14]
select 'foo' = any unnest([b'foo']);
             ^
==

# Arg to UNNEST must be array.
select 1 > all unnest('taco bell')
--
ERROR: Second argument of > ALL UNNEST must be an array but was STRING [at 1:10]
select 1 > all unnest('taco bell')
         ^
==

# Array elements must support equality for = and !=
select 1 {{=|!=|<>}} any unnest([st_geogfromtext('point empty')])
--
ALTERNATION GROUP: =
--
ERROR: Second argument to = ANY UNNEST of type ARRAY<GEOGRAPHY> is not supported because array element type is not equality comparable [at 1:10]
select 1 = any unnest([st_geogfromtext('point empty')])
         ^
--
ALTERNATION GROUP: !=
--
ERROR: Second argument to != ANY UNNEST of type ARRAY<GEOGRAPHY> is not supported because array element type is not equality comparable [at 1:10]
select 1 != any unnest([st_geogfromtext('point empty')])
         ^
--
ALTERNATION GROUP: <>
--
ERROR: Second argument to != ANY UNNEST of type ARRAY<GEOGRAPHY> is not supported because array element type is not equality comparable [at 1:10]
select 1 <> any unnest([st_geogfromtext('point empty')])
         ^
==

# Array elements must support ordering for <, >, etc
select 1 {{<|<=|>|>=}} all unnest([struct(1, 2)])
--
ALTERNATION GROUP: <
--
ERROR: Second argument to < ALL UNNEST of type ARRAY<STRUCT<INT64, INT64>> is not supported because array element type is not orderable [at 1:10]
select 1 < all unnest([struct(1, 2)])
         ^
--
ALTERNATION GROUP: <=
--
ERROR: Second argument to <= ALL UNNEST of type ARRAY<STRUCT<INT64, INT64>> is not supported because array element type is not orderable [at 1:10]
select 1 <= all unnest([struct(1, 2)])
         ^
--
ALTERNATION GROUP: >
--
ERROR: Second argument to > ALL UNNEST of type ARRAY<STRUCT<INT64, INT64>> is not supported because array element type is not orderable [at 1:10]
select 1 > all unnest([struct(1, 2)])
         ^
--
ALTERNATION GROUP: >=
--
ERROR: Second argument to >= ALL UNNEST of type ARRAY<STRUCT<INT64, INT64>> is not supported because array element type is not orderable [at 1:10]
select 1 >= all unnest([struct(1, 2)])
         ^
==

# Comparison value must support equality for = and !=
select st_geogfromtext('point empty') {{=|!=|<>}} all unnest([1,2,3]);
--
ALTERNATION GROUP: =
--
ERROR: First argument to = ALL UNNEST of type GEOGRAPHY does not support equality comparison [at 1:39]
select st_geogfromtext('point empty') = all unnest([1,2,3]);
                                      ^
--
ALTERNATION GROUP: !=
--
ERROR: First argument to != ALL UNNEST of type GEOGRAPHY does not support equality comparison [at 1:39]
select st_geogfromtext('point empty') != all unnest([1,2,3]);
                                      ^
--
ALTERNATION GROUP: <>
--
ERROR: First argument to != ALL UNNEST of type GEOGRAPHY does not support equality comparison [at 1:39]
select st_geogfromtext('point empty') <> all unnest([1,2,3]);
                                      ^
==

# Comparison value must support ordering for <, >, etc
select struct(1,2) {{<|<=|>|>=}} any unnest([1,2,3]);
--
ALTERNATION GROUP: <
--
ERROR: First argument to < ANY UNNEST of type STRUCT<INT64, INT64> does not support ordering [at 1:20]
select struct(1,2) < any unnest([1,2,3]);
                   ^
--
ALTERNATION GROUP: <=
--
ERROR: First argument to <= ANY UNNEST of type STRUCT<INT64, INT64> does not support ordering [at 1:20]
select struct(1,2) <= any unnest([1,2,3]);
                   ^
--
ALTERNATION GROUP: >
--
ERROR: First argument to > ANY UNNEST of type STRUCT<INT64, INT64> does not support ordering [at 1:20]
select struct(1,2) > any unnest([1,2,3]);
                   ^
--
ALTERNATION GROUP: >=
--
ERROR: First argument to >= ANY UNNEST of type STRUCT<INT64, INT64> does not support ordering [at 1:20]
select struct(1,2) >= any unnest([1,2,3]);
                   ^
==

