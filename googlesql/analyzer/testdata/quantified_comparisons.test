    |             +-input_scan=
    |               +-SingleRowScan
    +-input_scan=
      +-SingleRowScan
==

# Subquery with hints.
select 1 = any @{hint=1} (select 2)
--
QueryStmt
+-output_column_list=
| +-$query.$col1#2 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#2]
    +-expr_list=
    | +-$col1#2 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=EQ_ANY
    |     +-in_expr=
    |     | +-Literal(type=INT64, value=1)
    |     +-subquery=
    |     | +-ProjectScan
    |     |   +-column_list=[$expr_subquery.$col1#1]
    |     |   +-expr_list=
    |     |   | +-$col1#1 := Literal(type=INT64, value=2)
    |     |   +-input_scan=
    |     |     +-SingleRowScan
    |     +-hint_list=
    |       +-hint := Literal(type=INT64, value=1)
    +-input_scan=
      +-SingleRowScan

