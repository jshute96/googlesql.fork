###---------------------------------------------------------------------
### Error cases - Subquery form
###---------------------------------------------------------------------

# Subquery must have exactly one column.
select 1 = any (select 1, 2)
--
ERROR: Subquery of type EQ_ANY must have only one output column [at 1:17]
select 1 = any (select 1, 2)
                ^
==

# Relative comparisons (<, >, <=, >=) require ordering support.
# Structs do not support ordering.
select struct(1, 2) {{<|<=|>|>=}} {{any|some|all}} (select struct(3, 4))
--
ALTERNATION GROUP: <,any
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) < any (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: <,some
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) < some (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: <,all
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) < all (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: <=,any
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) <= any (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: <=,some
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) <= some (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: <=,all
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) <= all (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >,any
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) > any (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >,some
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) > some (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >,all
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) > all (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >=,any
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) >= any (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >=,some
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) >= some (select struct(3, 4))
                    ^
--
ALTERNATION GROUP: >=,all
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types STRUCT<INT64, INT64> and STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) >= all (select struct(3, 4))
                    ^
==

