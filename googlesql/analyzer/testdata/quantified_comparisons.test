###---------------------------------------------------------------------
### Error cases - Subquery form (Coercion specific)
###---------------------------------------------------------------------

# Incompatible types don't support coercion.
select 1 = any (select 'pattern')
--
ERROR: Cannot execute quantified comparison subquery with uncomparable types INT64 and STRING [at 1:10]
select 1 = any (select 'pattern')
         ^
==

###---------------------------------------------------------------------
### SQLBuilder / unanalyze tests.
###---------------------------------------------------------------------

# There is a special situation in the list rewriter where we attach
# the resolved collation to the LHS, and if we do it wrong it will not
# unanalyze correctly. (This is tested by the collation-related
# analyzer tests elsewhere in this file, which will unanalyze and
# re-analyze behind the scenes, but we want to show what it looks like
# here as well.)
[language_features=MAXIMUM,+GENERAL_QUANTIFIED_COMPARISONS,+ANNOTATION_FRAMEWORK,+COLLATION_SUPPORT,+COLLATION_IN_EXPLICIT_CAST]
[show_sqlbuilder_output]
[no_java]  # TODO
SELECT "a" = ANY (COLLATE("b", "und:ci"), "c");
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:$eq_any(STRING, repeated(2) STRING) -> BOOL)
    |     +-Literal(type=STRING, value="a")
    |     +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
    |     | +-type_annotation_map={Collation:"und:ci"}
    |     | +-Literal(type=STRING, value="b")
    |     | +-Literal(type=STRING, value="und:ci", preserve_in_literal_remover=TRUE)
    |     +-Literal(type=STRING, value="c")
    |     +-collation_list=[und:ci]
    +-input_scan=
      +-SingleRowScan

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  "a" = ANY(`COLLATE`("b", "und:ci"), "c") AS a_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
SELECT
  "a" = ANY(`COLLATE`("b", "und:ci"), "c") AS a_1;

[REWRITTEN AST]
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=SCALAR
    |     +-subquery=
    |       +-ProjectScan
    |         +-column_list=[$expr_subquery.$col1#5]
    |         +-expr_list=
    |         | +-$col1#5 :=
    |         |   +-FunctionCall(GoogleSQL:$or(BOOL, repeated(1) BOOL) -> BOOL)
    |         |     +-FunctionCall(GoogleSQL:$equal(STRING, STRING) -> BOOL)
    |         |     | +-ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=$subquery1.input_val#4{Collation:"und:ci"})
    |         |     | +-ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=$subquery1.arg1#2{Collation:"und:ci"})
    |         |     | +-collation_list=[und:ci]
    |         |     +-FunctionCall(GoogleSQL:$equal(STRING, STRING) -> BOOL)
    |         |       +-ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=$subquery1.input_val#4{Collation:"und:ci"})
    |         |       +-ColumnRef(type=STRING, column=$subquery1.arg2#3)
    |         |       +-collation_list=[und:ci]
    |         +-input_scan=
    |           +-ProjectScan
    |             +-column_list=$subquery1.[arg1#2, arg2#3, input_val#4]
    |             +-expr_list=
    |             | +-arg1#2 :=
    |             | | +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
    |             | |   +-type_annotation_map={Collation:"und:ci"}
    |             | |   +-Literal(type=STRING, value="b")
    |             | |   +-Literal(type=STRING, value="und:ci", preserve_in_literal_remover=TRUE)
    |             | +-arg2#3 := Literal(type=STRING, value="c")
    |             | +-input_val#4 :=
    |             |   +-Cast(STRING -> STRING)
    |             |     +-type_annotation_map={Collation:"und:ci"}
    |             |     +-Literal(type=STRING, value="a")
    |             |     +-type_modifiers=collation:und:ci
    |             +-input_scan=
    |               +-SingleRowScan
    +-input_scan=
      +-SingleRowScan
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  (
    SELECT
      ((projectscan_5.a_4) = (projectscan_5.a_2)) OR ((projectscan_5.a_4) = (projectscan_5.a_3)) AS a_6
    FROM
      (
        SELECT
          `COLLATE`("b", "und:ci") AS a_2,
          "c" AS a_3,
          CAST("a" AS STRING COLLATE 'und:ci') AS a_4
      ) AS projectscan_5
  ) AS a_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
SELECT
  (
    SELECT
      `COLLATE`("b", "und:ci") AS a_2,
      "c" AS a_3,
      CAST("a" AS STRING COLLATE 'und:ci') AS a_4
    |> AS projectscan_5
    |> SELECT
         ((projectscan_5.a_4) = (projectscan_5.a_2)) OR ((projectscan_5.a_4) = (projectscan_5.a_3)) AS a_6
  ) AS a_1;
