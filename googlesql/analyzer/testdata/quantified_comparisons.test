###---------------------------------------------------------------------
### Error cases - Expression list
###---------------------------------------------------------------------

# No matching signatures - type mismatch in rhs list.
select 1 = any (1, 'a')
--
ERROR: No matching signature for operator = ANY for argument types literal INT64 and {INT64, STRING} [at 1:10]
select 1 = any (1, 'a')
         ^
==

# No matching signatures - lhs is a different type than rhs elements.
[language_features=MAXIMUM,+GENERAL_QUANTIFIED_COMPARISONS,-IMPLICIT_COERCION_STRING_LITERAL_TO_BYTES]
select b'foo' = any ('foo', 'bar')
--
ERROR: No matching signature for operator = ANY for argument types literal BYTES and {STRING}. STRING and BYTES are different types that are not directly comparable. To write a BYTES literal, use a b-prefixed literal such as b'bytes value' [at 1:15]
select b'foo' = any ('foo', 'bar')
              ^
==

# No matching signatures - lhs and rhs are of the same type, but elements don't support ordering for <, >, etc
select struct(1, 2) {{<|<=|>|>=}} any (struct(1, 2), struct(3, 4))
--
ALTERNATION GROUP: <
--
ERROR: < is not defined for arguments of type STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) < any (struct(1, 2), struct(3, 4))
                    ^
--
ALTERNATION GROUP: <=
--
ERROR: <= is not defined for arguments of type STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) <= any (struct(1, 2), struct(3, 4))
                    ^
--
ALTERNATION GROUP: >
--
ERROR: > is not defined for arguments of type STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) > any (struct(1, 2), struct(3, 4))
                    ^
--
ALTERNATION GROUP: >=
--
ERROR: >= is not defined for arguments of type STRUCT<INT64, INT64> [at 1:21]
select struct(1, 2) >= any (struct(1, 2), struct(3, 4))
                    ^
==

# Non-scalar subquery in list (multiple rows). This fails at runtime.
select 1 > any ((select 1 union all select 2), 3)
