[default enabled_ast_rewrites=DEFAULTS]
[default language_features=MAXIMUM,+GENERAL_QUANTIFIED_COMPARISONS]

###---------------------------------------------------------------------
### Test the expression list form - all combinations.
###---------------------------------------------------------------------

select 123 {{=|!=|<>|<|<=|>|>=}} {{any|some|all}} (4,5,6)
--
ALTERNATION GROUPS:
    =,any
    =,some
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:$eq_any(INT64, repeated(3) INT64) -> BOOL)
    |     +-Literal(type=INT64, value=123)
    |     +-Literal(type=INT64, value=4)
    |     +-Literal(type=INT64, value=5)
    |     +-Literal(type=INT64, value=6)
    +-input_scan=
      +-SingleRowScan

[REWRITTEN AST]
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=SCALAR
    |     +-subquery=
    |       +-ProjectScan
    |         +-column_list=[$expr_subquery.$col1#6]
    |         +-expr_list=
    |         | +-$col1#6 :=
    |         |   +-FunctionCall(GoogleSQL:$or(BOOL, repeated(2) BOOL) -> BOOL)
    |         |     +-FunctionCall(GoogleSQL:$equal(INT64, INT64) -> BOOL)
    |         |     | +-ColumnRef(type=INT64, column=$subquery1.input_val#5)
    |         |     | +-ColumnRef(type=INT64, column=$subquery1.arg1#2)
    |         |     +-FunctionCall(GoogleSQL:$equal(INT64, INT64) -> BOOL)
    |         |     | +-ColumnRef(type=INT64, column=$subquery1.input_val#5)
    |         |     | +-ColumnRef(type=INT64, column=$subquery1.arg2#3)
    |         |     +-FunctionCall(GoogleSQL:$equal(INT64, INT64) -> BOOL)
    |         |       +-ColumnRef(type=INT64, column=$subquery1.input_val#5)
    |         |       +-ColumnRef(type=INT64, column=$subquery1.arg3#4)
    |         +-input_scan=
    |           +-ProjectScan
    |             +-column_list=$subquery1.[arg1#2, arg2#3, arg3#4, input_val#5]
    |             +-expr_list=
    |             | +-arg1#2 := Literal(type=INT64, value=4)
    |             | +-arg2#3 := Literal(type=INT64, value=5)
    |             | +-arg3#4 := Literal(type=INT64, value=6)
    |             | +-input_val#5 := Literal(type=INT64, value=123)
    |             +-input_scan=
    |               +-SingleRowScan
    +-input_scan=
      +-SingleRowScan
