select CAST("google" as string(12)) = any (COLLATE("Google","und:ci"))
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:$eq_any(STRING, repeated(1) STRING) -> BOOL)
    |     +-Cast(STRING -> STRING)
    |     | +-Literal(type=STRING, value="google", has_explicit_type=TRUE)
    |     | +-type_modifiers=type_parameters:(max_length=12)
    |     +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
    |     | +-type_annotation_map={Collation:"und:ci"}
