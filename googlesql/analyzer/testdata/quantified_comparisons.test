# Test a the subquery form with arrays since that triggers a special path in the rewrite.
select [123] = any (select [4])
--
QueryStmt
+-output_column_list=
| +-$query.$col1#2 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#2]
    +-expr_list=
    | +-$col1#2 :=
    |   +-SubqueryExpr
    |     +-type=BOOL
    |     +-subquery_type=EQ_ANY
    |     +-in_expr=
    |     | +-Literal(type=ARRAY<INT64>, value=[123])
    |     +-subquery=
    |       +-ProjectScan
    |         +-column_list=[$expr_subquery.$col1#1]
    |         +-expr_list=
    |         | +-$col1#1 := Literal(type=ARRAY<INT64>, value=[4])
    |         +-input_scan=
    |           +-SingleRowScan
    +-input_scan=
      +-SingleRowScan

