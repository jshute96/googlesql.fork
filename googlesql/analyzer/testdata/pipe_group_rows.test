    | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    +-aggregate_list=
      +-$group_rows_subquery#18 :=
        +-SubqueryExpr
          +-type=ARRAY<INT32>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[$pipe_select.$col1#17]
              +-expr_list=
              | +-$col1#17 :=
              |   +-SubqueryExpr
              |     +-type=INT32
              |     +-subquery_type=SCALAR
              |     +-subquery=
              |       +-ProjectScan
              |         +-column_list=[TestTable.key#14]
              |         +-input_scan=
              |           +-GroupRowsScan
              |             +-column_list=[TestTable.key#14]
              |             +-input_column_list=
              |               +-key#14 := ColumnRef(type=INT32, column=TestTable.key#1)
              |               +-TestEnum#15 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
              |               +-KitchenSink#16 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
              +-input_scan=
                +-GroupRowsScan
                  +-input_column_list=
                    +-key#11 := ColumnRef(type=INT32, column=TestTable.key#1)
                    +-TestEnum#12 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                    +-KitchenSink#13 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
==

# Sugar syntax GROUP ROWS has schema of operator immediately preceding aggregate (success).
FROM TestTable
|> SELECT key AS k1
|> AGGREGATE
     ARRAY(
       FROM GROUP ROWS AS gr
       |> SELECT gr.k1
     )
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#6 AS `$col1` [ARRAY<INT32>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#6]
    +-input_scan=
    | +-ProjectScan
    |   +-column_list=[TestTable.key#1]
    |   +-input_scan=
    |     +-TableScan(column_list=[TestTable.key#1], table=TestTable, column_index_list=[0])
    +-aggregate_list=
      +-$group_rows_subquery#6 :=
        +-SubqueryExpr
          +-type=ARRAY<INT32>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[TestTable.key#5]
              +-input_scan=
                +-GroupRowsScan
                  +-column_list=[TestTable.key#5]
                  +-input_column_list=
                    +-key#5 := ColumnRef(type=INT32, column=TestTable.key#1)
==

# EXTEND preserves original columns, allowing both original and extended columns in GROUP ROWS (success).
FROM TestTable
|> EXTEND key AS k1
|> EXTEND 20 AS k2
|> AGGREGATE
     ARRAY(
       FROM GROUP ROWS AS gr
       |> SELECT AS STRUCT gr.key AS a_1, gr.k1 AS a_2
     )
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#15 AS `$col1` [ARRAY<STRUCT<a_1 INT32, a_2 INT32>>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#15]
    +-input_scan=
    | +-ProjectScan
    |   +-column_list=[TestTable.key#1, TestTable.TestEnum#2, TestTable.KitchenSink#3, $pipe_extend.k2#4]
    |   +-expr_list=
    |   | +-k2#4 := Literal(type=INT64, value=20)
    |   +-input_scan=
    |     +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    +-aggregate_list=
      +-$group_rows_subquery#15 :=
        +-SubqueryExpr
          +-type=ARRAY<STRUCT<a_1 INT32, a_2 INT32>>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[$make_struct.$struct#14]
              +-expr_list=
              | +-$struct#14 :=
              |   +-MakeStruct
              |     +-type=STRUCT<a_1 INT32, a_2 INT32>
              |     +-field_list=
              |       +-ColumnRef(type=INT32, column=TestTable.key#10)
              |       +-ColumnRef(type=INT32, column=TestTable.key#10)
              +-input_scan=
                +-ProjectScan
                  +-column_list=TestTable.[key#10, key#10]
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[TestTable.key#10]
                      +-input_column_list=
                        +-key#10 := ColumnRef(type=INT32, column=TestTable.key#1)
                        +-TestEnum#11 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                        +-KitchenSink#12 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
                        +-k2#13 := ColumnRef(type=INT64, column=$pipe_extend.k2#4)
==

# Reference group rows schema through alias vs unaliased binding.
FROM TestTable
|> AGGREGATE ARRAY(
     FROM GROUP ROWS AS gr
     |> SELECT AS STRUCT gr.key, key
   )
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#12 AS `$col1` [ARRAY<STRUCT<key INT32, key INT32>>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#12]
    +-input_scan=
    | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    +-aggregate_list=
      +-$group_rows_subquery#12 :=
        +-SubqueryExpr
          +-type=ARRAY<STRUCT<key INT32, key INT32>>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[$make_struct.$struct#11]
              +-expr_list=
              | +-$struct#11 :=
              |   +-MakeStruct
              |     +-type=STRUCT<key INT32, key INT32>
              |     +-field_list=
              |       +-ColumnRef(type=INT32, column=TestTable.key#8)
              |       +-ColumnRef(type=INT32, column=TestTable.key#8)
              +-input_scan=
                +-ProjectScan
                  +-column_list=TestTable.[key#8, key#8]
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[TestTable.key#8]
                      +-input_column_list=
                        +-key#8 := ColumnRef(type=INT32, column=TestTable.key#1)
                        +-TestEnum#9 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                        +-KitchenSink#10 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
==

# Group rows with a nested subquery containing different scope.
FROM EnumTable
|> AGGREGATE
     ARRAY(
       WITH group_rows() AS GROUP ROWS
       FROM group_rows() gr
       |> SELECT (
            FROM MultipleColumns
            |> SELECT AS STRUCT gr.key, EnumTable.key, int_a
          )
     )
   GROUP BY EnumTable.key
--
QueryStmt
+-output_column_list=
| +-$groupby.key#21 AS key [INT32]
| +-$expr_subquery.$group_rows_subquery#37 AS `$col1` [ARRAY<STRUCT<key INT32, key INT32, int_a INT64>>]
+-query=
  +-AggregateScan
    +-column_list=[$groupby.key#21, $expr_subquery.$group_rows_subquery#37]
    +-input_scan=
    | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
    +-group_by_list=
    | +-key#21 := ColumnRef(type=INT32, column=EnumTable.key#1)
    +-aggregate_list=
      +-$group_rows_subquery#37 :=
        +-SubqueryExpr
          +-type=ARRAY<STRUCT<key INT32, key INT32, int_a INT64>>
          +-subquery_type=ARRAY
          +-parameter_list=
          | +-ColumnRef(type=INT32, column=$groupby.key#21)
          +-subquery=
            +-ProjectScan
              +-column_list=[$pipe_select.$col1#36]
              +-expr_list=
              | +-$col1#36 :=
              |   +-SubqueryExpr
              |     +-type=STRUCT<key INT32, key INT32, int_a INT64>
              |     +-subquery_type=SCALAR
              |     +-parameter_list=
              |     | +-ColumnRef(type=INT32, column=$groupby.key#21, is_correlated=TRUE)
              |     | +-ColumnRef(type=INT32, column=EnumTable.key#22)
              |     +-subquery=
              |       +-ProjectScan
              |         +-column_list=[$make_struct.$struct#35]
              |         +-expr_list=
              |         | +-$struct#35 :=
              |         |   +-MakeStruct
              |         |     +-type=STRUCT<key INT32, key INT32, int_a INT64>
              |         |     +-field_list=
              |         |       +-ColumnRef(type=INT32, column=$pipe_select.key#33)
              |         |       +-ColumnRef(type=INT32, column=$pipe_select.key#34)
              |         |       +-ColumnRef(type=INT64, column=MultipleColumns.int_a#27)
              |         +-input_scan=
              |           +-ProjectScan
              |             +-column_list=[$pipe_select.key#33, $pipe_select.key#34, MultipleColumns.int_a#27]
              |             +-expr_list=
              |             | +-key#33 := ColumnRef(type=INT32, column=EnumTable.key#22, is_correlated=TRUE)
              |             | +-key#34 := ColumnRef(type=INT32, column=$groupby.key#21, is_correlated=TRUE)
              |             +-input_scan=
              |               +-TableScan(column_list=[MultipleColumns.int_a#27], table=MultipleColumns, column_index_list=[0])
              +-input_scan=
                +-GroupRowsScan
                  +-column_list=[EnumTable.key#22]
                  +-input_column_list=
                    +-key#22 := ColumnRef(type=INT32, column=EnumTable.key#1)
                    +-TestEnum#23 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                    +-AnotherTestEnum#24 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                    +-Filename#25 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                    +-RowId#26 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

# Inner group rows TVF shadows outer group rows TVF.
FROM TestTable
|> AGGREGATE ARRAY(
  WITH group_rows() AS GROUP ROWS
  FROM MultipleColumns
  |> AGGREGATE (
    WITH group_rows() AS GROUP ROWS
    FROM group_rows()
    |> SELECT int_a
    |> LIMIT 1
  ) AS my_val GROUP BY int_b
  |> SELECT my_val
)
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#44 AS `$col1` [ARRAY<INT64>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#44]
    +-input_scan=
    | +-TableScan(table=TestTable)
    +-aggregate_list=
      +-$group_rows_subquery#44 :=
        +-SubqueryExpr
          +-type=ARRAY<INT64>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[$expr_subquery.$group_rows_subquery#43]
              +-input_scan=
                +-AggregateScan
                  +-column_list=[$groupby.int_b#36, $expr_subquery.$group_rows_subquery#43]
                  +-input_scan=
                  | +-TableScan(column_list=MultipleColumns.[int_a#24, string_a#25, int_b#26, string_b#27, int_c#28, int_d#29], table=MultipleColumns, column_index_list=[0, 1, 2, 3, 4, 5])
                  +-group_by_list=
                  | +-int_b#36 := ColumnRef(type=INT64, column=MultipleColumns.int_b#26)
                  +-aggregate_list=
                    +-$group_rows_subquery#43 :=
                      +-SubqueryExpr
                        +-type=INT64
                        +-subquery_type=SCALAR
                        +-subquery=
                          +-LimitOffsetScan
                            +-column_list=[MultipleColumns.int_a#37]
                            +-input_scan=
                            | +-ProjectScan
                            |   +-column_list=[MultipleColumns.int_a#37]
                            |   +-input_scan=
                            |     +-GroupRowsScan
                            |       +-column_list=[MultipleColumns.int_a#37]
                            |       +-input_column_list=
                            |         +-int_a#37 := ColumnRef(type=INT64, column=MultipleColumns.int_a#24)
                            |         +-string_a#38 := ColumnRef(type=STRING, column=MultipleColumns.string_a#25)
                            |         +-int_b#39 := ColumnRef(type=INT64, column=MultipleColumns.int_b#26)
                            |         +-string_b#40 := ColumnRef(type=STRING, column=MultipleColumns.string_b#27)
                            |         +-int_c#41 := ColumnRef(type=INT64, column=MultipleColumns.int_c#28)
                            |         +-int_d#42 := ColumnRef(type=INT64, column=MultipleColumns.int_d#29)
                            +-limit=
                              +-Literal(type=INT64, value=1)
