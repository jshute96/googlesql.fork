graph_table(aml
  MATCH (n:Person)
  RETURN
    1 AS id,
    EXISTS {
      GRAPH aml
      MATCH (n2:Person where n2.name = 'Dana')
      RETURN 1 as one
      UNION ALL
      MATCH (n2:Person where n2.name = 'Dana')
      RETURN 1 as one
    } AS val
) gt
