            -[a_5 IS (% | ! %)]->
            (a_6 IS (% | ! %))
            WHERE
              (a_4.name) != "Dana"
          ),
          (
            (a_7 IS Person)
            -[a_8 IS (% | ! %)]->
            (a_9 IS (Person &(% | ! %)))
            WHERE
              (a_7.age) = CAST(42 AS UINT32)
