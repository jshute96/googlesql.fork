SELECT
  aml_1.a_3 AS val
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS Person)
    RETURN
      EXISTS {
        GRAPH aml
        MATCH
          (
            (a_4 IS (Person &(% | ! %)))
            -[a_5 IS (% | ! %)]->
            (a_6 IS (% | ! %))
            WHERE
              (a_4.name) != "Dana"
          ),
          (
            (a_7 IS Person)
            -[a_8 IS (% | ! %)]->
            (a_9 IS (Person &(% | ! %)))
            WHERE
              (a_7.age) = CAST(42 AS UINT32)
          )
          WHERE
            a_4 = a_9
        OPTIONAL MATCH
          (a_10 IS Person)
          -[a_11 IS (% | ! %)]->
          (a_12 IS (% | ! %))
          WHERE
            a_12 = a_7
      } AS a_3
  ) AS aml_1;

