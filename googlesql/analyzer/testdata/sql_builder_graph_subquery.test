# EXISTS {linear_ops} subquery explicit equality check across subquery boundary
GRAPH aml
MATCH (n:Person)
RETURN NOT EXISTS { MATCH (n2:Person)->(p:Person) WHERE n = p } AS val
--
QueryStmt
+-output_column_list=
| +-$graph_table.val#6 AS val [BOOL]
+-query=
  +-GraphTableScan
    +-column_list=[$graph_table.val#6]
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-column_list=[$graph_table.val#6]
        +-scan_list=
          +-GraphLinearScan
            +-column_list=[$graph_table.val#6]
            +-scan_list=
              +-GraphScan
              | +-column_list=[$element_table.n#1]
              | +-input_scan_list=
              | | +-GraphPathScan
              | |   +-column_list=[$element_table.n#1]
              | |   +-input_scan_list=
              | |   | +-GraphNodeScan
              | |   |   +-column_list=[$element_table.n#1]
              | |   |   +-label_expr=
              | |   |   | +-GraphLabel(parse_location=19-25, label=aml.Person)
              | |   |   +-target_element_table_list=[aml.Person]
              | |   +-head=$element_table.n#1
              | |   +-tail=$element_table.n#1
              | +-input_scan=
              |   +-SingleRowScan
              +-ProjectScan
                +-column_list=[$graph_table.val#6]
                +-expr_list=
                | +-val#6 :=
                |   +-FunctionCall(GoogleSQL:$not(BOOL) -> BOOL)
                |     +-SubqueryExpr
                |       +-type=BOOL
                |       +-subquery_type=EXISTS
                |       +-parameter_list=
                |       | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n#1)
                |       +-subquery=
                |         +-GraphTableScan
                |           +-column_list=[$graph_table.literal_true#5]
                |           +-property_graph=aml
                |           +-input_scan=
                |             +-GraphLinearScan
                |               +-column_list=[$graph_table.literal_true#5]
                |               +-scan_list=
                |                 +-GraphLinearScan
                |                   +-column_list=[$graph_table.literal_true#5]
                |                   +-scan_list=
                |                     +-GraphScan
                |                     | +-column_list=$element_table.[n2#2, $element1#3, p#4]
                |                     | +-input_scan_list=
                |                     | | +-GraphPathScan
                |                     | |   +-column_list=$element_table.[n2#2, $element1#3, p#4]
                |                     | |   +-input_scan_list=
                |                     | |   | +-GraphNodeScan
