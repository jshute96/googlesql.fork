# ERROR: Optional function-typed parameter is not supported.
# TODO b/506944023 - Implement support for optional function-typed parameters.
[language_features=NONE,+INLINE_LAMBDA_ARGUMENT,+UDF_LAMBDA_ARGUMENTS,+FUNCTION_ARGUMENTS_WITH_DEFAULTS]
create function f_optional(p FUNCTION<INT64 -> INT64> DEFAULT NULL) AS (1);
--
ERROR: Function-typed arguments cannot have default values [at 1:63]
create function f_optional(p FUNCTION<INT64 -> INT64> DEFAULT NULL) AS (1);
                                                              ^
==

# ERROR: Argument to lambda itself cannot have a default.
create function f_lambda_arg_default(p FUNCTION<INT64 DEFAULT 1 -> BOOL>) AS (1);
