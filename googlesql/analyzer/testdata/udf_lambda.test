    +-Literal(type=DOUBLE, value=1)
==

[use_database=udf_db_coercion]

# Test coercion of function types (invalid).
# This requires coercing FUNCTION<INT64 -> BOOL> to FUNCTION<DOUBLE -> BOOL>.
# We expect it to fail because GoogleSQL requires exact matches for function types.
create function f_test_coercion(p FUNCTION<INT64 -> BOOL>) AS (f_expects_double(FUNCTION p));
--
ERROR: Lambda argument type mismatch at index 0: expected DOUBLE, found INT64 [at 4:81]
...p FUNCTION<INT64 -> BOOL>) AS (f_expects_double(FUNCTION p));
                                                   ^
==

# Test return type mismatch on propagation (invalid).
# This requires matching FUNCTION<DOUBLE -> INT64> to FUNCTION<DOUBLE -> BOOL> (defined in f_expects_double).
# We expect it to fail because GoogleSQL requires exact matches for function types.
[use_database=udf_db_coercion]
create function f_test_mismatched_return(p FUNCTION<DOUBLE -> INT64>) AS (f_expects_double(FUNCTION p));
--
ERROR: Lambda result type mismatch: expected BOOL, found INT64 [at 1:92]
...p FUNCTION<DOUBLE -> INT64>) AS (f_expects_double(FUNCTION p));
                                                     ^
==

# Test chained UDF lambda parameter calls.
[language_features=NONE,+INLINE_LAMBDA_ARGUMENT,+UDF_LAMBDA_ARGUMENTS,+WITH_EXPRESSION,+CHAINED_FUNCTION_CALLS]
create function chained_lambda_call(
  x INT64,
  arg_lambda FUNCTION<INT64 -> BOOL>,
  other_lambda FUNCTION<BOOL -> BOOL>
) AS (
  (x).arg_lambda().other_lambda()
);
--
CreateFunctionStmt
+-name_path=chained_lambda_call
+-return_type=BOOL
+-argument_name_list=[x, arg_lambda, other_lambda]
+-signature=(INT64 x, FUNCTION<INT64->BOOL> arg_lambda, FUNCTION<BOOL->BOOL> other_lambda) -> BOOL
+-language="SQL"
+-code="(x).arg_lambda().other_lambda()"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:other_lambda(BOOL) -> BOOL)
    +-FunctionCall(FUNCTION_TYPED_PARAMETER:arg_lambda(INT64) -> BOOL)
      +-ArgumentRef(type=INT64, name="x")

==

#####
## Call built-in functions that take lambdas with a function-typed argument.
#####

# Pass a function-typed parameter where a lambda is expected.
create function PropagateTransform(arr array<int64>, f function<int64 -> bool>)
as (array_transform(arr, FUNCTION f));
--
CreateFunctionStmt
+-name_path=PropagateTransform
+-return_type=ARRAY<BOOL>
+-argument_name_list=[arr, f]
+-signature=(ARRAY<INT64> arr, FUNCTION<INT64->BOOL> f) -> ARRAY<BOOL>
+-language="SQL"
+-code="array_transform(arr, FUNCTION f)"
+-function_expression=
  +-FunctionCall(GoogleSQL:array_transform(ARRAY<INT64> array_to_transform, FUNCTION<INT64->BOOL> transformation) -> ARRAY<BOOL>)
    +-FunctionArgument
    | +-expr=
    |   +-ArgumentRef(type=ARRAY<INT64>, name="arr")
    +-FunctionArgument
      +-function_ref=
        +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:f, signature=(INT64) -> BOOL)

==

# Multiple function-typed parameters passed where lambdas are expected.
create function MultiPropagate(arr array<int64>, f1 function<int64 -> int64>, f2 function<int64 -> bool>)
as (array_transform(array_transform(arr, FUNCTION f1), FUNCTION f2));
--
CreateFunctionStmt
+-name_path=MultiPropagate
+-return_type=ARRAY<BOOL>
+-argument_name_list=[arr, f1, f2]
+-signature=(ARRAY<INT64> arr, FUNCTION<INT64->INT64> f1, FUNCTION<INT64->BOOL> f2) -> ARRAY<BOOL>
+-language="SQL"
+-code="array_transform(array_transform(arr, FUNCTION f1), FUNCTION f2)"
+-function_expression=
  +-FunctionCall(GoogleSQL:array_transform(ARRAY<INT64> array_to_transform, FUNCTION<INT64->BOOL> transformation) -> ARRAY<BOOL>)
    +-FunctionArgument
    | +-expr=
    |   +-FunctionCall(GoogleSQL:array_transform(ARRAY<INT64> array_to_transform, FUNCTION<INT64->INT64> transformation) -> ARRAY<INT64>)
    |     +-FunctionArgument
    |     | +-expr=
    |     |   +-ArgumentRef(type=ARRAY<INT64>, name="arr")
    |     +-FunctionArgument
    |       +-function_ref=
    |         +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:f1, signature=(INT64) -> INT64)
    +-FunctionArgument
      +-function_ref=
        +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:f2, signature=(INT64) -> BOOL)

==

