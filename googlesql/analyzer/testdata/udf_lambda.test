CREATE FUNCTION f_try_pass_builtin(arr ARRAY<INT64>) AS (array_transform(arr, abs));
--
ERROR: Unrecognized name: abs [at 1:79]
...arr ARRAY<INT64>) AS (array_transform(arr, abs));
                                              ^
==

