# Propagate a lambda twice (same lambda is passed as two different lambda args),
# and also call the lambda in the same function.

[use_database=udf_db]

CREATE FUNCTION propagate_and_call_lambda(p FUNCTION<INT64 -> INT64>) AS (
  f_multi_lambda_arg(FUNCTION p, FUNCTION p, p(10))
);
--
CreateFunctionStmt
+-name_path=propagate_and_call_lambda
+-return_type=INT64
+-argument_name_list=[p]
+-signature=(FUNCTION<INT64->INT64> p) -> INT64
+-language="SQL"
+-code="f_multi_lambda_arg(FUNCTION p, FUNCTION p, p(10))"
+-function_expression=
  +-FunctionCall(Lazy_resolution_function:f_multi_lambda_arg(FUNCTION<INT64->INT64> p1, FUNCTION<INT64->INT64> p2, INT64 x) -> INT64)
    +-FunctionArgument
    | +-function_ref=
    |   +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:p, signature=(INT64) -> INT64)
    +-FunctionArgument
    | +-function_ref=
    |   +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:p, signature=(INT64) -> INT64)
    +-FunctionArgument
      +-expr=
        +-FunctionCall(FUNCTION_TYPED_PARAMETER:p(INT64) -> INT64)
          +-Literal(type=INT64, value=10)
==

# Check that parameter names are case-insensitive.
create function f_param_case_insensitive(param_x FUNCTION<INT64 -> BOOL>) AS (PaRaM_X(1));
--
CreateFunctionStmt
+-name_path=f_param_case_insensitive
+-return_type=BOOL
+-argument_name_list=[param_x]
+-signature=(FUNCTION<INT64->BOOL> param_x) -> BOOL
+-language="SQL"
+-code="PaRaM_X(1)"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:param_x(INT64) -> BOOL)
    +-Literal(type=INT64, value=1)
==

# Case mismatch on transitive parameter call.
# Declares parameter 'my_lambda' (lowercase) but body references 'MY_LAMBDA' (uppercase).
# This should succeed because name resolution is case-insensitive,
# and proxy lookup should be made case-insensitive.
# Without the fix, this triggers a compiler crash (RET_CHECK failure).
CREATE TEMP FUNCTION CaseMismatchPropagation(
  my_lambda FUNCTION<INT64 -> INT64>) AS (
    array_transform([1, 2], FUNCTION MY_LAMBDA)
  );
--
CreateFunctionStmt
+-name_path=CaseMismatchPropagation
+-create_scope=CREATE_TEMP
+-return_type=ARRAY<INT64>
+-argument_name_list=[my_lambda]
+-signature=(FUNCTION<INT64->INT64> my_lambda) -> ARRAY<INT64>
+-language="SQL"
+-code="array_transform([1, 2], FUNCTION MY_LAMBDA)"
+-function_expression=
  +-FunctionCall(GoogleSQL:array_transform(ARRAY<INT64> array_to_transform, FUNCTION<INT64->INT64> transformation) -> ARRAY<INT64>)
    +-FunctionArgument
    | +-expr=
    |   +-Literal(type=ARRAY<INT64>, value=[1, 2])
    +-FunctionArgument
      +-function_ref=
        +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:my_lambda, signature=(INT64) -> INT64)
==

# Catalog/Built-in Function Name Passing (Negative).
