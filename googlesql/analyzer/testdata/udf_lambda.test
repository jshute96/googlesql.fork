CreateFunctionStmt
+-name_path=f_expects_double
+-create_scope=CREATE_TEMP
+-return_type=BOOL
+-argument_name_list=[p]
+-signature=(FUNCTION<DOUBLE->BOOL> p) -> BOOL
+-language="SQL"
