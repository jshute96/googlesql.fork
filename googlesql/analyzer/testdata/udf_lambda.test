#####
## Collation tests
#####

[prepare_database=udf_db_collation]
[language_features=NONE,+INLINE_LAMBDA_ARGUMENT,+UDF_LAMBDA_ARGUMENTS,+ANNOTATION_FRAMEWORK,+COLLATION_SUPPORT,+TYPE_ANNOTATIONS_ON_SQL_FUNCTION_ARGUMENTS]
[no_java]

# Lambda called with a collation parameter, with type annotation on function argument enabled.
# TODO b/512814252 - Add test for lambda returning a collation
create function f_with_collation(p FUNCTION<STRING -> STRING>, s STRING) AS (p(COLLATE(s, 'und:ci')));

--
CreateFunctionStmt
+-name_path=f_with_collation
+-return_type=STRING
+-argument_name_list=[p, s]
+-signature=(FUNCTION<STRING->STRING> p, STRING s) -> STRING
+-language="SQL"
+-code="p(COLLATE(s, 'und:ci'))"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:p(STRING) -> STRING)
    +-type_annotation_map={Collation:"und:ci"}
    +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
      +-type_annotation_map={Collation:"und:ci"}
      +-ArgumentRef(type=STRING, name="s")
      +-Literal(type=STRING, value="und:ci", preserve_in_literal_remover=TRUE)
==

[use_database=udf_db_collation]
[language_features=NONE,+INLINE_LAMBDA_ARGUMENT,+UDF_LAMBDA_ARGUMENTS,+ANNOTATION_FRAMEWORK,+COLLATION_SUPPORT]
[no_java]

# Lambda returns collated string
SELECT 'abc' = f_with_collation(s -> COLLATE(s, 'und:ci'), 'abc');
--
QueryStmt
+-output_column_list=
| +-$query.$col1#2 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#2]
    +-expr_list=
    | +-$col1#2 :=
    |   +-FunctionCall(GoogleSQL:$equal(STRING, STRING) -> BOOL)
    |     +-Literal(type=STRING, value="abc")
    |     +-FunctionCall(Lazy_resolution_function:f_with_collation(FUNCTION<STRING->STRING> p, STRING s) -> STRING)
    |     | +-type_annotation_map={Collation:"und:ci"}
    |     | +-FunctionArgument
    |     | | +-inline_lambda=
    |     | |   +-InlineLambda
    |     | |     +-argument_list=[$lambda_arg.s#1]
    |     | |     +-body=
    |     | |       +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
    |     | |         +-type_annotation_map={Collation:"und:ci"}
    |     | |         +-ColumnRef(type=STRING, column=$lambda_arg.s#1)
    |     | |         +-Literal(type=STRING, value="und:ci", preserve_in_literal_remover=TRUE)
    |     | +-FunctionArgument
    |     |   +-expr=
    |     |     +-Literal(type=STRING, value="abc")
    |     +-collation_list=[und:ci]
    +-input_scan=
      +-SingleRowScan
==

