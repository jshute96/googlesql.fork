#####
## Negative tests for mismatched lambda signatures
#####

# ERROR: Call lambda parameter with wrong argument type.
create function f_wrong_arg(p FUNCTION<INT64 -> BOOL>) AS (p('abc'));
--
ERROR: No matching signature for function FUNCTION_TYPED_PARAMETER:P
  Argument types: STRING
  Signature: P(INT64)
    Argument 1: Unable to coerce type STRING to expected type INT64 [at 1:60]
create function f_wrong_arg(p FUNCTION<INT64 -> BOOL>) AS (p('abc'));
                                                           ^
==

# ERROR: Call lambda parameter with wrong number of arguments.
create function f_wrong_num_args(p FUNCTION<INT64 -> BOOL>) AS (p(1, 2));
--
ERROR: No matching signature for function FUNCTION_TYPED_PARAMETER:P
  Argument types: INT64, INT64
  Signature: P(INT64)
    Signature accepts at most 1 argument, found 2 arguments [at 1:65]
create function f_wrong_num_args(p FUNCTION<INT64 -> BOOL>) AS (p(1, 2));
                                                                ^
==

[use_database=udf_db]

# Call a function providing a lambda taking the wrong number of arguments.
SELECT my_filter((x, y) -> x > y);
--
ERROR: No matching signature for function Lazy_resolution_function:my_filter
  Argument types: LAMBDA
  Signature: my_filter(FUNCTION<INT64->BOOL>)
    Argument 1: lambda requires 1 arguments but 2 is provided [at 2:8]
SELECT my_filter((x, y) -> x > y);
       ^
==

#####
## Disallowed features in lambdas
