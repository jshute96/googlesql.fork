# Language feature not set.

CREATE FUNCTION f_lang_feature_unset(p FUNCTION<INT64 -> BOOL>) AS (p(1));
--
ERROR: Function-typed arguments in UDFs are not supported [at 1:40]
CREATE FUNCTION f_lang_feature_unset(p FUNCTION<INT64 -> BOOL>) AS (p(1));
                                       ^
==

#####
## Define functions with different types of lambda parameters.
#####

[default language_features=NONE,+INLINE_LAMBDA_ARGUMENT,+UDF_LAMBDA_ARGUMENTS,+WITH_EXPRESSION]

[prepare_database=udf_db]

# Create a function in udf_db.
CREATE FUNCTION my_filter(p FUNCTION<INT64 -> BOOL>) AS (p(1));
--
CreateFunctionStmt
+-name_path=my_filter
+-return_type=BOOL
+-argument_name_list=[p]
+-signature=(FUNCTION<INT64->BOOL> p) -> BOOL
+-language="SQL"
+-code="p(1)"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:p(INT64) -> BOOL)
    +-Literal(type=INT64, value=1)
==

[prepare_database=udf_db]

# Multiple function-typed parameters.
create function f_multi_lambda_arg(p1 FUNCTION<INT64 -> INT64>, p2 FUNCTION<INT64 -> INT64>, x INT64) AS (p1(p2(x)));
--
CreateFunctionStmt
+-name_path=f_multi_lambda_arg
+-return_type=INT64
+-argument_name_list=[p1, p2, x]
+-signature=(FUNCTION<INT64->INT64> p1, FUNCTION<INT64->INT64> p2, INT64 x) -> INT64
+-language="SQL"
+-code="p1(p2(x))"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:p1(INT64) -> INT64)
    +-FunctionCall(FUNCTION_TYPED_PARAMETER:p2(INT64) -> INT64)
      +-ArgumentRef(type=INT64, name="x")
==

[prepare_database=udf_db]

# Function-typed parameter with multiple arguments.
create function f_lambda_multi_arg(p FUNCTION<(INT64, INT64) -> INT64>, x INT64, y INT64) AS (p(x, y));
--
CreateFunctionStmt
+-name_path=f_lambda_multi_arg
+-return_type=INT64
+-argument_name_list=[p, x, y]
+-signature=(FUNCTION<(INT64, INT64)->INT64> p, INT64 x, INT64 y) -> INT64
+-language="SQL"
+-code="p(x, y)"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:p(INT64, INT64) -> INT64)
    +-ArgumentRef(type=INT64, name="x")
    +-ArgumentRef(type=INT64, name="y")
==

[prepare_database=udf_db]

# Function-typed parameter with no arguments.
create function zero_lambda_arg(p FUNCTION<() -> INT64>) AS (p());
--
CreateFunctionStmt
+-name_path=zero_lambda_arg
+-return_type=INT64
+-argument_name_list=[p]
+-signature=(FUNCTION<()->INT64> p) -> INT64
+-language="SQL"
+-code="p()"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:p() -> INT64)
==

[prepare_database=udf_db]

# Create a function that calls a lambda parameter multiple times.
create function call_twice(f FUNCTION<INT64 -> INT64>, x INT64) AS (f(f(x)));
--
CreateFunctionStmt
+-name_path=call_twice
+-return_type=INT64
+-argument_name_list=[f, x]
+-signature=(FUNCTION<INT64->INT64> f, INT64 x) -> INT64
+-language="SQL"
+-code="f(f(x))"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:f(INT64) -> INT64)
    +-FunctionCall(FUNCTION_TYPED_PARAMETER:f(INT64) -> INT64)
      +-ArgumentRef(type=INT64, name="x")
==

#####
## Query that calls different variations of functions that take lambda parameters.
#####

[use_database=udf_db]

SELECT my_filter(x-> x > 5),
       f_multi_lambda_arg(x->x+10, x->x+20, 100),
       f_lambda_multi_arg((x, y) -> 10*x + 5, 3, 4),
       zero_lambda_arg(()->3),
       call_twice(x -> x*3, 4);
--
QueryStmt
+-output_column_list=
| +-$query.$col1#7 AS `$col1` [BOOL]
| +-$query.$col2#8 AS `$col2` [INT64]
| +-$query.$col3#9 AS `$col3` [INT64]
| +-$query.$col4#10 AS `$col4` [INT64]
| +-$query.$col5#11 AS `$col5` [INT64]
+-query=
  +-ProjectScan
    +-column_list=$query.[$col1#7, $col2#8, $col3#9, $col4#10, $col5#11]
    +-expr_list=
    | +-$col1#7 :=
    | | +-FunctionCall(Lazy_resolution_function:my_filter(FUNCTION<INT64->BOOL> p) -> BOOL)
    | |   +-FunctionArgument
    | |     +-inline_lambda=
    | |       +-InlineLambda
    | |         +-argument_list=[$lambda_arg.x#1]
    | |         +-body=
    | |           +-FunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
    | |             +-ColumnRef(type=INT64, column=$lambda_arg.x#1)
    | |             +-Literal(type=INT64, value=5)
    | +-$col2#8 :=
    | | +-FunctionCall(Lazy_resolution_function:f_multi_lambda_arg(FUNCTION<INT64->INT64> p1, FUNCTION<INT64->INT64> p2, INT64 x) -> INT64)
    | |   +-FunctionArgument
    | |   | +-inline_lambda=
    | |   |   +-InlineLambda
    | |   |     +-argument_list=[$lambda_arg.x#2]
    | |   |     +-body=
    | |   |       +-FunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
    | |   |         +-ColumnRef(type=INT64, column=$lambda_arg.x#2)
    | |   |         +-Literal(type=INT64, value=10)
    | |   +-FunctionArgument
    | |   | +-inline_lambda=
    | |   |   +-InlineLambda
    | |   |     +-argument_list=[$lambda_arg.x#3]
    | |   |     +-body=
    | |   |       +-FunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
    | |   |         +-ColumnRef(type=INT64, column=$lambda_arg.x#3)
    | |   |         +-Literal(type=INT64, value=20)
    | |   +-FunctionArgument
    | |     +-expr=
    | |       +-Literal(type=INT64, value=100)
    | +-$col3#9 :=
    | | +-FunctionCall(Lazy_resolution_function:f_lambda_multi_arg(FUNCTION<(INT64, INT64)->INT64> p, INT64 x, INT64 y) -> INT64)
    | |   +-FunctionArgument
    | |   | +-inline_lambda=
    | |   |   +-InlineLambda
    | |   |     +-argument_list=$lambda_arg.[x#4, y#5]
    | |   |     +-body=
    | |   |       +-FunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
    | |   |         +-FunctionCall(GoogleSQL:$multiply(INT64, INT64) -> INT64)
    | |   |         | +-Literal(type=INT64, value=10)
    | |   |         | +-ColumnRef(type=INT64, column=$lambda_arg.x#4)
    | |   |         +-Literal(type=INT64, value=5)
    | |   +-FunctionArgument
    | |   | +-expr=
    | |   |   +-Literal(type=INT64, value=3)
    | |   +-FunctionArgument
    | |     +-expr=
    | |       +-Literal(type=INT64, value=4)
    | +-$col4#10 :=
    | | +-FunctionCall(Lazy_resolution_function:zero_lambda_arg(FUNCTION<()->INT64> p) -> INT64)
    | |   +-FunctionArgument
    | |     +-inline_lambda=
    | |       +-InlineLambda
    | |         +-argument_list=[]
    | |         +-body=
    | |           +-Literal(type=INT64, value=3)
    | +-$col5#11 :=
    |   +-FunctionCall(Lazy_resolution_function:call_twice(FUNCTION<INT64->INT64> f, INT64 x) -> INT64)
    |     +-FunctionArgument
    |     | +-inline_lambda=
    |     |   +-InlineLambda
    |     |     +-argument_list=[$lambda_arg.x#6]
    |     |     +-body=
    |     |       +-FunctionCall(GoogleSQL:$multiply(INT64, INT64) -> INT64)
    |     |         +-ColumnRef(type=INT64, column=$lambda_arg.x#6)
    |     |         +-Literal(type=INT64, value=3)
    |     +-FunctionArgument
    |       +-expr=
    |         +-Literal(type=INT64, value=4)
    +-input_scan=
      +-SingleRowScan
==

#####
## Lambdas shadow catalog functions
#####

# Here, 'abs' is a built-in function, but we use it as a parameter name.
CREATE FUNCTION ShadowingTest(abs FUNCTION<INT64 -> INT64>, x INT64)
AS (abs(x));
--
CreateFunctionStmt
+-name_path=ShadowingTest
+-return_type=INT64
+-argument_name_list=[abs, x]
+-signature=(FUNCTION<INT64->INT64> abs, INT64 x) -> INT64
+-language="SQL"
+-code="abs(x)"
+-function_expression=
  +-FunctionCall(FUNCTION_TYPED_PARAMETER:abs(INT64) -> INT64)
    +-ArgumentRef(type=INT64, name="x")
==

#####
## Table definition for shadowing / name resolution tests.
#####

[prepare_database=udf_db]

# Set up table for qualified column name shadowing test below.
CREATE TABLE Table_with_f_column (f INT64);
--
CreateTableStmt
+-name_path=Table_with_f_column
+-column_definition_list=
  +-ColumnDefinition(name="f", type=INT64, column=Table_with_f_column.f#1)
==

[use_database=udf_db]

# Lambda parameter f shadows column f in table.

CREATE TEMP FUNCTION Table_with_f_column_filter_unqualified (
  f FUNCTION<INT64 -> BOOL>) AS (
    (SELECT f FROM Table_with_f_column T
    WHERE f(f))
  );
--
CreateFunctionStmt
+-name_path=Table_with_f_column_filter_unqualified
+-create_scope=CREATE_TEMP
+-return_type=INT64
+-argument_name_list=[f]
+-signature=(FUNCTION<INT64->BOOL> f) -> INT64
+-language="SQL"
+-code="(SELECT f FROM Table_with_f_column T\n    WHERE f(f))"
+-function_expression=
  +-SubqueryExpr
    +-type=INT64
    +-subquery_type=SCALAR
    +-subquery=
      +-ProjectScan
        +-column_list=[Table_with_f_column.f#1]
        +-input_scan=
          +-FilterScan
            +-column_list=[Table_with_f_column.f#1]
            +-input_scan=
            | +-TableScan(column_list=[Table_with_f_column.f#1], table=Table_with_f_column, column_index_list=[0], alias="T")
            +-filter_expr=
              +-FunctionCall(FUNCTION_TYPED_PARAMETER:f(INT64) -> BOOL)
                +-ColumnRef(type=INT64, column=Table_with_f_column.f#1)
==

[use_database=udf_db]

# Lambda parameter f shadows column f in table during propagation.
CREATE TEMP FUNCTION Table_with_f_column_propagate (
  f FUNCTION<INT64 -> BOOL>) AS (
    (SELECT f FROM Table_with_f_column T
    WHERE my_filter(FUNCTION f))
  );
--
CreateFunctionStmt
+-name_path=Table_with_f_column_propagate
+-create_scope=CREATE_TEMP
+-return_type=INT64
+-argument_name_list=[f]
+-signature=(FUNCTION<INT64->BOOL> f) -> INT64
+-language="SQL"
+-code="(SELECT f FROM Table_with_f_column T\n    WHERE my_filter(FUNCTION f))"
+-function_expression=
  +-SubqueryExpr
    +-type=INT64
    +-subquery_type=SCALAR
    +-subquery=
      +-ProjectScan
        +-column_list=[Table_with_f_column.f#1]
        +-input_scan=
          +-FilterScan
            +-column_list=[Table_with_f_column.f#1]
            +-input_scan=
            | +-TableScan(column_list=[Table_with_f_column.f#1], table=Table_with_f_column, column_index_list=[0], alias="T")
            +-filter_expr=
              +-FunctionCall(Lazy_resolution_function:my_filter(FUNCTION<INT64->BOOL> p) -> BOOL)
                +-FunctionArgument
                  +-function_ref=
                    +-FunctionRef(function=FUNCTION_TYPED_PARAMETER:f, signature=(INT64) -> BOOL)
==

[use_database=udf_db]

# Qualified column name T.f does not conflict with lambda parameter f.

CREATE TEMP FUNCTION Table_with_f_column_filter_qualified (
  f FUNCTION<INT64 -> BOOL>) AS (
    (SELECT T.f FROM Table_with_f_column T
    WHERE f(T.f))
  );
--
CreateFunctionStmt
+-name_path=Table_with_f_column_filter_qualified
+-create_scope=CREATE_TEMP
+-return_type=INT64
+-argument_name_list=[f]
+-signature=(FUNCTION<INT64->BOOL> f) -> INT64
+-language="SQL"
+-code="(SELECT T.f FROM Table_with_f_column T\n    WHERE f(T.f))"
+-function_expression=
  +-SubqueryExpr
    +-type=INT64
    +-subquery_type=SCALAR
    +-subquery=
      +-ProjectScan
        +-column_list=[Table_with_f_column.f#1]
        +-input_scan=
          +-FilterScan
            +-column_list=[Table_with_f_column.f#1]
            +-input_scan=
            | +-TableScan(column_list=[Table_with_f_column.f#1], table=Table_with_f_column, column_index_list=[0], alias="T")
            +-filter_expr=
              +-FunctionCall(FUNCTION_TYPED_PARAMETER:f(INT64) -> BOOL)
                +-ColumnRef(type=INT64, column=Table_with_f_column.f#1)
==

