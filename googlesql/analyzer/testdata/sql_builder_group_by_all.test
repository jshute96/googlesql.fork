[default show_sqlbuilder_output]
[default no_show_resolved_ast]
[default language_features=MAXIMUM,+GROUP_BY_ALL]

select kv.key, key{{| AS alias}} from KeyValue kv where true
GROUP BY ALL
--
ALTERNATION GROUP: <empty>
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aggregatescan_3.a_2 AS key,
  aggregatescan_3.a_2 AS key
FROM
  (
    SELECT
      KeyValue.Key AS a_2
    FROM
      KeyValue
    WHERE
      true
    GROUP BY ALL
  ) AS aggregatescan_3;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> WHERE
     true
|> AGGREGATE
   GROUP BY KeyValue.Key AS key_2
|> AS aggregatescan_1
|> SELECT
     aggregatescan_1.key_2 AS key,
     aggregatescan_1.key_2 AS key;
--
ALTERNATION GROUP:  AS alias
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aggregatescan_3.a_2 AS key,
  aggregatescan_3.a_2 AS alias
FROM
  (
    SELECT
      KeyValue.Key AS a_2
    FROM
      KeyValue
    WHERE
      true
    GROUP BY ALL
  ) AS aggregatescan_3;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> WHERE
     true
|> AGGREGATE
   GROUP BY KeyValue.Key AS key_2
|> AS aggregatescan_1
|> SELECT
     aggregatescan_1.key_2 AS key,
     aggregatescan_1.key_2 AS alias;
==

select DISTINCT key, key
from TestTable
GROUP BY ALL
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aggregatescan_6.a_5 AS key,
  aggregatescan_6.a_5 AS key
FROM
  (
    SELECT
      aggregatescan_4.a_3 AS a_5
    FROM
      (
        SELECT
          testtable_2.a_1 AS a_3
        FROM
          (
            SELECT
              TestTable.key AS a_1
            FROM
              TestTable
          ) AS testtable_2
        GROUP BY ALL
      ) AS aggregatescan_4
    GROUP BY 1
  ) AS aggregatescan_6;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  TestTable
|> AGGREGATE
   GROUP BY TestTable.key AS key_2
|> AS aggregatescan_1
|> AGGREGATE
   GROUP BY aggregatescan_1.key_2 AS key_3
|> AS aggregatescan_2
|> SELECT
     aggregatescan_2.key_3,
     aggregatescan_2.key_3 AS a_3
|> AS aggregatescan_2
|> SELECT
     aggregatescan_2.key_3 AS key,
     aggregatescan_2.key_3 AS key;
==

select value, cast(count(*) as double) from KeyValue group by all
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aggregatescan_5.a_3 AS value,
  CAST(aggregatescan_5.a_4 AS DOUBLE) AS a_6
FROM
  (
    SELECT
      keyvalue_2.a_1 AS a_3,
      COUNT(*) AS a_4
    FROM
      (
        SELECT
          KeyValue.Value AS a_1
        FROM
          KeyValue
      ) AS keyvalue_2
    GROUP BY ALL
  ) AS aggregatescan_5;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  KeyValue
|> AGGREGATE
     COUNT(*) AS a_1
   GROUP BY KeyValue.Value AS value_2
|> AS aggregatescan_2
|> SELECT
     aggregatescan_2.value_2 AS value,
     CAST(aggregatescan_2.a_1 AS DOUBLE) AS a_3;
==

select cast(count(*) as double) from KeyValue group by all
--
[SQLBUILDER_TARGET_SYNTAX_MODE standard]
