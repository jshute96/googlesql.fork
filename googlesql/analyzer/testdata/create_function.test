CreateFunctionStmt
+-name_path=myfunc
+-has_explicit_return_type=TRUE
+-return_type=STRUCT<x STRING>
+-argument_name_list=[s]
+-signature=(STRUCT<x NUMERIC, y STRING> type_parameters:[(precision=10,scale=2),(max_length=11)], collation:[_,und:ci] s) -> STRUCT<x STRING> type_parameters:[(max_length=10)], collation:[und:ci]
+-language="SQL"
+-code="STRUCT(s.y)"
+-function_expression=
  +-MakeStruct
    +-type=STRUCT<x STRING>
    +-type_annotation_map=<{Collation:"und:ci"}>
    +-field_list=
      +-Cast(STRING -> STRING)
        +-type_annotation_map={Collation:"und:ci"}
        +-GetStructField
        | +-type=STRING
        | +-type_annotation_map={Collation:"und:ci"}
        | +-expr=
        | | +-ArgumentRef(type=STRUCT<x NUMERIC, y STRING>, type_annotation_map=<_,{Collation:"und:ci"}>, name="s")
        | +-field_idx=1
        +-type_modifiers=type_parameters:(max_length=10), collation:und:ci
