+-function_expression=
  +-Cast(STRUCT<first INT64> -> STRUCT<x DOUBLE>)
    +-FunctionCall(GoogleSQL:if(BOOL, STRUCT<first INT64>, STRUCT<first INT64>) -> STRUCT<first INT64>)
      +-FunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
      | +-ArgumentRef(type=INT64, name="first")
      | +-ArgumentRef(type=INT64, name="second")
      +-MakeStruct
      | +-type=STRUCT<first INT64>
      | +-field_list=
      |   +-ArgumentRef(type=INT64, name="first")
      +-MakeStruct
        +-type=STRUCT<first INT64>
        +-field_list=
          +-ArgumentRef(type=INT64, name="second")
