[language_features=NONE,{{+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION|+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION|+REMOTE_FUNCTION|}}]
create function myfunc() returns boolean
remote with connection `` as (false);
--
ERROR: Syntax error: Invalid empty identifier [at 2:24]
remote with connection `` as (false);
                       ^
==

[language_features=NONE,{{+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION|+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION|+REMOTE_FUNCTION|}}]
create function myfunc() returns boolean
remote with connection default as (false);
--
ALTERNATION GROUPS:
    +CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION
    +REMOTE_FUNCTION
--
ERROR: CONNECTION DEFAULT is not supported [at 2:24]
remote with connection default as (false);
                       ^
--
ALTERNATION GROUPS:
    +CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION
    <empty>
--
ERROR: Keyword REMOTE is not supported [at 2:1]
remote with connection default as (false);
^
==


# LANGUAGE clause with WITH CONNECTION
[language_features=NONE,{{+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION|+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION|+REMOTE_FUNCTION|}}]
create function myfunc() returns string
language javascript
with connection connection1 as """5""";
--
ALTERNATION GROUPS:
    +CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION
    +CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION
--
CreateFunctionStmt
+-name_path=myfunc
+-has_explicit_return_type=TRUE
+-return_type=STRING
+-signature=() -> STRING
+-language="javascript"
+-code="5"
+-connection=
  +-Connection(connection=connection1)
--
ALTERNATION GROUP: +REMOTE_FUNCTION
--
ERROR: WITH CONNECTION clause should be preceded by keyword REMOTE and can't be used together with LANGUAGE clause [at 3:1]
with connection connection1 as """5""";
^
--
ALTERNATION GROUP: <empty>
--
ERROR: WITH CONNECTION clause is not supported [at 3:1]
with connection connection1 as """5""";
^
==

# WITH CONNECTION, without LANGUAGE clause and REMOTE
[language_features=NONE,{{+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION,+REMOTE_FUNCTION|+CREATE_FUNCTION_LANGUAGE_WITH_CONNECTION|+REMOTE_FUNCTION|}}]
create function myfunc() returns INT64
with connection connection1 AS ((SELECT 1));
