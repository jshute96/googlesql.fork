# Disallow more than one anonymous data payload field with explicit STRUCT(...)
# constructor.
SELECT
AI.IF(
STRUCT("payload1" AS field1, "data_payload_1", "data_payload_2"),
model => "gemini",
options => "option1");
--
ERROR: More than one anonymous data payload field is not allowed [at 2:1]
AI.IF(
^
==

# No error occurs since only the second field and onward is counted as data
# payload fields.
SELECT
AI.IF(STRUCT("prompt", "data_payload_1"), model => "gemini", options => "option1");
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:ai.if(STRUCT<STRING, STRING> prompt, STRING model, STRING options) -> BOOL)
    |     +-Literal(type=STRUCT<STRING, STRING>, value={"prompt", "data_payload_1"})
    |     +-Literal(type=STRING, value="gemini")
    |     +-Literal(type=STRING, value="option1")
    +-input_scan=
      +-SingleRowScan
==

# No errors since the data payload field names are inferred because they are a
# defined column from an existing table.
SELECT Value
FROM KeyValue
WHERE
AI.IF(STRUCT("payload1", Value, Value), model => "gemini", options => "option1");
--
QueryStmt
+-output_column_list=
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=[KeyValue.Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValue.Value#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRUCT<STRING, Value STRING, Value STRING> prompt, STRING model, STRING options) -> BOOL)
            +-MakeStruct
            | +-type=STRUCT<STRING, Value STRING, Value STRING>
            | +-field_list=
            |   +-Literal(type=STRING, value="payload1")
            |   +-ColumnRef(type=STRING, column=KeyValue.Value#2)
            |   +-ColumnRef(type=STRING, column=KeyValue.Value#2)
            +-Literal(type=STRING, value="gemini")
            +-Literal(type=STRING, value="option1")
==

# Disallow more than one anonymous data payload field with implicit STRUCT.
SELECT
AI.IF(("prompt", "data_payload_1", "data_payload_2"), model => "gemini", options => "option1");
--
ERROR: More than one anonymous data payload field is not allowed [at 2:1]
AI.IF(("prompt", "data_payload_1", "data_payload_2"), model => "gemini", opti...
^
==

# No error still since only the second field and onward is counted as data
# payload fields.
SELECT
AI.IF(("prompt", "data_payload_1"), model => "gemini", options => "option1");
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:ai.if(STRUCT<STRING, STRING> prompt, STRING model, STRING options) -> BOOL)
    |     +-Literal(type=STRUCT<STRING, STRING>, value={"prompt", "data_payload_1"})
    |     +-Literal(type=STRING, value="gemini")
    |     +-Literal(type=STRING, value="option1")
    +-input_scan=
      +-SingleRowScan

==

# Error since data payload field names can't be inferred with this type of
# STRUCT constructor.
SELECT Value
FROM KeyValue
WHERE
AI.IF(("prompt", Value, Value), model => "gemini", options => "option1");
--
ERROR: More than one anonymous data payload field is not allowed [at 4:1]
AI.IF(("prompt", Value, Value), model => "gemini", options => "option1");
^
==

# `model` must be query-const
SELECT AI.IF("prompt", model => "gemini" || CAST(rand() AS STRING));
--
ERROR: Argument 'model' to AI.IF must be a query-level constant [at 1:24]
SELECT AI.IF("prompt", model => "gemini" || CAST(rand() AS STRING));
                       ^
==

# `options` must be query-const
SELECT AI.IF("prompt", options => "option1" || CAST(rand() AS STRING));
--
ERROR: Argument 'options' to AI.IF must be a query-level constant [at 1:24]
SELECT AI.IF("prompt", options => "option1" || CAST(rand() AS STRING));
                       ^
