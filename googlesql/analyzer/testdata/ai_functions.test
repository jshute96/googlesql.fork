# AI.IF function tests.
[language_features=MAXIMUM]
# AI.IF is disabled by default under a language feature marked with
# in_development=true, due to naming conflicts with other engines that have their
# own version of AI.IF.
SELECT product
FROM
    KeyValue
WHERE
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", product));
--
ERROR: Function not found: AI.`IF`; Chained function calls require parentheses on input paths; Did you mean (AI).`IF`(...)? [at 8:5]
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", produc...
    ^
==

[language_features=NONE]
# Different error message if the feature gating chained function calls is not
# enabled and AI.IF is still disabled.
SELECT Value
FROM
    KeyValue
WHERE
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", product));
--
ERROR: Function not found: AI.`IF` [at 7:5]
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", produc...
    ^
==

[language_features=NONE,+AI_IF,+JSON_TYPE]
# Error if named arguments are not enabled.
SELECT product
FROM
    KeyValue
WHERE
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", Value),
    model => "gemini");
--
ERROR: Named arguments are not supported [at 7:5]
    model => "gemini");
    ^
==

[language_features=NONE,+AI_IF,+NAMED_ARGUMENTS]
# Error if JSON_TYPE is not enabled.
SELECT product
FROM
    KeyValue
WHERE
    AI.IF(CONCAT("Is this product environmentally friendly? Product:", Value),
    JSON '{"product_description":"This product is made from recyclable materials."}',
    model => "gemini");
--
ERROR: JSON literals are not supported [at 7:5]
    JSON '{"product_description":"This product is made from recyclable materi...
    ^
==

# The following tests run with AI.IF, JSON_TYPE, and NAMED_ARGUMENTS enabled.
[default language_features=NONE,+AI_IF,+JSON_TYPE,+NAMED_ARGUMENTS]
# Basic test that a ResolvedAST is produced with all arguments specified.
SELECT *
FROM
    KeyValue
WHERE
    AI.IF("Is this product with the following description considered environmentally friendly or sustainable?",
    JSON '{"product_description":"This product is made from recyclable materials."}',
    model => "gemini",
    options => JSON '{"option1": "value1"}');
--
QueryStmt
+-output_column_list=
| +-KeyValue.Key#1 AS Key [INT64]
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=KeyValue.[Key#1, Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=KeyValue.[Key#1, Value#2]
        +-input_scan=
        | +-TableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt, JSON payload, STRING model, JSON options) -> BOOL)
            +-Literal(type=STRING, value="Is this product with the following description considered environmentally friendly or sustainable?")
            +-Literal(type=JSON, value={"product_description":"This product is made from recyclable materials."}, has_explicit_type=TRUE)
            +-Literal(type=STRING, value="gemini")
            +-Literal(type=JSON, value={"option1":"value1"}, has_explicit_type=TRUE)
==

# `prompt` can be a STRUCT and `payload` shouldn't be specified.
SELECT *
FROM
    KeyValue
WHERE
    AI.IF(STRUCT("Is this product environmentally friendly?" as prompt, "this product is known to contain toxic components" AS product_description, "lead" AS product_material),
    model => "gemini", options => JSON '{}');
--
QueryStmt
+-output_column_list=
| +-KeyValue.Key#1 AS Key [INT64]
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=KeyValue.[Key#1, Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=KeyValue.[Key#1, Value#2]
        +-input_scan=
        | +-TableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRUCT<prompt STRING, product_description STRING, product_material STRING> prompt, STRING model, JSON options) -> BOOL)
            +-Literal(type=STRUCT<prompt STRING, product_description STRING, product_material STRING>, value={prompt:"Is this product environmentally friendly?", product_description:"this product is known to contain toxic components", product_material:"lead"})
            +-Literal(type=STRING, value="gemini")
            +-Literal(type=JSON, value={}, has_explicit_type=TRUE)
==

# `options` can be a STRING but formatted as JSON if engines don't support JSON
# as a native type.
SELECT *
FROM
    KeyValue
WHERE
    AI.IF(prompt => "Is this product environmentally friendly?", options => "{\"option1\": \"value1\"}");
--
QueryStmt
+-output_column_list=
| +-KeyValue.Key#1 AS Key [INT64]
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=KeyValue.[Key#1, Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=KeyValue.[Key#1, Value#2]
        +-input_scan=
        | +-TableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt, STRING options) -> BOOL)
            +-Literal(type=STRING, value="Is this product environmentally friendly?")
            +-Literal(type=STRING, value='{"option1": "value1"}')
==

# Real column names can be referenced within calls to AI.IF.
SELECT Value
FROM
    KeyValue
WHERE
    AI.IF(CONCAT("Does Value equal to c?: ", Value), "payload", model => "gemini")
--
QueryStmt
+-output_column_list=
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=[KeyValue.Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValue.Value#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt, STRING payload, STRING model) -> BOOL)
            +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
            | +-Literal(type=STRING, value="Does Value equal to c?: ")
            | +-ColumnRef(type=STRING, column=KeyValue.Value#2)
            +-Literal(type=STRING, value="payload")
            +-Literal(type=STRING, value="gemini")
==

# At least `prompt` must be passed in as an argument.
SELECT Value
FROM
    KeyValue
WHERE
    AI.IF(prompt => CONCAT("Does Value equal to c?: ", Value));
--
QueryStmt
+-output_column_list=
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=[KeyValue.Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValue.Value#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt) -> BOOL)
            +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
              +-Literal(type=STRING, value="Does Value equal to c?: ")
              +-ColumnRef(type=STRING, column=KeyValue.Value#2)
==

# `options` can be passed as a STRUCT.
SELECT Value
FROM KeyValue
WHERE AI.IF(CONCAT("Does Value equal to c?: ", Value), options =>
STRUCT('param_value' AS model_param_1));
--
QueryStmt
+-output_column_list=
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=[KeyValue.Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValue.Value#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt, STRUCT<model_param_1 STRING> options) -> BOOL)
            +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
            | +-Literal(type=STRING, value="Does Value equal to c?: ")
            | +-ColumnRef(type=STRING, column=KeyValue.Value#2)
            +-Literal(type=STRUCT<model_param_1 STRING>, value={model_param_1:"param_value"})
==

# `options` and `model` can be called in an order opposite to what's defined in
# the signature.
SELECT Value
FROM KeyValue
WHERE AI.IF(CONCAT("Does Value equal to c?: ", Value), options =>
STRUCT('param_value' AS model_param_1), model => "gemini");
--
QueryStmt
+-output_column_list=
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=[KeyValue.Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=[KeyValue.Value#2]
        +-input_scan=
        | +-TableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt, STRING model, STRUCT<model_param_1 STRING> options) -> BOOL)
            +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
            | +-Literal(type=STRING, value="Does Value equal to c?: ")
            | +-ColumnRef(type=STRING, column=KeyValue.Value#2)
            +-Literal(type=STRING, value="gemini")
            +-Literal(type=STRUCT<model_param_1 STRING>, value={model_param_1:"param_value"})
==

# NULL passed in won't cause analysis errors but should be handled by the
# reference and engine implementations.
SELECT *
FROM
    KeyValue
WHERE
    AI.IF(NULL);
--
QueryStmt
+-output_column_list=
| +-KeyValue.Key#1 AS Key [INT64]
| +-KeyValue.Value#2 AS Value [STRING]
+-query=
  +-ProjectScan
    +-column_list=KeyValue.[Key#1, Value#2]
    +-input_scan=
      +-FilterScan
        +-column_list=KeyValue.[Key#1, Value#2]
        +-input_scan=
        | +-TableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
        +-filter_expr=
          +-FunctionCall(GoogleSQL:ai.if(STRING prompt) -> BOOL)
            +-Literal(type=STRING, value=NULL)
==

