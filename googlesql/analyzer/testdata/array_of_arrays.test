# Ensure that ARRAY_ZIP with lambda applies correctly to nested ARRAYs.
SELECT
  ARRAY_ZIP(arr1, arr2, (e1, e2) -> [e1, e2]) AS arr_zip
FROM (
  SELECT [[1,2], [3,4]] AS arr1,
         [[5,6], [7,8]] AS arr2,
)
