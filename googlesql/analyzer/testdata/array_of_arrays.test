+-output_column_list=
| +-$query.arr_zip#5 AS arr_zip [ARRAY<ARRAY<ARRAY<INT64>>>]
+-query=
  +-ProjectScan
    +-column_list=[$query.arr_zip#5]
    +-expr_list=
    | +-arr_zip#5 :=
    |   +-FunctionCall(GoogleSQL:array_zip(ARRAY<ARRAY<INT64>> input_array_1, ARRAY<ARRAY<INT64>> input_array_2, FUNCTION<(ARRAY<INT64>, ARRAY<INT64>)->ARRAY<ARRAY<INT64>>> transformation, optional(1) ENUM<ARRAY_ZIP_MODE> mode) -> ARRAY<ARRAY<ARRAY<INT64>>>)
    |     +-FunctionArgument
    |     | +-expr=
    |     |   +-ColumnRef(type=ARRAY<ARRAY<INT64>>, column=$subquery1.arr1#1)
    |     +-FunctionArgument
    |     | +-expr=
    |     |   +-ColumnRef(type=ARRAY<ARRAY<INT64>>, column=$subquery1.arr2#2)
    |     +-FunctionArgument
    |     | +-inline_lambda=
    |     |   +-InlineLambda
    |     |     +-argument_list=$lambda_arg.[e1#3, e2#4]
    |     |     +-body=
    |     |       +-FunctionCall(GoogleSQL:$make_array(repeated(2) ARRAY<INT64>) -> ARRAY<ARRAY<INT64>>)
    |     |         +-ColumnRef(type=ARRAY<INT64>, column=$lambda_arg.e1#3)
    |     |         +-ColumnRef(type=ARRAY<INT64>, column=$lambda_arg.e2#4)
    |     +-FunctionArgument
    |       +-expr=
    |         +-Literal(type=ENUM<ARRAY_ZIP_MODE>, value=STRICT)
    +-input_scan=
      +-ProjectScan
        +-column_list=$subquery1.[arr1#1, arr2#2]
        +-expr_list=
        | +-arr1#1 := Literal(type=ARRAY<ARRAY<INT64>>, value=[[1, 2], [3, 4]])
        | +-arr2#2 := Literal(type=ARRAY<ARRAY<INT64>>, value=[[5, 6], [7, 8]])
        +-input_scan=
          +-SingleRowScan

