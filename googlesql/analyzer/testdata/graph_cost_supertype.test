[default language_features=NONE,+SQL_GRAPH,+SQL_GRAPH_ADVANCED_QUERY,+SQL_GRAPH_CHEAPEST_PATH,+SQL_GRAPH_BOUNDED_PATH_QUANTIFICATION,+NUMERIC_TYPE,+BIGNUMERIC_TYPE]
[default no_test_extract_table_names]

GRAPH aml
MATCH -[a:Transfer cost (select {{uint32|uint64|int32|int64|float|double|numeric|bignumeric}} from SimpleTypes)]->
RETURN 1 as col
--
ALTERNATION GROUP: uint32
--
QueryStmt
+-output_column_list=
| +-$graph_table.col#45 AS col [INT64]
+-query=
  +-GraphTableScan
    +-column_list=[$graph_table.col#45]
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-column_list=[$graph_table.col#45]
        +-scan_list=
          +-GraphLinearScan
            +-column_list=[$graph_table.col#45]
            +-scan_list=
              +-GraphScan
              | +-column_list=$element_table.[$element3#23, a#24, $element4#44]
              | +-input_scan_list=
              | | +-GraphPathScan
              | |   +-column_list=$element_table.[$element3#23, a#24, $element4#44]
              | |   +-input_scan_list=
              | |   | +-GraphNodeScan
              | |   | | +-column_list=[$element_table.$element3#23]
              | |   | | +-label_expr=
              | |   | | | +-GraphLabelNaryExpr
              | |   | | |   +-op=OR
              | |   | | |   +-operand_list=
              | |   | | |     +-GraphWildCardLabel
              | |   | | |     +-GraphLabelNaryExpr
              | |   | | |       +-op=NOT
              | |   | | |       +-operand_list=
              | |   | | |         +-GraphWildCardLabel
              | |   | | +-target_element_table_list=[aml.Account,aml.Person,aml.Syndicate]
              | |   | +-GraphEdgeScan
              | |   | | +-column_list=[$element_table.a#24]
              | |   | | +-label_expr=
              | |   | | | +-GraphLabel(parse_location=20-28, label=aml.Transfer)
              | |   | | +-target_element_table_list=[aml.Transfer]
              | |   | | +-orientation=RIGHT
              | |   | | +-cost_expr=
              | |   | |   +-Cast(UINT32 -> UINT64)
              | |   | |     +-SubqueryExpr
              | |   | |       +-type=UINT32
              | |   | |       +-subquery_type=SCALAR
              | |   | |       +-subquery=
              | |   | |         +-ProjectScan
              | |   | |           +-column_list=[SimpleTypes.uint32#27]
              | |   | |           +-input_scan=
              | |   | |             +-TableScan(column_list=[SimpleTypes.uint32#27], table=SimpleTypes, column_index_list=[2])
              | |   | +-GraphNodeScan
              | |   |   +-column_list=[$element_table.$element4#44]
              | |   |   +-label_expr=
              | |   |   | +-GraphLabelNaryExpr
              | |   |   |   +-op=OR
              | |   |   |   +-operand_list=
              | |   |   |     +-GraphWildCardLabel
              | |   |   |     +-GraphLabelNaryExpr
              | |   |   |       +-op=NOT
              | |   |   |       +-operand_list=
              | |   |   |         +-GraphWildCardLabel
              | |   |   +-target_element_table_list=[aml.Account,aml.Person,aml.Syndicate]
              | |   +-head=$element_table.$element3#23
              | |   +-tail=$element_table.$element4#44
              | |   +-path_cost=
              | |     +-GraphPathCost(cost_supertype=UINT64)
              | +-input_scan=
              |   +-SingleRowScan
              +-ProjectScan
                +-column_list=[$graph_table.col#45]
                +-expr_list=
                | +-col#45 := Literal(type=INT64, value=1)
                +-input_scan=
                  +-GraphRefScan(column_list=$element_table.[$element3#23, a#24, $element4#44])
