              +-property=id(INT64)

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aml_1.a_8 AS Id,
  aml_1.a_9 AS PersonId,
  aml_1.a_10 AS c_id,
  aml_1.a_11 AS n_id
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS ((% | ! %) &(% | ! %)))
      -[a_3 IS PersonOwnAccount]->
      (a_4 IS (% | ! %)),
      (a_5 IS ((% | ! %) &(% | ! %)))
      -[a_6 IS (% | ! %)]->
      (a_7 IS (% | ! %))
      WHERE
        (a_2 = a_5) AND ((a_2.id) < (a_7.id))
    COLUMNS(
      a_2.id AS a_8,
      a_3.personId AS a_9,
      a_4.id AS a_10,
      a_7.id AS a_11
    )
  ) AS aml_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS ((% | ! %) &(% | ! %)))
      -[a_3 IS PersonOwnAccount]->
      (a_4 IS (% | ! %)),
      (a_5 IS ((% | ! %) &(% | ! %)))
      -[a_6 IS (% | ! %)]->
      (a_7 IS (% | ! %))
      WHERE
        (a_2 = a_5) AND ((a_2.id) < (a_7.id))
    COLUMNS(
      a_2.id AS a_8,
      a_3.personId AS a_9,
      a_4.id AS a_10,
      a_7.id AS a_11
    )
  ) AS aml_1
|> SELECT
     aml_1.a_8 AS Id,
     aml_1.a_9 AS PersonId,
     aml_1.a_10 AS c_id,
     aml_1.a_11 AS n_id;
