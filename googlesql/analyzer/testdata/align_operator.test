# ALIGN operator cannot be combined with other postfix operators or itself
# without using a subquery.
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  PARTITION BY borg_job, borg_task_num
) ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN TIMESTAMP('2000-01-01 00:00:00+00')
)
--
ERROR: Unsupported combination of table operators. The only allowed combination is PIVOT/UNPIVOT followed by TABLESAMPLE.  [at 5:3]
) ALIGN (
  ^
==

SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  PARTITION BY borg_job, borg_task_num
) MATCH_RECOGNIZE (
  ORDER BY borg_job
  MEASURES max(borg_task_num) AS m
  PATTERN (p1)
  DEFINE
    p1 AS ts_col > TIMESTAMP('2000-01-01 00:00:00+00')
)
--
ERROR: Unsupported combination of table operators. The only allowed combination is PIVOT/UNPIVOT followed by TABLESAMPLE.  [at 5:3]
) MATCH_RECOGNIZE (
  ^
==

[language_features=NONE,+ALIGN_OPERATOR,+MATCH_RECOGNIZE,+INTERVAL_TYPE]
SELECT * FROM (
  Select * FROM TimeseriesTable ALIGN (
    TIMESTAMP ts_col
    PERIOD INTERVAL 1 MINUTE
    PARTITION BY borg_job, borg_task_num
  )
) MATCH_RECOGNIZE (
    ORDER BY borg_job
    MEASURES max(borg_task_num) AS m
    PATTERN (p1)
    DEFINE
      p1 AS ts_col > TIMESTAMP('2000-01-01 00:00:00+00')
)
--
QueryStmt
+-output_column_list=
| +-$match_recognize.m#13 AS m [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$match_recognize.m#13]
    +-input_scan=
      +-ProjectScan
        +-column_list=[$match_recognize.m#13]
        +-expr_list=
        | +-m#13 := ColumnRef(type=INT64, column=$aggregate.$agg1#12)
        +-input_scan=
          +-MatchRecognizeScan
            +-column_list=[$aggregate.$agg1#12]
            +-input_scan=
            | +-ProjectScan
            |   +-column_list=$align.[borg_job#6, borg_task_num#7, aligned_timestamp#8]
            |   +-input_scan=
            |     +-AlignScan
            |       +-column_list=$align.[borg_job#6, borg_task_num#7, aligned_timestamp#8]
            |       +-input_scan=
            |       | +-ProjectScan
            |       |   +-column_list=[TimeseriesTable.borg_job#1, TimeseriesTable.borg_task_num#2, TimeseriesTable.ts_col#3, $align.borg_job#6, $align.borg_task_num#7]
            |       |   +-expr_list=
            |       |   | +-borg_job#6 := ColumnRef(type=STRING, column=TimeseriesTable.borg_job#1)
            |       |   | +-borg_task_num#7 := ColumnRef(type=INT64, column=TimeseriesTable.borg_task_num#2)
            |       |   +-input_scan=
            |       |     +-TableScan(column_list=TimeseriesTable.[borg_job#1, borg_task_num#2, ts_col#3], table=TimeseriesTable, column_index_list=[0, 1, 2])
            |       +-timestamp_column=
            |       | +-ColumnRef(type=TIMESTAMP, column=TimeseriesTable.ts_col#3)
            |       +-period=
            |       | +-FunctionCall(GoogleSQL:$interval(INT64, ENUM<googlesql.functions.DateTimestampPart>) -> INTERVAL)
            |       |   +-Literal(type=INT64, value=1)
            |       |   +-Literal(type=ENUM<googlesql.functions.DateTimestampPart>, value=MINUTE)
            |       +-output_within=
            |       | +-WithinBounds
            |       |   +-lower_bound=
            |       |   | +-WithinBoundExpr(within_bound_kind=UNBOUNDED PRECEDING)
            |       |   +-upper_bound=
            |       |     +-WithinBoundExpr(within_bound_kind=ANCHOR TIMESTAMP)
            |       +-partition_by_list=
            |       | +-ColumnRef(type=STRING, column=$align.borg_job#6)
            |       | +-ColumnRef(type=INT64, column=$align.borg_task_num#7)
            |       +-aligned_timestamp_column=$align.aligned_timestamp#8
            +-analytic_function_group_list=
            | +-AnalyticFunctionGroup
            |   +-order_by=
            |     +-WindowOrdering
            |       +-order_by_item_list=
            |         +-OrderByItem
            |           +-column_ref=
            |             +-ColumnRef(type=STRING, column=$align.borg_job#6)
            +-pattern_variable_definition_list=
            | +-MatchRecognizeVariableDefinition
            |   +-name="p1"
            |   +-predicate=
            |     +-FunctionCall(GoogleSQL:$greater(TIMESTAMP, TIMESTAMP) -> BOOL)
            |       +-ColumnRef(type=TIMESTAMP, column=$align.aligned_timestamp#8)
