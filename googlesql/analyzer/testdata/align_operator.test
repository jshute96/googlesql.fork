        |   +-right_scan=
        |   | +-ProjectScan
        |   |   +-column_list=KeyValue.[Key#6, Value#7]
        |   |   +-input_scan=
        |   |     +-TableScan(column_list=KeyValue.[Key#6, Value#7], table=KeyValue, column_index_list=[0, 1])
