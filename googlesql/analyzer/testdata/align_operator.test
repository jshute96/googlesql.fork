# The epoch identifier in "ORIGIN EPOCH" shadows any other possible references.
SELECT * FROM (
  SELECT INTERVAL 1 MINUTE AS period_col,
         TIMESTAMP('2000-01-01 00:00:00+00') AS epoch)
WHERE EXISTS(
  SELECT * FROM TimeseriesTable ALIGN (
    TIMESTAMP ts_col
    PERIOD period_col
    ORIGIN epoch
  )
)
--
QueryStmt
+-output_column_list=
| +-$subquery1.period_col#1 AS period_col [INTERVAL]
| +-$subquery1.epoch#2 AS `epoch` [TIMESTAMP]
+-query=
  +-ProjectScan
    +-column_list=$subquery1.[period_col#1, epoch#2]
    +-input_scan=
      +-FilterScan
        +-column_list=$subquery1.[period_col#1, epoch#2]
        +-input_scan=
        | +-ProjectScan
        |   +-column_list=$subquery1.[period_col#1, epoch#2]
        |   +-expr_list=
        |   | +-period_col#1 :=
        |   | | +-FunctionCall(GoogleSQL:$interval(INT64, ENUM<googlesql.functions.DateTimestampPart>) -> INTERVAL)
        |   | |   +-Literal(type=INT64, value=1)
        |   | |   +-Literal(type=ENUM<googlesql.functions.DateTimestampPart>, value=MINUTE)
        |   | +-epoch#2 :=
        |   |   +-FunctionCall(GoogleSQL:timestamp(STRING, optional(0) STRING) -> TIMESTAMP)
        |   |     +-Literal(type=STRING, value="2000-01-01 00:00:00+00")
        |   +-input_scan=
        |     +-SingleRowScan
        +-filter_expr=
          +-SubqueryExpr
            +-type=BOOL
            +-subquery_type=EXISTS
            +-parameter_list=
            | +-ColumnRef(type=INTERVAL, column=$subquery1.period_col#1)
            +-subquery=
              +-ProjectScan
                +-column_list=[$align.aligned_timestamp#8]
                +-input_scan=
                  +-AlignScan
                    +-column_list=[$align.aligned_timestamp#8]
                    +-input_scan=
                    | +-TableScan(column_list=[TimeseriesTable.ts_col#5], table=TimeseriesTable, column_index_list=[2])
                    +-timestamp_column=
                    | +-ColumnRef(type=TIMESTAMP, column=TimeseriesTable.ts_col#5)
                    +-period=
                    | +-ColumnRef(type=INTERVAL, column=$subquery1.period_col#1, is_correlated=TRUE)
                    +-origin=
                    | +-Literal(type=TIMESTAMP, value=1970-01-01 00:00:00+00, has_explicit_type=TRUE, preserve_in_literal_remover=TRUE)
                    +-output_within=
                    | +-WithinBounds
                    |   +-lower_bound=
                    |   | +-WithinBoundExpr(within_bound_kind=UNBOUNDED PRECEDING)
                    |   +-upper_bound=
                    |     +-WithinBoundExpr(within_bound_kind=ANCHOR TIMESTAMP)
                    +-aligned_timestamp_column=$align.aligned_timestamp#8
==

