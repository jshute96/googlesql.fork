# OUTPUT WITHIN clause - invalid cases
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  OUTPUT WITHIN {{RANGE FROM TIMESTAMP('2000-01-01') TO 1 PERIOD FOLLOWING|RANGE FROM INTERVAL "1" MINUTE|"1" PERIOD FOLLOWING|[1] PRECEDING}}
)
--
ALTERNATION GROUP: RANGE FROM TIMESTAMP('2000-01-01') TO 1 PERIOD FOLLOWING
--
ERROR: A WITHIN clause cannot mix absolute (TIMESTAMP) and relative (INTERVAL or PERIOD) bounds [at 4:17]
  OUTPUT WITHIN RANGE FROM TIMESTAMP('2000-01-01') TO 1 PERIOD FOLLOWING
                ^
--
ALTERNATION GROUP: RANGE FROM INTERVAL "1" MINUTE
--
ERROR: Expression must be of type TIMESTAMP, but has type INTERVAL [at 4:28]
  OUTPUT WITHIN RANGE FROM INTERVAL "1" MINUTE
                           ^
--
ALTERNATION GROUP: "1" PERIOD FOLLOWING
--
ERROR: Expression must be of type INT64 or DOUBLE, but has type STRING [at 4:17]
  OUTPUT WITHIN "1" PERIOD FOLLOWING
                ^
--
ALTERNATION GROUP: [1] PRECEDING
--
ERROR: Expression must be of type INTERVAL, but has type ARRAY<INT64> [at 4:17]
  OUTPUT WITHIN [1] PRECEDING
                ^
==

# WITHIN BOUND expression must be query const
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  OUTPUT WITHIN INTERVAL CAST(RAND() as INT64) MINUTE PRECEDING
)
--
ERROR: WITHIN bound expression must be a query constant [at 4:17]
  OUTPUT WITHIN INTERVAL CAST(RAND() as INT64) MINUTE PRECEDING
                ^
==

# TODO: b/477116035 - Support METRICS clause.
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN TIMESTAMP('2000-01-01')
  METRICS SUM(requests) WITHIN (1 PERIOD PRECEDING) AS total_requests
)
--
ERROR: METRICS clause is not supported [at 5:3]
  METRICS SUM(requests) WITHIN (1 PERIOD PRECEDING) AS total_requests
  ^
==

# Correlated columns are allowed
SELECT * FROM (
  SELECT INTERVAL 1 MINUTE AS a_col,
         TIMESTAMP('2000-01-01 00:00:00+00') AS b_col)
WHERE EXISTS(SELECT * FROM TimeseriesTable ALIGN (
    TIMESTAMP {{b_col|ts_col + a_col}}
    PERIOD a_col
    ORIGIN b_col
    PARTITION BY b_col AS b, ts_col + a_col AS t, borg_job, borg_task_num + 1 as task_num
))
--
ALTERNATION GROUP: b_col
--
QueryStmt
+-output_column_list=
| +-$subquery1.a_col#1 AS a_col [INTERVAL]
| +-$subquery1.b_col#2 AS b_col [TIMESTAMP]
+-query=
  +-ProjectScan
    +-column_list=$subquery1.[a_col#1, b_col#2]
    +-input_scan=
      +-FilterScan
        +-column_list=$subquery1.[a_col#1, b_col#2]
        +-input_scan=
        | +-ProjectScan
        |   +-column_list=$subquery1.[a_col#1, b_col#2]
        |   +-expr_list=
        |   | +-a_col#1 :=
        |   | | +-FunctionCall(GoogleSQL:$interval(INT64, ENUM<googlesql.functions.DateTimestampPart>) -> INTERVAL)
        |   | |   +-Literal(type=INT64, value=1)
        |   | |   +-Literal(type=ENUM<googlesql.functions.DateTimestampPart>, value=MINUTE)
        |   | +-b_col#2 :=
        |   |   +-FunctionCall(GoogleSQL:timestamp(STRING, optional(0) STRING) -> TIMESTAMP)
        |   |     +-Literal(type=STRING, value="2000-01-01 00:00:00+00")
        |   +-input_scan=
        |     +-SingleRowScan
        +-filter_expr=
          +-SubqueryExpr
            +-type=BOOL
            +-subquery_type=EXISTS
            +-parameter_list=
            | +-ColumnRef(type=INTERVAL, column=$subquery1.a_col#1)
            | +-ColumnRef(type=TIMESTAMP, column=$subquery1.b_col#2)
            +-subquery=
              +-ProjectScan
                +-column_list=$align.[b#8, t#9, borg_job#10, task_num#11, aligned_timestamp#12]
                +-input_scan=
                  +-AlignScan
                    +-column_list=$align.[b#8, t#9, borg_job#10, task_num#11, aligned_timestamp#12]
                    +-input_scan=
                    | +-ProjectScan
                    |   +-column_list=[TimeseriesTable.borg_job#3, TimeseriesTable.borg_task_num#4, TimeseriesTable.ts_col#5, $align.b#8, $align.t#9, $align.borg_job#10, $align.task_num#11]
                    |   +-expr_list=
                    |   | +-b#8 := ColumnRef(type=TIMESTAMP, column=$subquery1.b_col#2, is_correlated=TRUE)
                    |   | +-t#9 :=
                    |   | | +-FunctionCall(GoogleSQL:$add(TIMESTAMP, INTERVAL) -> TIMESTAMP)
                    |   | |   +-ColumnRef(type=TIMESTAMP, column=TimeseriesTable.ts_col#5)
                    |   | |   +-ColumnRef(type=INTERVAL, column=$subquery1.a_col#1, is_correlated=TRUE)
                    |   | +-borg_job#10 := ColumnRef(type=STRING, column=TimeseriesTable.borg_job#3)
                    |   | +-task_num#11 :=
                    |   |   +-FunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
                    |   |     +-ColumnRef(type=INT64, column=TimeseriesTable.borg_task_num#4)
                    |   |     +-Literal(type=INT64, value=1)
                    |   +-input_scan=
                    |     +-TableScan(column_list=TimeseriesTable.[borg_job#3, borg_task_num#4, ts_col#5], table=TimeseriesTable, column_index_list=[0, 1, 2])
                    +-timestamp_column=
                    | +-ColumnRef(type=TIMESTAMP, column=$subquery1.b_col#2, is_correlated=TRUE)
                    +-period=
                    | +-ColumnRef(type=INTERVAL, column=$subquery1.a_col#1, is_correlated=TRUE)
                    +-origin=
                    | +-ColumnRef(type=TIMESTAMP, column=$subquery1.b_col#2, is_correlated=TRUE)
                    +-output_within=
                    | +-WithinBounds
                    |   +-lower_bound=
                    |   | +-WithinBoundExpr(within_bound_kind=UNBOUNDED PRECEDING)
                    |   +-upper_bound=
                    |     +-WithinBoundExpr(within_bound_kind=ANCHOR TIMESTAMP)
                    +-partition_by_list=
                    | +-ColumnRef(type=TIMESTAMP, column=$align.b#8)
                    | +-ColumnRef(type=TIMESTAMP, column=$align.t#9)
                    | +-ColumnRef(type=STRING, column=$align.borg_job#10)
                    | +-ColumnRef(type=INT64, column=$align.task_num#11)
                    +-aligned_timestamp_column=$align.aligned_timestamp#12
--
ALTERNATION GROUP: ts_col + a_col
