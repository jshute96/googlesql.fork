# Some aliases are not allowed for PARTITION BY expression
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN TIMESTAMP('2000-01-01 00:00:00+00')
  PARTITION BY {{borg_task_num as timestamp|borg_task_num as aligned_timestamp|borg_task_num+1}}
)
--
ALTERNATION GROUP: borg_task_num as timestamp
--
ERROR: PARTITION BY expression can't be aliased as 'timestamp' or 'aligned_timestamp' [at 5:16]
  PARTITION BY borg_task_num as timestamp
               ^
--
ALTERNATION GROUP: borg_task_num as aligned_timestamp
--
ERROR: PARTITION BY expression can't be aliased as 'timestamp' or 'aligned_timestamp' [at 5:16]
  PARTITION BY borg_task_num as aligned_timestamp
               ^
--
ALTERNATION GROUP: borg_task_num+1
--
ERROR: Cannot infer alias for PARTITION BY expression, please provide an explicit alias [at 5:16]
  PARTITION BY borg_task_num+1
               ^
==

# Non orderable type problem for PARTITION BY expression
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN TIMESTAMP('2000-01-01 00:00:00+00')
  PARTITION BY FLOOR(borg_task_num) as task_num
)
--
ERROR: Partitioning expression of type DOUBLE is not allowed [at 5:16]
  PARTITION BY FLOOR(borg_task_num) as task_num
               ^
==

