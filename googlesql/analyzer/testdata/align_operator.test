# Some aliases are not allowed for TIMESTAMP expression
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col AS aligned_timestamp
  PERIOD INTERVAL 1 MINUTE
  PARTITION BY borg_job
)
--
ERROR: TIMESTAMP expression in ALIGN operator can't be aliased as 'aligned_timestamp' [at 2:13]
  TIMESTAMP ts_col AS aligned_timestamp
            ^
==

# PERIOD expression must be of interval type
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD TIMESTAMP("2026-01-01")
  PARTITION BY borg_job
)
--
ERROR: Expression must be of type INTERVAL, but has type TIMESTAMP [at 3:10]
  PERIOD TIMESTAMP("2026-01-01")
         ^
==

# PERIOD expression must be query const
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD MAKE_INTERVAL(second => CAST(RAND() as INT64))
)
--
ERROR: Expression must be a query constant [at 3:10]
  PERIOD MAKE_INTERVAL(second => CAST(RAND() as INT64))
         ^
==

# ORIGIN expression must be of timestamp type
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN INTERVAL 1 MINUTE
)
--
ERROR: Expression must be of type TIMESTAMP, but has type INTERVAL [at 4:10]
  ORIGIN INTERVAL 1 MINUTE
         ^
==

# ORIGIN expression must be query const
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL 1 MINUTE
  ORIGIN TIMESTAMP_SECONDS(CAST(RAND() as INT64))
)
--
ERROR: Expression must be a query constant [at 4:10]
  ORIGIN TIMESTAMP_SECONDS(CAST(RAND() as INT64))
         ^
==

# For "ORIGIN EPOCH", origin is set to the literal value - GoogleSQL epoch.
# EPOCH should not be parenthesized or backquoted.
SELECT * FROM TimeseriesTable ALIGN (
  TIMESTAMP ts_col
  PERIOD INTERVAL "1" MINUTE
  ORIGIN {{EPOCH|epoch|(EPOCH)|`EPOCH`}}
)
--
ALTERNATION GROUPS:
    EPOCH
    epoch
--
QueryStmt
+-output_column_list=
| +-$align.aligned_timestamp#6 AS ts_col [TIMESTAMP]
+-query=
  +-ProjectScan
    +-column_list=[$align.aligned_timestamp#6]
    +-input_scan=
      +-AlignScan
        +-column_list=[$align.aligned_timestamp#6]
        +-input_scan=
        | +-TableScan(column_list=[TimeseriesTable.ts_col#3], table=TimeseriesTable, column_index_list=[2])
        +-timestamp_column=
        | +-ColumnRef(type=TIMESTAMP, column=TimeseriesTable.ts_col#3)
        +-period=
        | +-Literal(type=INTERVAL, value=0-0 0 0:1:0)
        +-origin=
        | +-Literal(type=TIMESTAMP, value=1970-01-01 00:00:00+00, has_explicit_type=TRUE, preserve_in_literal_remover=TRUE)
        +-output_within=
        | +-WithinBounds
        |   +-lower_bound=
        |   | +-WithinBoundExpr(within_bound_kind=UNBOUNDED PRECEDING)
        |   +-upper_bound=
        |     +-WithinBoundExpr(within_bound_kind=ANCHOR TIMESTAMP)
        +-aligned_timestamp_column=$align.aligned_timestamp#6
--
ALTERNATION GROUP: (EPOCH)
--
ERROR: Unrecognized name: `EPOCH` [at 4:11]
  ORIGIN (EPOCH)
          ^
--
ALTERNATION GROUP: `EPOCH`
--
ERROR: Unrecognized name: `EPOCH` [at 4:10]
  ORIGIN `EPOCH`
