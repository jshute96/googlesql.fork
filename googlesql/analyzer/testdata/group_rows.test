# Aliased group rows erases <from> value table alias. Referencing <from> alias
# results in a correlated column.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (gr, t.str_value)
  FROM group_rows() gr
)
FROM TestExtraValueTable t
GROUP BY t.str_value
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#13 AS `$col1` [ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, ARRAY<STRING>>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#13]
    +-input_scan=
      +-AggregateScan
