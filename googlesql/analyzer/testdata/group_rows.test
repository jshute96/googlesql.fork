# Define and use group rows within a CTE.
WITH cte AS (
  SELECT ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT t.key
    FROM group_rows()
  )
  FROM EnumTable t
)
SELECT *
FROM cte
--
QueryStmt
+-output_column_list=
| +-cte.$col1#17 AS `$col1` [ARRAY<INT32>]
+-query=
  +-WithScan
    +-column_list=[cte.$col1#17]
    +-with_entry_list=
    | +-WithEntry
    |   +-with_query_name="cte"
    |   +-with_subquery=
    |     +-ProjectScan
    |       +-column_list=[$expr_subquery.$group_rows_subquery#16]
    |       +-input_scan=
    |         +-AggregateScan
    |           +-column_list=[$expr_subquery.$group_rows_subquery#16]
    |           +-input_scan=
    |           | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t")
    |           +-aggregate_list=
    |             +-$group_rows_subquery#16 :=
    |               +-SubqueryExpr
    |                 +-type=ARRAY<INT32>
    |                 +-subquery_type=ARRAY
    |                 +-subquery=
    |                   +-ProjectScan
    |                     +-column_list=[EnumTable.key#11]
    |                     +-input_scan=
    |                       +-GroupRowsScan
    |                         +-column_list=[EnumTable.key#11]
    |                         +-input_column_list=
    |                           +-key#11 := ColumnRef(type=INT32, column=EnumTable.key#1)
    |                           +-TestEnum#12 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
    |                           +-AnotherTestEnum#13 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
    |                           +-Filename#14 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
    |                           +-RowId#15 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
    +-query=
      +-ProjectScan
        +-column_list=[cte.$col1#17]
        +-input_scan=
          +-WithRefScan(column_list=[cte.$col1#17], with_query_name="cte")
==

# Define group rows and use it in a following CTE.
SELECT ARRAY(
  WITH
    group_rows() AS GROUP ROWS,
    cte AS (
      SELECT t.key
      FROM group_rows()
    )
    SELECT *
    FROM cte
)
FROM EnumTable t
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#18 AS `$col1` [ARRAY<INT32>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#18]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#18]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t")
        +-aggregate_list=
          +-$group_rows_subquery#18 :=
            +-SubqueryExpr
              +-type=ARRAY<INT32>
              +-subquery_type=ARRAY
              +-subquery=
                +-WithScan
                  +-column_list=[cte_1.key#17]
                  +-with_entry_list=
                  | +-WithEntry
                  |   +-with_query_name="cte_1"
                  |   +-with_subquery=
                  |     +-ProjectScan
                  |       +-column_list=[EnumTable.key#12]
                  |       +-input_scan=
                  |         +-GroupRowsScan
                  |           +-column_list=[EnumTable.key#12]
                  |           +-input_column_list=
                  |             +-key#12 := ColumnRef(type=INT32, column=EnumTable.key#1)
                  |             +-TestEnum#13 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                  |             +-AnotherTestEnum#14 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                  |             +-Filename#15 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                  |             +-RowId#16 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
                  +-query=
                    +-ProjectScan
                      +-column_list=[cte_1.key#17]
                      +-input_scan=
                        +-WithRefScan(column_list=[cte_1.key#17], with_query_name="cte_1")
==

# Group rows not supported in UDAs.
[prepare_database=db1]
CREATE AGGREGATE FUNCTION UdafWithNonTemplatedArgs(a STRING, b STRING) AS (
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT STRING_AGG(CONCAT(a,b))
    FROM group_rows()
  )
)
--
ERROR: GROUP ROWS is not supported in this (sub)query. [at 3:5]
    WITH group_rows() AS GROUP ROWS
    ^
==

# Group rows not supported inside FROM clause.
SELECT COUNT(*)
FROM (
  WITH group_rows() AS GROUP ROWS
  SELECT Filename FROM group_rows()
  WHERE Filename LIKE '%.txt'
)
--
ERROR: GROUP ROWS is not supported in this (sub)query. [at 3:3]
  WITH group_rows() AS GROUP ROWS
  ^
==

# Group rows within having clause.
SELECT key
FROM EnumTable
GROUP BY key
HAVING (
  WITH group_rows() AS GROUP ROWS
  SELECT COUNT(*)
  FROM group_rows()
  WHERE Filename LIKE '%.txt'
) > 1
--
QueryStmt
+-output_column_list=
| +-$groupby.key#6 AS key [INT32]
+-query=
  +-ProjectScan
    +-column_list=[$groupby.key#6]
    +-input_scan=
      +-FilterScan
        +-column_list=[$groupby.key#6, $expr_subquery.$group_rows_subquery#13]
        +-input_scan=
        | +-AggregateScan
        |   +-column_list=[$groupby.key#6, $expr_subquery.$group_rows_subquery#13]
        |   +-input_scan=
        |   | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
        |   +-group_by_list=
        |   | +-key#6 := ColumnRef(type=INT32, column=EnumTable.key#1)
        |   +-aggregate_list=
        |     +-$group_rows_subquery#13 :=
        |       +-SubqueryExpr
        |         +-type=INT64
        |         +-subquery_type=SCALAR
        |         +-subquery=
        |           +-ProjectScan
        |             +-column_list=[$aggregate.$agg1#12]
        |             +-input_scan=
        |               +-AggregateScan
        |                 +-column_list=[$aggregate.$agg1#12]
        |                 +-input_scan=
        |                 | +-FilterScan
        |                 |   +-column_list=[EnumTable.Filename#10]
        |                 |   +-input_scan=
        |                 |   | +-GroupRowsScan
        |                 |   |   +-column_list=[EnumTable.Filename#10]
        |                 |   |   +-input_column_list=
        |                 |   |     +-key#7 := ColumnRef(type=INT32, column=EnumTable.key#1)
        |                 |   |     +-TestEnum#8 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
        |                 |   |     +-AnotherTestEnum#9 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
        |                 |   |     +-Filename#10 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
        |                 |   |     +-RowId#11 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
        |                 |   +-filter_expr=
        |                 |     +-FunctionCall(GoogleSQL:$like(STRING, STRING) -> BOOL)
        |                 |       +-ColumnRef(type=STRING, column=EnumTable.Filename#10)
        |                 |       +-Literal(type=STRING, value="%.txt")
        |                 +-aggregate_list=
        |                   +-$agg1#12 := AggregateFunctionCall(GoogleSQL:$count_star() -> INT64)
        +-filter_expr=
          +-FunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
            +-ColumnRef(type=INT64, column=$expr_subquery.$group_rows_subquery#13)
            +-Literal(type=INT64, value=1)
==

# Group rows within qualify clause.
SELECT
  key,
  COUNT(*) as row_count,
  RANK() OVER(ORDER BY COUNT(*) DESC) as popularity_rank
FROM EnumTable
GROUP BY key
QUALIFY (
  WITH group_rows() AS GROUP ROWS
  SELECT AVG(LENGTH(Filename))
  FROM group_rows()
) > 10;
--
QueryStmt
+-output_column_list=
| +-$groupby.key#9 AS key [INT32]
| +-$aggregate.row_count#6 AS row_count [INT64]
| +-$analytic.popularity_rank#10 AS popularity_rank [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$groupby.key#9, $aggregate.row_count#6, $analytic.popularity_rank#10]
    +-input_scan=
      +-FilterScan
        +-column_list=[$groupby.key#9, $aggregate.row_count#6, $aggregate.$agg2#7, $expr_subquery.$group_rows_subquery#17, $analytic.popularity_rank#10]
        +-input_scan=
        | +-AnalyticScan
        |   +-column_list=[$groupby.key#9, $aggregate.row_count#6, $aggregate.$agg2#7, $expr_subquery.$group_rows_subquery#17, $analytic.popularity_rank#10]
        |   +-input_scan=
        |   | +-AggregateScan
        |   |   +-column_list=[$groupby.key#9, $aggregate.row_count#6, $aggregate.$agg2#7, $expr_subquery.$group_rows_subquery#17]
        |   |   +-input_scan=
        |   |   | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
        |   |   +-group_by_list=
        |   |   | +-key#9 := ColumnRef(type=INT32, column=EnumTable.key#1)
        |   |   +-aggregate_list=
        |   |     +-row_count#6 := AggregateFunctionCall(GoogleSQL:$count_star() -> INT64)
        |   |     +-$agg2#7 := AggregateFunctionCall(GoogleSQL:$count_star() -> INT64)
        |   |     +-$group_rows_subquery#17 :=
        |   |       +-SubqueryExpr
        |   |         +-type=DOUBLE
        |   |         +-subquery_type=SCALAR
        |   |         +-subquery=
        |   |           +-ProjectScan
        |   |             +-column_list=[$aggregate.$agg1#16]
        |   |             +-input_scan=
        |   |               +-AggregateScan
        |   |                 +-column_list=[$aggregate.$agg1#16]
        |   |                 +-input_scan=
        |   |                 | +-GroupRowsScan
        |   |                 |   +-column_list=[EnumTable.Filename#14]
        |   |                 |   +-input_column_list=
        |   |                 |     +-key#11 := ColumnRef(type=INT32, column=EnumTable.key#1)
        |   |                 |     +-TestEnum#12 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
        |   |                 |     +-AnotherTestEnum#13 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
        |   |                 |     +-Filename#14 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
        |   |                 |     +-RowId#15 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
        |   |                 +-aggregate_list=
        |   |                   +-$agg1#16 :=
        |   |                     +-AggregateFunctionCall(GoogleSQL:avg(INT64) -> DOUBLE)
        |   |                       +-FunctionCall(GoogleSQL:length(STRING) -> INT64)
        |   |                         +-ColumnRef(type=STRING, column=EnumTable.Filename#14)
        |   +-function_group_list=
        |     +-AnalyticFunctionGroup
        |       +-order_by=
        |       | +-WindowOrdering
        |       |   +-order_by_item_list=
        |       |     +-OrderByItem
        |       |       +-column_ref=
        |       |       | +-ColumnRef(type=INT64, column=$aggregate.$agg2#7)
        |       |       +-is_descending=TRUE
        |       +-analytic_function_list=
        |         +-popularity_rank#10 := AnalyticFunctionCall(GoogleSQL:rank() -> INT64)
        +-filter_expr=
          +-FunctionCall(GoogleSQL:$greater(DOUBLE, DOUBLE) -> BOOL)
            +-ColumnRef(type=DOUBLE, column=$expr_subquery.$group_rows_subquery#17)
            +-Literal(type=DOUBLE, value=10)
==

# Group rows cannot reference analytic output directly.
SELECT
  ANY_VALUE(TestEnum) as val,
  ROW_NUMBER() OVER(ORDER BY key) as rn
FROM TestTable
GROUP BY key
QUALIFY (
  WITH group_rows() AS GROUP ROWS
  SELECT rn
  FROM group_rows()
) IS NOT NULL
--
ERROR: Analytic functions cannot be arguments to aggregate functions [at 8:10]
  SELECT rn
         ^
==

# Group rows cannot reference aggregate output (aggregations of aggregations).
SELECT
  ANY_VALUE(TestEnum) as val,
FROM TestTable
GROUP BY key
HAVING (
  WITH group_rows() AS GROUP ROWS
  SELECT val
  FROM group_rows()
) IS NOT NULL
--
ERROR: Aggregations of aggregations are not allowed [at 7:10]
  SELECT val
         ^
==

# Group rows cannot reference post-grouping column that is not a group-by column.
SELECT
  key as a,
  a + 1 as b
FROM TestTable
GROUP BY key
HAVING (
  WITH group_rows() AS GROUP ROWS
  SELECT b
  FROM group_rows()
) IS NOT NULL
--
ERROR: Post-grouping column cannot be used in arguments to aggregations [at 8:10]
  SELECT b
         ^
==

# Aggregate subqueries are not allowed to have OVER clauses after.
SELECT
  key,
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT SUM(key)
    FROM group_rows()
  ) OVER(ORDER BY key) AS group_rows_value
FROM TestTable
GROUP BY key
--
ERROR: Syntax error: OVER keyword must follow a function call [at 7:5]
  ) OVER(ORDER BY key) AS group_rows_value
    ^
==

# Sugar syntax on top level fails.
SELECT *
FROM GROUP ROWS
--
ERROR: GROUP ROWS is not supported in this (sub)query. [at 2:6]
FROM GROUP ROWS
     ^
==

# Sugar syntax basic usage.
