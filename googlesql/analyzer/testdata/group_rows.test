                        +-key#18 := ColumnRef(type=INT32, column=EnumTable.key#4)
                        +-TestEnum#19 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#5)
                        +-AnotherTestEnum#20 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#6)
                        +-Filename#21 := ColumnRef(type=STRING, column=TestExtraValueTable.Filename#2)
