ERROR: PIVOT expression must be an aggregate function call [at 6:5]
    ARRAY(
    ^
==

# Group rows not supported in MATCH_RECOGNIZE.
SELECT * FROM TestTable
MATCH_RECOGNIZE(
  ORDER BY key
  MEASURES
    ARRAY(
      WITH group_rows() AS GROUP ROWS
      SELECT AS STRUCT *
      FROM group_rows()) AS matched_rows_array
  PATTERN (A+)
  DEFINE A AS KitchenSink.int64_key_1 > 0
);
--
ERROR: GROUP ROWS is not supported in this (sub)query. [at 6:7]
      WITH group_rows() AS GROUP ROWS
      ^
==

[default enabled_ast_rewrites=NONE]
# Use group rows TVF inside graph horizontal aggregation.
# TODO: Turn on rewriter when supporting graph in group rows.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT AS STRUCT (z)
  FROM (
    SELECT *
    FROM GRAPH_TABLE(aml
      let x = [4]
      let y = SUM(x) + (SELECT SUM(key) FROM group_rows())
      let z = ARRAY_AGG(x + y)
      return z
    )
  )
)
FROM TestTable
