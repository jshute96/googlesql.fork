        +-aggregate_list=
          +-$group_rows_subquery#25 :=
            +-SubqueryExpr
              +-type=ARRAY<INT32>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[EnumTable.key#18]
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[EnumTable.key#18]
                      +-input_column_list=
