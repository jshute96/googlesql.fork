# Add group rows subquery to another group rows subquery, ensuring each sits on
# it's own agg column on the Agg Scan.
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT SUM(key)
  FROM group_rows()
) + (
  WITH group_rows() AS GROUP ROWS
  SELECT MAX(key)
  FROM group_rows()
)
FROM TestTable
--
QueryStmt
+-output_column_list=
| +-$query.$col1#22 AS `$col1` [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#22]
    +-expr_list=
    | +-$col1#22 :=
    |   +-FunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
    |     +-ColumnRef(type=INT64, column=$expr_subquery.$group_rows_subquery#16)
    |     +-Cast(INT32 -> INT64)
    |       +-ColumnRef(type=INT32, column=$expr_subquery.$group_rows_subquery#21)
    +-input_scan=
      +-AggregateScan
        +-column_list=$expr_subquery.[$group_rows_subquery#16, $group_rows_subquery#21]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#16 :=
          | +-SubqueryExpr
          |   +-type=INT64
          |   +-subquery_type=SCALAR
          |   +-subquery=
          |     +-ProjectScan
          |       +-column_list=[$aggregate.$agg1#15]
          |       +-input_scan=
          |         +-AggregateScan
          |           +-column_list=[$aggregate.$agg1#15]
          |           +-input_scan=
          |           | +-GroupRowsScan
          |           |   +-column_list=[TestTable.key#12]
          |           |   +-input_column_list=
          |           |     +-key#12 := ColumnRef(type=INT32, column=TestTable.key#1)
          |           |     +-TestEnum#13 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
          |           |     +-KitchenSink#14 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
          |           +-aggregate_list=
          |             +-$agg1#15 :=
          |               +-AggregateFunctionCall(GoogleSQL:sum(INT64) -> INT64)
          |                 +-Cast(INT32 -> INT64)
          |                   +-ColumnRef(type=INT32, column=TestTable.key#12)
          +-$group_rows_subquery#21 :=
            +-SubqueryExpr
              +-type=INT32
              +-subquery_type=SCALAR
              +-subquery=
                +-ProjectScan
                  +-column_list=[$aggregate.$agg1#20]
                  +-input_scan=
                    +-AggregateScan
                      +-column_list=[$aggregate.$agg1#20]
                      +-input_scan=
                      | +-GroupRowsScan
                      |   +-column_list=[TestTable.key#17]
                      |   +-input_column_list=
                      |     +-key#17 := ColumnRef(type=INT32, column=TestTable.key#1)
                      |     +-TestEnum#18 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                      |     +-KitchenSink#19 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
                      +-aggregate_list=
                        +-$agg1#20 :=
                          +-AggregateFunctionCall(GoogleSQL:max(INT32) -> INT32)
                            +-ColumnRef(type=INT32, column=TestTable.key#17)
