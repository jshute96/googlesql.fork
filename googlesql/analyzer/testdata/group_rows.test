# Dot star expansion on group rows subquery is allowed.
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT AS STRUCT SUM(key) AS sum_key
  FROM group_rows()
).*
FROM TestTable
--
QueryStmt
+-output_column_list=
| +-$query.sum_key#16 AS sum_key [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$query.sum_key#16]
    +-expr_list=
    | +-sum_key#16 :=
    |   +-GetStructField
    |     +-type=INT64
    |     +-expr=
    |     | +-ColumnRef(type=STRUCT<sum_key INT64>, column=$expr_subquery.$group_rows_subquery#15)
    |     +-field_idx=0
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#15]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#15 :=
            +-SubqueryExpr
              +-type=STRUCT<sum_key INT64>
              +-subquery_type=SCALAR
              +-subquery=
                +-ProjectScan
                  +-column_list=[$make_struct.$struct#14]
                  +-expr_list=
                  | +-$struct#14 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<sum_key INT64>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT64, column=$aggregate.sum_key#13)
                  +-input_scan=
                    +-ProjectScan
                      +-column_list=[$aggregate.sum_key#13]
                      +-input_scan=
                        +-AggregateScan
                          +-column_list=[$aggregate.sum_key#13]
                          +-input_scan=
                          | +-GroupRowsScan
                          |   +-column_list=[TestTable.key#10]
                          |   +-input_column_list=
                          |     +-key#10 := ColumnRef(type=INT32, column=TestTable.key#1)
                          |     +-TestEnum#11 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                          |     +-KitchenSink#12 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
                          +-aggregate_list=
                            +-sum_key#13 :=
                              +-AggregateFunctionCall(GoogleSQL:sum(INT64) -> INT64)
                                +-Cast(INT32 -> INT64)
                                  +-ColumnRef(type=INT32, column=TestTable.key#10)
