# Nested group rows with the same name (name shadowing).
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT AS STRUCT
    key,
    ARRAY(
      WITH group_rows() AS GROUP ROWS
      SELECT int_a
      FROM group_rows()
    )
  FROM MultipleColumns
  GROUP BY int_a
)
FROM TestTable
GROUP BY key
