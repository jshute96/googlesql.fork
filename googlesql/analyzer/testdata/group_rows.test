# Create group rows TVF inside graph horizontal aggregation.
# TODO: b/430036320 - This should fail with error message because the spec
# disallows group rows subqueries inside horizontal aggregation.
# TODO: b/430036320 - Support creating group rows inside vertical aggregation
# inside graph return clause.
# FROM GRAPH_TABLE(aml
#   let x = 4
#   let y = (
#     WITH group_rows() AS GROUP ROWS
#     SELECT SUM(x)
#     FROM group_rows()
#   )
#   return y
# )

# Perform multi-level aggregation using group rows.
SELECT (
  WITH g() AS GROUP ROWS
  SELECT AVG(int_a_sum)
  FROM (
    SELECT SUM(int_a) AS int_a_sum
    FROM g()
    GROUP BY int_b
  )
)
FROM MultipleColumns
GROUP BY int_c
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#26 AS `$col1` [DOUBLE]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#26]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#26]
        +-input_scan=
        | +-TableScan(column_list=MultipleColumns.[int_a#1, string_a#2, int_b#3, string_b#4, int_c#5, int_d#6], table=MultipleColumns, column_index_list=[0, 1, 2, 3, 4, 5])
        +-group_by_list=
        | +-int_c#16 := ColumnRef(type=INT64, column=MultipleColumns.int_c#5)
        +-aggregate_list=
          +-$group_rows_subquery#26 :=
            +-SubqueryExpr
              +-type=DOUBLE
              +-subquery_type=SCALAR
              +-subquery=
                +-ProjectScan
                  +-column_list=[$aggregate.$agg1#25]
                  +-input_scan=
                    +-AggregateScan
                      +-column_list=[$aggregate.$agg1#25]
                      +-input_scan=
                      | +-ProjectScan
                      |   +-column_list=[$aggregate.int_a_sum#23]
                      |   +-input_scan=
                      |     +-AggregateScan
                      |       +-column_list=[$aggregate.int_a_sum#23]
                      |       +-input_scan=
                      |       | +-GroupRowsScan
                      |       |   +-column_list=MultipleColumns.[int_a#17, int_b#19]
                      |       |   +-input_column_list=
                      |       |     +-int_a#17 := ColumnRef(type=INT64, column=MultipleColumns.int_a#1)
                      |       |     +-string_a#18 := ColumnRef(type=STRING, column=MultipleColumns.string_a#2)
                      |       |     +-int_b#19 := ColumnRef(type=INT64, column=MultipleColumns.int_b#3)
                      |       |     +-string_b#20 := ColumnRef(type=STRING, column=MultipleColumns.string_b#4)
                      |       |     +-int_c#21 := ColumnRef(type=INT64, column=MultipleColumns.int_c#5)
                      |       |     +-int_d#22 := ColumnRef(type=INT64, column=MultipleColumns.int_d#6)
                      |       +-group_by_list=
                      |       | +-int_b#24 := ColumnRef(type=INT64, column=MultipleColumns.int_b#19)
                      |       +-aggregate_list=
                      |         +-int_a_sum#23 :=
                      |           +-AggregateFunctionCall(GoogleSQL:sum(INT64) -> INT64)
                      |             +-ColumnRef(type=INT64, column=MultipleColumns.int_a#17)
                      +-aggregate_list=
                        +-$agg1#25 :=
                          +-AggregateFunctionCall(GoogleSQL:avg(INT64) -> DOUBLE)
                            +-ColumnRef(type=INT64, column=$aggregate.int_a_sum#23)
==

# Use multi-level aggregation inside group rows subquery.
SELECT (
  WITH g() AS GROUP ROWS
  SELECT AVG(SUM(int_a) GROUP BY int_b)
  FROM g()
)
FROM MultipleColumns
GROUP BY int_c
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#26 AS `$col1` [DOUBLE]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#26]
