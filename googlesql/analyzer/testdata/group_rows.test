[default language_features=MAXIMUM]
[default no_java]
# TODO: b/430036320 - Enable java tests.

# Group rows not supported.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows()
)
FROM TestTable
--
ERROR: GROUP ROWS is not supported. [at 5:24]
  WITH group_rows() AS GROUP ROWS
                       ^
==

# Sugar syntax without group rows feature.
SELECT ARRAY(
  SELECT key
  FROM GROUP ROWS
)
FROM TestTable
--
ERROR: GROUP ROWS is not supported [at 3:8]
  FROM GROUP ROWS
       ^
==

[default language_features=MAXIMUM,+WITH_GROUP_ROWS,+LATERAL_COLUMN_REFERENCES,+GENERAL_QUANTIFIED_COMPARISONS,+LIKE_ANY_SOME_ALL_SUBQUERY,+COLLATION_SUPPORT,+TIMESTAMP_PRECISION_ANNOTATION]
[default enabled_ast_rewrites=ALL]
[default no_run_sqlbuilder]
# TODO: b/430036320 - Enable SQL builder once it supports GROUP ROWS.
# TODO: b/430036320 - Attach group rows subquery to AggregateScan.

# Group rows in outer query fails.
WITH group_rows() AS GROUP ROWS
SELECT key
FROM group_rows()
--
ERROR: GROUP ROWS are not allowed in the outer-most query [at 5:6]
WITH group_rows() AS GROUP ROWS
     ^
==

# Multiple group rows entries fail.
SELECT ARRAY(
  WITH
    group_rows1() AS GROUP ROWS,
    group_rows2() AS GROUP ROWS
  SELECT key
  FROM group_rows1()
)
FROM TestTable
--
ERROR: Cannot have more than one GROUP ROWS alias in a with clause [at 4:5]
    group_rows2() AS GROUP ROWS
    ^
==

# Group rows entry not being first fails.
SELECT ARRAY(
  WITH
    t AS (SELECT 1, 2),
    group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows()
)
FROM TestTable
--
ERROR: GROUP ROWS must be the first entry in a WITH clause [at 4:5]
    group_rows() AS GROUP ROWS
    ^
==

# Referencing group rows alias as a table fails.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows
)
FROM TestTable
--
ERROR: Table not found: group_rows [at 4:8]
  FROM group_rows
       ^
==

# Call group rows TVF with arguments fail.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows(1)
)
FROM TestTable
--
ERROR: Cannot call group rows TVF with arguments. [at 4:8]
  FROM group_rows(1)
       ^
==

# Group rows has same schema as <from>.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (key, Filename)
  FROM group_rows()
)
FROM EnumTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#18 AS `$col1` [ARRAY<STRUCT<INT32, STRING>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#18]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#18]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
        +-aggregate_list=
          +-$group_rows_subquery#18 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<INT32, STRING>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#17]
                  +-expr_list=
                  | +-$col1#17 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<INT32, STRING>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#12)
                  |       +-ColumnRef(type=STRING, column=EnumTable.Filename#15)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=EnumTable.[key#12, Filename#15]
                      +-input_column_list=
                        +-key#12 := ColumnRef(type=INT32, column=EnumTable.key#1)
                        +-TestEnum#13 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                        +-AnotherTestEnum#14 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                        +-Filename#15 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                        +-RowId#16 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

# Aliased group rows has same schema as <from>.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (gr, gr.Filename, RowId)
  FROM group_rows() gr
)
FROM EnumTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#20 AS `$col1` [ARRAY<STRUCT<STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>, STRING, BYTES>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#20]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#20]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
        +-aggregate_list=
          +-$group_rows_subquery#20 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>, STRING, BYTES>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#19]
                  +-expr_list=
                  | +-$col1#19 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>, STRING, BYTES>
                  |     +-field_list=
                  |       +-MakeStruct
                  |       | +-type=STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>
                  |       | +-field_list=
                  |       |   +-ColumnRef(type=INT32, column=EnumTable.key#13)
                  |       |   +-ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#14)
                  |       |   +-ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#15)
                  |       +-ColumnRef(type=STRING, column=EnumTable.Filename#16)
                  |       +-ColumnRef(type=BYTES, column=EnumTable.RowId#17)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=EnumTable.[key#13, TestEnum#14, AnotherTestEnum#15, Filename#16, RowId#17]
                      +-input_column_list=
                        +-key#13 := ColumnRef(type=INT32, column=EnumTable.key#1)
                        +-TestEnum#14 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                        +-AnotherTestEnum#15 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                        +-Filename#16 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                        +-RowId#17 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

# Aliased group rows with dot-star has same schema as <from>.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT AS STRUCT gr.*
  FROM group_rows() gr
)
FROM EnumTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#18 AS `$col1` [ARRAY<STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#18]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#18]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4])
        +-aggregate_list=
          +-$group_rows_subquery#18 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$make_struct.$struct#17]
                  +-expr_list=
                  | +-$struct#17 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<key INT32, TestEnum ENUM<googlesql_test.TestEnum>, AnotherTestEnum ENUM<googlesql_test.AnotherTestEnum>>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#12)
                  |       +-ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#13)
                  |       +-ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#14)
                  +-input_scan=
                    +-ProjectScan
                      +-column_list=EnumTable.[key#12, TestEnum#13, AnotherTestEnum#14]
                      +-input_scan=
                        +-GroupRowsScan
                          +-column_list=EnumTable.[key#12, TestEnum#13, AnotherTestEnum#14]
                          +-input_column_list=
                            +-key#12 := ColumnRef(type=INT32, column=EnumTable.key#1)
                            +-TestEnum#13 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                            +-AnotherTestEnum#14 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                            +-Filename#15 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                            +-RowId#16 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

# Group rows propagates <from> alias. (uncorrelated)
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT t.key
  FROM group_rows()
)
FROM EnumTable t
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#16 AS `$col1` [ARRAY<INT32>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#16]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#16]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t")
        +-aggregate_list=
          +-$group_rows_subquery#16 :=
            +-SubqueryExpr
              +-type=ARRAY<INT32>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[EnumTable.key#11]
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[EnumTable.key#11]
                      +-input_column_list=
                        +-key#11 := ColumnRef(type=INT32, column=EnumTable.key#1)
                        +-TestEnum#12 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                        +-AnotherTestEnum#13 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                        +-Filename#14 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                        +-RowId#15 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

