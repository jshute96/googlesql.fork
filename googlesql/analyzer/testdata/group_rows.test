                  +-input_scan=
                    +-FilterScan
                      +-column_list=EnumTable.[key#9, TestEnum#10]
                      +-input_scan=
                      | +-GroupRowsScan
                      |   +-column_list=EnumTable.[key#9, TestEnum#10]
                      |   +-input_column_list=
                      |     +-key#9 := ColumnRef(type=INT32, column=EnumTable.key#1)
                      |     +-TestEnum#10 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                      +-filter_expr=
                        +-FunctionCall(GoogleSQL:$equal(INT32, INT32) -> BOOL)
                          +-ColumnRef(type=INT32, column=EnumTable.key#9)
                          +-Literal(type=INT32, value=55)
