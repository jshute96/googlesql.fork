# Group rows has same schema as <from> join clause.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows()
)
FROM TestExtraValueTable, EnumTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#25 AS `$col1` [ARRAY<INT32>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#25]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#25]
        +-input_scan=
        | +-JoinScan
        |   +-column_list=[TestExtraValueTable.value#1, TestExtraValueTable.Filename#2, TestExtraValueTable.RowId#3, EnumTable.key#4, EnumTable.TestEnum#5, EnumTable.AnotherTestEnum#6, EnumTable.Filename#7, EnumTable.RowId#8]
        |   +-left_scan=
