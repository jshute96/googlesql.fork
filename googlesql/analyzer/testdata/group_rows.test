| +-$expr_subquery.$group_rows_subquery#12 AS `$col1` [ARRAY<STRUCT<INT32, ENUM<googlesql_test.TestEnum>>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#12]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#12]
        +-input_scan=
        | +-ProjectScan
        |   +-column_list=EnumTable.[key#1, key#1, TestEnum#2]
        |   +-input_scan=
        |     +-TableScan(column_list=EnumTable.[key#1, TestEnum#2], table=EnumTable, column_index_list=[0, 1])
        +-aggregate_list=
          +-$group_rows_subquery#12 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<INT32, ENUM<googlesql_test.TestEnum>>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#11]
                  +-expr_list=
                  | +-$col1#11 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<INT32, ENUM<googlesql_test.TestEnum>>
                  |     +-field_list=
