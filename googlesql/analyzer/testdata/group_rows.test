# Group rows propagates <from> join clause table aliases. (uncorrelated)
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (t1, t1.Filename, t2.key, t2.RowId)
  FROM group_rows()
)
FROM TestExtraValueTable t1, EnumTable t2
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#27 AS `$col1` [ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#27]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#27]
        +-input_scan=
        | +-JoinScan
        |   +-column_list=[TestExtraValueTable.value#1, TestExtraValueTable.Filename#2, TestExtraValueTable.RowId#3, EnumTable.key#4, EnumTable.TestEnum#5, EnumTable.AnotherTestEnum#6, EnumTable.Filename#7, EnumTable.RowId#8]
        |   +-left_scan=
        |   | +-TableScan(column_list=TestExtraValueTable.[value#1, Filename#2, RowId#3], table=TestExtraValueTable, column_index_list=[0, 1, 2], alias="t1")
        |   +-right_scan=
        |     +-TableScan(column_list=EnumTable.[key#4, TestEnum#5, AnotherTestEnum#6, Filename#7, RowId#8], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t2")
        +-aggregate_list=
          +-$group_rows_subquery#27 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#26]
                  +-expr_list=
                  | +-$col1#26 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>
                  |     +-field_list=
                  |       +-ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#18)
                  |       +-ColumnRef(type=STRING, column=TestExtraValueTable.Filename#22)
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#19)
                  |       +-ColumnRef(type=BYTES, column=EnumTable.RowId#25)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[TestExtraValueTable.value#18, EnumTable.key#19, TestExtraValueTable.Filename#22, EnumTable.RowId#25]
                      +-input_column_list=
                        +-value#18 := ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#1)
                        +-key#19 := ColumnRef(type=INT32, column=EnumTable.key#4)
                        +-TestEnum#20 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#5)
                        +-AnotherTestEnum#21 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#6)
                        +-Filename#22 := ColumnRef(type=STRING, column=TestExtraValueTable.Filename#2)
                        +-RowId#23 := ColumnRef(type=BYTES, column=TestExtraValueTable.RowId#3)
                        +-Filename#24 := ColumnRef(type=STRING, column=EnumTable.Filename#7)
                        +-RowId#25 := ColumnRef(type=BYTES, column=EnumTable.RowId#8)
==

# Aliased group rows erases <from> value table alias. Referencing <from> alias
# results in a correlated column.
# NOTE: As per the spec, value tables in join clauses continue to be accessible
#       from the group rows namelist by their original alias, which is why they
#       appear as uncorrelated.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (
    gr.key,  # uncorrelated
    t1,      # uncorrelated
    t2.key   # correlated
  )
  FROM group_rows() gr
)
FROM TestExtraValueTable t1, EnumTable t2
GROUP BY t2.key
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#28 AS `$col1` [ARRAY<STRUCT<INT32, PROTO<googlesql_test.TestExtraPB>, INT32>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#28]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$groupby.key#18, $expr_subquery.$group_rows_subquery#28]
        +-input_scan=
        | +-JoinScan
        |   +-column_list=[TestExtraValueTable.value#1, TestExtraValueTable.Filename#2, TestExtraValueTable.RowId#3, EnumTable.key#4, EnumTable.TestEnum#5, EnumTable.AnotherTestEnum#6, EnumTable.Filename#7, EnumTable.RowId#8]
        |   +-left_scan=
        |   | +-TableScan(column_list=TestExtraValueTable.[value#1, Filename#2, RowId#3], table=TestExtraValueTable, column_index_list=[0, 1, 2], alias="t1")
        |   +-right_scan=
        |     +-TableScan(column_list=EnumTable.[key#4, TestEnum#5, AnotherTestEnum#6, Filename#7, RowId#8], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t2")
        +-group_by_list=
        | +-key#18 := ColumnRef(type=INT32, column=EnumTable.key#4)
        +-aggregate_list=
          +-$group_rows_subquery#28 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<INT32, PROTO<googlesql_test.TestExtraPB>, INT32>>
              +-subquery_type=ARRAY
              +-parameter_list=
              | +-ColumnRef(type=INT32, column=$groupby.key#18)
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#27]
                  +-expr_list=
                  | +-$col1#27 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<INT32, PROTO<googlesql_test.TestExtraPB>, INT32>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#20)
                  |       +-ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#19)
                  |       +-ColumnRef(type=INT32, column=$groupby.key#18, is_correlated=TRUE)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[TestExtraValueTable.value#19, EnumTable.key#20]
                      +-input_column_list=
                        +-value#19 := ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#1)
                        +-key#20 := ColumnRef(type=INT32, column=EnumTable.key#4)
                        +-TestEnum#21 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#5)
                        +-AnotherTestEnum#22 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#6)
                        +-Filename#23 := ColumnRef(type=STRING, column=TestExtraValueTable.Filename#2)
                        +-RowId#24 := ColumnRef(type=BYTES, column=TestExtraValueTable.RowId#3)
                        +-Filename#25 := ColumnRef(type=STRING, column=EnumTable.Filename#7)
                        +-RowId#26 := ColumnRef(type=BYTES, column=EnumTable.RowId#8)
==

# Group rows with parenthesized join.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (t1, t1.Filename, t2.key, t2.RowId)
  FROM group_rows()
)
FROM (TestExtraValueTable t1 CROSS JOIN EnumTable t2)
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#27 AS `$col1` [ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#27]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#27]
        +-input_scan=
        | +-JoinScan
        |   +-column_list=[TestExtraValueTable.value#1, TestExtraValueTable.Filename#2, TestExtraValueTable.RowId#3, EnumTable.key#4, EnumTable.TestEnum#5, EnumTable.AnotherTestEnum#6, EnumTable.Filename#7, EnumTable.RowId#8]
        |   +-left_scan=
        |   | +-TableScan(column_list=TestExtraValueTable.[value#1, Filename#2, RowId#3], table=TestExtraValueTable, column_index_list=[0, 1, 2], alias="t1")
        |   +-right_scan=
        |     +-TableScan(column_list=EnumTable.[key#4, TestEnum#5, AnotherTestEnum#6, Filename#7, RowId#8], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t2")
        +-aggregate_list=
          +-$group_rows_subquery#27 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#26]
                  +-expr_list=
                  | +-$col1#26 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, INT32, BYTES>
                  |     +-field_list=
                  |       +-ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#18)
                  |       +-ColumnRef(type=STRING, column=TestExtraValueTable.Filename#22)
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#19)
                  |       +-ColumnRef(type=BYTES, column=EnumTable.RowId#25)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[TestExtraValueTable.value#18, EnumTable.key#19, TestExtraValueTable.Filename#22, EnumTable.RowId#25]
                      +-input_column_list=
                        +-value#18 := ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#1)
                        +-key#19 := ColumnRef(type=INT32, column=EnumTable.key#4)
                        +-TestEnum#20 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#5)
                        +-AnotherTestEnum#21 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#6)
                        +-Filename#22 := ColumnRef(type=STRING, column=TestExtraValueTable.Filename#2)
                        +-RowId#23 := ColumnRef(type=BYTES, column=TestExtraValueTable.RowId#3)
                        +-Filename#24 := ColumnRef(type=STRING, column=EnumTable.Filename#7)
                        +-RowId#25 := ColumnRef(type=BYTES, column=EnumTable.RowId#8)
==

# Group rows in scalar subquery.
SELECT (
  WITH group_rows() AS GROUP ROWS
  SELECT SUM(key)
  FROM group_rows()
)
FROM TestTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#12 AS `$col1` [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#12]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#12]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#12 :=
            +-SubqueryExpr
              +-type=INT64
              +-subquery_type=SCALAR
              +-subquery=
                +-ProjectScan
                  +-column_list=[$aggregate.$agg1#11]
                  +-input_scan=
                    +-AggregateScan
                      +-column_list=[$aggregate.$agg1#11]
                      +-input_scan=
                      | +-GroupRowsScan
                      |   +-column_list=[TestTable.key#8]
                      |   +-input_column_list=
                      |     +-key#8 := ColumnRef(type=INT32, column=TestTable.key#1)
                      |     +-TestEnum#9 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                      |     +-KitchenSink#10 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
                      +-aggregate_list=
                        +-$agg1#11 :=
                          +-AggregateFunctionCall(GoogleSQL:sum(INT64) -> INT64)
                            +-Cast(INT32 -> INT64)
                              +-ColumnRef(type=INT32, column=TestTable.key#8)
==

# Group rows in EXISTS(...) subquery.
SELECT EXISTS(
  WITH group_rows() AS GROUP ROWS
  SELECT key
  FROM group_rows()
  WHERE key = 1
)
FROM TestTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#10 AS `$col1` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#10]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#10]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#10 :=
            +-SubqueryExpr
              +-type=BOOL
              +-subquery_type=EXISTS
              +-subquery=
                +-ProjectScan
                  +-column_list=[TestTable.key#7]
                  +-input_scan=
                    +-FilterScan
                      +-column_list=[TestTable.key#7]
                      +-input_scan=
                      | +-GroupRowsScan
                      |   +-column_list=[TestTable.key#7]
                      |   +-input_column_list=
                      |     +-key#7 := ColumnRef(type=INT32, column=TestTable.key#1)
                      |     +-TestEnum#8 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                      |     +-KitchenSink#9 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
                      +-filter_expr=
                        +-FunctionCall(GoogleSQL:$equal(INT32, INT32) -> BOOL)
                          +-ColumnRef(type=INT32, column=TestTable.key#7)
                          +-Literal(type=INT32, value=1)
==

# Multiple group rows subqueries.
SELECT
  ARRAY(
    WITH group_rows1() AS GROUP ROWS
    SELECT key
    FROM group_rows1()
  ),
  (
    WITH group_rows2() AS GROUP ROWS
    SELECT SUM(key)
    FROM group_rows2()
  ),
  (
    WITH group_rows2() AS GROUP ROWS
    SELECT key
    FROM group_rows2()
  )
FROM TestTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#17 AS `$col1` [ARRAY<INT32>]
| +-$expr_subquery.$group_rows_subquery#22 AS `$col2` [INT64]
| +-$expr_subquery.$group_rows_subquery#26 AS `$col3` [INT32]
+-query=
  +-ProjectScan
    +-column_list=$expr_subquery.[$group_rows_subquery#17, $group_rows_subquery#22, $group_rows_subquery#26]
    +-input_scan=
      +-AggregateScan
        +-column_list=$expr_subquery.[$group_rows_subquery#17, $group_rows_subquery#22, $group_rows_subquery#26]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#17 :=
          | +-SubqueryExpr
          |   +-type=ARRAY<INT32>
          |   +-subquery_type=ARRAY
          |   +-subquery=
          |     +-ProjectScan
          |       +-column_list=[TestTable.key#14]
          |       +-input_scan=
          |         +-GroupRowsScan
          |           +-column_list=[TestTable.key#14]
          |           +-input_column_list=
          |             +-key#14 := ColumnRef(type=INT32, column=TestTable.key#1)
          |             +-TestEnum#15 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
          |             +-KitchenSink#16 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
          +-$group_rows_subquery#22 :=
          | +-SubqueryExpr
          |   +-type=INT64
          |   +-subquery_type=SCALAR
          |   +-subquery=
          |     +-ProjectScan
          |       +-column_list=[$aggregate.$agg1#21]
          |       +-input_scan=
          |         +-AggregateScan
          |           +-column_list=[$aggregate.$agg1#21]
          |           +-input_scan=
          |           | +-GroupRowsScan
          |           |   +-column_list=[TestTable.key#18]
          |           |   +-input_column_list=
          |           |     +-key#18 := ColumnRef(type=INT32, column=TestTable.key#1)
