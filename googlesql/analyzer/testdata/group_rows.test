                                        | |         +-ProjectScan
                                        | |           +-column_list=[$aggregate.$agg1#20]
                                        | |           +-input_scan=
                                        | |             +-AggregateScan
                                        | |               +-column_list=[$aggregate.$agg1#20]
                                        | |               +-input_scan=
                                        | |               | +-GroupRowsScan
                                        | |               |   +-column_list=[TestTable.key#17]
