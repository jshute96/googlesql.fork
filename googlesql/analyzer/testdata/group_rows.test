# Aliased group rows erases <from> aliases. Referencing <from> alias results in
# a correlated column.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (gr.key, t.key)
  FROM group_rows() gr
)
FROM EnumTable t
GROUP BY key
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#19 AS `$col1` [ARRAY<STRUCT<INT32, INT32>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#19]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$groupby.key#12, $expr_subquery.$group_rows_subquery#19]
        +-input_scan=
        | +-TableScan(column_list=EnumTable.[key#1, TestEnum#2, AnotherTestEnum#3, Filename#4, RowId#5], table=EnumTable, column_index_list=[0, 1, 2, 3, 4], alias="t")
        +-group_by_list=
        | +-key#12 := ColumnRef(type=INT32, column=EnumTable.key#1)
        +-aggregate_list=
          +-$group_rows_subquery#19 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<INT32, INT32>>
              +-subquery_type=ARRAY
              +-parameter_list=
              | +-ColumnRef(type=INT32, column=$groupby.key#12)
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#18]
                  +-expr_list=
                  | +-$col1#18 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<INT32, INT32>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT32, column=EnumTable.key#13)
                  |       +-ColumnRef(type=INT32, column=$groupby.key#12, is_correlated=TRUE)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[EnumTable.key#13]
                      +-input_column_list=
                        +-key#13 := ColumnRef(type=INT32, column=EnumTable.key#1)
                        +-TestEnum#14 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=EnumTable.TestEnum#2)
                        +-AnotherTestEnum#15 := ColumnRef(type=ENUM<googlesql_test.AnotherTestEnum>, column=EnumTable.AnotherTestEnum#3)
                        +-Filename#16 := ColumnRef(type=STRING, column=EnumTable.Filename#4)
                        +-RowId#17 := ColumnRef(type=BYTES, column=EnumTable.RowId#5)
==

# Referencing <from> column that isn't grouped results in error.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (gr.key, t.key)
  FROM group_rows() gr
)
FROM EnumTable t
--
ERROR: SELECT expression references t.key which is neither grouped nor aggregated [at 3:19]
  SELECT (gr.key, t.key)
                  ^
==

# Group rows has same schema as <from> value table.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT *
  FROM group_rows()
)
FROM Int64ValueTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#4 AS `$col1` [ARRAY<INT64>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#4]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#4]
        +-input_scan=
        | +-TableScan(column_list=[Int64ValueTable.IntValue#1], table=Int64ValueTable, column_index_list=[0])
        +-aggregate_list=
          +-$group_rows_subquery#4 :=
            +-SubqueryExpr
              +-type=ARRAY<INT64>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[Int64ValueTable.IntValue#3]
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[Int64ValueTable.IntValue#3]
                      +-input_column_list=
                        +-IntValue#3 := ColumnRef(type=INT64, column=Int64ValueTable.IntValue#1)
==

# Aliased group rows has same schema as <from> value table.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (t, t.Filename, RowId)
  FROM group_rows() t
)
FROM TestExtraValueTable
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#12 AS `$col1` [ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, BYTES>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#12]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#12]
        +-input_scan=
        | +-TableScan(column_list=TestExtraValueTable.[value#1, Filename#2, RowId#3], table=TestExtraValueTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#12 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, BYTES>>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[$expr_subquery.$col1#11]
                  +-expr_list=
                  | +-$col1#11 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<PROTO<googlesql_test.TestExtraPB>, STRING, BYTES>
                  |     +-field_list=
                  |       +-ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#8)
                  |       +-ColumnRef(type=STRING, column=TestExtraValueTable.Filename#9)
                  |       +-ColumnRef(type=BYTES, column=TestExtraValueTable.RowId#10)
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=TestExtraValueTable.[value#8, Filename#9, RowId#10]
                      +-input_column_list=
                        +-value#8 := ColumnRef(type=PROTO<googlesql_test.TestExtraPB>, column=TestExtraValueTable.value#1)
                        +-Filename#9 := ColumnRef(type=STRING, column=TestExtraValueTable.Filename#2)
                        +-RowId#10 := ColumnRef(type=BYTES, column=TestExtraValueTable.RowId#3)
==

# Group rows with value table preserves name in STATIC_DESCRIBE.
SELECT
  ARRAY(
     WITH group_rows() AS GROUP ROWS
     FROM group_rows() |>STATIC_DESCRIBE
  )
FROM (SELECT AS STRUCT 1 as key, 2 as val) AS TableX
GROUP BY TableX.key;
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#7 AS `$col1` [ARRAY<STRUCT<key INT64, val INT64>>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#7]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#7]
        +-input_scan=
        | +-ProjectScan
        |   +-column_list=[$make_struct.$struct#3]
        |   +-expr_list=
        |   | +-$struct#3 :=
        |   |   +-MakeStruct
        |   |     +-type=STRUCT<key INT64, val INT64>
        |   |     +-field_list=
        |   |       +-ColumnRef(type=INT64, column=TableX.key#1)
        |   |       +-ColumnRef(type=INT64, column=TableX.val#2)
        |   +-input_scan=
        |     +-ProjectScan
        |       +-column_list=TableX.[key#1, val#2]
        |       +-expr_list=
        |       | +-key#1 := Literal(type=INT64, value=1)
        |       | +-val#2 := Literal(type=INT64, value=2)
        |       +-input_scan=
        |         +-SingleRowScan
        +-group_by_list=
        | +-key#5 :=
        |   +-GetStructField
        |     +-type=INT64
        |     +-expr=
        |     | +-ColumnRef(type=STRUCT<key INT64, val INT64>, column=$make_struct.$struct#3)
        |     +-field_idx=0
        +-aggregate_list=
          +-$group_rows_subquery#7 :=
            +-SubqueryExpr
              +-type=ARRAY<STRUCT<key INT64, val INT64>>
              +-subquery_type=ARRAY
              +-subquery=
                +-StaticDescribeScan
                  +-column_list=[$make_struct.$struct#6]
                  +-describe_text=
                  |   """
                  |   NameList (is_value_table = true):
                  |     TableX STRUCT<key INT64, val INT64> $make_struct.$struct#6 (value table)
                  |   NameScope:
                  |     Range variables:
                  |       TableX -> RANGE_VARIABLE<$struct#6> (value table)
                  |     Value table columns:
                  |       $make_struct.$struct#6
                  |   """
                  +-input_scan=
                    +-GroupRowsScan
                      +-column_list=[$make_struct.$struct#6]
                      +-input_column_list=
                        +-$struct#6 := ColumnRef(type=STRUCT<key INT64, val INT64>, column=$make_struct.$struct#3)
==

