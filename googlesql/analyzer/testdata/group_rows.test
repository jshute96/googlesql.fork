QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#10 AS `$col1` [ARRAY<INT32>]
+-query=
  +-ProjectScan
    +-column_list=[$expr_subquery.$group_rows_subquery#10]
    +-input_scan=
      +-AggregateScan
        +-column_list=[$expr_subquery.$group_rows_subquery#10]
        +-input_scan=
        | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
        +-aggregate_list=
          +-$group_rows_subquery#10 :=
            +-SubqueryExpr
              +-type=ARRAY<INT32>
              +-subquery_type=ARRAY
              +-subquery=
                +-ProjectScan
                  +-column_list=[TestTable.key#7]
