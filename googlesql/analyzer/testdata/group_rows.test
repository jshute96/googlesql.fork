# Group rows with multiple aliases to same column in FROM clause subquery.
SELECT ARRAY(
  WITH group_rows() AS GROUP ROWS
  SELECT (k1, e)
  FROM group_rows()
  WHERE k2 = 55
)
FROM (
  SELECT key AS k1, key AS k2, TestEnum AS e
  FROM EnumTable
)
--
