                            +-GraphTableScan
                              +-column_list=[$graph_table.z#24]
                              +-property_graph=aml
                              +-input_scan=
                                +-GraphLinearScan
                                  +-column_list=[$graph_table.z#24]
                                  +-scan_list=
                                    +-GraphLinearScan
                                      +-column_list=[$graph_table.z#24]
                                      +-scan_list=
                                        +-ProjectScan
                                        | +-column_list=[$graph_table.x#15]
