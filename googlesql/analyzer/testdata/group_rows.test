# Group rows with order by on aggregation result.
SELECT
  key,
  ARRAY(
    WITH group_rows() AS GROUP ROWS
    SELECT TestEnum
    FROM group_rows()
  ) AS group_rows_value
FROM TestTable
GROUP BY key
ORDER BY key
--
QueryStmt
+-output_column_list=
| +-$groupby.key#7 AS key [INT32]
| +-$expr_subquery.$group_rows_subquery#11 AS group_rows_value [ARRAY<ENUM<googlesql_test.TestEnum>>]
+-query=
  +-OrderByScan
    +-column_list=[$groupby.key#7, $expr_subquery.$group_rows_subquery#11]
    +-is_ordered=TRUE
    +-input_scan=
    | +-AggregateScan
    |   +-column_list=[$groupby.key#7, $expr_subquery.$group_rows_subquery#11]
    |   +-input_scan=
    |   | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    |   +-group_by_list=
    |   | +-key#7 := ColumnRef(type=INT32, column=TestTable.key#1)
    |   +-aggregate_list=
    |     +-$group_rows_subquery#11 :=
    |       +-SubqueryExpr
    |         +-type=ARRAY<ENUM<googlesql_test.TestEnum>>
    |         +-subquery_type=ARRAY
    |         +-subquery=
    |           +-ProjectScan
    |             +-column_list=[TestTable.TestEnum#9]
    |             +-input_scan=
    |               +-GroupRowsScan
    |                 +-column_list=[TestTable.TestEnum#9]
    |                 +-input_column_list=
    |                   +-key#8 := ColumnRef(type=INT32, column=TestTable.key#1)
    |                   +-TestEnum#9 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
    |                   +-KitchenSink#10 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
    +-order_by_item_list=
      +-OrderByItem
        +-column_ref=
          +-ColumnRef(type=INT32, column=$groupby.key#7)
