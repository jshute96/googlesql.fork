# Group rows not supported within pivot operator.
SELECT *
FROM (
  SELECT key, KitchenSink.int64_key_1, KitchenSink.int64_key_2
  FROM TestTable alias1
) PIVOT(
    ARRAY(
      WITH group_rows() AS GROUP ROWS
      SELECT AS STRUCT int64_key_1
      FROM group_rows()
    ) FOR int64_key_2 IN (0)
) alias2
