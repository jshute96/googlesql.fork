        | | +-argument_column_list=[TableWithTimestampColumn.ts_col#1]
        | +-FunctionArgument
        | | +-expr=
        | |   +-Literal(type=STRING, value="ts_col")
        | +-FunctionArgument
        | | +-expr=
        | |   +-FunctionCall(GoogleSQL:$interval(INT64, ENUM<googlesql.functions.DateTimestampPart>) -> INTERVAL)
        | |     +-Literal(type=INT64, value=1)
        | |     +-Literal(type=ENUM<googlesql.functions.DateTimestampPart>, value=DAY)
        | +-FunctionArgument
        | | +-expr=
        | |   +-FunctionCall(GoogleSQL:$interval(INT64, ENUM<googlesql.functions.DateTimestampPart>) -> INTERVAL)
        | |     +-Literal(type=INT64, value=1)
        | |     +-Literal(type=ENUM<googlesql.functions.DateTimestampPart>, value=HOUR)
        | +-FunctionArgument
