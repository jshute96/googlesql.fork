WITH T AS (
  SELECT [[  -- Outermost array
    STRUCT(  -- arr element
      [  -- f1 array
        STRUCT(  -- f1 element
          ARRAY<ARRAY<INT64>>[[1, 2], [3]] AS f2
        ),
        STRUCT(  -- f1 element
          ARRAY<ARRAY<INT64>>[[4, 5]] AS f2
        )
      ] AS f1
    ),
    STRUCT(  -- arr element
      [  -- f1 array
        STRUCT(  -- f1 element
          ARRAY<ARRAY<INT64>>[[6]] AS f2
        )
      ] AS f1
    )
  ]] AS arr
)
SELECT FLATTEN(a.f1.f2) FROM T, {{t.arr|UNNEST(T.arr)}} a
