# Depth checks take into account any array offset access
SELECT
  FLATTEN(arr.a[OFFSET(2)], depth => 3) AS depth_3
FROM (
  SELECT [[[
    STRUCT([[[1, 2, 3]]] AS a),
    STRUCT([[[4, 5]]] AS a)
  ]]] AS arr
)
--
ERROR: FLATTEN depth (3) exceeds the number of available nested layers (2) [at 2:3]
  FLATTEN(arr.a[OFFSET(2)], depth => 3) AS depth_3
  ^
==

