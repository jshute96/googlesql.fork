                    +-column_list=$element_table.[p#1, otherPerson#2]
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-p#1 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="id"
                    | |   |   +-property=id(INT64)
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=INT64, value=1)
                    | |   +-label_list=
                    | |   | +-GraphLabel
                    | |   |   +-label=aml_dynamic.Entity
                    | |   |   +-label_name=
                    | |   |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    | |   +-element_table=DynamicGraphNode
                    | +-otherPerson#2 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=2)
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label=aml_dynamic.Entity
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
