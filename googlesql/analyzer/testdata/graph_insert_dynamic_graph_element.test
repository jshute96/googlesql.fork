# RETURN after INSERT is supported.
GRAPH aml_dynamic
INSERT (n:Entity {code: 1})
RETURN n.code AS code
--
GeneralizedQueryStmt
+-output_schema=
| +-OutputSchema
|   +-output_column_list=
|     +-$graph_table.code#2 AS code [INT64]
+-query=
  +-GraphTableScan
    +-column_list=[$graph_table.code#2]
    +-property_graph=aml_dynamic
    +-input_scan=
      +-GraphLinearScan
        +-column_list=[$graph_table.code#2]
        +-scan_list=
          +-GraphLinearScan
            +-column_list=[$graph_table.code#2]
            +-scan_list=
              +-GraphInsertScan
              | +-column_list=[$element_table.n#1]
              | +-input_scan=
              | | +-SingleRowScan
              | +-insert_node_list=
              | | +-n#1 :=
              | |   +-GraphInsertElement
              | |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
              | |     +-property_list=
              | |     | +-GraphDMLPropertyItem
              | |     |   +-property_name="code"
              | |     |   +-property=code(INT64)
              | |     |   +-property_value=
              | |     |     +-Literal(type=INT64, value=1)
              | |     +-label_list=
              | |     | +-GraphLabel
              | |     |   +-label=aml_dynamic.Entity
              | |     |   +-label_name=
              | |     |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
              | |     +-element_table=DynamicGraphNode
              | +-path_element_list=[$element_table.n#1]
              +-ProjectScan
                +-column_list=[$graph_table.code#2]
                +-expr_list=
                | +-code#2 :=
                |   +-GraphGetElementProperty
                |     +-type=INT64
                |     +-expr=
                |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.n#1)
                |     +-property=code(INT64)
                |     +-property_name=
                |       +-Literal(type=STRING, value="code", has_explicit_type=TRUE)
                +-input_scan=
                  +-GraphRefScan(column_list=[$element_table.n#1])
==

