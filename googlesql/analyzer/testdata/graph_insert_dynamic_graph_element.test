                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.p#1)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.otherPerson#2)
                    |     +-element_table=DynamicGraphEdge
                    +-path_element_list=$element_table.[p#1, $insert_edge#3, otherPerson#2]
