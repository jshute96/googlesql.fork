[language_features=NONE,+SQL_GRAPH,+SQL_GRAPH_ADVANCED_QUERY,+SQL_GRAPH_RETURN_EXTENSIONS,+SQL_GRAPH_TERMINAL_INSERT]
# Dynamic graph: Insert dynamic graph element with dynamic element language feature disabled yields error
GRAPH aml_dynamic
INSERT (n:Person {code: 1, id: 1})
--
ERROR: Dynamic label is not supported [at 2:7]
GRAPH aml_dynamic
      ^
==

#######################################################
# INSERT property writability
#######################################################

# Dynamic graph: Insert with dynamic properties on read-only dynamic properties backing column yields error
GRAPH aml_dynamic_read_only
INSERT (n:Entity {name: "Alice"})
--
ERROR: Cannot insert dynamic property 'name' because the dynamic properties backing column 'nodeJsonProp' is read-only [at 2:19]
INSERT (n:Entity {name: "Alice"})
                  ^
==

#######################################################
# INSERT based on static labels and static properties
#######################################################

# Labels: Label conjunction (&) works
GRAPH aml_dynamic
INSERT (n:Entity & DynamicGraphNode {code: 1, id: 1})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml_dynamic
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-n#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     | | +-property_name="code"
                    |     | | +-property=code(INT64)
                    |     | | +-property_value=
                    |     | |   +-Literal(type=INT64, value=1)
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     | | +-label=aml_dynamic.Entity
                    |     | | +-label_name=
                    |     | |   +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    |     | +-GraphLabel
                    |     |   +-label=aml_dynamic.DynamicGraphNode
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="DynamicGraphNode", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
                    +-path_element_list=[$element_table.n#1]
==

