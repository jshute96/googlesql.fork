          | |   |       | +-n#4 := ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.n#3)
          | |   |       +-input_scan=
          | |   |         +-GraphRefScan(column_list=[$element_table.n#3])
          | |   +-output_column_list=[$graph_table.n#4]
          | +-column_match_mode=CORRESPONDING
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-column_list=[$graph_set_op.n#5, $element_table.m#6]
                    +-input_scan=
                    | +-GraphRefScan(column_list=[$graph_set_op.n#5])
                    +-insert_node_list=
                    | +-m#6 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label=aml_dynamic.Entity
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
                    +-insert_edge_list=
                    | +-e#7 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml_dynamic)<category STRING, dst_id INT64, edgeJsonProp JSON, edgeLabelCol STRING, id INT64, DYNAMIC>
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label=aml_dynamic.CONNECTION
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Connection", has_explicit_type=TRUE)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$graph_set_op.n#5)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.m#6)
                    |     +-element_table=DynamicGraphEdge
                    +-path_element_list=[$graph_set_op.n#5, $element_table.e#7, $element_table.m#6]
==

#######################################################
# INSERT based on dynamic labels and dynamic properties
