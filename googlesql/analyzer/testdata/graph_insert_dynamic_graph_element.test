# Dynamic graph: Insert static node + dynamic edge with dynamic label and dynamic properties
GRAPH aml_dynamic
INSERT (p:Entity {id: 1})-[e:Follow {category: "A", detail: "close"}]->(q:Entity {id: 2})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml_dynamic
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-column_list=$element_table.[p#1, q#2]
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-p#1 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="id"
                    | |   |   +-property=id(INT64)
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=INT64, value=1)
                    | |   +-label_list=
                    | |   | +-GraphLabel
                    | |   |   +-label=aml_dynamic.Entity
                    | |   |   +-label_name=
                    | |   |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    | |   +-element_table=DynamicGraphNode
                    | +-q#2 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=2)
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label=aml_dynamic.Entity
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Entity", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
                    +-insert_edge_list=
                    | +-e#3 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml_dynamic)<category STRING, dst_id INT64, edgeJsonProp JSON, edgeLabelCol STRING, id INT64, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     | | +-property_name="category"
                    |     | | +-property=category(STRING)
                    |     | | +-property_value=
                    |     | |   +-Literal(type=STRING, value="A")
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="detail"
                    |     |   +-property_value=
                    |     |     +-Literal(type=STRING, value="close")
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Follow", has_explicit_type=TRUE)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.p#1)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.q#2)
                    |     +-element_table=DynamicGraphEdge
                    +-path_element_list=$element_table.[p#1, e#3, q#2]
==

# Dynamic graph: Insert nodes and edge with fully dynamic labels and dynamic properties
GRAPH aml_dynamic
INSERT (p:Person {name: "Alice"})-[e:Follow {detail: "close friend"}]->(q:Person {name: "Bob"})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml_dynamic
