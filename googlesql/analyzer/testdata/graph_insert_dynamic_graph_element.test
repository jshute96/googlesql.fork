# Insert with dynamic label and static property
GRAPH aml_dynamic
INSERT (n:Person {code: 1})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml_dynamic
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-n#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="code"
                    |     |   +-property=code(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Person", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
                    +-path_element_list=[$element_table.n#1]
==

