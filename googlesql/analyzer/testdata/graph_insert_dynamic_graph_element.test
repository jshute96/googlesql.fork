                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="name"
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=STRING, value="Alice")
                    | |   +-label_list=
                    | |   | +-GraphLabel
                    | |   |   +-label_name=
                    | |   |     +-Literal(type=STRING, value="Person", has_explicit_type=TRUE)
                    | |   +-element_table=DynamicGraphNode
                    | +-x#2 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="name"
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=STRING, value="Bob")
                    | |   +-label_list=
                    | |   | +-GraphLabel
                    | |   |   +-label_name=
                    | |   |     +-Literal(type=STRING, value="Person", has_explicit_type=TRUE)
                    | |   +-element_table=DynamicGraphNode
                    | +-y#4 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="name"
                    |     |   +-property_value=
                    |     |     +-Literal(type=STRING, value="Cindy")
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Person", has_explicit_type=TRUE)
                    |     +-element_table=DynamicGraphNode
                    +-insert_edge_list=
                    | +-e#3 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_EDGE(aml_dynamic)<category STRING, dst_id INT64, edgeJsonProp JSON, edgeLabelCol STRING, id INT64, DYNAMIC>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="detail"
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=STRING, value="close friend")
                    | |   +-label_list=
                    | |   | +-GraphLabel
                    | |   |   +-label_name=
                    | |   |     +-Literal(type=STRING, value="Follow", has_explicit_type=TRUE)
                    | |   +-source_node=
                    | |   | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.p#1)
                    | |   +-dest_node=
                    | |   | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.x#2)
                    | |   +-element_table=DynamicGraphEdge
                    | +-$insert_edge#5 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml_dynamic)<category STRING, dst_id INT64, edgeJsonProp JSON, edgeLabelCol STRING, id INT64, DYNAMIC>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="detail"
                    |     |   +-property_value=
                    |     |     +-Literal(type=STRING, value="professional connection")
                    |     +-label_list=
                    |     | +-GraphLabel
                    |     |   +-label_name=
                    |     |     +-Literal(type=STRING, value="Follow", has_explicit_type=TRUE)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.p#1)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml_dynamic)<code INT64, id INT64, nodeJsonProp JSON, nodeLabelCol STRING, DYNAMIC>, column=$element_table.y#4)
                    |     +-element_table=DynamicGraphEdge
                    +-path_element_list=$element_table.[p#1, e#3, x#2, p#1, $insert_edge#5, y#4]
==

