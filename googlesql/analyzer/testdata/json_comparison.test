    +-column_list=[$query.$col1#1]
    +-expr_list=
    | +-$col1#1 :=
    |   +-FunctionCall(GoogleSQL:$less(JSON, JSON) -> BOOL)
    |     +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    |     +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    +-input_scan=
      +-SingleRowScan

==

SELECT JSON '1' = JSON '1', JSON '1' < JSON '1.0', JSON '1' != JSON '1.0',
       JSON '1' > JSON '1.0', JSON '1' <= JSON '1.0', JSON '1' >= JSON '1.0';
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
| +-$query.$col2#2 AS `$col2` [BOOL]
| +-$query.$col3#3 AS `$col3` [BOOL]
| +-$query.$col4#4 AS `$col4` [BOOL]
| +-$query.$col5#5 AS `$col5` [BOOL]
| +-$query.$col6#6 AS `$col6` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=$query.[$col1#1, $col2#2, $col3#3, $col4#4, $col5#5, $col6#6]
    +-expr_list=
    | +-$col1#1 :=
    | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | +-$col2#2 :=
    | | +-FunctionCall(GoogleSQL:$less(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1.0, has_explicit_type=TRUE)
    | +-$col3#3 :=
    | | +-FunctionCall(GoogleSQL:$not_equal(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1.0, has_explicit_type=TRUE)
    | +-$col4#4 :=
    | | +-FunctionCall(GoogleSQL:$greater(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1.0, has_explicit_type=TRUE)
    | +-$col5#5 :=
    | | +-FunctionCall(GoogleSQL:$less_or_equal(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1.0, has_explicit_type=TRUE)
    | +-$col6#6 :=
    |   +-FunctionCall(GoogleSQL:$greater_or_equal(JSON, JSON) -> BOOL)
    |     +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    |     +-Literal(type=JSON, value=1.0, has_explicit_type=TRUE)
    +-input_scan=
      +-SingleRowScan

