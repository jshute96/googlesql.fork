# Expansive and negative tests for JSON_TYPE_COMPARISON_COERCION are now in
# googlesql/analyzer/json_comparison_analyzer_test.cc.

# Negative test for CAST_TO_JSON_TYPE, which is required for coercing other
# types to JSON for comparison.
[language_features=MAXIMUM,-CAST_TO_JSON_TYPE,+JSON_TYPE_COMPARISON_COERCION]
SELECT
  JSON 'true' = true;
--
ERROR: No matching signature for operator = for argument types: JSON, BOOL
  Signature: T1 = T1
    Unable to find common supertype for templated argument <T1>
      Input types for <T1>: {BOOL, JSON}
  Signature: INT64 = UINT64
    Argument 1: Unable to coerce type JSON to expected type INT64
  Signature: UINT64 = INT64
    Argument 1: Unable to coerce type JSON to expected type UINT64 [at 2:3]
  JSON 'true' = true;
  ^
