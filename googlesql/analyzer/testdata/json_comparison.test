# Sample Literal Equality test
[language_features=MAXIMUM,+JSON_TYPE_COMPARISON_COERCION]
SELECT
  JSON 'true' = true,
  JSON '1' IS DISTINCT FROM CAST(1 AS INT32),
  JSON '"abc"' = "abc",
  JSON '[1, 2]' = [1, 2];
--
QueryStmt
+-output_column_list=
| +-$query.$col1#1 AS `$col1` [BOOL]
| +-$query.$col2#2 AS `$col2` [BOOL]
| +-$query.$col3#3 AS `$col3` [BOOL]
| +-$query.$col4#4 AS `$col4` [BOOL]
+-query=
  +-ProjectScan
    +-column_list=$query.[$col1#1, $col2#2, $col3#3, $col4#4]
    +-expr_list=
    | +-$col1#1 :=
    | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=true, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=true)
    | +-$col2#2 :=
    | | +-FunctionCall(GoogleSQL:$is_distinct_from(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value=1, has_explicit_type=TRUE)
    | +-$col3#3 :=
    | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
    | |   +-Literal(type=JSON, value="abc", has_explicit_type=TRUE)
    | |   +-Literal(type=JSON, value="abc")
    | +-$col4#4 :=
    |   +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
    |     +-Literal(type=JSON, value=[1,2], has_explicit_type=TRUE)
    |     +-Literal(type=JSON, value=[1,2])
    +-input_scan=
      +-SingleRowScan
==

# Sample Column Equality test
[language_features=MAXIMUM,+JSON_TYPE_COMPARISON_COERCION]
WITH MyTable AS (
  SELECT
    JSON 'null' AS json_col,
    true AS bool_col,
    CAST(1 AS INT64) AS int64_col,
    "abc" AS string_col,
    [1, 2] AS array_col
)
SELECT
  json_col = bool_col,
  json_col = int64_col,
  json_col = string_col,
  json_col = array_col
FROM MyTable;
--
QueryStmt
+-output_column_list=
| +-$query.$col1#11 AS `$col1` [BOOL]
| +-$query.$col2#12 AS `$col2` [BOOL]
| +-$query.$col3#13 AS `$col3` [BOOL]
| +-$query.$col4#14 AS `$col4` [BOOL]
+-query=
  +-WithScan
    +-column_list=$query.[$col1#11, $col2#12, $col3#13, $col4#14]
    +-with_entry_list=
    | +-WithEntry
    |   +-with_query_name="MyTable"
    |   +-with_subquery=
    |     +-ProjectScan
    |       +-column_list=MyTable.[json_col#1, bool_col#2, int64_col#3, string_col#4, array_col#5]
    |       +-expr_list=
    |       | +-json_col#1 := Literal(type=JSON, value=null, has_explicit_type=TRUE)
    |       | +-bool_col#2 := Literal(type=BOOL, value=true)
    |       | +-int64_col#3 := Literal(type=INT64, value=1, has_explicit_type=TRUE)
    |       | +-string_col#4 := Literal(type=STRING, value="abc")
    |       | +-array_col#5 := Literal(type=ARRAY<INT64>, value=[1, 2])
    |       +-input_scan=
    |         +-SingleRowScan
    +-query=
      +-ProjectScan
        +-column_list=$query.[$col1#11, $col2#12, $col3#13, $col4#14]
        +-expr_list=
        | +-$col1#11 :=
        | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
        | |   +-ColumnRef(type=JSON, column=MyTable.json_col#6)
        | |   +-Cast(BOOL -> JSON)
        | |     +-ColumnRef(type=BOOL, column=MyTable.bool_col#7)
        | +-$col2#12 :=
        | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
        | |   +-ColumnRef(type=JSON, column=MyTable.json_col#6)
        | |   +-Cast(INT64 -> JSON)
        | |     +-ColumnRef(type=INT64, column=MyTable.int64_col#8)
        | +-$col3#13 :=
        | | +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
        | |   +-ColumnRef(type=JSON, column=MyTable.json_col#6)
        | |   +-Cast(STRING -> JSON)
        | |     +-ColumnRef(type=STRING, column=MyTable.string_col#9)
        | +-$col4#14 :=
        |   +-FunctionCall(GoogleSQL:$equal(JSON, JSON) -> BOOL)
        |     +-ColumnRef(type=JSON, column=MyTable.json_col#6)
        |     +-Cast(ARRAY<INT64> -> JSON)
        |       +-ColumnRef(type=ARRAY<INT64>, column=MyTable.array_col#10)
        +-input_scan=
          +-WithRefScan(column_list=MyTable.[json_col#6, bool_col#7, int64_col#8, string_col#9, array_col#10], with_query_name="MyTable")
==

