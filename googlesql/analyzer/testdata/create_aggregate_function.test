[no_java]
create aggregate function uda_array_numeric(a ARRAY<numeric(10,2)>) as (SUM(a[OFFSET(0)]));
--
CreateFunctionStmt
+-name_path=uda_array_numeric
+-return_type=NUMERIC
+-argument_name_list=[a]
+-signature=(ARRAY<NUMERIC> type_parameters:[(precision=10,scale=2)] a) -> NUMERIC
+-is_aggregate=TRUE
+-language="SQL"
+-code="SUM(a[OFFSET(0)])"
+-aggregate_expression_list=
| +-$agg1#1 :=
|   +-AggregateFunctionCall(GoogleSQL:sum(NUMERIC) -> NUMERIC)
|     +-FunctionCall(GoogleSQL:$array_at_offset(ARRAY<NUMERIC>, INT64) -> NUMERIC)
|       +-ArgumentRef(parse_location=76-77, type=ARRAY<NUMERIC>, name="a", argument_kind=AGGREGATE)
|       +-Literal(type=INT64, value=0)
+-function_expression=
  +-ColumnRef(type=NUMERIC, column=$aggregate.$agg1#1)
==

