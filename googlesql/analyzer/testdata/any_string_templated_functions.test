# Collation is handled correctly, even when optional argument is supplied.
SELECT
  udf(col, CAST("foo" AS STRING COLLATE "und:ci"), CAST("xyz" AS STRING COLLATE "binary")),
  uda(col, CAST("bar" AS STRING COLLATE "und:ci"), CAST("hjk" AS STRING COLLATE "binary"))
FROM tvf((SELECT COLLATE("A", "und:ci") AS col), "baz")
GROUP BY col
--
QueryStmt
+-output_column_list=
| +-$query.$col1#6{Collation:"und:ci"} AS `$col1` [STRING]
| +-$aggregate.$agg1#4{Collation:"und:ci"} AS `$col2` [STRING]
+-query=
  +-ProjectScan
    +-column_list=[$query.$col1#6{Collation:"und:ci"}, $aggregate.$agg1#4{Collation:"und:ci"}]
    +-expr_list=
    | +-$col1#6 :=
    |   +-FunctionCall(Templated_SQL_Function:udf(STRING s1, optional(1) STRING s2, optional(1) STRING s3) -> STRING)
    |     +-type_annotation_map={Collation:"und:ci"}
    |     +-ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=$groupby.col#5{Collation:"und:ci"})
    |     +-Cast(STRING -> STRING)
    |     | +-type_annotation_map={Collation:"und:ci"}
    |     | +-Literal(type=STRING, value="foo", has_explicit_type=TRUE)
    |     | +-type_modifiers=collation:und:ci
    |     +-Cast(STRING -> STRING)
    |       +-Cast(STRING -> STRING)
    |         +-type_annotation_map={Collation:"binary"}
    |         +-Literal(type=STRING, value="xyz", has_explicit_type=TRUE)
    |         +-type_modifiers=collation:binary
    +-input_scan=
      +-AggregateScan
        +-column_list=[$groupby.col#5{Collation:"und:ci"}, $aggregate.$agg1#4{Collation:"und:ci"}]
        +-input_scan=
        | +-TVFScan
        |   +-column_list=[tvf.col#2{Collation:"und:ci"}]
        |   +-tvf=tvf((ANY TABLE t, optional ANY STRING {default_value: "abc"} x, optional STRING {default_value: "xyz"} y) -> ANY TABLE)
        |   +-signature=(TABLE<col STRING{Collation:"und:ci"}>, literal STRING, literal STRING) -> TABLE<col STRING{Collation:"und:ci"}, x STRING>
        |   +-argument_list=
        |   | +-FunctionArgument
        |   | | +-scan=
        |   | | | +-ProjectScan
        |   | | |   +-column_list=[$subquery1.col#1{Collation:"und:ci"}]
        |   | | |   +-expr_list=
        |   | | |   | +-col#1 :=
        |   | | |   |   +-FunctionCall(GoogleSQL:collate(STRING, STRING) -> STRING)
        |   | | |   |     +-type_annotation_map={Collation:"und:ci"}
        |   | | |   |     +-Literal(type=STRING, value="A")
        |   | | |   |     +-Literal(type=STRING, value="und:ci", preserve_in_literal_remover=TRUE)
        |   | | |   +-input_scan=
        |   | | |     +-SingleRowScan
        |   | | +-argument_column_list=[$subquery1.col#1{Collation:"und:ci"}]
        |   | +-FunctionArgument
        |   | | +-expr=
        |   | |   +-Literal(type=STRING, value="baz")
        |   | +-FunctionArgument
        |   |   +-expr=
        |   |     +-Literal(type=STRING, value="xyz")
        |   +-column_index_list=[0]
        |   +-function_call_signature=(ANY TABLE t, optional(1) STRING x, optional(1) STRING y) -> ANY TABLE
        +-group_by_list=
        | +-col#5 := ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=tvf.col#2{Collation:"und:ci"})
        +-collation_list=[und:ci]
        +-aggregate_list=
          +-$agg1#4 :=
            +-AggregateFunctionCall(Templated_SQL_Function:uda(optional(1) STRING s1, optional(1) STRING s2, optional(1) STRING s3) -> STRING)
              +-type_annotation_map={Collation:"und:ci"}
              +-ColumnRef(type=STRING, type_annotation_map={Collation:"und:ci"}, column=tvf.col#2{Collation:"und:ci"})
              +-Cast(STRING -> STRING)
