# Feature flag is required for UDF.
[language_features=MAXIMUM,-ANY_STRING_TEMPLATED_ARGUMENT]
CREATE FUNCTION udf_no_flag(s1 ANY STRING) AS (s1);
--
ERROR: Templated arguments with ANY STRING are not supported [at 1:32]
CREATE FUNCTION udf_no_flag(s1 ANY STRING) AS (s1);
                               ^
