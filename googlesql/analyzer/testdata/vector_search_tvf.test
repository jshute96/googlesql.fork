# Call with alias

WITH base_table AS (
  SELECT 1 AS _INDEX_LEAF_ID, ARRAY<FLOAT>[1.0, 2.0, 3.0] AS EmbeddingColumn
),
query AS (
  SELECT
    [
      STRUCT(
        CAST(1 AS INT64) AS id,
        ARRAY<FLOAT>[0.1, 0.2, 0.3] AS embd
      ),
      STRUCT(
        CAST(2 AS INT64) AS id,
        ARRAY<FLOAT>[0.4, 0.5, 0.6, 0.7] AS embd
      )
    ]
)
SELECT query.*, base._INDEX_LEAF_ID, distance
FROM VECTOR_SEARCH(
   (
    SELECT _INDEX_LEAF_ID,  EmbeddingColumn  AS embedding
    FROM base_table
  ),  -- Inlined base_table
  'embedding',
(SELECT id, embd FROM UNNEST(
    [
      STRUCT(
        CAST(1 AS INT64) AS id,
        ARRAY<FLOAT>[0.1, 0.2, 0.3] AS embd
      ),
      STRUCT(
        CAST(2 AS INT64) AS id,
        ARRAY<FLOAT>[0.4, 0.5, 0.6, 0.7] AS embd
      )
    ])),
  query_column_to_search => 'embd',
  top_k => 10 /* @top_k */,
  distance_type => 'DOT_PRODUCT')
