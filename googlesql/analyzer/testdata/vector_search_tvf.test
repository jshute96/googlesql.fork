# Call with all arguments
[language_features={{MAXIMUM,+SINGLE_HYBRID_VECTOR_SEARCH_TVF|MAXIMUM}}]
SELECT * FROM vector_search(
  TABLE base_table,
  'embedding',
  TABLE query_table,
  'query_embedding',
  top_k => 5,
  distance_type => 'COSINE',
  max_distance => 0.8,
  options => {{JSON '{"key1": 1, "key2": "value2"}'|new googlesql_test.TestApproxDistanceFunctionOptionsProto(1 as key, "value2" as value)}}
)
