            |                 |   |   +-input_scan=
            |                 |   |     +-JoinScan
            |                 |   |       +-column_list=[$array.arr0#9, $array_offset.offset#10, $array.arr1#11, $array_offset.offset#12]
            |                 |   |       +-join_type=FULL
            |                 |   |       +-left_scan=
