            |                 |   |       |   +-column_list=[$array.arr1#11, $array_offset.offset#12]
            |                 |   |       |   +-array_expr_list=
            |                 |   |       |   | +-ColumnRef(type=ARRAY<INT64>, column=$with_expr.arr1#5, is_correlated=TRUE)
            |                 |   |       |   +-element_column_list=[$array.arr1#11]
            |                 |   |       |   +-array_offset_column=
            |                 |   |       |     +-ColumnHolder(column=$array_offset.offset#12)
            |                 |   |       +-join_expr=
