            |                 +-is_ordered=TRUE
            |                 +-input_scan=
            |                 | +-FilterScan
            |                 |   +-column_list=[$array.arr0#9, $array_offset.offset#10, $array.arr1#11, $array_offset.offset#12, $full_join.offset#13]
            |                 |   +-input_scan=
            |                 |   | +-ProjectScan
            |                 |   |   +-column_list=[$array.arr0#9, $array_offset.offset#10, $array.arr1#11, $array_offset.offset#12, $full_join.offset#13]
            |                 |   |   +-expr_list=
