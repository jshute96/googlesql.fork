            |       +-FunctionCall(GoogleSQL:error(STRING) -> ARRAY<STRUCT<arr0 INT64, arr1 INT64, offset INT64>>)
            |       | +-Literal(type=STRING, value="Unnested arrays under STRICT mode must have equal lengths")
