FROM
  TestTable
|> SELECT
     TestTable.key,
     TestTable.TestEnum,
     TestTable.KitchenSink
|> AS testtable_1
|> JOIN
   UNNEST(WITH(arr0 AS testtable_1.KitchenSink.repeated_int32_val, arr0_len AS `IF`((arr0) IS NULL, 0, ARRAY_LENGTH(arr0)), arr1 AS testtable_1.KitchenSink.repeated_int32_val, arr1_len AS `IF`((arr1) IS NULL,
     0, ARRAY_LENGTH(arr1)), mode AS `IF`(CAST("PAD" AS ARRAY_ZIP_MODE) IS NULL, ERROR("UNNEST does not allow NULL mode argument"),
     CAST("PAD" AS ARRAY_ZIP_MODE)), result_len AS `IF`(mode = CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(arr0_len,
       arr1_len), GREATEST(arr0_len, arr1_len)), `IF`((mode = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND ((LEAST(arr0_len,
       arr1_len)) != (GREATEST(arr0_len, arr1_len))), ERROR("Unnested arrays under STRICT mode must have equal lengths"),
     ARRAY(
       FROM
         UNNEST(arr0 AS arr0_2) WITH OFFSET AS offset
       |> SELECT
