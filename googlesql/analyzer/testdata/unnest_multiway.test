# Repro b/499289705: Multiway UNNEST arguments should not share FlattenState
[language_features=NONE,+MULTIWAY_UNNEST,+UNNEST_AND_FLATTEN_ARRAYS]
[enabled_ast_rewrites=DEFAULTS]
SELECT *
FROM KitchenSinkValueTable k,
UNNEST(
  k.nested_repeated_value.nested_int64 as val1,
  k.repeated_holder.(googlesql_test.TestExtraPBExtensionHolder.test_extra_proto_extension) as val2
)
