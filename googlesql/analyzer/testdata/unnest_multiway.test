            GREATEST(a_7, a_8)), `IF`((a_6 = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND ((LEAST(a_7, a_8)) != (GREATEST(a_7,
              a_8))), ERROR("Unnested arrays under STRICT mode must have equal lengths"), ARRAY(
              SELECT
                STRUCT< arr0 INT32, arr1 INT32, offset INT64 > (orderbyscan_21.a_10, orderbyscan_21.a_14, orderbyscan_21.a_17) AS a_22
              FROM
