[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  a_18.arr0 AS a_19,
  a_18.arr1 AS a_20
FROM
  UNNEST(WITH(a_4 AS ARRAY< INT64 >[1, 2], a_2 AS `IF`((a_4) IS NULL, 0, ARRAY_LENGTH(a_4)), a_8 AS ARRAY<
  INT64 >[2], a_3 AS `IF`((a_8) IS NULL, 0, ARRAY_LENGTH(a_8)), a_1 AS `IF`(CAST("PAD" AS ARRAY_ZIP_MODE) IS NULL,
    ERROR("UNNEST does not allow NULL mode argument"), CAST("PAD" AS ARRAY_ZIP_MODE)), a_14 AS `IF`(a_1 =
    CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(a_2, a_3), GREATEST(a_2, a_3)), `IF`((a_1 = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND
    ((LEAST(a_2, a_3)) != (GREATEST(a_2, a_3))), ERROR("Unnested arrays under STRICT mode must have equal lengths"),
    ARRAY(
      SELECT
        STRUCT< arr0 INT64, arr1 INT64, offset INT64 > (orderbyscan_16.a_5, orderbyscan_16.a_9, orderbyscan_16.a_12) AS a_17
      FROM
        (
          SELECT
            filterscan_15.a_5 AS a_5,
            filterscan_15.a_6 AS a_6,
            filterscan_15.a_9 AS a_9,
            filterscan_15.a_10 AS a_10,
            filterscan_15.a_12 AS a_12
          FROM
            (
              SELECT
                projectscan_13.a_5 AS a_5,
                projectscan_13.a_6 AS a_6,
                projectscan_13.a_9 AS a_9,
                projectscan_13.a_10 AS a_10,
                projectscan_13.a_12 AS a_12
              FROM
                (
                  SELECT
                    arrayscan_7.a_5 AS a_5,
                    arrayscan_7.a_6 AS a_6,
                    arrayscan_11.a_9 AS a_9,
                    arrayscan_11.a_10 AS a_10,
                    COALESCE(arrayscan_7.a_6, arrayscan_11.a_10) AS a_12
                  FROM
                    (
                      SELECT
                        a_5 AS a_5,
                        a_6 AS a_6
                      FROM
                        UNNEST(a_4 AS a_5) WITH OFFSET AS a_6
                    ) AS arrayscan_7
                    FULL JOIN
                    (
                      SELECT
                        a_9 AS a_9,
                        a_10 AS a_10
                      FROM
                        UNNEST(a_8 AS a_9) WITH OFFSET AS a_10
                    ) AS arrayscan_11
                    ON (arrayscan_7.a_6) = (arrayscan_11.a_10)
                ) AS projectscan_13
              WHERE
                (projectscan_13.a_12) < a_14
            ) AS filterscan_15
          ORDER BY filterscan_15.a_12
        ) AS orderbyscan_16
    ))) AS a_18);

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
