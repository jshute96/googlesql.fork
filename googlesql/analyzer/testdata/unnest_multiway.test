SELECT
  testtable_4.a_1 AS key,
  testtable_4.a_2 AS TestEnum,
  testtable_4.a_3 AS KitchenSink,
  a_22.arr0 AS array1,
  a_22.arr1 AS array2
FROM
  (
    SELECT
      TestTable.key AS a_1,
      TestTable.TestEnum AS a_2,
      TestTable.KitchenSink AS a_3
    FROM
      TestTable
  ) AS testtable_4
  JOIN
  UNNEST(WITH(a_8 AS testtable_4.a_3.repeated_int32_val, a_6 AS `IF`((a_8) IS NULL, 0, ARRAY_LENGTH(a_8)), a_12 AS testtable_4.a_3.repeated_string_val, a_7 AS `IF`((a_12) IS NULL,
    0, ARRAY_LENGTH(a_12)), a_5 AS `IF`(CAST("PAD" AS ARRAY_ZIP_MODE) IS NULL, ERROR("UNNEST does not allow NULL mode argument"),
    CAST("PAD" AS ARRAY_ZIP_MODE)), a_18 AS `IF`(a_5 = CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(a_6, a_7),
    GREATEST(a_6, a_7)), `IF`((a_5 = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND ((LEAST(a_6, a_7)) != (GREATEST(a_6,
      a_7))), ERROR("Unnested arrays under STRICT mode must have equal lengths"), ARRAY(
      SELECT
        STRUCT< arr0 INT32, arr1 STRING, offset INT64 > (orderbyscan_20.a_9, orderbyscan_20.a_13, orderbyscan_20.a_16) AS a_21
      FROM
        (
          SELECT
            filterscan_19.a_9 AS a_9,
            filterscan_19.a_10 AS a_10,
            filterscan_19.a_13 AS a_13,
            filterscan_19.a_14 AS a_14,
            filterscan_19.a_16 AS a_16
          FROM
            (
              SELECT
                projectscan_17.a_9 AS a_9,
                projectscan_17.a_10 AS a_10,
                projectscan_17.a_13 AS a_13,
                projectscan_17.a_14 AS a_14,
                projectscan_17.a_16 AS a_16
              FROM
                (
                  SELECT
                    arrayscan_11.a_9 AS a_9,
                    arrayscan_11.a_10 AS a_10,
                    arrayscan_15.a_13 AS a_13,
                    arrayscan_15.a_14 AS a_14,
                    COALESCE(arrayscan_11.a_10, arrayscan_15.a_14) AS a_16
                  FROM
                    (
                      SELECT
                        a_9 AS a_9,
                        a_10 AS a_10
                      FROM
                        UNNEST(a_8 AS a_9) WITH OFFSET AS a_10
                    ) AS arrayscan_11
                    FULL JOIN
                    (
                      SELECT
                        a_13 AS a_13,
                        a_14 AS a_14
                      FROM
                        UNNEST(a_12 AS a_13) WITH OFFSET AS a_14
                    ) AS arrayscan_15
                    ON (arrayscan_11.a_10) = (arrayscan_15.a_14)
                ) AS projectscan_17
              WHERE
                (projectscan_17.a_16) < a_18
            ) AS filterscan_19
          ORDER BY filterscan_19.a_16
        ) AS orderbyscan_20
    ))) AS a_22);

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  TestTable
|> SELECT
     TestTable.key,
     TestTable.TestEnum,
     TestTable.KitchenSink
|> AS testtable_1
|> JOIN
   UNNEST(WITH(arr0 AS testtable_1.KitchenSink.repeated_int32_val, arr0_len AS `IF`((arr0) IS NULL, 0, ARRAY_LENGTH(arr0)), arr1 AS testtable_1.KitchenSink.repeated_string_val, arr1_len AS `IF`((arr1) IS NULL,
     0, ARRAY_LENGTH(arr1)), mode AS `IF`(CAST("PAD" AS ARRAY_ZIP_MODE) IS NULL, ERROR("UNNEST does not allow NULL mode argument"),
     CAST("PAD" AS ARRAY_ZIP_MODE)), result_len AS `IF`(mode = CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(arr0_len,
       arr1_len), GREATEST(arr0_len, arr1_len)), `IF`((mode = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND ((LEAST(arr0_len,
       arr1_len)) != (GREATEST(arr0_len, arr1_len))), ERROR("Unnested arrays under STRICT mode must have equal lengths"),
     ARRAY(
       FROM
         UNNEST(arr0 AS arr0_2) WITH OFFSET AS offset
       |> SELECT
            arr0_2,
            offset
       |> AS arrayscan_2
       |> FULL JOIN
          (
            FROM
              UNNEST(arr1 AS arr1_2) WITH OFFSET AS offset_2
            |> SELECT
                 arr1_2,
                 offset_2
            |> AS arrayscan_3
          )
          ON (arrayscan_2.offset) = (arrayscan_3.offset_2)
       |> SELECT
            arrayscan_2.arr0_2,
            arrayscan_2.offset,
            arrayscan_3.arr1_2,
            arrayscan_3.offset_2,
            COALESCE(arrayscan_2.offset, arrayscan_3.offset_2) AS offset_3
       |> WHERE
            offset_3 < result_len
       |> ORDER BY offset_3
       |> SELECT
            STRUCT< arr0 INT32, arr1 STRING, offset INT64 > (arr0_2, arr1_2, offset_3) AS a_4
     ))) AS a_5)
|> SELECT
     testtable_1.key,
     testtable_1.TestEnum,
     testtable_1.KitchenSink,
     a_5.arr0 AS array1,
     a_5.arr1 AS array2
|> AS projectscan_6
|> SELECT
     projectscan_6.key,
     projectscan_6.TestEnum,
     projectscan_6.KitchenSink,
     projectscan_6.array1,
     projectscan_6.array2;
