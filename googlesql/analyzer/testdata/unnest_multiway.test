[SQLBUILDER_OUTPUT]
SELECT
  a_18.arr0 AS a_19,
  a_18.arr1 AS a_20,
  a_18.offset AS off
FROM
  UNNEST(WITH(a_4 AS ARRAY< INT64 >[1, 2], a_2 AS `IF`((a_4) IS NULL, 0, ARRAY_LENGTH(a_4)), a_8 AS ARRAY<
  INT64 >[1, 2], a_3 AS `IF`((a_8) IS NULL, 0, ARRAY_LENGTH(a_8)), a_1 AS `IF`(CAST("STRICT" AS ARRAY_ZIP_MODE) IS NULL,
    ERROR("UNNEST does not allow NULL mode argument"), CAST("STRICT" AS ARRAY_ZIP_MODE)), a_14 AS `IF`(a_1 =
    CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(a_2, a_3), GREATEST(a_2, a_3)), `IF`((a_1 = CAST("STRICT" AS ARRAY_ZIP_MODE)) AND
    ((LEAST(a_2, a_3)) != (GREATEST(a_2, a_3))), ERROR("Unnested arrays under STRICT mode must have equal lengths"),
    ARRAY(
      SELECT
        STRUCT< arr0 INT64, arr1 INT64, offset INT64 > (orderbyscan_16.a_5, orderbyscan_16.a_9, orderbyscan_16.a_12) AS a_17
      FROM
        (
          SELECT
            filterscan_15.a_5 AS a_5,
            filterscan_15.a_6 AS a_6,
            filterscan_15.a_9 AS a_9,
            filterscan_15.a_10 AS a_10,
            filterscan_15.a_12 AS a_12
          FROM
            (
              SELECT
                projectscan_13.a_5 AS a_5,
                projectscan_13.a_6 AS a_6,
                projectscan_13.a_9 AS a_9,
                projectscan_13.a_10 AS a_10,
                projectscan_13.a_12 AS a_12
              FROM
                (
                  SELECT
                    arrayscan_7.a_5 AS a_5,
                    arrayscan_7.a_6 AS a_6,
                    arrayscan_11.a_9 AS a_9,
                    arrayscan_11.a_10 AS a_10,
                    COALESCE(arrayscan_7.a_6, arrayscan_11.a_10) AS a_12
                  FROM
                    (
                      SELECT
                        a_5 AS a_5,
                        a_6 AS a_6
                      FROM
                        UNNEST(a_4 AS a_5) WITH OFFSET AS a_6
                    ) AS arrayscan_7
                    FULL JOIN
                    (
                      SELECT
                        a_9 AS a_9,
                        a_10 AS a_10
                      FROM
                        UNNEST(a_8 AS a_9) WITH OFFSET AS a_10
                    ) AS arrayscan_11
                    ON (arrayscan_7.a_6) = (arrayscan_11.a_10)
                ) AS projectscan_13
              WHERE
                (projectscan_13.a_12) < a_14
            ) AS filterscan_15
          ORDER BY filterscan_15.a_12
        ) AS orderbyscan_16
    ))) AS a_18);

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  UNNEST(WITH(arr0 AS ARRAY< INT64 >[1, 2], arr0_len AS `IF`((arr0) IS NULL, 0, ARRAY_LENGTH(arr0)), arr1 AS ARRAY<
  INT64 >[1, 2], arr1_len AS `IF`((arr1) IS NULL, 0, ARRAY_LENGTH(arr1)), mode AS `IF`(CAST("STRICT" AS ARRAY_ZIP_MODE) IS NULL,
    ERROR("UNNEST does not allow NULL mode argument"), CAST("STRICT" AS ARRAY_ZIP_MODE)), result_len AS `IF`(mode =
    CAST("TRUNCATE" AS ARRAY_ZIP_MODE), LEAST(arr0_len, arr1_len), GREATEST(arr0_len, arr1_len)), `IF`((mode =
    CAST("STRICT" AS ARRAY_ZIP_MODE)) AND ((LEAST(arr0_len, arr1_len)) != (GREATEST(arr0_len, arr1_len))),
    ERROR("Unnested arrays under STRICT mode must have equal lengths"), ARRAY(
      FROM
        UNNEST(arr0 AS arr0_2) WITH OFFSET AS offset
      |> SELECT
           arr0_2,
           offset
      |> AS arrayscan_1
      |> FULL JOIN
         (
           FROM
             UNNEST(arr1 AS arr1_2) WITH OFFSET AS offset_2
           |> SELECT
                arr1_2,
                offset_2
           |> AS arrayscan_2
         )
         ON (arrayscan_1.offset) = (arrayscan_2.offset_2)
      |> SELECT
           arrayscan_1.arr0_2,
           arrayscan_1.offset,
           arrayscan_2.arr1_2,
           arrayscan_2.offset_2,
           COALESCE(arrayscan_1.offset, arrayscan_2.offset_2) AS offset_3
      |> WHERE
           offset_3 < result_len
      |> ORDER BY offset_3
      |> SELECT
           STRUCT< arr0 INT64, arr1 INT64, offset INT64 > (arr0_2, arr1_2, offset_3) AS a_3
    ))) AS a_4)
|> SELECT
     a_4.arr0 AS a_5,
     a_4.arr1 AS a_6,
     a_4.offset AS off
|> AS projectscan_7
|> SELECT
     projectscan_7.a_5,
     projectscan_7.a_6,
     projectscan_7.off;
==

# ============== UNNEST with table alias or argument alias =========
# Table alias is not allowed when UNNEST has multiple expressions with aliases.
SELECT *
FROM UNNEST([1, 2] AS col_alias, [2, 3] AS another_col_alias) AS table_alias
--
ERROR: When 2 or more array arguments are supplied to UNNEST, aliases for the element columns must be specified following the argument inside the parenthesis [at 2:63]
FROM UNNEST([1, 2] AS col_alias, [2, 3] AS another_col_alias) AS table_alias
                                                              ^
==

# Table alias is not allowed when UNNEST has multiple expressions, some with
# alias some not.
SELECT *
FROM UNNEST([1, 2] AS col_alias, [2, 3]) AS table_alias
--
ERROR: When 2 or more array arguments are supplied to UNNEST, aliases for the element columns must be specified following the argument inside the parenthesis [at 2:42]
FROM UNNEST([1, 2] AS col_alias, [2, 3]) AS table_alias
                                         ^
==

# Table alias is not allowed when UNNEST has multiple expressions, none of them
# has alias.
SELECT *
FROM UNNEST([1, 2], [2, 3]) AS table_alias
--
ERROR: When 2 or more array arguments are supplied to UNNEST, aliases for the element columns must be specified following the argument inside the parenthesis [at 2:29]
FROM UNNEST([1, 2], [2, 3]) AS table_alias
                            ^
==

# Table alias is not allowed when UNNEST argument has alias.
SELECT *
FROM UNNEST([1, 2] AS col_alias) AS table_alias
--
ERROR: Alias outside UNNEST is not allowed when the argument inside the parenthesis has alias [at 2:34]
FROM UNNEST([1, 2] AS col_alias) AS table_alias
                                 ^
==

# Column alias in single argument.
[show_sqlbuilder_output]
SELECT *
FROM UNNEST([1,2] AS array_alias)
--
QueryStmt
+-output_column_list=
| +-$array.array_alias#1 AS array_alias [INT64]
+-query=
  +-ProjectScan
    +-column_list=[$array.array_alias#1]
    +-input_scan=
      +-ArrayScan
        +-column_list=[$array.array_alias#1]
        +-array_expr_list=
        | +-Literal(type=ARRAY<INT64>, value=[1, 2])
        +-element_column_list=[$array.array_alias#1]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  a_1 AS array_alias
FROM
  UNNEST(ARRAY< INT64 >[1, 2] AS a_1);

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  UNNEST(ARRAY< INT64 >[1, 2] AS array_alias)
|> SELECT
     array_alias;
==

# ============== UNNEST with multiple array arguments =========
# 2 arguments: NULL literal does not coerce to array, so it is only accepted if
# it has explicit type.
SELECT *
FROM UNNEST({{NULL, NULL|CAST(NULL AS ARRAY<INT64>), CAST(NULL AS ARRAY<STRING>)}})
--
ALTERNATION GROUP: NULL, NULL
--
ERROR: Values referenced in UNNEST must be arrays. UNNEST contains expression of type INT64 [at 2:13]
FROM UNNEST(NULL, NULL)
            ^
--
ALTERNATION GROUP: CAST(NULL AS ARRAY<INT64>), CAST(NULL AS ARRAY<STRING>)
--
QueryStmt
+-output_column_list=
| +-$array.$unnest1#1 AS `$unnest1` [INT64]
| +-$array.$unnest2#2 AS `$unnest2` [STRING]
+-query=
  +-ProjectScan
    +-column_list=$array.[$unnest1#1, $unnest2#2]
    +-input_scan=
      +-ArrayScan
        +-column_list=$array.[$unnest1#1, $unnest2#2]
        +-array_expr_list=
        | +-Literal(type=ARRAY<INT64>, value=NULL, has_explicit_type=TRUE)
        | +-Literal(type=ARRAY<STRING>, value=NULL, has_explicit_type=TRUE)
        +-element_column_list=$array.[$unnest1#1, $unnest2#2]
        +-array_zip_mode=
          +-Literal(type=ENUM<ARRAY_ZIP_MODE>, value=PAD)

[REWRITTEN AST]
QueryStmt
+-output_column_list=
| +-$array.$unnest1#1 AS `$unnest1` [INT64]
| +-$array.$unnest2#2 AS `$unnest2` [STRING]
+-query=
  +-ProjectScan
    +-column_list=$array.[$unnest1#1, $unnest2#2]
