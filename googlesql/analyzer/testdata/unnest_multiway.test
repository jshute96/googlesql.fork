            offset
       |> AS arrayscan_2
       |> FULL JOIN
          (
            FROM
              UNNEST(arr1 AS arr1_2) WITH OFFSET AS offset_2
            |> SELECT
                 arr1_2,
                 offset_2
            |> AS arrayscan_3
          )
          ON (arrayscan_2.offset) = (arrayscan_3.offset_2)
       |> SELECT
