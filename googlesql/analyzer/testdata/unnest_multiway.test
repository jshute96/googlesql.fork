            arrayscan_2.offset,
            arrayscan_3.arr1_2,
            arrayscan_3.offset_2,
            COALESCE(arrayscan_2.offset, arrayscan_3.offset_2) AS offset_3
       |> WHERE
            offset_3 < result_len
       |> ORDER BY offset_3
       |> SELECT
            STRUCT< arr0 INT32, arr1 INT32, offset INT64 > (arr0_2, arr1_2, offset_3) AS a_4
     ))) AS a_5)
|> SELECT
     testtable_1.key,
     testtable_1.TestEnum,
     testtable_1.KitchenSink,
     a_5.arr0 AS repeated_int32_val,
     a_5.arr1 AS array2
|> AS projectscan_6
|> SELECT
     projectscan_6.key,
