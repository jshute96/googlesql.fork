SELECT
  graphtablescan_15.a_2.name AS source_name,
  graphtablescan_15.a_3.name AS destination_name,
  graphtablescan_15.a_4.accountId AS transfer_id
FROM
  (
    SELECT
      aml_1.a_4 AS a_4,
      aml_1.a_2 AS a_2,
      aml_1.a_3 AS a_3
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (
            (a_5 IS (% | ! %))
            -[a_6 IS Transfer]->
            (
              (a_7 IS (% | ! %))
              -[a_8 IS (% | ! %)]->
              (a_9 IS (% | ! %))
            )
            WHERE
              (a_6.accountId) = (a_7.id)
          )
        RETURN
          a_7 AS a_2,
          a_9 AS a_3,
          a_6 AS a_4
        INTERSECT DISTINCT
        MATCH
          (
            (a_10 IS (% | ! %))
            -[a_11 IS Transfer]->
            (
              (a_12 IS (% | ! %))
              -[a_13 IS (% | ! %)]->
              (a_14 IS (% | ! %))
            )
            WHERE
              (a_11.accountId) = (a_12.id)
          )
        RETURN
          a_11 AS a_4,
          a_12 AS a_2,
          a_14 AS a_3
      ) AS aml_1
  ) AS graphtablescan_15;

