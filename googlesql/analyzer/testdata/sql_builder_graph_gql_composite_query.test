                | | |       +-input_scan=
                | | |         +-GraphRefScan(column_list=[$element_table.n#5])
                | | +-output_column_list=$graph_table.[name#7, number#6, concat_str#8]
                | +-SetOperationItem
                |   +-scan=
                |   | +-GraphLinearScan
                |   |   +-column_list=$graph_table.[name#10, number#12, concat_str#11]
                |   |   +-scan_list=
                |   |     +-GraphScan
                |   |     | +-column_list=[$element_table.n#9]
                |   |     | +-input_scan_list=
                |   |     | | +-GraphPathScan
                |   |     | |   +-column_list=[$element_table.n#9]
                |   |     | |   +-input_scan_list=
