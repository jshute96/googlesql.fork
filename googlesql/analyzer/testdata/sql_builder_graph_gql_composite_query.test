                | | |     | |   | | | +-GraphLabelNaryExpr
                | | |     | |   | | |   +-op=OR
                | | |     | |   | | |   +-operand_list=
                | | |     | |   | | |     +-GraphWildCardLabel
                | | |     | |   | | |     +-GraphLabelNaryExpr
