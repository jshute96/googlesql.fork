+-output_column_list=
| +-$graph_set_op.id#11 AS id [INT64]
| +-$graph_set_op.val#12 AS val [BOOL]
+-query=
  +-GraphTableScan
    +-column_list=$graph_set_op.[id#11, val#12]
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-column_list=$graph_set_op.[id#11, val#12]
        +-scan_list=
          +-SetOperationScan
            +-column_list=$graph_set_op.[id#11, val#12]
            +-op_type=UNION_ALL
            +-input_item_list=
            | +-SetOperationItem
            | | +-scan=
            | | | +-GraphLinearScan
            | | |   +-column_list=$graph_table.[id#4, val#5]
            | | |   +-scan_list=
            | | |     +-GraphScan
            | | |     | +-column_list=[$element_table.n#1]
            | | |     | +-input_scan_list=
            | | |     | | +-GraphPathScan
            | | |     | |   +-column_list=[$element_table.n#1]
            | | |     | |   +-input_scan_list=
