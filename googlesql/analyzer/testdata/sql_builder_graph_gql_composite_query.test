|> SELECT
     aml_1.a_3 AS a_3,
     aml_1.a_2 AS a_2
|> AS projectscan_10
|> SELECT
     projectscan_10.a_2 AS id,
     projectscan_10.a_3 AS val;
==

# SQLBuilder test for GQL set op with subquery, in a top level GRAPH statement.
GRAPH aml
MATCH (n:Person)
RETURN
  1 AS id,
  EXISTS {
    GRAPH aml
    MATCH (n2:Person where n2.name = 'Dana')
    RETURN 1 as one
  } AS val
UNION ALL
MATCH (n:Person)
RETURN
  EXISTS {
    GRAPH aml
    MATCH (n2:Person where n2.name = 'Dana')
    RETURN 1 as one
  } AS val,
  2 AS id
