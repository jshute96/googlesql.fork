# SQLBuilder test for GQL set op with three inputs.
select gt.* from
graph_table(aml
  match (n)
  return n.name, 1 AS number, CONCAT("str", "_suffix") AS concat_str
  UNION DISTINCT
  match (n)
  return 2 AS number, n.name, CONCAT("str", "_suffix") AS concat_str
  UNION DISTINCT
  match (n)
  return n.name, CONCAT("str", "_suffix") AS concat_str, 3 AS number
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_set_op.name#13 AS name [STRING]
| +-$graph_set_op.number#14 AS number [INT64]
| +-$graph_set_op.concat_str#15 AS concat_str [STRING]
+-query=
  +-ProjectScan
    +-column_list=$graph_set_op.[name#13, number#14, concat_str#15]
