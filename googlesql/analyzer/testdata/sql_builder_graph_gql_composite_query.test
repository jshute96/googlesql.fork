                |   |       | +-e#25 := ColumnRef(type=GRAPH_EDGE(aml)<accountId INT64, amount UINT64, personId INT64, targetAccountId INT64>, column=$element_table.e#21)
                |   |       | +-name#26 := Literal(type=STRING, value="Alice")
                |   |       | +-distinct_ids#27 := Literal(type=INT64, value=1)
                |   |       | +-first_acc_id#28 := Literal(type=INT64, value=100)
