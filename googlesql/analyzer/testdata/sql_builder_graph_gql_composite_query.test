# SQLBuilder test for GQL set op with quantified path, which produces
# group name list during resolution.
select ARRAY_LENGTH(a) AS a_len, ARRAY_LENGTH(e) AS e_len, ARRAY_LENGTH(b) AS b_len
from graph_table(aml
  MATCH ((a)-[e]->(b)){1, 3}
  RETURN *
  UNION ALL
  MATCH ((a)-[e]->(b)){1, 3}
  RETURN *
)
--
QueryStmt
+-output_column_list=
| +-$query.a_len#26 AS a_len [INT64]
| +-$query.e_len#27 AS e_len [INT64]
| +-$query.b_len#28 AS b_len [INT64]
+-query=
  +-ProjectScan
    +-column_list=$query.[a_len#26, e_len#27, b_len#28]
    +-expr_list=
    | +-a_len#26 :=
    | | +-FunctionCall(GoogleSQL:array_length(ARRAY<GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>>) -> INT64)
    | |   +-ColumnRef(type=ARRAY<GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>>, column=$graph_set_op.a#23)
    | +-e_len#27 :=
