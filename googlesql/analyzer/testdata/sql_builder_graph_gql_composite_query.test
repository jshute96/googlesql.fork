[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  ARRAY_LENGTH(graphtablescan_11.a_2) AS a_len,
  ARRAY_LENGTH(graphtablescan_11.a_3) AS e_len,
  ARRAY_LENGTH(graphtablescan_11.a_4) AS b_len
FROM
  (
    SELECT
      aml_1.a_2 AS a_2,
      aml_1.a_3 AS a_3,
      aml_1.a_4 AS a_4
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (
            (a_5 IS (% | ! %))
            -[a_6 IS (% | ! %)]->
            (a_7 IS (% | ! %))
          ) { 1, 3 }
        RETURN
          a_5 AS a_2,
          a_6 AS a_3,
          a_7 AS a_4
        UNION ALL
        MATCH
          (
            (a_8 IS (% | ! %))
            -[a_9 IS (% | ! %)]->
            (a_10 IS (% | ! %))
          ) { 1, 3 }
        RETURN
          a_8 AS a_2,
          a_9 AS a_3,
          a_10 AS a_4
      ) AS aml_1
  ) AS graphtablescan_11;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (
        (a_5 IS (% | ! %))
        -[a_6 IS (% | ! %)]->
        (a_7 IS (% | ! %))
      ) { 1, 3 }
    RETURN
      a_5 AS a_2,
      a_6 AS a_3,
      a_7 AS a_4
    UNION ALL
    MATCH
      (
        (a_8 IS (% | ! %))
        -[a_9 IS (% | ! %)]->
        (a_10 IS (% | ! %))
      ) { 1, 3 }
    RETURN
      a_8 AS a_2,
      a_9 AS a_3,
      a_10 AS a_4
  ) AS aml_1
|> SELECT
     aml_1.a_2 AS a_2,
     aml_1.a_3 AS a_3,
     aml_1.a_4 AS a_4
|> AS graphtablescan_11
|> SELECT
     ARRAY_LENGTH(graphtablescan_11.a_2) AS a_len,
     ARRAY_LENGTH(graphtablescan_11.a_3) AS e_len,
     ARRAY_LENGTH(graphtablescan_11.a_4) AS b_len;
==

# SQLBuilder test for GQL set op with sub-path, which produces
# group name list during resolution.
select a.name AS source_name, b.name AS destination_name, e.accountId AS transfer_id
from graph_table(aml
  MATCH ( -[e:Transfer]-> ((a) -> (b)) WHERE e.accountId = a.id)
  RETURN a, b, e
  INTERSECT DISTINCT
  MATCH ( -[e:Transfer]-> ((a) -> (b)) WHERE e.accountId = a.id)
  RETURN e, a, b
)
--
QueryStmt
+-output_column_list=
| +-$query.source_name#20 AS source_name [STRING]
| +-$query.destination_name#21 AS destination_name [STRING]
| +-$query.transfer_id#22 AS transfer_id [INT64]
+-query=
  +-ProjectScan
    +-column_list=$query.[source_name#20, destination_name#21, transfer_id#22]
    +-expr_list=
    | +-source_name#20 :=
    | | +-GraphGetElementProperty
    | |   +-type=STRING
    | |   +-expr=
    | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>, column=$graph_set_op.a#17)
    | |   +-property=name(STRING)
    | +-destination_name#21 :=
    | | +-GraphGetElementProperty
    | |   +-type=STRING
    | |   +-expr=
    | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>, column=$graph_set_op.b#18)
    | |   +-property=name(STRING)
    | +-transfer_id#22 :=
    |   +-GraphGetElementProperty
    |     +-type=INT64
    |     +-expr=
    |     | +-ColumnRef(type=GRAPH_EDGE(aml)<accountId INT64, amount UINT64, targetAccountId INT64>, column=$graph_set_op.e#19)
    |     +-property=accountId(INT64)
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_set_op.[a#17, b#18, e#19]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_set_op.[a#17, b#18, e#19]
            +-scan_list=
              +-SetOperationScan
                +-column_list=$graph_set_op.[a#17, b#18, e#19]
                +-op_type=INTERSECT_DISTINCT
                +-input_item_list=
                | +-SetOperationItem
                | | +-scan=
                | | | +-GraphLinearScan
                | | |   +-column_list=$graph_table.[a#6, b#7, e#8]
                | | |   +-scan_list=
                | | |     +-GraphScan
                | | |     | +-column_list=$element_table.[$element1#1, e#2, a#3, $element2#4, b#5]
                | | |     | +-input_scan_list=
