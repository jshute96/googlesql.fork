# Repro for b/330730443
# SQLBuilder test for GQL RETURN * and ORDER BY.
SELECT *
FROM graph_table(aml
  RETURN 1 AS a, COUNT(1) AS c
  GROUP BY a
  NEXT
  RETURN *
  ORDER BY a, c
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_table.a#3 AS a [INT64]
| +-$graph_table.c#4 AS c [INT64]
+-query=
  +-ProjectScan
    +-column_list=$graph_table.[a#3, c#4]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_table.[a#3, c#4]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_table.[a#3, c#4]
            +-scan_list=
              +-GraphLinearScan
              | +-column_list=$graph_table.[a#2, c#1]
              | +-scan_list=
              |   +-ProjectScan
              |     +-column_list=$graph_table.[a#2, c#1]
              |     +-input_scan=
              |       +-AggregateScan
              |         +-column_list=$graph_table.[a#2, c#1]
              |         +-input_scan=
              |         | +-SingleRowScan
              |         +-group_by_list=
              |         | +-a#2 := Literal(type=INT64, value=1)
              |         +-aggregate_list=
              |           +-c#1 :=
              |             +-AggregateFunctionCall(GoogleSQL:count(INT64) -> INT64)
              |               +-Literal(type=INT64, value=1)
              +-GraphLinearScan
                +-column_list=$graph_table.[a#3, c#4]
                +-scan_list=
                  +-OrderByScan
                    +-column_list=$graph_table.[a#3, c#4]
                    +-is_ordered=TRUE
                    +-input_scan=
                    | +-ProjectScan
                    |   +-column_list=$graph_table.[a#2, c#1, a#3, c#4]
                    |   +-expr_list=
                    |   | +-a#3 := ColumnRef(type=INT64, column=$graph_table.a#2)
                    |   | +-c#4 := ColumnRef(type=INT64, column=$graph_table.c#1)
                    |   +-input_scan=
                    |     +-GraphRefScan(column_list=$graph_table.[a#2, c#1])
                    +-order_by_item_list=
                      +-OrderByItem
                      | +-column_ref=
                      |   +-ColumnRef(type=INT64, column=$graph_table.a#3)
                      +-OrderByItem
                        +-column_ref=
                          +-ColumnRef(type=INT64, column=$graph_table.c#4)

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aml_1.a_4 AS a,
  aml_1.a_5 AS c
FROM
  GRAPH_TABLE(
    aml
    RETURN
      1 AS a_2,
      COUNT(1) AS a_3
    GROUP BY a_2
    NEXT
    RETURN
      a_2 AS a_4,
      a_3 AS a_5
    ORDER BY a_4, a_5
  ) AS aml_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    RETURN
      1 AS a_2,
      COUNT(1) AS a_3
    GROUP BY a_2
    NEXT
    RETURN
      a_2 AS a_4,
      a_3 AS a_5
    ORDER BY a_4, a_5
  ) AS aml_1
|> SELECT
     aml_1.a_4 AS a,
     aml_1.a_5 AS c;
==

# SQLBuilder test: verify column order preservation in GQL NEXT (repro for bug)
select gt.* from
graph_table(aml
  match (n:Person)
  return n.name as name_val, COUNT(n) as count_val
    group by name_val
  next
  return name_val, count_val
) gt
--


QueryStmt
+-output_column_list=
| +-$graph_table.name_val#4 AS name_val [STRING]
| +-$graph_table.count_val#5 AS count_val [INT64]
+-query=
  +-ProjectScan
    +-column_list=$graph_table.[name_val#4, count_val#5]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_table.[name_val#4, count_val#5]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_table.[name_val#4, count_val#5]
            +-scan_list=
              +-GraphLinearScan
              | +-column_list=$graph_table.[name_val#3, count_val#2]
              | +-scan_list=
              |   +-GraphScan
              |   | +-column_list=[$element_table.n#1]
              |   | +-input_scan_list=
              |   | | +-GraphPathScan
              |   | |   +-column_list=[$element_table.n#1]
              |   | |   +-input_scan_list=
              |   | |   | +-GraphNodeScan
              |   | |   |   +-column_list=[$element_table.n#1]
              |   | |   |   +-label_expr=
              |   | |   |   | +-GraphLabel(parse_location=44-50, label=aml.Person)
              |   | |   |   +-target_element_table_list=[aml.Person]
              |   | |   +-head=$element_table.n#1
              |   | |   +-tail=$element_table.n#1
              |   | +-input_scan=
              |   |   +-SingleRowScan
              |   +-ProjectScan
              |     +-column_list=$graph_table.[name_val#3, count_val#2]
              |     +-input_scan=
              |       +-AggregateScan
              |         +-column_list=$graph_table.[name_val#3, count_val#2]
              |         +-input_scan=
              |         | +-GraphRefScan(column_list=[$element_table.n#1])
              |         +-group_by_list=
              |         | +-name_val#3 :=
              |         |   +-GraphGetElementProperty
              |         |     +-type=STRING
              |         |     +-expr=
              |         |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n#1)
              |         |     +-property=name(STRING)
              |         +-aggregate_list=
              |           +-count_val#2 :=
              |             +-AggregateFunctionCall(GoogleSQL:count(GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>) -> INT64)
              |               +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n#1)
              +-GraphLinearScan
                +-column_list=$graph_table.[name_val#4, count_val#5]
                +-scan_list=
                  +-ProjectScan
                    +-column_list=$graph_table.[name_val#4, count_val#5]
                    +-expr_list=
                    | +-name_val#4 := ColumnRef(type=STRING, column=$graph_table.name_val#3)
                    | +-count_val#5 := ColumnRef(type=INT64, column=$graph_table.count_val#2)
                    +-input_scan=
                      +-GraphRefScan(column_list=$graph_table.[name_val#3, count_val#2])

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aml_1.a_5 AS name_val,
  aml_1.a_6 AS count_val
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS Person)
    RETURN
      a_2.name AS a_3,
      COUNT(a_2) AS a_4
    GROUP BY a_3
    NEXT
    RETURN
      a_3 AS a_5,
      a_4 AS a_6
  ) AS aml_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS Person)
    RETURN
      a_2.name AS a_3,
      COUNT(a_2) AS a_4
    GROUP BY a_3
    NEXT
    RETURN
      a_3 AS a_5,
      a_4 AS a_6
  ) AS aml_1
|> SELECT
     aml_1.a_5 AS name_val,
     aml_1.a_6 AS count_val;
