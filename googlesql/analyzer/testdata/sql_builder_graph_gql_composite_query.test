SELECT
  graphtablescan_20.a_8 AS name,
  graphtablescan_20.a_9 AS distinct_ids,
  graphtablescan_20.a_10 AS first_acc_id
FROM
  (
    SELECT
      aml_1.a_11 AS a_11,
      aml_1.a_13 AS a_13,
      aml_1.a_12 AS a_12,
      aml_1.a_8 AS a_8,
      aml_1.a_9 AS a_9,
      aml_1.a_10 AS a_10
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_2 IS Person)
          -[a_3 IS (% | ! %)]->
          (a_4 IS Account)
        RETURN DISTINCT
          a_2.name AS a_5,
          COUNT(DISTINCT a_2.id) AS a_6,
          ARRAY_AGG(a_4.id)[OFFSET(0)] AS a_7
        GROUP BY a_2.name
        NEXT
        MATCH
          (a_14 IS Person)
          -[a_15 IS (% | ! %)]->
          (a_16 IS Account)
        RETURN
          a_5 AS a_8,
          a_6 AS a_9,
          a_7 AS a_10,
          a_14 AS a_11,
          a_15 AS a_12,
          a_16 AS a_13
        UNION ALL
        MATCH
          (a_17 IS Person)
          -[a_18 IS (% | ! %)]->
          (a_19 IS Account)
        RETURN
          a_17 AS a_11,
          a_19 AS a_13,
          a_18 AS a_12,
          "Alice" AS a_8,
          1 AS a_9,
          100 AS a_10
      ) AS aml_1
  ) AS graphtablescan_20;

