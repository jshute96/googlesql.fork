# Repro for b/330730443
# SQLBuilder test for GQL RETURN * and ORDER BY.
SELECT p.name AS person_name, a.id AS account_id
FROM graph_table(aml
  MATCH (p:Person)-[e]->(a:Account)
  RETURN *
  ORDER BY p.name, a.id
) gt
--
QueryStmt
+-output_column_list=
| +-$query.person_name#9 AS person_name [STRING]
| +-$query.account_id#10 AS account_id [INT64]
+-query=
  +-ProjectScan
    +-column_list=$query.[person_name#9, account_id#10]
    +-expr_list=
    | +-person_name#9 :=
    | | +-GraphGetElementProperty
    | |   +-type=STRING
    | |   +-expr=
    | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$graph_table.p#4)
    | |   +-property=name(STRING)
    | +-account_id#10 :=
    |   +-GraphGetElementProperty
    |     +-type=INT64
    |     +-expr=
    |     | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$graph_table.a#6)
    |     +-property=id(INT64)
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_table.[p#4, e#5, a#6]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_table.[p#4, e#5, a#6]
            +-scan_list=
              +-GraphLinearScan
                +-column_list=$graph_table.[p#4, e#5, a#6]
                +-scan_list=
                  +-GraphScan
                  | +-column_list=$element_table.[p#1, e#2, a#3]
                  | +-input_scan_list=
                  | | +-GraphPathScan
                  | |   +-column_list=$element_table.[p#1, e#2, a#3]
                  | |   +-input_scan_list=
                  | |   | +-GraphNodeScan
                  | |   | | +-column_list=[$element_table.p#1]
                  | |   | | +-label_expr=
                  | |   | | | +-GraphLabel(parse_location=81-87, label=aml.Person)
                  | |   | | +-target_element_table_list=[aml.Person]
                  | |   | +-GraphEdgeScan
                  | |   | | +-column_list=[$element_table.e#2]
                  | |   | | +-label_expr=
                  | |   | | | +-GraphLabelNaryExpr
                  | |   | | |   +-op=OR
                  | |   | | |   +-operand_list=
                  | |   | | |     +-GraphWildCardLabel
                  | |   | | |     +-GraphLabelNaryExpr
                  | |   | | |       +-op=NOT
                  | |   | | |       +-operand_list=
                  | |   | | |         +-GraphWildCardLabel
                  | |   | | +-target_element_table_list=[aml.PersonOwnAccount,aml.Transfer]
                  | |   | | +-orientation=RIGHT
                  | |   | +-GraphNodeScan
                  | |   |   +-column_list=[$element_table.a#3]
                  | |   |   +-label_expr=
                  | |   |   | +-GraphLabel(parse_location=97-104, label=aml.Account)
                  | |   |   +-target_element_table_list=[aml.Account]
                  | |   +-head=$element_table.p#1
                  | |   +-tail=$element_table.a#3
                  | +-input_scan=
                  |   +-SingleRowScan
                  +-OrderByScan
                    +-column_list=$graph_table.[p#4, e#5, a#6]
                    +-is_ordered=TRUE
                    +-input_scan=
                    | +-ProjectScan
                    |   +-column_list=[$element_table.p#1, $element_table.e#2, $element_table.a#3, $graph_table.p#4, $graph_table.e#5, $graph_table.a#6, $orderby.$orderbycol1#7, $orderby.$orderbycol2#8]
                    |   +-expr_list=
                    |   | +-$orderbycol1#7 :=
                    |   | | +-GraphGetElementProperty
                    |   | |   +-type=STRING
                    |   | |   +-expr=
                    |   | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$graph_table.p#4)
                    |   | |   +-property=name(STRING)
                    |   | +-$orderbycol2#8 :=
                    |   |   +-GraphGetElementProperty
                    |   |     +-type=INT64
                    |   |     +-expr=
                    |   |     | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$graph_table.a#6)
                    |   |     +-property=id(INT64)
                    |   +-input_scan=
                    |     +-ProjectScan
                    |       +-column_list=[$element_table.p#1, $element_table.e#2, $element_table.a#3, $graph_table.p#4, $graph_table.e#5, $graph_table.a#6]
                    |       +-expr_list=
                    |       | +-p#4 := ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                    |       | +-e#5 := ColumnRef(type=GRAPH_EDGE(aml)<accountId INT64, amount UINT64, personId INT64, targetAccountId INT64>, column=$element_table.e#2)
                    |       | +-a#6 := ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a#3)
                    |       +-input_scan=
                    |         +-GraphRefScan(column_list=$element_table.[p#1, e#2, a#3])
                    +-order_by_item_list=
                      +-OrderByItem
                      | +-column_ref=
                      |   +-ColumnRef(type=STRING, column=$orderby.$orderbycol1#7)
                      +-OrderByItem
                        +-column_ref=
                          +-ColumnRef(type=INT64, column=$orderby.$orderbycol2#8)

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  graphtablescan_8.a_5.name AS person_name,
  graphtablescan_8.a_7.id AS account_id
FROM
  (
    SELECT
      aml_1.a_5 AS a_5,
      aml_1.a_6 AS a_6,
      aml_1.a_7 AS a_7
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_2 IS Person)
          -[a_3 IS (% | ! %)]->
          (a_4 IS Account)
        RETURN
          a_2 AS a_5,
          a_3 AS a_6,
          a_4 AS a_7
        ORDER BY a_2.name, a_4.id
      ) AS aml_1
  ) AS graphtablescan_8;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_2 IS Person)
      -[a_3 IS (% | ! %)]->
      (a_4 IS Account)
    RETURN
      a_2 AS a_5,
      a_3 AS a_6,
      a_4 AS a_7
    ORDER BY a_2.name, a_4.id
  ) AS aml_1
|> SELECT
     aml_1.a_5 AS a_5,
     aml_1.a_6 AS a_6,
     aml_1.a_7 AS a_7
|> AS graphtablescan_8
|> SELECT
     graphtablescan_8.a_5.name AS person_name,
     graphtablescan_8.a_7.id AS account_id;
