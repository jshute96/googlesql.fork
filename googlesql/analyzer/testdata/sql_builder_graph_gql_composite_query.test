[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  aml_1.a_14 AS name,
  aml_1.a_15 AS distinct_ids,
  aml_1.a_16 AS first_acc_id
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_5 IS Person)
      -[a_6 IS (% | ! %)]->
      (a_7 IS Account)
    RETURN
      a_5 AS a_2,
      a_6 AS a_3,
      a_7 AS a_4
    UNION ALL
    MATCH
      (a_8 IS Person)
      -[a_9 IS (% | ! %)]->
      (a_10 IS Account)
    RETURN
      a_8 AS a_2,
      a_10 AS a_4,
      a_9 AS a_3
    NEXT
    MATCH
      (a_11 IS Person)
      -[a_12 IS (% | ! %)]->
      (a_13 IS Account)
      WHERE
        (a_13 = a_4) AND (a_12 = a_3) AND (a_11 = a_2)
    RETURN DISTINCT
      a_11.name AS a_14,
      COUNT(DISTINCT a_11.id) AS a_15,
      ARRAY_AGG(a_13.id)[OFFSET(0)] AS a_16
    GROUP BY a_11.name
  ) AS aml_1;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_5 IS Person)
      -[a_6 IS (% | ! %)]->
      (a_7 IS Account)
    RETURN
      a_5 AS a_2,
      a_6 AS a_3,
      a_7 AS a_4
    UNION ALL
    MATCH
      (a_8 IS Person)
      -[a_9 IS (% | ! %)]->
      (a_10 IS Account)
    RETURN
      a_8 AS a_2,
      a_10 AS a_4,
      a_9 AS a_3
    NEXT
    MATCH
      (a_11 IS Person)
      -[a_12 IS (% | ! %)]->
      (a_13 IS Account)
      WHERE
        (a_13 = a_4) AND (a_12 = a_3) AND (a_11 = a_2)
    RETURN DISTINCT
      a_11.name AS a_14,
      COUNT(DISTINCT a_11.id) AS a_15,
      ARRAY_AGG(a_13.id)[OFFSET(0)] AS a_16
    GROUP BY a_11.name
  ) AS aml_1
|> SELECT
     aml_1.a_14 AS name,
     aml_1.a_15 AS distinct_ids,
     aml_1.a_16 AS first_acc_id;
==

# SQLBuilder test for GQL set op after NEXT.
select name, distinct_ids, first_acc_id
from
graph_table(aml
  MATCH (p:Person)-[e]->(a:Account)
  RETURN distinct p.name as name, COUNT(DISTINCT p.id) as distinct_ids, ARRAY_AGG(a.id)[OFFSET(0)] AS first_acc_id
    GROUP BY name

  NEXT

  MATCH (p:Person)-[e]->(a:Account)
  RETURN *
  UNION ALL
  MATCH (p:Person)-[e]->(a:Account)
  RETURN p, a, e, "Alice" AS name, 1 AS distinct_ids, 100 AS first_acc_id
) gt
