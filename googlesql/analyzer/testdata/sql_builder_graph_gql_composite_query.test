# SQLBuilder test for GQL set op with RETURN *.
select gt.* from
graph_table(aml
  MATCH (p:Person)-[e]->(a:Account)
  RETURN *
  UNION ALL
  MATCH (p:Person)-[e]->(a:Account)
  RETURN p, a, e

  NEXT

  MATCH (p:Person)-[e]->(a:Account)
  RETURN distinct p.name as name, COUNT(DISTINCT p.id) as distinct_ids, ARRAY_AGG(a.id)[OFFSET(0)] AS first_acc_id
    GROUP BY name
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_table.name#23 AS name [STRING]
| +-$graph_table.distinct_ids#24 AS distinct_ids [INT64]
| +-$graph_table.first_acc_id#25 AS first_acc_id [INT64]
+-query=
  +-ProjectScan
    +-column_list=$graph_table.[name#23, distinct_ids#24, first_acc_id#25]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_table.[name#23, distinct_ids#24, first_acc_id#25]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_table.[name#23, distinct_ids#24, first_acc_id#25]
            +-scan_list=
              +-SetOperationScan
              | +-column_list=$graph_set_op.[p#13, e#14, a#15]
              | +-op_type=UNION_ALL
              | +-input_item_list=
              | | +-SetOperationItem
              | | | +-scan=
              | | | | +-GraphLinearScan
              | | | |   +-column_list=$graph_table.[p#4, e#5, a#6]
              | | | |   +-scan_list=
              | | | |     +-GraphScan
              | | | |     | +-column_list=$element_table.[p#1, e#2, a#3]
              | | | |     | +-input_scan_list=
              | | | |     | | +-GraphPathScan
              | | | |     | |   +-column_list=$element_table.[p#1, e#2, a#3]
              | | | |     | |   +-input_scan_list=
              | | | |     | |   | +-GraphNodeScan
              | | | |     | |   | | +-column_list=[$element_table.p#1]
              | | | |     | |   | | +-label_expr=
              | | | |     | |   | | | +-GraphLabel(parse_location=44-50, label=aml.Person)
              | | | |     | |   | | +-target_element_table_list=[aml.Person]
              | | | |     | |   | +-GraphEdgeScan
              | | | |     | |   | | +-column_list=[$element_table.e#2]
              | | | |     | |   | | +-label_expr=
              | | | |     | |   | | | +-GraphLabelNaryExpr
              | | | |     | |   | | |   +-op=OR
              | | | |     | |   | | |   +-operand_list=
              | | | |     | |   | | |     +-GraphWildCardLabel
              | | | |     | |   | | |     +-GraphLabelNaryExpr
              | | | |     | |   | | |       +-op=NOT
              | | | |     | |   | | |       +-operand_list=
              | | | |     | |   | | |         +-GraphWildCardLabel
              | | | |     | |   | | +-target_element_table_list=[aml.PersonOwnAccount,aml.Transfer]
              | | | |     | |   | | +-orientation=RIGHT
              | | | |     | |   | +-GraphNodeScan
              | | | |     | |   |   +-column_list=[$element_table.a#3]
              | | | |     | |   |   +-label_expr=
              | | | |     | |   |   | +-GraphLabel(parse_location=60-67, label=aml.Account)
              | | | |     | |   |   +-target_element_table_list=[aml.Account]
              | | | |     | |   +-head=$element_table.p#1
              | | | |     | |   +-tail=$element_table.a#3
              | | | |     | +-input_scan=
              | | | |     |   +-SingleRowScan
              | | | |     +-ProjectScan
              | | | |       +-column_list=$graph_table.[p#4, e#5, a#6]
              | | | |       +-expr_list=
              | | | |       | +-p#4 := ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
              | | | |       | +-e#5 := ColumnRef(type=GRAPH_EDGE(aml)<accountId INT64, amount UINT64, personId INT64, targetAccountId INT64>, column=$element_table.e#2)
              | | | |       | +-a#6 := ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a#3)
              | | | |       +-input_scan=
              | | | |         +-GraphRefScan(column_list=$element_table.[p#1, e#2, a#3])
              | | | +-output_column_list=$graph_table.[p#4, e#5, a#6]
              | | +-SetOperationItem
