SELECT
  projectscan_8.a_2 AS name,
  projectscan_8.a_3 AS number,
  projectscan_8.a_4 AS concat_str
FROM
  (
    SELECT
      aml_1.a_2 AS a_2,
      aml_1.a_4 AS a_4,
      aml_1.a_3 AS a_3
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_5 IS (% | ! %))
        RETURN
          a_5.name AS a_2,
          1 AS a_3,
          CONCAT("str", "_suffix") AS a_4
        UNION DISTINCT
        MATCH
          (a_6 IS (% | ! %))
        RETURN
          2 AS a_3,
          a_6.name AS a_2,
          CONCAT("str", "_suffix") AS a_4
        UNION DISTINCT
        MATCH
          (a_7 IS (% | ! %))
        RETURN
          a_7.name AS a_2,
          CONCAT("str", "_suffix") AS a_4,
          3 AS a_3
      ) AS aml_1
  ) AS projectscan_8;

