[default language_features=NONE,+ORDER_BY_COLLATE,+NULLS_FIRST_LAST_IN_ORDER_BY,+SQL_GRAPH,+SQL_GRAPH_ADVANCED_QUERY,+SQL_GRAPH_EXPOSE_GRAPH_ELEMENT,+SQL_GRAPH_BOUNDED_PATH_QUANTIFICATION]
[default no_test_extract_table_names]
[default enabled_ast_rewrites=DEFAULTS]
[default run_sqlbuilder]
[default show_sqlbuilder_output]

# SQLBuilder test for GQL set op with two inputs.
select gt.* from
graph_table(aml
  match (n)
  return n.name, 1 AS number, CONCAT("str", "_suffix") AS concat_str
  UNION ALL
  match (n)
  return 2 AS number, n.name, CONCAT("str", "_suffix") AS concat_str
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_set_op.name#9 AS name [STRING]
| +-$graph_set_op.number#10 AS number [INT64]
| +-$graph_set_op.concat_str#11 AS concat_str [STRING]
+-query=
  +-ProjectScan
    +-column_list=$graph_set_op.[name#9, number#10, concat_str#11]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_set_op.[name#9, number#10, concat_str#11]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_set_op.[name#9, number#10, concat_str#11]
            +-scan_list=
              +-SetOperationScan
                +-column_list=$graph_set_op.[name#9, number#10, concat_str#11]
                +-op_type=UNION_ALL
                +-input_item_list=
                | +-SetOperationItem
                | | +-scan=
                | | | +-GraphLinearScan
                | | |   +-column_list=$graph_table.[name#2, number#3, concat_str#4]
                | | |   +-scan_list=
                | | |     +-GraphScan
                | | |     | +-column_list=[$element_table.n#1]
                | | |     | +-input_scan_list=
                | | |     | | +-GraphPathScan
                | | |     | |   +-column_list=[$element_table.n#1]
                | | |     | |   +-input_scan_list=
                | | |     | |   | +-GraphNodeScan
                | | |     | |   |   +-column_list=[$element_table.n#1]
                | | |     | |   |   +-label_expr=
                | | |     | |   |   | +-GraphLabelNaryExpr
                | | |     | |   |   |   +-op=OR
                | | |     | |   |   |   +-operand_list=
                | | |     | |   |   |     +-GraphWildCardLabel
                | | |     | |   |   |     +-GraphLabelNaryExpr
                | | |     | |   |   |       +-op=NOT
                | | |     | |   |   |       +-operand_list=
                | | |     | |   |   |         +-GraphWildCardLabel
                | | |     | |   |   +-target_element_table_list=[aml.Account,aml.Person,aml.Syndicate]
                | | |     | |   +-head=$element_table.n#1
                | | |     | |   +-tail=$element_table.n#1
                | | |     | +-input_scan=
                | | |     |   +-SingleRowScan
                | | |     +-ProjectScan
                | | |       +-column_list=$graph_table.[name#2, number#3, concat_str#4]
                | | |       +-expr_list=
                | | |       | +-name#2 :=
                | | |       | | +-GraphGetElementProperty
                | | |       | |   +-type=STRING
                | | |       | |   +-expr=
                | | |       | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>, column=$element_table.n#1)
                | | |       | |   +-property=name(STRING)
                | | |       | +-number#3 := Literal(type=INT64, value=1)
                | | |       | +-concat_str#4 :=
                | | |       |   +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
                | | |       |     +-Literal(type=STRING, value="str")
                | | |       |     +-Literal(type=STRING, value="_suffix")
                | | |       +-input_scan=
                | | |         +-GraphRefScan(column_list=[$element_table.n#1])
                | | +-output_column_list=$graph_table.[name#2, number#3, concat_str#4]
                | +-SetOperationItem
                |   +-scan=
                |   | +-GraphLinearScan
                |   |   +-column_list=$graph_table.[name#7, number#6, concat_str#8]
                |   |   +-scan_list=
                |   |     +-GraphScan
                |   |     | +-column_list=[$element_table.n#5]
                |   |     | +-input_scan_list=
                |   |     | | +-GraphPathScan
                |   |     | |   +-column_list=[$element_table.n#5]
                |   |     | |   +-input_scan_list=
                |   |     | |   | +-GraphNodeScan
                |   |     | |   |   +-column_list=[$element_table.n#5]
                |   |     | |   |   +-label_expr=
                |   |     | |   |   | +-GraphLabelNaryExpr
                |   |     | |   |   |   +-op=OR
                |   |     | |   |   |   +-operand_list=
                |   |     | |   |   |     +-GraphWildCardLabel
                |   |     | |   |   |     +-GraphLabelNaryExpr
                |   |     | |   |   |       +-op=NOT
                |   |     | |   |   |       +-operand_list=
                |   |     | |   |   |         +-GraphWildCardLabel
                |   |     | |   |   +-target_element_table_list=[aml.Account,aml.Person,aml.Syndicate]
                |   |     | |   +-head=$element_table.n#5
                |   |     | |   +-tail=$element_table.n#5
                |   |     | +-input_scan=
                |   |     |   +-SingleRowScan
                |   |     +-ProjectScan
                |   |       +-column_list=$graph_table.[number#6, name#7, concat_str#8]
                |   |       +-expr_list=
                |   |       | +-number#6 := Literal(type=INT64, value=2)
                |   |       | +-name#7 :=
                |   |       | | +-GraphGetElementProperty
                |   |       | |   +-type=STRING
                |   |       | |   +-expr=
                |   |       | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, balance UINT64, birthday DATE, data BYTES, id INT64, name STRING, syndicateData ARRAY<INT64>, syndicateId INT64, syndicateName STRING>, column=$element_table.n#5)
                |   |       | |   +-property=name(STRING)
                |   |       | +-concat_str#8 :=
                |   |       |   +-FunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
                |   |       |     +-Literal(type=STRING, value="str")
                |   |       |     +-Literal(type=STRING, value="_suffix")
                |   |       +-input_scan=
                |   |         +-GraphRefScan(column_list=[$element_table.n#5])
                |   +-output_column_list=$graph_table.[name#7, number#6, concat_str#8]
                +-column_match_mode=CORRESPONDING

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  projectscan_7.a_2 AS name,
  projectscan_7.a_3 AS number,
  projectscan_7.a_4 AS concat_str
FROM
  (
    SELECT
      aml_1.a_3 AS a_3,
      aml_1.a_2 AS a_2,
      aml_1.a_4 AS a_4
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_5 IS (% | ! %))
        RETURN
          a_5.name AS a_2,
          1 AS a_3,
          CONCAT("str", "_suffix") AS a_4
        UNION ALL
        MATCH
          (a_6 IS (% | ! %))
        RETURN
          2 AS a_3,
          a_6.name AS a_2,
          CONCAT("str", "_suffix") AS a_4
      ) AS aml_1
  ) AS projectscan_7;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_5 IS (% | ! %))
    RETURN
      a_5.name AS a_2,
      1 AS a_3,
      CONCAT("str", "_suffix") AS a_4
    UNION ALL
    MATCH
      (a_6 IS (% | ! %))
    RETURN
      2 AS a_3,
      a_6.name AS a_2,
      CONCAT("str", "_suffix") AS a_4
  ) AS aml_1
|> SELECT
     aml_1.a_3 AS a_3,
     aml_1.a_2 AS a_2,
     aml_1.a_4 AS a_4
|> AS projectscan_7
|> SELECT
     projectscan_7.a_2 AS name,
     projectscan_7.a_3 AS number,
     projectscan_7.a_4 AS concat_str;
==

# SQLBuilder test for GQL set op with ORDER BY and GROUP BY in each RETURN.
select gt.* from
graph_table(aml
  MATCH (p:Person)-[e]->(a:Account)
  RETURN distinct p.name as name, COUNT(DISTINCT p.id) as distinct_ids, ARRAY_AGG(a.id)[OFFSET(0)] AS first_acc_id
    GROUP BY name
  UNION ALL
  MATCH (p:Person)-[e]->(a:Account)
  RETURN DISTINCT
    COUNT(DISTINCT p.id) as distinct_ids, ARRAY_AGG(a.id)[OFFSET(0)] AS first_acc_id, p.name as name
    GROUP BY name
    ORDER BY name COLLATE "en_US" DESC NULLS LAST
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_set_op.name#22 AS name [STRING]
| +-$graph_set_op.distinct_ids#23 AS distinct_ids [INT64]
| +-$graph_set_op.first_acc_id#24 AS first_acc_id [INT64]
+-query=
  +-ProjectScan
    +-column_list=$graph_set_op.[name#22, distinct_ids#23, first_acc_id#24]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_set_op.[name#22, distinct_ids#23, first_acc_id#24]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_set_op.[name#22, distinct_ids#23, first_acc_id#24]
            +-scan_list=
              +-SetOperationScan
                +-column_list=$graph_set_op.[name#22, distinct_ids#23, first_acc_id#24]
                +-op_type=UNION_ALL
                +-input_item_list=
                | +-SetOperationItem
                | | +-scan=
                | | | +-GraphLinearScan
                | | |   +-column_list=$graph_table.[name#8, distinct_ids#9, first_acc_id#10]
                | | |   +-scan_list=
                | | |     +-GraphScan
                | | |     | +-column_list=$element_table.[p#1, e#2, a#3]
                | | |     | +-input_scan_list=
                | | |     | | +-GraphPathScan
                | | |     | |   +-column_list=$element_table.[p#1, e#2, a#3]
                | | |     | |   +-input_scan_list=
                | | |     | |   | +-GraphNodeScan
                | | |     | |   | | +-column_list=[$element_table.p#1]
                | | |     | |   | | +-label_expr=
                | | |     | |   | | | +-GraphLabel(parse_location=44-50, label=aml.Person)
                | | |     | |   | | +-target_element_table_list=[aml.Person]
                | | |     | |   | +-GraphEdgeScan
                | | |     | |   | | +-column_list=[$element_table.e#2]
                | | |     | |   | | +-label_expr=
                | | |     | |   | | | +-GraphLabelNaryExpr
                | | |     | |   | | |   +-op=OR
                | | |     | |   | | |   +-operand_list=
                | | |     | |   | | |     +-GraphWildCardLabel
                | | |     | |   | | |     +-GraphLabelNaryExpr
                | | |     | |   | | |       +-op=NOT
                | | |     | |   | | |       +-operand_list=
                | | |     | |   | | |         +-GraphWildCardLabel
                | | |     | |   | | +-target_element_table_list=[aml.PersonOwnAccount,aml.Transfer]
                | | |     | |   | | +-orientation=RIGHT
                | | |     | |   | +-GraphNodeScan
                | | |     | |   |   +-column_list=[$element_table.a#3]
                | | |     | |   |   +-label_expr=
                | | |     | |   |   | +-GraphLabel(parse_location=60-67, label=aml.Account)
                | | |     | |   |   +-target_element_table_list=[aml.Account]
                | | |     | |   +-head=$element_table.p#1
                | | |     | |   +-tail=$element_table.a#3
                | | |     | +-input_scan=
                | | |     |   +-SingleRowScan
                | | |     +-AggregateScan
                | | |       +-column_list=$graph_table.[name#8, distinct_ids#9, first_acc_id#10]
                | | |       +-input_scan=
                | | |       | +-ProjectScan
                | | |       |   +-column_list=$graph_table.[name#6, distinct_ids#4, $agg2#5, first_acc_id#7]
                | | |       |   +-expr_list=
                | | |       |   | +-first_acc_id#7 :=
                | | |       |   |   +-FunctionCall(GoogleSQL:$array_at_offset(ARRAY<INT64>, INT64) -> INT64)
                | | |       |   |     +-ColumnRef(type=ARRAY<INT64>, column=$graph_table.$agg2#5)
                | | |       |   |     +-Literal(type=INT64, value=0)
                | | |       |   +-input_scan=
                | | |       |     +-AggregateScan
                | | |       |       +-column_list=$graph_table.[name#6, distinct_ids#4, $agg2#5]
                | | |       |       +-input_scan=
                | | |       |       | +-GraphRefScan(column_list=$element_table.[p#1, e#2, a#3])
                | | |       |       +-group_by_list=
                | | |       |       | +-name#6 :=
                | | |       |       |   +-GraphGetElementProperty
                | | |       |       |     +-type=STRING
                | | |       |       |     +-expr=
                | | |       |       |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                | | |       |       |     +-property=name(STRING)
                | | |       |       +-aggregate_list=
                | | |       |         +-distinct_ids#4 :=
                | | |       |         | +-AggregateFunctionCall(GoogleSQL:count(INT64) -> INT64)
                | | |       |         |   +-GraphGetElementProperty
                | | |       |         |   | +-type=INT64
                | | |       |         |   | +-expr=
                | | |       |         |   | | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                | | |       |         |   | +-property=id(INT64)
                | | |       |         |   +-distinct=TRUE
                | | |       |         +-$agg2#5 :=
                | | |       |           +-AggregateFunctionCall(GoogleSQL:array_agg(INT64) -> ARRAY<INT64>)
                | | |       |             +-GraphGetElementProperty
                | | |       |               +-type=INT64
                | | |       |               +-expr=
                | | |       |               | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a#3)
                | | |       |               +-property=id(INT64)
                | | |       +-group_by_list=
                | | |         +-name#8 := ColumnRef(type=STRING, column=$graph_table.name#6)
                | | |         +-distinct_ids#9 := ColumnRef(type=INT64, column=$graph_table.distinct_ids#4)
                | | |         +-first_acc_id#10 := ColumnRef(type=INT64, column=$graph_table.first_acc_id#7)
                | | +-output_column_list=$graph_table.[name#8, distinct_ids#9, first_acc_id#10]
                | +-SetOperationItem
                |   +-scan=
                |   | +-GraphLinearScan
                |   |   +-column_list=$graph_table.[name#21, distinct_ids#19, first_acc_id#20]
                |   |   +-scan_list=
                |   |     +-GraphScan
                |   |     | +-column_list=$element_table.[p#11, e#12, a#13]
                |   |     | +-input_scan_list=
                |   |     | | +-GraphPathScan
                |   |     | |   +-column_list=$element_table.[p#11, e#12, a#13]
                |   |     | |   +-input_scan_list=
                |   |     | |   | +-GraphNodeScan
                |   |     | |   | | +-column_list=[$element_table.p#11]
                |   |     | |   | | +-label_expr=
                |   |     | |   | | | +-GraphLabel(parse_location=225-231, label=aml.Person)
                |   |     | |   | | +-target_element_table_list=[aml.Person]
                |   |     | |   | +-GraphEdgeScan
                |   |     | |   | | +-column_list=[$element_table.e#12]
                |   |     | |   | | +-label_expr=
                |   |     | |   | | | +-GraphLabelNaryExpr
                |   |     | |   | | |   +-op=OR
                |   |     | |   | | |   +-operand_list=
                |   |     | |   | | |     +-GraphWildCardLabel
                |   |     | |   | | |     +-GraphLabelNaryExpr
                |   |     | |   | | |       +-op=NOT
                |   |     | |   | | |       +-operand_list=
                |   |     | |   | | |         +-GraphWildCardLabel
                |   |     | |   | | +-target_element_table_list=[aml.PersonOwnAccount,aml.Transfer]
                |   |     | |   | | +-orientation=RIGHT
                |   |     | |   | +-GraphNodeScan
                |   |     | |   |   +-column_list=[$element_table.a#13]
                |   |     | |   |   +-label_expr=
                |   |     | |   |   | +-GraphLabel(parse_location=241-248, label=aml.Account)
                |   |     | |   |   +-target_element_table_list=[aml.Account]
                |   |     | |   +-head=$element_table.p#11
                |   |     | |   +-tail=$element_table.a#13
                |   |     | +-input_scan=
                |   |     |   +-SingleRowScan
                |   |     +-OrderByScan
                |   |       +-column_list=$graph_table.[distinct_ids#19, first_acc_id#20, name#21]
                |   |       +-is_ordered=TRUE
                |   |       +-input_scan=
                |   |       | +-AggregateScan
                |   |       |   +-column_list=$graph_table.[distinct_ids#19, first_acc_id#20, name#21]
                |   |       |   +-input_scan=
                |   |       |   | +-ProjectScan
                |   |       |   |   +-column_list=$graph_table.[name#17, distinct_ids#14, $agg2#15, first_acc_id#18]
                |   |       |   |   +-expr_list=
                |   |       |   |   | +-first_acc_id#18 :=
                |   |       |   |   |   +-FunctionCall(GoogleSQL:$array_at_offset(ARRAY<INT64>, INT64) -> INT64)
                |   |       |   |   |     +-ColumnRef(type=ARRAY<INT64>, column=$graph_table.$agg2#15)
                |   |       |   |   |     +-Literal(type=INT64, value=0)
                |   |       |   |   +-input_scan=
                |   |       |   |     +-AggregateScan
                |   |       |   |       +-column_list=$graph_table.[name#17, distinct_ids#14, $agg2#15]
                |   |       |   |       +-input_scan=
                |   |       |   |       | +-ProjectScan
                |   |       |   |       |   +-column_list=[$element_table.p#11, $element_table.e#12, $element_table.a#13, $pre_groupby.name#16]
                |   |       |   |       |   +-expr_list=
                |   |       |   |       |   | +-name#16 :=
                |   |       |   |       |   |   +-GraphGetElementProperty
                |   |       |   |       |   |     +-type=STRING
                |   |       |   |       |   |     +-expr=
                |   |       |   |       |   |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#11)
                |   |       |   |       |   |     +-property=name(STRING)
                |   |       |   |       |   +-input_scan=
                |   |       |   |       |     +-GraphRefScan(column_list=$element_table.[p#11, e#12, a#13])
                |   |       |   |       +-group_by_list=
