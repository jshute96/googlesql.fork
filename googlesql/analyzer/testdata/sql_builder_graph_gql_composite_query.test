                |   |       |   |       +-aggregate_list=
                |   |       |   |         +-distinct_ids#14 :=
                |   |       |   |         | +-AggregateFunctionCall(GoogleSQL:count(INT64) -> INT64)
                |   |       |   |         |   +-GraphGetElementProperty
                |   |       |   |         |   | +-type=INT64
                |   |       |   |         |   | +-expr=
                |   |       |   |         |   | | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#11)
                |   |       |   |         |   | +-property=id(INT64)
                |   |       |   |         |   +-distinct=TRUE
                |   |       |   |         +-$agg2#15 :=
                |   |       |   |           +-AggregateFunctionCall(GoogleSQL:array_agg(INT64) -> ARRAY<INT64>)
                |   |       |   |             +-GraphGetElementProperty
                |   |       |   |               +-type=INT64
                |   |       |   |               +-expr=
                |   |       |   |               | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a#13)
                |   |       |   |               +-property=id(INT64)
                |   |       |   +-group_by_list=
                |   |       |     +-distinct_ids#19 := ColumnRef(type=INT64, column=$graph_table.distinct_ids#14)
                |   |       |     +-first_acc_id#20 := ColumnRef(type=INT64, column=$graph_table.first_acc_id#18)
                |   |       |     +-name#21 := ColumnRef(type=STRING, column=$graph_table.name#17)
                |   |       +-order_by_item_list=
                |   |         +-OrderByItem
                |   |           +-column_ref=
                |   |           | +-ColumnRef(type=STRING, column=$graph_table.name#21)
                |   |           +-collation_name=
                |   |           | +-Literal(type=STRING, value="en_US")
                |   |           +-is_descending=TRUE
                |   |           +-null_order=NULLS_LAST
                |   +-output_column_list=$graph_table.[name#21, distinct_ids#19, first_acc_id#20]
                +-column_match_mode=CORRESPONDING

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  projectscan_11.a_2 AS name,
  projectscan_11.a_3 AS distinct_ids,
  projectscan_11.a_4 AS first_acc_id
FROM
  (
    SELECT
      aml_1.a_3 AS a_3,
      aml_1.a_4 AS a_4,
      aml_1.a_2 AS a_2
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_5 IS Person)
          -[a_6 IS (% | ! %)]->
          (a_7 IS Account)
        RETURN DISTINCT
          a_5.name AS a_2,
          COUNT(DISTINCT a_5.id) AS a_3,
          ARRAY_AGG(a_7.id)[OFFSET(0)] AS a_4
        GROUP BY a_5.name
        UNION ALL
        MATCH
          (a_8 IS Person)
          -[a_9 IS (% | ! %)]->
          (a_10 IS Account)
        RETURN DISTINCT
          COUNT(DISTINCT a_8.id) AS a_3,
          ARRAY_AGG(a_10.id)[OFFSET(0)] AS a_4,
          a_8.name AS a_2
        GROUP BY a_8.name
        ORDER BY a_2 COLLATE "en_US" DESC NULLS LAST
      ) AS aml_1
  ) AS projectscan_11;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
      (a_5 IS Person)
      -[a_6 IS (% | ! %)]->
      (a_7 IS Account)
    RETURN DISTINCT
      a_5.name AS a_2,
      COUNT(DISTINCT a_5.id) AS a_3,
      ARRAY_AGG(a_7.id)[OFFSET(0)] AS a_4
    GROUP BY a_5.name
    UNION ALL
    MATCH
      (a_8 IS Person)
      -[a_9 IS (% | ! %)]->
      (a_10 IS Account)
    RETURN DISTINCT
      COUNT(DISTINCT a_8.id) AS a_3,
      ARRAY_AGG(a_10.id)[OFFSET(0)] AS a_4,
      a_8.name AS a_2
    GROUP BY a_8.name
    ORDER BY a_2 COLLATE "en_US" DESC NULLS LAST
  ) AS aml_1
|> SELECT
     aml_1.a_3 AS a_3,
     aml_1.a_4 AS a_4,
     aml_1.a_2 AS a_2
|> AS projectscan_11
|> SELECT
     projectscan_11.a_2 AS name,
     projectscan_11.a_3 AS distinct_ids,
     projectscan_11.a_4 AS first_acc_id;
==

# SQLBuilder test for GQL set op with subquery, in a GRAPH_TABLE operator.
select gt.* from
graph_table(aml
  MATCH (n:Person)
  RETURN
    1 AS id,
    EXISTS {
      GRAPH aml
      MATCH (n2:Person where n2.name = 'Dana')
      RETURN 1 as one
    } AS val
  UNION ALL
  MATCH (n:Person)
  RETURN
    EXISTS {
      GRAPH aml
      MATCH (n2:Person where n2.name = 'Dana')
      RETURN 1 as one
    } AS val,
    2 AS id
) gt
--
QueryStmt
+-output_column_list=
| +-$graph_set_op.id#11 AS id [INT64]
| +-$graph_set_op.val#12 AS val [BOOL]
+-query=
  +-ProjectScan
    +-column_list=$graph_set_op.[id#11, val#12]
    +-input_scan=
      +-GraphTableScan
        +-column_list=$graph_set_op.[id#11, val#12]
        +-property_graph=aml
        +-input_scan=
          +-GraphLinearScan
            +-column_list=$graph_set_op.[id#11, val#12]
            +-scan_list=
              +-SetOperationScan
                +-column_list=$graph_set_op.[id#11, val#12]
                +-op_type=UNION_ALL
                +-input_item_list=
                | +-SetOperationItem
                | | +-scan=
                | | | +-GraphLinearScan
                | | |   +-column_list=$graph_table.[id#4, val#5]
                | | |   +-scan_list=
                | | |     +-GraphScan
                | | |     | +-column_list=[$element_table.n#1]
                | | |     | +-input_scan_list=
                | | |     | | +-GraphPathScan
                | | |     | |   +-column_list=[$element_table.n#1]
                | | |     | |   +-input_scan_list=
                | | |     | |   | +-GraphNodeScan
                | | |     | |   |   +-column_list=[$element_table.n#1]
                | | |     | |   |   +-label_expr=
                | | |     | |   |   | +-GraphLabel(parse_location=44-50, label=aml.Person)
                | | |     | |   |   +-target_element_table_list=[aml.Person]
                | | |     | |   +-head=$element_table.n#1
                | | |     | |   +-tail=$element_table.n#1
                | | |     | +-input_scan=
                | | |     |   +-SingleRowScan
                | | |     +-ProjectScan
                | | |       +-column_list=$graph_table.[id#4, val#5]
                | | |       +-expr_list=
                | | |       | +-id#4 := Literal(type=INT64, value=1)
                | | |       | +-val#5 :=
                | | |       |   +-SubqueryExpr
                | | |       |     +-type=BOOL
                | | |       |     +-subquery_type=EXISTS
                | | |       |     +-subquery=
                | | |       |       +-GraphTableScan
                | | |       |         +-column_list=[$graph_table.one#3]
                | | |       |         +-property_graph=aml
                | | |       |         +-input_scan=
                | | |       |           +-GraphLinearScan
                | | |       |             +-column_list=[$graph_table.one#3]
                | | |       |             +-scan_list=
                | | |       |               +-GraphLinearScan
                | | |       |                 +-column_list=[$graph_table.one#3]
                | | |       |                 +-scan_list=
                | | |       |                   +-GraphScan
                | | |       |                   | +-column_list=[$element_table.n2#2]
                | | |       |                   | +-input_scan_list=
                | | |       |                   | | +-GraphPathScan
                | | |       |                   | |   +-column_list=[$element_table.n2#2]
                | | |       |                   | |   +-input_scan_list=
                | | |       |                   | |   | +-GraphNodeScan
                | | |       |                   | |   |   +-column_list=[$element_table.n2#2]
                | | |       |                   | |   |   +-filter_expr=
                | | |       |                   | |   |   | +-FunctionCall(GoogleSQL:$equal(STRING, STRING) -> BOOL)
                | | |       |                   | |   |   |   +-GraphGetElementProperty
                | | |       |                   | |   |   |   | +-type=STRING
                | | |       |                   | |   |   |   | +-expr=
                | | |       |                   | |   |   |   | | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n2#2)
                | | |       |                   | |   |   |   | +-property=name(STRING)
                | | |       |                   | |   |   |   +-Literal(type=STRING, value="Dana")
                | | |       |                   | |   |   +-label_expr=
                | | |       |                   | |   |   | +-GraphLabel(parse_location=119-125, label=aml.Person)
                | | |       |                   | |   |   +-target_element_table_list=[aml.Person]
                | | |       |                   | |   +-head=$element_table.n2#2
                | | |       |                   | |   +-tail=$element_table.n2#2
                | | |       |                   | +-input_scan=
                | | |       |                   |   +-SingleRowScan
                | | |       |                   +-ProjectScan
                | | |       |                     +-column_list=[$graph_table.one#3]
                | | |       |                     +-expr_list=
                | | |       |                     | +-one#3 := Literal(type=INT64, value=1)
                | | |       |                     +-input_scan=
                | | |       |                       +-GraphRefScan(column_list=[$element_table.n2#2])
                | | |       +-input_scan=
                | | |         +-GraphRefScan(column_list=[$element_table.n#1])
                | | +-output_column_list=$graph_table.[id#4, val#5]
                | +-SetOperationItem
                |   +-scan=
                |   | +-GraphLinearScan
                |   |   +-column_list=$graph_table.[id#10, val#9]
                |   |   +-scan_list=
                |   |     +-GraphScan
                |   |     | +-column_list=[$element_table.n#6]
                |   |     | +-input_scan_list=
                |   |     | | +-GraphPathScan
                |   |     | |   +-column_list=[$element_table.n#6]
                |   |     | |   +-input_scan_list=
                |   |     | |   | +-GraphNodeScan
                |   |     | |   |   +-column_list=[$element_table.n#6]
                |   |     | |   |   +-label_expr=
                |   |     | |   |   | +-GraphLabel(parse_location=208-214, label=aml.Person)
                |   |     | |   |   +-target_element_table_list=[aml.Person]
                |   |     | |   +-head=$element_table.n#6
                |   |     | |   +-tail=$element_table.n#6
                |   |     | +-input_scan=
                |   |     |   +-SingleRowScan
                |   |     +-ProjectScan
                |   |       +-column_list=$graph_table.[val#9, id#10]
                |   |       +-expr_list=
                |   |       | +-val#9 :=
                |   |       | | +-SubqueryExpr
                |   |       | |   +-type=BOOL
                |   |       | |   +-subquery_type=EXISTS
                |   |       | |   +-subquery=
                |   |       | |     +-GraphTableScan
                |   |       | |       +-column_list=[$graph_table.one#8]
                |   |       | |       +-property_graph=aml
                |   |       | |       +-input_scan=
                |   |       | |         +-GraphLinearScan
                |   |       | |           +-column_list=[$graph_table.one#8]
                |   |       | |           +-scan_list=
                |   |       | |             +-GraphLinearScan
                |   |       | |               +-column_list=[$graph_table.one#8]
                |   |       | |               +-scan_list=
                |   |       | |                 +-GraphScan
                |   |       | |                 | +-column_list=[$element_table.n2#7]
                |   |       | |                 | +-input_scan_list=
                |   |       | |                 | | +-GraphPathScan
                |   |       | |                 | |   +-column_list=[$element_table.n2#7]
                |   |       | |                 | |   +-input_scan_list=
                |   |       | |                 | |   | +-GraphNodeScan
                |   |       | |                 | |   |   +-column_list=[$element_table.n2#7]
                |   |       | |                 | |   |   +-filter_expr=
                |   |       | |                 | |   |   | +-FunctionCall(GoogleSQL:$equal(STRING, STRING) -> BOOL)
                |   |       | |                 | |   |   |   +-GraphGetElementProperty
                |   |       | |                 | |   |   |   | +-type=STRING
                |   |       | |                 | |   |   |   | +-expr=
                |   |       | |                 | |   |   |   | | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n2#7)
                |   |       | |                 | |   |   |   | +-property=name(STRING)
                |   |       | |                 | |   |   |   +-Literal(type=STRING, value="Dana")
                |   |       | |                 | |   |   +-label_expr=
                |   |       | |                 | |   |   | +-GraphLabel(parse_location=270-276, label=aml.Person)
                |   |       | |                 | |   |   +-target_element_table_list=[aml.Person]
                |   |       | |                 | |   +-head=$element_table.n2#7
                |   |       | |                 | |   +-tail=$element_table.n2#7
                |   |       | |                 | +-input_scan=
                |   |       | |                 |   +-SingleRowScan
                |   |       | |                 +-ProjectScan
                |   |       | |                   +-column_list=[$graph_table.one#8]
                |   |       | |                   +-expr_list=
                |   |       | |                   | +-one#8 := Literal(type=INT64, value=1)
                |   |       | |                   +-input_scan=
                |   |       | |                     +-GraphRefScan(column_list=[$element_table.n2#7])
                |   |       | +-id#10 := Literal(type=INT64, value=2)
                |   |       +-input_scan=
                |   |         +-GraphRefScan(column_list=[$element_table.n#6])
                |   +-output_column_list=$graph_table.[id#10, val#9]
                +-column_match_mode=CORRESPONDING

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
SELECT
  projectscan_10.a_2 AS id,
  projectscan_10.a_3 AS val
FROM
  (
    SELECT
      aml_1.a_3 AS a_3,
      aml_1.a_2 AS a_2
    FROM
      GRAPH_TABLE(
        aml
        MATCH
          (a_4 IS Person)
        RETURN
          1 AS a_2,
          EXISTS {
            GRAPH aml
            MATCH
              (a_5 IS Person
              WHERE
                (a_5.name) = "Dana")
            RETURN
              1 AS a_6
          } AS a_3
        UNION ALL
        MATCH
          (a_7 IS Person)
        RETURN
          EXISTS {
            GRAPH aml
            MATCH
              (a_8 IS Person
              WHERE
                (a_8.name) = "Dana")
            RETURN
              1 AS a_9
          } AS a_3,
          2 AS a_2
      ) AS aml_1
  ) AS projectscan_10;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
FROM
  GRAPH_TABLE(
    aml
    MATCH
