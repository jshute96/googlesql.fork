SELECT * FROM t
UNPIVOT(s FOR q IN (**COLUMNS(['a', 'b']) as 'columns'));
--
ERROR: Syntax error: Expected ")" or "," but got keyword AS [at 2:43]
UNPIVOT(s FOR q IN (**COLUMNS(['a', 'b']) as 'columns'));
                                          ^

