# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

select 1 from Foo
order by **cols {{|COLLATE 'binary'}} {{|ASC|DESC}} {{|NULLS FIRST|NULLS LAST}};

--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-33] [select 1 from...by **cols]
  Query [0-33] [select 1 from...by **cols]
    Select [0-17] [select 1 from Foo]
      SelectList [7-8] [1]
        SelectColumn [7-8] [1]
          IntLiteral(1) [7-8] [1]
      FromClause [9-17] [from Foo]
        TablePathExpression [14-17] [Foo]
          PathExpression [14-17] [Foo]
            Identifier(Foo) [14-17] [Foo]
    OrderBy [18-33] [order by **cols]
      OrderingExpression(ASC) [27-33] [**cols]
        UnpackExpression [27-33] [**cols]
          PathExpression [29-33] [cols]
            Identifier(cols) [29-33] [cols]
