    PipeOrderBy [9-33] [|> order by x, **cols ,y]
      OrderBy [12-33] [order by x, **cols ,y]
        OrderingExpression(ASC) [21-22] [x]
          PathExpression [21-22] [x]
            Identifier(x) [21-22] [x]
        OrderingExpression(ASC) [24-30] [**cols]
          UnpackExpression [24-30] [**cols]
            PathExpression [26-30] [cols]
              Identifier(cols) [26-30] [cols]
        OrderingExpression(ASC) [32-33] [y]
          PathExpression [32-33] [y]
            Identifier(y) [32-33] [y]
--
FROM
  Foo
|> ORDER BY x, ** (cols), y
