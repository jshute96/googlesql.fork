# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

from Foo
|> DROP {{|x,}} **cols {{|,**cols2}} {{|,y}};
--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-24] [from Foo |> DROP  **cols]
  Query [0-24] [from Foo |> DROP  **cols]
    FromQuery [0-8] [from Foo]
      FromClause [0-8] [from Foo]
        TablePathExpression [5-8] [Foo]
          PathExpression [5-8] [Foo]
            Identifier(Foo) [5-8] [Foo]
    PipeDrop [9-24] [|> DROP  **cols]
      ExpressionList [18-24] [**cols]
        UnpackExpression [18-24] [**cols]
          PathExpression [20-24] [cols]
            Identifier(cols) [20-24] [cols]

--
FROM
  Foo
|> DROP ** (cols)
--
