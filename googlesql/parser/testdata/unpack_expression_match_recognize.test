            Identifier(t) [18-19] [t]
          MatchRecognizeClause [20-139] [MATCH_RECOGNIZE...AS true   )]
            OrderBy [41-57] [ORDER BY  **cols]
              OrderingExpression(ASC) [51-57] [**cols]
                UnpackExpression [51-57] [**cols]
                  PathExpression [53-57] [cols]
                    Identifier(cols) [53-57] [cols]
            SelectList [78-92] [max(A.b) AS m1]
              SelectColumn [78-92] [max(A.b) AS m1]
                FunctionCall [78-86] [max(A.b)]
                  PathExpression [78-81] [max]
                    Identifier(max) [78-81] [max]
                  PathExpression [82-85] [A.b]
                    Identifier(A) [82-83] [A]
                    Identifier(b) [84-85] [b]
                Alias [87-92] [AS m1]
                  Identifier(m1) [90-92] [m1]
            RowPatternVariable [106-107] [A]
              Identifier(A) [106-107] [A]
            SelectList [126-135] [A AS true]
              SelectColumn [126-135] [A AS true]
                BooleanLiteral(true) [131-135] [true]
