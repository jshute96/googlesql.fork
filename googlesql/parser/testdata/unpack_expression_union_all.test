          SetOperationType [22-27] [UNION]
          SetOperationAllOrDistinct [28-31] [ALL]
          SetOperationColumnMatchMode [32-42] [BY NAME ON]
          ExpressionList [43-53] [( **cols )]
            UnpackExpression [45-51] [**cols]
              PathExpression [47-51] [cols]
                Identifier(cols) [47-51] [cols]
      Select [0-21] [SELECT 1 AS x, 2 AS y]
        SelectList [7-21] [1 AS x, 2 AS y]
          SelectColumn [7-13] [1 AS x]
            IntLiteral(1) [7-8] [1]
            Alias [9-13] [AS x]
              Identifier(x) [12-13] [x]
          SelectColumn [15-21] [2 AS y]
            IntLiteral(2) [15-16] [2]
            Alias [17-21] [AS y]
              Identifier(y) [20-21] [y]
      Select [54-77] [SELECT 20 AS y, 10 AS x]
        SelectList [61-77] [20 AS y, 10 AS x]
          SelectColumn [61-68] [20 AS y]
            IntLiteral(20) [61-63] [20]
            Alias [64-68] [AS y]
              Identifier(y) [67-68] [y]
          SelectColumn [70-77] [10 AS x]
            IntLiteral(10) [70-72] [10]
            Alias [73-77] [AS x]
              Identifier(x) [76-77] [x]
