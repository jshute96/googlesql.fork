# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

SELECT 1 AS x, 2 AS y
UNION ALL BY NAME ON ({{|x,}} **cols {{|,y}})
SELECT 20 AS y, 10 AS x;

--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-77] [SELECT 1 AS...y, 10 AS x]
  Query [0-77] [SELECT 1 AS...y, 10 AS x]
    SetOperation(UNION ALL) [0-77] [SELECT 1 AS...y, 10 AS x]
      SetOperationMetadataList [22-53] [UNION ALL...( **cols )]
