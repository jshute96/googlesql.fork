# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

GRAPH FinGraph
MATCH (p:Person {Id: 1})
CALL graph.neighbors(p) YIELD neighbor AS friend
RETURN {{|p.name AS person_name,}} **cols {{|, friend.name AS friend_name}};

