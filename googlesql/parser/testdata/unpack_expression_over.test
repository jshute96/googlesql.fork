          AnalyticFunctionCall [12-75] [RANK() OVER...y DESC   )]
            FunctionCall [12-18] [RANK()]
              PathExpression [12-16] [RANK]
                Identifier(RANK) [12-16] [RANK]
            WindowSpecification [24-75] [(     PARTITION...y DESC   )]
              PartitionBy [30-50] [PARTITION BY  **cols]
                UnpackExpression [44-50] [**cols]
                  PathExpression [46-50] [cols]
                    Identifier(cols) [46-50] [cols]
              OrderBy [56-71] [ORDER BY y DESC]
                OrderingExpression(DESC) [65-71] [y DESC]
                  PathExpression [65-66] [y]
                    Identifier(y) [65-66] [y]
          Alias [76-83] [as rank]
            Identifier(rank) [79-83] [rank]
      FromClause [84-92] [from Foo]
        TablePathExpression [89-92] [Foo]
          PathExpression [89-92] [Foo]
            Identifier(Foo) [89-92] [Foo]
