  Query [0-40] [from Foo |...x, **cols]
    FromQuery [0-8] [from Foo]
      FromClause [0-8] [from Foo]
        TablePathExpression [5-8] [Foo]
          PathExpression [5-8] [Foo]
            Identifier(Foo) [5-8] [Foo]
    PipeSelect [9-20] [|> select y]
      Select [12-20] [select y]
        SelectList [19-20] [y]
          SelectColumn [19-20] [y]
            PathExpression [19-20] [y]
              Identifier(y) [19-20] [y]
    PipeExtend [21-40] [|> EXTEND x, **cols]
      Select [24-40] [EXTEND x, **cols]
        SelectList [31-40] [x, **cols]
          SelectColumn [31-32] [x]
            PathExpression [31-32] [x]
              Identifier(x) [31-32] [x]
          SelectColumn [34-40] [**cols]
            UnpackExpression [34-40] [**cols]
              PathExpression [36-40] [cols]
