# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

from Foo
|> select y
|> EXTEND {{|x,}} **cols {{|,y}};
--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-38] [from Foo |...EXTEND  **cols]
  Query [0-38] [from Foo |...EXTEND  **cols]
    FromQuery [0-8] [from Foo]
      FromClause [0-8] [from Foo]
        TablePathExpression [5-8] [Foo]
          PathExpression [5-8] [Foo]
            Identifier(Foo) [5-8] [Foo]
    PipeSelect [9-20] [|> select y]
      Select [12-20] [select y]
        SelectList [19-20] [y]
          SelectColumn [19-20] [y]
            PathExpression [19-20] [y]
              Identifier(y) [19-20] [y]
    PipeExtend [21-38] [|> EXTEND  **cols]
      Select [24-38] [EXTEND  **cols]
        SelectList [32-38] [**cols]
          SelectColumn [32-38] [**cols]
            UnpackExpression [32-38] [**cols]
              PathExpression [34-38] [cols]
                Identifier(cols) [34-38] [cols]
--
FROM
  Foo
|> SELECT
     y
|> EXTEND
     ** (cols)
--
ALTERNATION GROUP: ,y
--
QueryStatement [0-41] [from Foo |...**cols ,y]
  Query [0-41] [from Foo |...**cols ,y]
    FromQuery [0-8] [from Foo]
      FromClause [0-8] [from Foo]
        TablePathExpression [5-8] [Foo]
          PathExpression [5-8] [Foo]
            Identifier(Foo) [5-8] [Foo]
    PipeSelect [9-20] [|> select y]
      Select [12-20] [select y]
        SelectList [19-20] [y]
          SelectColumn [19-20] [y]
            PathExpression [19-20] [y]
              Identifier(y) [19-20] [y]
    PipeExtend [21-41] [|> EXTEND  **cols ,y]
      Select [24-41] [EXTEND  **cols ,y]
        SelectList [32-41] [**cols ,y]
          SelectColumn [32-38] [**cols]
            UnpackExpression [32-38] [**cols]
              PathExpression [34-38] [cols]
                Identifier(cols) [34-38] [cols]
          SelectColumn [40-41] [y]
            PathExpression [40-41] [y]
              Identifier(y) [40-41] [y]
--
FROM
  Foo
|> SELECT
     y
|> EXTEND
     ** (cols),
     y
--
ALTERNATION GROUP: x,,
--
