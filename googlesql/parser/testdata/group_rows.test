# Group Rows with TIMESTAMP and VERSION keyword as the identifier is not
# allowed. This avoids a parser conflict.
SELECT (
  WITH {{timestamp|version}}() AS GROUP ROWS
  SELECT col
  FROM timestamp
)
FROM Transactions
GROUP BY State
--
ALTERNATION GROUP: timestamp
--
ERROR: Syntax error: Expected keyword AS but got "(" [at 2:17]
