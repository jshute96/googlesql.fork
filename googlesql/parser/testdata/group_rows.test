                ^
--
ALTERNATION GROUP: version
--
ERROR: Syntax error: Expected keyword AS but got "(" [at 2:15]
  WITH version() AS GROUP ROWS
              ^
==

# With backticks, timestamp and version are allowed.
SELECT (
  WITH `{{timestamp|version}}`() AS GROUP ROWS
  SELECT col
  FROM timestamp
)
FROM Transactions
GROUP BY State
