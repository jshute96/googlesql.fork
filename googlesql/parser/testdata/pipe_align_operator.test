[default language_features=NONE,+PIPES]
[default reserve_align]
# minimal case
FROM t
|> ALIGN (
  TIMESTAMP ts AS timestamp
  PERIOD INTERVAL 1 MINUTE
  METRICS SUM(value) WITHIN () AS sm
)
--
QueryStatement [15-126] [FROM t |>...() AS sm )]
  Query [15-126] [FROM t |>...() AS sm )]
    FromQuery [15-21] [FROM t]
      FromClause [15-21] [FROM t]
        TablePathExpression [20-21] [t]
          PathExpression [20-21] [t]
            Identifier(t) [20-21] [t]
    PipeAlignOperator [22-126] [|> ALIGN (...() AS sm )]
      AlignOperator [25-126] [ALIGN (...() AS sm )]
        ExpressionWithOptAlias [45-60] [ts AS timestamp]
          PathExpression [45-47] [ts]
            Identifier(ts) [45-47] [ts]
          Alias [48-60] [AS timestamp]
            Identifier(timestamp) [51-60] [timestamp]
        IntervalExpr [70-87] [INTERVAL 1 MINUTE]
          IntLiteral(1) [79-80] [1]
          Identifier(MINUTE) [81-87] [MINUTE]
        MetricsClause [90-124] [METRICS SUM...WITHIN () AS sm]
          ExpressionWithAlias [98-124] [SUM(value) WITHIN () AS sm]
            EstimatorFunctionCall [98-118] [SUM(value) WITHIN ()]
              FunctionCall [98-108] [SUM(value)]
                PathExpression [98-101] [SUM]
                  Identifier(SUM) [98-101] [SUM]
                PathExpression [102-107] [value]
                  Identifier(value) [102-107] [value]
              AlignWithinClause [109-118] [WITHIN ()]
                AlignWithinBoundExpr(UNBOUNDED PRECEDING) [117-117] []
                AlignWithinBoundExpr(UNBOUNDED FOLLOWING) [117-117] []
            Alias [119-124] [AS sm]
              Identifier(sm) [122-124] [sm]
--
FROM
  t
|> ALIGN (
     TIMESTAMP ts AS timestamp
     PERIOD INTERVAL 1 MINUTE
     METRICS SUM(value) WITHIN (RANGE FROM UNBOUNDED PRECEDING TO UNBOUNDED FOLLOWING) AS sm)
==

# maximal case
FROM t
|> ALIGN (
  TIMESTAMP ts AS timestamp
  PERIOD INTERVAL 1 MIN
  ORIGIN TIMESTAMP('2000-01-01 00:00:00+00')
  OUTPUT WITHIN RANGE FROM TIMESTAMP('2000-01-01 00:00:00+00') TO TIMESTAMP('2021-01-01 00:00:00+00')
  PARTITION BY k, v
  METRICS SUM(value) WITHIN () AS sm
)
