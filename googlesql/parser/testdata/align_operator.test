# match recognize with align
SELECT * FROM ts_table ALIGN (
  TIMESTAMP ts
  PERIOD INTERVAL 1 MINUTE
) MATCH_RECOGNIZE(
  ORDER BY key, value
  MEASURES SUM(key) AS m
  PATTERN ( a | bc )
  DEFINE
    a AS key >= 5,
    b AS key <= 6,
    c AS key >= 7
)
