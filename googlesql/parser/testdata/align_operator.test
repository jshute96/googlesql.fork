# metrics clause
SELECT * FROM ts_table ALIGN (
  TIMESTAMP ts
  PERIOD INTERVAL 1 MINUTE
  METRICS SUM(value) WITHIN () {{ AS sm| AS sm, SUM(value) WITHIN () + 1 AS sn| - SUM(key) WITHIN () AS diff}}
)
