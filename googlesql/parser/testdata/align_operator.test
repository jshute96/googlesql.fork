                                                ^
--
ALTERNATION GROUP: TIMESTAMP('2000-01-01 00:00:00+00')
--
ERROR: Syntax error: Function call cannot be applied to this expression. Function calls require a path, e.g. a.b.c() [at 4:58]
...WITHIN RANGE FROM INTERVAL 1 MINUTE TO TIMESTAMP('2000-01-01 00:00:00+00')...
                                                   ^
--
ALTERNATION GROUP: UNBOUNDED
--
ERROR: Syntax error: Unexpected keyword UNBOUNDED [at 4:49]
  OUTPUT WITHIN RANGE FROM INTERVAL 1 MINUTE TO UNBOUNDED FOLLOWING
                                                ^
==

# PERIOD / UNBOUNDED should be followed by PRECEDING/FOLLOWING
SELECT * FROM ts_table ALIGN (
