# In FROM interval_expr TO end_bound, interval_expr should be followed by PRECEDING/FOLLOWING
SELECT * FROM ts_table ALIGN (
  TIMESTAMP ts
  PERIOD MAKE_INTERVAL(minute => 10)
  OUTPUT WITHIN RANGE FROM INTERVAL 1 MINUTE TO {{INTERVAL 1 MINUTE|MAKE_INTERVAL(minute => 10)|1 PERIOD|TIMESTAMP('2000-01-01 00:00:00+00')|UNBOUNDED}} FOLLOWING
)

--
ALTERNATION GROUP: INTERVAL 1 MINUTE
