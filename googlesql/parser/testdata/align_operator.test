--
SELECT
  *
FROM
  ts_table ALIGN (
    TIMESTAMP ts AS timestamp
    PERIOD INTERVAL 1 MINUTE
    ORIGIN TIMESTAMP('2000-01-01 00:00:00+00')
    OUTPUT WITHIN RANGE FROM 50 PERIOD PRECEDING
    PARTITION BY k AS kv
    METRICS SUM(value) WITHIN (RANGE FROM INTERVAL 5 MINUTE PRECEDING) AS sm)
==

