==

SELECT **cols as c FROM Foo
--
QueryStatement [0-27] [SELECT **cols as c FROM Foo]
  Query [0-27] [SELECT **cols as c FROM Foo]
    Select [0-27] [SELECT **cols as c FROM Foo]
      SelectList [7-18] [**cols as c]
        SelectColumn [7-18] [**cols as c]
          UnpackExpression [7-13] [**cols]
            PathExpression [9-13] [cols]
              Identifier(cols) [9-13] [cols]
          Alias [14-18] [as c]
            Identifier(c) [17-18] [c]
      FromClause [19-27] [FROM Foo]
        TablePathExpression [24-27] [Foo]
          PathExpression [24-27] [Foo]
            Identifier(Foo) [24-27] [Foo]
--
SELECT
  ** (cols) AS c
FROM
  Foo
