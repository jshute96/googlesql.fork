# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

select 1 from Foo
group by {{|x,}} **cols {{|,y}};
--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-34] [select 1 from...by  **cols]
  Query [0-34] [select 1 from...by  **cols]
    Select [0-34] [select 1 from...by  **cols]
      SelectList [7-8] [1]
        SelectColumn [7-8] [1]
          IntLiteral(1) [7-8] [1]
      FromClause [9-17] [from Foo]
        TablePathExpression [14-17] [Foo]
          PathExpression [14-17] [Foo]
            Identifier(Foo) [14-17] [Foo]
      GroupBy [18-34] [group by  **cols]
        GroupingItem [28-34] [**cols]
          UnpackExpression [28-34] [**cols]
            PathExpression [30-34] [cols]
              Identifier(cols) [30-34] [cols]

