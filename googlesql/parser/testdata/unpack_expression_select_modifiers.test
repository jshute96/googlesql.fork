# Tests for ** unpack expressions
[default language_features=MAXIMUM,+PIPES]

select * EXCEPT ({{|x,}} **cols {{|,y}})
from Foo;

--
ALTERNATION GROUP: <empty>
--
QueryStatement [0-35] [select * EXCEPT...) from Foo]
  Query [0-35] [select * EXCEPT...) from Foo]
    Select [0-35] [select * EXCEPT...) from Foo]
      SelectList [7-26] [* EXCEPT ( **cols )]
        SelectColumn [7-26] [* EXCEPT ( **cols )]
          StarWithModifiers [7-26] [* EXCEPT ( **cols )]
            StarModifiers [9-26] [EXCEPT ( **cols )]
              StarExceptList [9-26] [EXCEPT ( **cols )]
                ExpressionList [16-26] [( **cols )]
                  UnpackExpression [18-24] [**cols]
                    PathExpression [20-24] [cols]
                      Identifier(cols) [20-24] [cols]
      FromClause [27-35] [from Foo]
        TablePathExpression [32-35] [Foo]
          PathExpression [32-35] [Foo]
            Identifier(Foo) [32-35] [Foo]
--
SELECT
  * EXCEPT (** (cols))
FROM
  Foo
