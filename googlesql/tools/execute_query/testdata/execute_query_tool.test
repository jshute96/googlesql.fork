# Make sure ExplainAndOrExecuteSql runs just once, so we get one output
# for each of the two modes.
[mode=explain,execute]
select 1 x, 2 y
--
ComputeOp(
+-map: {
| +-$x := ConstExpr(1),
| +-$y := ConstExpr(2)},
+-input: EnumerateOp(ConstExpr(1)))

в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ
в”Ӯ x в”Ӯ y в”Ӯ
в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
в”Ӯ 1 в”Ӯ 2 в”Ӯ
в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
\
==

# Unused column Key gets pruned.
[mode=analyze,unanalyze]
FROM KeyValue
|> SELECT value
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в””в”ҖKeyValue.Value#2 AS value [STRING]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=[KeyValue.Value#2]
    в””в”Җinput_scan=
      в””в”ҖTableScan(column_list=[KeyValue.Value#2], table=KeyValue, column_index_list=[1])

SELECT KeyValue.Value AS value FROM KeyValue
\
==

# Unused column Key gets pruned.
[mode=analyze,unanalyze]
select 1 from KeyValue GROUP BY key, key+1
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в””в”Җ$query.$col1#5 AS `$col1` [INT64]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=[$query.$col1#5]
    в”ңв”Җexpr_list=
    в”Ӯ в””в”Җ$col1#5 := Literal(type=INT64, value=1)
    в””в”Җinput_scan=
      в””в”ҖAggregateScan
        в”ңв”Җinput_scan=
        в”Ӯ в””в”ҖTableScan(column_list=[KeyValue.Key#1], table=KeyValue, column_index_list=[0])
        в””в”Җgroup_by_list=
          в”ңв”Җkey#3 := ColumnRef(type=INT64, column=KeyValue.Key#1)
          в””в”Җ$groupbycol2#4 :=
            в””в”ҖFunctionCall(GoogleSQL:$add(INT64, INT64) -> INT64)
              в”ңв”ҖColumnRef(type=INT64, column=KeyValue.Key#1)
              в””в”ҖLiteral(type=INT64, value=1)

SELECT 1 AS a_4
FROM
  (
    SELECT NULL
    FROM (SELECT KeyValue.Key AS a_1 FROM KeyValue) AS keyvalue_2
    GROUP BY keyvalue_2.a_1, (keyvalue_2.a_1) + 1
  ) AS aggregatescan_3
\
==
