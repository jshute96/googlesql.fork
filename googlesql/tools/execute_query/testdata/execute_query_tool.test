# Constant evaluation in pipe IF can handle SQLConstants.
[mode=analyze,execute]
[enabled_language_features=MAXIMUM,+PIPE_IF]
create constant c1 = 1 < 2;
create constant c2 = 1 > 2;
from KeyValue
|> IF c1 THEN ( |> EXTEND 55 )
|> IF c2 THEN ( |> EXTEND 66 )
--
CreateConstantStmt
в”ңв”Җname_path=c1
в””в”Җexpr=
  в””в”ҖFunctionCall(GoogleSQL:$less(INT64, INT64) -> BOOL)
    в”ңв”ҖLiteral(type=INT64, value=1)
    в””в”ҖLiteral(type=INT64, value=2)

Constant registered.
Constant evaluated.
CreateConstantStmt
в”ңв”Җname_path=c2
в””в”Җexpr=
  в””в”ҖFunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
    в”ңв”ҖLiteral(type=INT64, value=1)
    в””в”ҖLiteral(type=INT64, value=2)

Constant registered.
Constant evaluated.
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в”ңв”ҖKeyValue.Key#1 AS Key [INT64]
в”Ӯ в”ңв”ҖKeyValue.Value#2 AS Value [STRING]
в”Ӯ в””в”Җ$pipe_extend.$col1#3 AS `$col1` [INT64]
в””в”Җquery=
  в””в”ҖPipeIfScan
    в”ңв”Җcolumn_list=[KeyValue.Key#1, KeyValue.Value#2, $pipe_extend.$col1#3]
    в”ңв”Җinput_scan=
    в”Ӯ в””в”ҖPipeIfScan
    в”Ӯ   в”ңв”Җcolumn_list=[KeyValue.Key#1, KeyValue.Value#2, $pipe_extend.$col1#3]
    в”Ӯ   в”ңв”Җinput_scan=
    в”Ӯ   в”Ӯ в””в”ҖTableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
    в”Ӯ   в”ңв”Җselected_case=0
    в”Ӯ   в””в”Җif_case_list=
    в”Ӯ     в””в”ҖPipeIfCase
    в”Ӯ       в”ңв”Җcondition=
    в”Ӯ       в”Ӯ в””в”ҖConstant(c1, type=BOOL, value=true)
    в”Ӯ       в”ңв”Җsubpipeline_sql="( |> EXTEND 55 )"
    в”Ӯ       в””в”Җsubpipeline=
    в”Ӯ         в””в”ҖSubpipeline
    в”Ӯ           в””в”Җscan=
    в”Ӯ             в””в”ҖProjectScan
    в”Ӯ               в”ңв”Җcolumn_list=[KeyValue.Key#1, KeyValue.Value#2, $pipe_extend.$col1#3]
    в”Ӯ               в”ңв”Җexpr_list=
    в”Ӯ               в”Ӯ в””в”Җ$col1#3 := Literal(type=INT64, value=55)
    в”Ӯ               в””в”Җinput_scan=
    в”Ӯ                 в””в”ҖSubpipelineInputScan(column_list=KeyValue.[Key#1, Value#2])
    в”ңв”Җselected_case=-1
    в””в”Җif_case_list=
      в””в”ҖPipeIfCase
        в”ңв”Җcondition=
        в”Ӯ в””в”ҖConstant(c2, type=BOOL, value=false)
        в””в”Җsubpipeline_sql="( |> EXTEND 66 )"


