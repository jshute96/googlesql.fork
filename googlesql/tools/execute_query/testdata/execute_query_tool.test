в”ңв”Җname_path=c1
в””в”Җexpr=
  в””в”ҖFunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
    в”ңв”ҖLiteral(type=STRING, value="abc")
    в””в”ҖLiteral(type=STRING, value="def")

Constant registered.
CreateConstantStmt
в”ңв”Җname_path=c2
в””в”Җexpr=
  в””в”ҖFunctionCall(GoogleSQL:$greater(INT64, INT64) -> BOOL)
    в”ңв”ҖFunctionCall(GoogleSQL:error(STRING) -> INT64)
    в”Ӯ в””в”ҖLiteral(type=STRING, value="abc")
    в””в”ҖLiteral(type=INT64, value=0)

Constant registered.
CreateConstantStmt
в”ңв”Җname_path=c3
в””в”Җexpr=
  в””в”ҖFunctionCall(GoogleSQL:concat(STRING, repeated(1) STRING) -> STRING)
    в”ңв”ҖConstant(c1, type=STRING, value=Uninitialized value)
    в””в”ҖLiteral(type=STRING, value="ghi")

Constant registered.
