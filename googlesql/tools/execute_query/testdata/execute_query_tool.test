Error: Only INSERT statements are supported in multi-statement queries
==

# An empty statement causes no output.
--
==

# A statement that is just a comment works like an empty statement.
/* comment */
--
==

# A statement that is just a semicolon is not allowed.
;
--
ERROR: INVALID_ARGUMENT: Syntax error: Unexpected ";" [at 1:1]
;
^
==

# Empty statements from double-semicolons are not allowed.
select 1;;
select 2;
--
в”Ңв”Җв”Җв”Җв”җ
в”Ӯ   в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ 1 в”Ӯ
в””в”Җв”Җв”Җв”ҳ

ERROR: INVALID_ARGUMENT: Syntax error: Unexpected ";" [at 1:10]
select 1;;
         ^
в”Ңв”Җв”Җв”Җв”җ
в”Ӯ   в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ 2 в”Ӯ
в””в”Җв”Җв”Җв”ҳ
\
==

# Trailing comments are allowed.
/* comment */
select 1;
/* comment */
--
в”Ңв”Җв”Җв”Җв”җ
в”Ӯ   в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ 1 в”Ӯ
в””в”Җв”Җв”Җв”ҳ
\

