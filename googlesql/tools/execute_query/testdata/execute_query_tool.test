# Two conflicting INSERTs, only one will succeed.
[mode=execute]
CREATE TABLE t (key INT64, value STRING, PRIMARY KEY(key))
AS
SELECT 1 AS key, 'one' AS value;

SELECT 11 AS key, 'eleven' AS value
|> FORK (
  |> INSERT INTO t
), (
  |> INSERT INTO t
);

FROM t;
--
Table created
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ rows_modified в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 1             в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

Error: Key already exists for INSERT operation
в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ key в”Ӯ value  в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 1   в”Ӯ one    в”Ӯ
в”Ӯ 11  в”Ӯ eleven в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
\
==

