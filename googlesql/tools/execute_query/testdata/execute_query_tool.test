в”ңв”Җstatement=
в”Ӯ в””в”ҖShowStmt(identifier="TABLES")
в””в”Җsuffix_subpipeline_sql=
  в””в”ҖStringWithLocation(parse_location=12-73, value="|> WHERE TableName like '%e%'\n|> CREATE TEMP TABLE SomeTables")

SubpipelineStmt
в”ңв”Җtable_scan=
