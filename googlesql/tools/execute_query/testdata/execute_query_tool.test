# Test multi-statement with a single failure in a TRY-CATCH block in a script.
[mode=execute]
[sql_mode=script]
BEGIN
  SELECT 1
  |> FORK (
    |> SELECT ERROR("this is an error")
  ), (
    |> SELECT 2
  );
EXCEPTION WHEN ERROR THEN
  SELECT 'caught', @@error.message AS error_message;
END;
--

Error: this is an error
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ $col_1 в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 2      в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ $col_1 в”Ӯ error_message    в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ caught в”Ӯ this is an error в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
