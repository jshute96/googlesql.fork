# Subscript access on MAP types using
[catalog=none]
[mode=analyze,execute]
[enabled_language_features=DEV,+BARE_ARRAY_ACCESS]

SELECT MAP_FROM_ARRAY([('a', 1)])['a']
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в””в”Җ$query.$col1#1 AS `$col1` [INT64]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=[$query.$col1#1]
    в”ңв”Җexpr_list=
    в”Ӯ в””в”Җ$col1#1 :=
    в”Ӯ   в””в”ҖFunctionCall(GoogleSQL:$subscript(MAP<STRING, INT64>, STRING) -> INT64)
    в”Ӯ     в”ңв”ҖFunctionCall(GoogleSQL:map_from_array(ARRAY<STRUCT<STRING, INT64>>) -> MAP<STRING, INT64>)
    в”Ӯ     в”Ӯ в””в”ҖLiteral(type=ARRAY<STRUCT<STRING, INT64>>, value=[{"a", 1}])
    в”Ӯ     в””в”ҖLiteral(type=STRING, value="a")
    в””в”Җinput_scan=
      в””в”ҖSingleRowScan

в”Ңв”Җв”Җв”Җв”җ
в”Ӯ   в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ 1 в”Ӯ
в””в”Җв”Җв”Җв”ҳ
\
==

# Deprecation warnings
[catalog=sample]
[mode=analyze]

FROM KeyValue
|> WINDOW RANK() OVER (order by key)
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в”ңв”ҖKeyValue.Key#1 AS Key [INT64]
в”Ӯ в”ңв”ҖKeyValue.Value#2 AS Value [STRING]
в”Ӯ в””в”Җ$analytic.$analytic1#4 AS `$col1` [INT64]
в””в”Җquery=
  в””в”ҖAnalyticScan
    в”ңв”Җcolumn_list=[KeyValue.Key#1, KeyValue.Value#2, $analytic.$analytic1#4]
    в”ңв”Җinput_scan=
    в”Ӯ в””в”ҖTableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])
    в””в”Җfunction_group_list=
      в””в”ҖAnalyticFunctionGroup
        в”ңв”Җorder_by=
        в”Ӯ в””в”ҖWindowOrdering
        в”Ӯ   в””в”Җorder_by_item_list=
        в”Ӯ     в””в”ҖOrderByItem
        в”Ӯ       в””в”Җcolumn_ref=
        в”Ӯ         в””в”ҖColumnRef(type=INT64, column=KeyValue.Key#1)
        в””в”Җanalytic_function_list=
          в””в”Җ$analytic1#4 := AnalyticFunctionCall(GoogleSQL:rank() -> INT64)

Deprecation warnings:
The pipe WINDOW operator is deprecated; Use EXTEND instead [at 2:1]
|> WINDOW RANK() OVER (order by key)
^
==

# STATIC_DESCRIBE can analyze and execute.
# The static logging output current doesn't go anywhere in execute mode.
[catalog=sample]
[mode=analyze,execute]
FROM KeyValue
|> STATIC_DESCRIBE
|> SELECT key
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в””в”ҖKeyValue.Key#1 AS key [INT64]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=[KeyValue.Key#1]
    в””в”Җinput_scan=
      в””в”ҖStaticDescribeScan
        в”ңв”Җcolumn_list=[KeyValue.Key#1]
        в”ңв”Җdescribe_text=
        в”Ӯ   """
        в”Ӯ   NameList:
        в”Ӯ     Key INT64 KeyValue.Key#1
        в”Ӯ     Value STRING KeyValue.Value#2
        в”Ӯ   NameScope:
        в”Ӯ     Names:
        в”Ӯ       Key -> INT64 (KeyValue.Key#1) (implicit)
        в”Ӯ       Value -> STRING (KeyValue.Value#2) (implicit)
        в”Ӯ     Range variables:
        в”Ӯ       KeyValue -> RANGE_VARIABLE<Key#1,Value#2>
        в”Ӯ   """
        в””в”Җinput_scan=
          в””в”ҖTableScan(column_list=[KeyValue.Key#1], table=KeyValue, column_index_list=[0])

в”Ңв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ key в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 1   в”Ӯ
в”Ӯ 2   в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”ҳ
\
==

