# Test reading some SimpleConstants from the sample catalog.
[mode=analyze,execute]
[catalog=sample]
select TestConstantTrue, TestConstantInt64, TestConstantProto;
--
QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в”ңв”Җ$query.TestConstantTrue#1 AS TestConstantTrue [BOOL]
в”Ӯ в”ңв”Җ$query.TestConstantInt64#2 AS TestConstantInt64 [INT64]
в”Ӯ в””в”Җ$query.TestConstantProto#3 AS TestConstantProto [PROTO<googlesql_test.KitchenSinkPB>]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=$query.[TestConstantTrue#1, TestConstantInt64#2, TestConstantProto#3]
    в”ңв”Җexpr_list=
    в”Ӯ в”ңв”ҖTestConstantTrue#1 := Constant(TestConstantTrue, type=BOOL, value=true)
    в”Ӯ в”ңв”ҖTestConstantInt64#2 := Constant(TestConstantInt64, type=INT64, value=1)
    в”Ӯ в””в”ҖTestConstantProto#3 := Constant(TestConstantProto, type=PROTO<googlesql_test.KitchenSinkPB>, value={int64_key_1: 1 int64_key_2: -999})
    в””в”Җinput_scan=
      в””в”ҖSingleRowScan

в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ TestConstantTrue в”Ӯ TestConstantInt64 в”Ӯ TestConstantProto                  в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ true             в”Ӯ 1                 в”Ӯ {int64_key_1: 1 int64_key_2: -999} в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
