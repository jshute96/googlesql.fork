в”Ӯ в”ңв”Җ$query.c2#2 AS c2 [BOOL]
в”Ӯ в””в”Җ$query.c3#3 AS c3 [STRING]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=$query.[c1#1, c2#2, c3#3]
    в”ңв”Җexpr_list=
    в”Ӯ в”ңв”Җc1#1 := Constant(c1, type=STRING, value=Uninitialized value)
    в”Ӯ в”ңв”Җc2#2 := Constant(c2, type=BOOL, value=Uninitialized value)
    в”Ӯ в””в”Җc3#3 := Constant(c3, type=STRING, value=Uninitialized value)
    в””в”Җinput_scan=
      в””в”ҖSingleRowScan
\
