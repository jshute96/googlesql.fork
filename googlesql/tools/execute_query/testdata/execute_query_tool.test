            в””в”Җquery=
              в””в”ҖFilterScan
                в”ңв”Җcolumn_list=[ShowTables.TableName#1]
                в”ңв”Җinput_scan=
                в”Ӯ в””в”ҖSubpipelineInputScan(column_list=[ShowTables.TableName#1])
                в””в”Җfilter_expr=
                  в””в”ҖFunctionCall(GoogleSQL:$like(STRING, STRING) -> BOOL)
                    в”ңв”ҖColumnRef(type=STRING, column=ShowTables.TableName#1)
