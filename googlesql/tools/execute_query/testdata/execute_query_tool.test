# Test multi-statement with simple queries in a script.
[mode=execute,analyze]
[sql_mode=script]
SELECT 1 AS a, 'x' AS b
|> FORK (
  |> SELECT a
), (
  |> SELECT b
);

SELECT 1;
--
MultiStmt
в””в”Җstatement_list=
  в”ңв”ҖCreateWithEntryStmt
  в”Ӯ в””в”Җwith_entry=
  в”Ӯ   в””в”ҖWithEntry
  в”Ӯ     в”ңв”Җwith_query_name="$fork_cte_1"
  в”Ӯ     в””в”Җwith_subquery=
  в”Ӯ       в””в”ҖProjectScan
  в”Ӯ         в”ңв”Җcolumn_list=$query.[a#1, b#2]
  в”Ӯ         в”ңв”Җexpr_list=
  в”Ӯ         в”Ӯ в”ңв”Җa#1 := Literal(type=INT64, value=1)
  в”Ӯ         в”Ӯ в””в”Җb#2 := Literal(type=STRING, value="x")
  в”Ӯ         в””в”Җinput_scan=
  в”Ӯ           в””в”ҖSingleRowScan
  в”ңв”ҖQueryStmt
  в”Ӯ в”ңв”Җoutput_column_list=
  в”Ӯ в”Ӯ в””в”Җ$query.a#1 AS a [INT64]
  в”Ӯ в””в”Җquery=
  в”Ӯ   в””в”ҖProjectScan
  в”Ӯ     в”ңв”Җcolumn_list=[$query.a#1]
  в”Ӯ     в””в”Җinput_scan=
  в”Ӯ       в””в”ҖWithRefScan(column_list=$query.[a#1, b#2], with_query_name="$fork_cte_1")
  в””в”ҖQueryStmt
    в”ңв”Җoutput_column_list=
    в”Ӯ в””в”Җ$query.b#2 AS b [STRING]
    в””в”Җquery=
      в””в”ҖProjectScan
        в”ңв”Җcolumn_list=[$query.b#2]
        в””в”Җinput_scan=
          в””в”ҖWithRefScan(column_list=$query.[a#1, b#2], with_query_name="$fork_cte_1")

в”Ңв”Җв”Җв”Җв”җ
в”Ӯ a в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ 1 в”Ӯ
в””в”Җв”Җв”Җв”ҳ

в”Ңв”Җв”Җв”Җв”җ
в”Ӯ b в”Ӯ
в”ңв”Җв”Җв”Җв”Ө
в”Ӯ x в”Ӯ
в””в”Җв”Җв”Җв”ҳ

QueryStmt
в”ңв”Җoutput_column_list=
в”Ӯ в””в”Җ$query.$col1#1 AS `$col1` [INT64]
в””в”Җquery=
  в””в”ҖProjectScan
    в”ңв”Җcolumn_list=[$query.$col1#1]
    в”ңв”Җexpr_list=
    в”Ӯ в””в”Җ$col1#1 := Literal(type=INT64, value=1)
    в””в”Җinput_scan=
      в””в”ҖSingleRowScan

в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ $col_1 в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 1      в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
\
==

