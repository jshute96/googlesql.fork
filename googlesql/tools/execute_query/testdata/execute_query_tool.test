    в”ңв”Җcolumn_list=[KeyValue.Key#1, KeyValue.Value#2, $pipe_extend.$col1#3]
    в”ңв”Җexpr_list=
    в”Ӯ в””в”Җ$col1#3 := Literal(type=INT64, value=55)
    в””в”Җinput_scan=
      в””в”ҖTableScan(column_list=KeyValue.[Key#1, Value#2], table=KeyValue, column_index_list=[0, 1])

в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”җ
в”Ӯ Key в”Ӯ Value в”Ӯ    в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Ө
в”Ӯ 1   в”Ӯ a     в”Ӯ 55 в”Ӯ
в”Ӯ 2   в”Ӯ b     в”Ӯ 55 в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҳ
\
==

# In script mode, variables act like constants and are available to
# analysis and evaluation.
[mode=execute]
[sql_mode=script]
declare x bool default true;
select x AS xx |> IF x THEN ( |> EXTEND 55 );
set x = 1 > 2;
select x AS xx |> IF x THEN ( |> EXTEND 66 );
--
в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ xx   в”Ӯ $col_2 в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ true в”Ӯ 55     в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
в”Ӯ xx    в”Ӯ
в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
в”Ӯ false в”Ӯ
в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
\
==

SELECT (JSON "{}")[0];
