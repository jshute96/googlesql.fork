# This module calls a template function that ends up calling a 26-long chain of
# template functions before getting to an innermost template with a compile
# error due to the argument.
#
# This repro's b/460140787. Before that bug was fixed, this would generate an
# error with 2**(2*26) ErrorSources attached to it causing a timeout.
[error_message_mode=WITH_PAYLOAD]
MODULE m;

IMPORT MODULE googlesql.testdata.modules.nested_error_source;

CREATE PUBLIC FUNCTION main() AS (
  nested_error_source.nested_error_a(STRUCT(1 AS non_matching_field))
);
--
