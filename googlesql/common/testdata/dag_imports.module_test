# This test takes an IMPORT statement as input, reads the module contents
# from the related file (residing in googlesql/testdata/modules),
# creates a ModuleCatalog from the contents (including nested imports), and
# then dumps the Catalog - including:
#   1) nested catalogs
#   2) functions
#   3) other (non-catalog function) errors.
#
# For this test case, the module imports are:
#
#                           import_a1_a2_a3
#                             /    |    \
#                           a1    a2    a3
#                             \  /  \  /
#                              b1    b2
#                             /  \  /  \
#                           c1    c2    c3

[no_input_is_module_contents]
IMPORT MODULE googlesql.testdata.modules.import_a1_a2_a3
    AS module_with_dag_imports
--
Lazy_resolution_function:func
  (STRING a) -> STRING
