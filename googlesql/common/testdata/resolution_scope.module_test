# Tests for resolution scope behavior when a global catalog is provided.
[default no_show_imported_modules]

# No scope on module- or statement-level, default is builtin.
MODULE a.b.c;

CREATE PUBLIC FUNCTION function_valid_noscope()
AS (1);

CREATE PUBLIC TABLE FUNCTION tvf_valid_noscope()
AS (SELECT 1 AS val);
--
Lazy_resolution_function:function_valid_noscope
  () -> INT64

TVF:tvf_valid_noscope
  () -> TABLE<val INT64>
==

# Statement-level option takes precedence over module-level option.
MODULE a.b.c OPTIONS (allowed_references='global');

CREATE PUBLIC FUNCTION function_valid_builtin()
OPTIONS (allowed_references='builtin')
AS (1);

CREATE PUBLIC TABLE FUNCTION tvf_valid_builtin()
OPTIONS (allowed_references='builtin')
AS (SELECT 1 AS val);
--
Lazy_resolution_function:function_valid_builtin
  () -> INT64

TVF:tvf_valid_builtin
  () -> TABLE<val INT64>
==

# Module-level option defines global scope.
MODULE a.b.c OPTIONS (allowed_references='global');

CREATE PUBLIC FUNCTION function_valid_global()
AS (1);

CREATE PUBLIC TABLE FUNCTION tvf_valid_global()
AS (SELECT 1 AS val);
--
Lazy_resolution_function:function_valid_global
  () -> INT64

TVF:tvf_valid_global
  () -> TABLE<val INT64>
==

MODULE a.b.c OPTIONS (allowed_references='global', allowed_references='global');
--
ModuleCatalog creation failed with status:
generic::invalid_argument: Duplicate option allowed_references in module a.b.c
==

# Non-literal module-level option can be resolved if a constant evaluator is
# provided by the caller.
MODULE a.b.c OPTIONS (allowed_references=CONCAT('glob', 'al'));
--
==

MODULE a.b.c OPTIONS (allowed_references='invalid');
--
ModuleCatalog creation failed with status:
generic::invalid_argument: Allowed values for the allowed_references module option are [BUILTIN, GLOBAL], but got: invalid
==

MODULE a.b.c OPTIONS (allowed_references=123);
--
ModuleCatalog creation failed with status:
generic::invalid_argument: Module option allowed_references is expected to have type STRING, but got: INT64
==

MODULE a.b.c;

