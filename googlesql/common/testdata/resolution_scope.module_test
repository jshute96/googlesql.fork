# Builtin-scope objects cannot reference objects in global catalog.
MODULE a.b.c;

CREATE PUBLIC FUNCTION function_error_builtin_references_table()
AS ((SELECT Key FROM nested_catalog.KeyValueNested LIMIT 1));

CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_table()
AS (SELECT Key FROM nested_catalog.KeyValueNested LIMIT 1);
--
Lazy_resolution_function:function_error_builtin_references_table
ERROR: Function function_error_builtin_references_table is invalid [at 3:24]
CREATE PUBLIC FUNCTION function_error_builtin_references_table()
                       ^
Invalid reference to global-scope table 'nested_catalog.KeyValueNested' from a context which only allows builtin references. If this is an intended reference from a module function or TVF, the module function or TVF may be missing the option allowed_references='global' to allow global references

TVF:tvf_error_builtin_references_table
ERROR: Table function tvf_error_builtin_references_table is invalid [at 6:30]
CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_table()
                             ^
Invalid reference to global-scope table 'nested_catalog.KeyValueNested' from a context which only allows builtin references. If this is an intended reference from a module function or TVF, the module function or TVF may be missing the option allowed_references='global' to allow global references
==

# Global-scope objects can reference objects in global catalog.
MODULE a.b.c OPTIONS (allowed_references='global');

CREATE PUBLIC FUNCTION function_error_builtin_references_table()
AS ((SELECT Key FROM nested_catalog.KeyValueNested LIMIT 1));

CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_table()
AS (SELECT Key FROM nested_catalog.KeyValueNested LIMIT 1);
--
Lazy_resolution_function:function_error_builtin_references_table
  () -> INT64

TVF:tvf_error_builtin_references_table
  () -> TABLE<Key INT64>
==

# Builtin-scope objects cannot refer to global-scope objects in the same module.
MODULE a.b.c;

CREATE PUBLIC FUNCTION function_public_global()
OPTIONS (allowed_references='global')
AS (1);

CREATE PRIVATE FUNCTION function_private_global()
OPTIONS (allowed_references='global')
AS (1);

CREATE PUBLIC FUNCTION function_error_builtin_references_public_global()
AS (function_public_global());

CREATE PUBLIC FUNCTION function_error_builtin_references_private_global()
AS (function_private_global());

CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_public_global()
AS (SELECT function_public_global() AS val);

CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_private_global()
AS (SELECT function_private_global() AS val);

CREATE PUBLIC CONSTANT constant_error_builtin_references_public_global =
function_public_global();

CREATE PUBLIC CONSTANT constant_error_builtin_references_private_global =
function_private_global();
--
