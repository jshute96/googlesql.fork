# Global-scope objects can reference global+public module imports.
MODULE a.b.c OPTIONS (allowed_references='global');
IMPORT MODULE googlesql.testdata.modules.resolution_scope AS test;

CREATE PUBLIC FUNCTION function_error_builtin_references_public_global()
AS (test.function_valid_public_global());

CREATE PUBLIC TABLE FUNCTION tvf_error_builtin_references_public_global()
AS (SELECT * FROM test.tvf_valid_public_global());
