# These tests take an IMPORT statement as input, read the module contents
# from the related file (residing in googlesql/testdata), create a
# ModuleCatalog from the contents, and then dump the Catalog functions and
# other (non-catalog function) errors.

[no_input_is_module_contents]
IMPORT MODULE googlesql.testdata.modules.simple AS simple2;
--
PRIVATE Lazy_resolution_function:abc
  (UINT32 c) -> UINT64

Lazy_resolution_function:b1
  (INT32 b) -> INT64

Lazy_resolution_function:b2
ERROR: Function b2 is invalid [at .../googlesql/testdata/modules/simple.sqlm:14:35]
create or replace public function b2(a int64) as (a);       -- bad OR REPLACE
                                  ^
Modules do not support CREATE OR REPLACE for CREATE FUNCTION [at .../googlesql/testdata/modules/simple.sqlm:14:1]
create or replace public function b2(a int64) as (a);       -- bad OR REPLACE
^

