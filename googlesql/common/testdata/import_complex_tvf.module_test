# These tests take an IMPORT statement as input, read the module contents
# from the related file (residing in googlesql/testdata), create a
# ModuleCatalog from the contents, and then dump the Catalog functions
# and tvfs.
#
# Module 'complex_tvf' imports 'complex_tvf_nested'.
# UDFs and TVFs in 'complex_tvf' reference other UDFs and TVFS in
# both itself and the imported 'complex_tvf_nested'.

[no_input_is_module_contents]
IMPORT MODULE googlesql.testdata.modules.complex_tvf AS complex_tvf;
