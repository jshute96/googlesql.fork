# Infinite loop:
#   foo -> bar -> baz -> foo
#
#   bat - invalid since it refers to bar which takes part in an infinite loop
#   good_fn - valid function
MODULE simple_module;
CREATE PUBLIC FUNCTION foo(d int64) as (1 + bar(d));
CREATE PRIVATE FUNCTION bar(c int64) as (baz(c+10));
CREATE PUBLIC FUNCTION baz(c int64) as (foo(c+10));
CREATE PUBLIC FUNCTION bat(c int64) as (bar(c+10));
CREATE PUBLIC FUNCTION good_fn(c int64) as (c+10);
--
PRIVATE Lazy_resolution_function:bar
ERROR: Function bar is invalid [at 3:25]
CREATE PRIVATE FUNCTION bar(c int64) as (baz(c+10));
                        ^
Invalid function baz [at 3:42]
CREATE PRIVATE FUNCTION bar(c int64) as (baz(c+10));
                                         ^
Function baz is invalid [at 4:24]
CREATE PUBLIC FUNCTION baz(c int64) as (foo(c+10));
                       ^
Invalid function foo [at 4:41]
CREATE PUBLIC FUNCTION baz(c int64) as (foo(c+10));
                                        ^
Function foo is invalid [at 2:24]
CREATE PUBLIC FUNCTION foo(d int64) as (1 + bar(d));
                       ^
Invalid function bar [at 2:45]
CREATE PUBLIC FUNCTION foo(d int64) as (1 + bar(d));
                                            ^
Recursive dependencies detected when resolving function simple_module.bar, which include objects (simple_module.bar, simple_module.baz, simple_module.foo, simple_module.bar) [at 3:25]

Lazy_resolution_function:bat
ERROR: Function bat is invalid [at 5:24]
CREATE PUBLIC FUNCTION bat(c int64) as (bar(c+10));
                       ^
Invalid function bar [at 5:41]
