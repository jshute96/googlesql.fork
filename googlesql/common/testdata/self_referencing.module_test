Lazy_resolution_function:good_fn
  (INT64 c) -> INT64
==

# Reference chain, where the end of the reference chain is invalid:
#   foo -> bar -> baz -> bat
#
#   bat - invalid due to bad expression
MODULE simple_module;
CREATE PUBLIC FUNCTION foo(d int64) as (1 + bar(d));
CREATE PRIVATE FUNCTION bar(c int64) as (baz(c+10));
CREATE PUBLIC FUNCTION baz(c int64) as (bat(c));
CREATE PUBLIC FUNCTION bat(c double) as (c + "foo");
--
PRIVATE Lazy_resolution_function:bar
ERROR: Function bar is invalid [at 3:25]
CREATE PRIVATE FUNCTION bar(c int64) as (baz(c+10));
                        ^
Invalid function baz [at 3:42]
