# These tests take an IMPORT statement as input, read the module contents
# from the related file (residing in googlesql/testdata), create a
# ModuleCatalog from the contents, and then dump the Catalog functions
# and TVFs.
#
# Module 'complex_tvf_nested' creates UDFs and TVFs that reference other
# UDFs and TVFS inside itself.

[no_input_is_module_contents]
IMPORT MODULE googlesql.testdata.modules.complex_tvf_nested
    AS complex_tvf_nested;
--
Lazy_resolution_function:nested_fun1
  (INT64 a) -> INT64

Lazy_resolution_function:nested_fun2
  (INT64 a) -> INT64

TVF:cliff_em_all
  (INT64 a) -> TABLE<a INT64, x INT64, y INT64, p INT64, q INT64>

TVF:nested_tvf1
  (INT64 b) -> TABLE<b INT64, c INT64>

TVF:nested_tvf2
  (INT64 a) -> TABLE<a INT64, b INT64>
