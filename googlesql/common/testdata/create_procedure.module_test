# Simple PUBLIC procedure
MODULE m;
CREATE PUBLIC PROCEDURE p0() OPTIONS (allowed_references = 'global') BEGIN SELECT 1; END;
--
PROCEDURE p0
==

# Simple PRIVATE procedure
MODULE m;
CREATE PRIVATE PROCEDURE p1() OPTIONS (allowed_references = 'global') BEGIN SELECT 1; END;
--
PRIVATE PROCEDURE p1
==

