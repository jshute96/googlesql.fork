# This test takes an IMPORT statement as input, reads the module contents
# from the related file (residing in googlesql/testdata), creates a
# ModuleCatalog from the contents, and then dumps the Catalog udfs/tvfs.
#
# This test imports a module that imports other modules, where various
# kinds of module errors are present in both the top level and nested
# imports (parser errors, initialization errors, import errors, resolution
# errors, etc.).

[no_input_is_module_contents]
IMPORT MODULE googlesql.testdata.modules.module_test_errors_main;
--
