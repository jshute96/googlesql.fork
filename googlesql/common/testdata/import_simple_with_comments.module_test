# These tests take an IMPORT statement as input, read the module contents
# from the related file (residing in googlesql/testdata), create a
# ModuleCatalog from the contents, and then dump the module DebugString().

[no_input_is_module_contents]
[use_full_debugstring]
IMPORT MODULE googlesql.testdata.modules.simple_with_comments
    AS simple2;
--
Lazy_resolution_function:bar
  (INT64 b) -> INT64
Statement:
   
  -- some more comments before function bar  
  /* Comments with another comment indicator type, multi-line, 
   * and here is line #2 of the comment */
\# yet another comment type before function bar   
CREATE PUBLIC FUNCTION bar(b int64) as (b)
CreateFunctionStmt
+-name_path=bar
+-create_scope=CREATE_PUBLIC
+-return_type=INT64
+-argument_name_list=[b]
+-signature=(INT64 b) -> INT64
+-language="SQL"
+-code="b"
+-function_expression=
  +-ArgumentRef(type=INT64, name="b")


Lazy_resolution_function:bat
  (INT64 d) -> INT64
Statement:
        -- some more comments before function bat
\--even more comments before function bat
\--where bat is a multiline CREATE statement with an embedded comment
  CREATE
    -- embedded comment in bat function definition
 PUBLIC FUNCTION bat   
\-- another embedded comment in bat
  (d int64) as (d)
CreateFunctionStmt
+-name_path=bat
+-create_scope=CREATE_PUBLIC
+-return_type=INT64
+-argument_name_list=[d]
+-signature=(INT64 d) -> INT64
+-language="SQL"
+-code="d"
+-function_expression=
  +-ArgumentRef(type=INT64, name="d")


Lazy_resolution_function:baz
  (INT64 c) -> INT64
Statement:
CREATE PUBLIC FUNCTION baz(c int64) as (c)
CreateFunctionStmt
+-name_path=baz
+-create_scope=CREATE_PUBLIC
+-return_type=INT64
+-argument_name_list=[c]
+-signature=(INT64 c) -> INT64
+-language="SQL"
+-code="c"
+-function_expression=
  +-ArgumentRef(type=INT64, name="c")


Lazy_resolution_function:foo
  (INT64 a) -> INT64
Statement:

\-- This is a module comment at the start of the file
  -- some more comments   (trailing spaces on various lines is intentional)   
   CREATE PUBLIC FUNCTION foo(a int64) as (a)
CreateFunctionStmt
+-name_path=foo
+-create_scope=CREATE_PUBLIC
+-return_type=INT64
+-argument_name_list=[a]
+-signature=(INT64 a) -> INT64
+-language="SQL"
+-code="a"
+-function_expression=
  +-ArgumentRef(type=INT64, name="a")
\
