MODULE m;
CREATE PUBLIC VIEW v0 OPTIONS (allowed_references = 'builtin') as Select 1 a, 2 b;
--
VIEW v0
==

MODULE m;
CREATE VIEW v1 as Select 1 a, 2 b;
--
VIEW v1
ERROR: View v1 is invalid [at 2:13]
CREATE VIEW v1 as Select 1 a, 2 b;
            ^
CREATE statements within modules require the PUBLIC or PRIVATE modifier [at 2:1]
CREATE VIEW v1 as Select 1 a, 2 b;
^
==

MODULE m;
CREATE OR REPLACE PUBLIC view v2 as Select 1 a, 2 b;
--
VIEW v2
ERROR: View v2 is invalid [at 2:31]
CREATE OR REPLACE PUBLIC view v2 as Select 1 a, 2 b;
                              ^
Modules do not support CREATE OR REPLACE for CREATE VIEW [at 2:1]
CREATE OR REPLACE PUBLIC view v2 as Select 1 a, 2 b;
^
==

MODULE m;
CREATE PUBLIC VIEW IF NOT EXISTS v3 as Select 1 a, 2 b;
--
VIEW v3
ERROR: View v3 is invalid [at 2:34]
CREATE PUBLIC VIEW IF NOT EXISTS v3 as Select 1 a, 2 b;
                                 ^
Modules do not support IF NOT EXISTS for CREATE VIEW [at 2:1]
CREATE PUBLIC VIEW IF NOT EXISTS v3 as Select 1 a, 2 b;
^
