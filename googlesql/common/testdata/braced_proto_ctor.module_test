[no_debug_string_include_types]
MODULE a.b.c;
IMPORT PROTO 'googlesql/testdata/test_schema.proto';
CREATE PUBLIC FUNCTION foo(a int32) as (
  NEW googlesql_test.KitchenSinkPB {
    int64_key_1: 1
    int64_key_2: 2
    nested_repeated_value: [{
      nested_int64: 10
      nested_repeated_int64: [100, 200]
    }, {
      nested_int64: 20
      nested_repeated_int64: [300, 400]
    }]
  }
);
--
Lazy_resolution_function:foo
  (INT32 a) -> PROTO<googlesql_test.KitchenSinkPB>
