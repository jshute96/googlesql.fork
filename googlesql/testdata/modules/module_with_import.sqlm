-- This module is used for test case:
--   googlesql/common/testdata/import_nested_module.module_test
-- See the test file comments for details about how this module is
-- related to other modules in that test.

MODULE module_with_import;

-- This module defines UDFs 'nested_fn1', 'nested_fn2'
IMPORT MODULE googlesql.testdata.modules.nested_module_with_import
    as nested;

CREATE PUBLIC FUNCTION module_fn1(a int64, b int64) as
  (private_module_fn1(a,b));

CREATE PRIVATE FUNCTION private_module_fn1(a int64, b int64) as
  (nested.nested_fn1(a, b) + Nested.Nested_fn2(b, a));

CREATE PUBLIC FUNCTION module_fn2(a int64, b int64) AS
  (nested.nested_fn1(a, b) + nested.nested_fn2(b, a));

-- This function tries to reference a private function from 'nested',
-- which is invalid.
CREATE PUBLIC FUNCTION invalid_fn2(a int64) as (nested.private_fn(a));

-- Accessing names inside nested imports does not work.
CREATE PUBLIC FUNCTION invalid_fn3(a int64) as (nested.doubly_nested.fn1(a));

CREATE PUBLIC FUNCTION module_fn3(a int64) as (nested.nested_fn3(a) + 1);
