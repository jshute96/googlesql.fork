MODULE doubly_nested_module;

CREATE PUBLIC FUNCTION fn1(a int64) as (a+1);

CREATE PUBLIC FUNCTION fn2(a int64) as (private_fn(a));

CREATE PRIVATE FUNCTION private_fn(a int64) as (a - 1);
